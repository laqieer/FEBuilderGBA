<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Tests.TestApp">
  <Application.Styles>
    <FluentTheme />
    <!-- Mirror App.axaml global styles for headless testing (#315) -->
    <Style Selector="NumericUpDown">
      <Setter Property="MinWidth" Value="120"/>
    </Style>
    <!-- Clickable hyperlink labels for cross-editor navigation (#318) -->
    <Style Selector="TextBlock.Hyperlink">
      <Setter Property="Foreground" Value="#0066CC"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="TextDecorations" Value="Underline"/>
    </Style>
    <Style Selector="TextBlock.Hyperlink:pointerover">
      <Setter Property="Foreground" Value="#0044AA"/>
    </Style>
  </Application.Styles>
</Application>
