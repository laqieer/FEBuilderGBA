<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Tests.TestApp">
  <Application.Styles>
    <FluentTheme />
    <!-- Mirror App.axaml global styles for headless testing (#315) -->
    <Style Selector="NumericUpDown">
      <Setter Property="MinWidth" Value="90"/>
    </Style>
  </Application.Styles>
</Application>
