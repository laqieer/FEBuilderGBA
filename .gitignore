*.gba
/roms/

# Build outputs — all regenerated by dotnet build
FEBuilderGBA/bin/
FEBuilderGBA/obj/
FEBuilderGBA/bin/x64
FEBuilderGBA.Core/bin/
FEBuilderGBA.Core/obj/

# Avalonia build outputs
FEBuilderGBA.Avalonia/bin/
FEBuilderGBA.Avalonia/obj/

# Android head (Avalonia.Android skeleton, #1070) build outputs
FEBuilderGBA.Android/bin/
FEBuilderGBA.Android/obj/

# Test build outputs
FEBuilderGBA.Tests/bin/
FEBuilderGBA.Tests/obj/
FEBuilderGBA.E2ETests/bin/
FEBuilderGBA.E2ETests/obj/
FEBuilderGBA.Core.Tests/bin/
FEBuilderGBA.Core.Tests/obj/
FEBuilderGBA.Avalonia.Tests/bin/
FEBuilderGBA.Avalonia.Tests/obj/

# CLI build outputs
FEBuilderGBA.CLI/bin/
FEBuilderGBA.CLI/obj/

# SkiaSharp build outputs
FEBuilderGBA.SkiaSharp/bin/
FEBuilderGBA.SkiaSharp/obj/

# Test results and coverage
**/TestResults/
coverage-report/

# Temp files
lint_stdout.txt
lint_stderr.txt
/tmp/

# Stale release folder
r/

# Python build artifacts
__pycache__/
*.egg-info/
.venv/

# Temporary test/export artifacts
build.log
export_avalonia/
export_test/
export_winforms/
roundtrip_*.tsv
e2e-screenshots/
screenshots-*/
screenshots_stderr.txt
screenshots_stdout.txt
ss-stderr.txt
ss-stdout.txt
docs/screenshots/*_test_output.txt
cli-logs/
config/log/
# config/config.xml is a runtime user-preferences file (machine-specific);
# keep it out of the index so local prefs can't be accidentally committed.
config/config.xml

# Generated by the WebAssembly head's ZipConfigForBrowser target (#1864) — the config/ tree
# zipped for the browser to fetch. Generated at build time, ~6.8 MB, never committed.
FEBuilderGBA.Browser/wwwroot/config.zip

# Prevent screenshots in project root (use pr-screenshots/ instead)
/*.png

# Gap-sweep Phase 3 — per-ROM screenshot manifests commit only index.md;
# the captured PNGs and per-side directories stay local (see
# docs/avalonia-gaps/README.md for the report-churn policy).
docs/avalonia-gaps/*-screenshots/**/*.png
docs/avalonia-gaps/*-screenshots/**/wf/
docs/avalonia-gaps/*-screenshots/**/av/

# IDE / editor
.vs/
.claude/*
.claude.json
!.claude/skills/
FEBuilderGBA/FEBuilderGBA.csproj.user

# tools/ subprojects (WinCapture, etc.) — build artifacts only
tools/**/bin/
tools/**/obj/
