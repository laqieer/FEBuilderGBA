<local:TranslatedUserControl xmlns="https://github.com/avaloniaui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:local="clr-namespace:FEBuilderGBA.Avalonia.Services;assembly=FEBuilderGBA.Avalonia"
                             x:Class="FEBuilderGBA.Avalonia.Dialogs.MapTilesetMappingDialogContent"
                             Width="480" Height="360">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="16" Spacing="10">
      <TextBlock AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Title_Label"
                 Text="Map Tileset for External FEMapCreator"
                 FontSize="16"
                 FontWeight="Bold" />

      <Button AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Discover_Button"
              Name="DiscoverButton"
              Content="Discover Tilesets"
              Click="Discover_Click" />

      <ComboBox AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Tileset_Combo"
                Name="TilesetComboBox"
                HorizontalAlignment="Stretch"
                SelectionChanged="TilesetComboBox_SelectionChanged" />

      <TextBlock AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Status_Label"
                 Name="StatusText"
                 TextWrapping="Wrap" />

      <TextBlock AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Error_Label"
                 Name="ErrorText"
                 TextWrapping="Wrap"
                 Foreground="OrangeRed" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Save_Button"
                Name="SaveButton"
                Content="Save Mapping"
                Click="Save_Click"
                Width="120"
                IsDefault="True" />
        <Button AutomationProperties.AutomationId="MapTilesetMappingDialogContent_Cancel_Button"
                Content="Cancel"
                Click="Cancel_Click"
                Width="100"
                IsCancel="True" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</local:TranslatedUserControl>
