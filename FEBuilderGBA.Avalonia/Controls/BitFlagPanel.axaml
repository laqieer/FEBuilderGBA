<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Controls.BitFlagPanel">
  <WrapPanel x:Name="FlagContainer" Orientation="Horizontal">
    <CheckBox x:Name="Bit0" Margin="4,2" Content="Bit 0" />
    <CheckBox x:Name="Bit1" Margin="4,2" Content="Bit 1" />
    <CheckBox x:Name="Bit2" Margin="4,2" Content="Bit 2" />
    <CheckBox x:Name="Bit3" Margin="4,2" Content="Bit 3" />
    <CheckBox x:Name="Bit4" Margin="4,2" Content="Bit 4" />
    <CheckBox x:Name="Bit5" Margin="4,2" Content="Bit 5" />
    <CheckBox x:Name="Bit6" Margin="4,2" Content="Bit 6" />
    <CheckBox x:Name="Bit7" Margin="4,2" Content="Bit 7" />
  </WrapPanel>
</UserControl>
