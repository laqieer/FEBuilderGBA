<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Controls.EditorTopBarWithInputs">
  <!--
    Editable variant of EditorTopBar (#701 Slice A foundation, slot
    visibility / InputsEnabled added in #649 Slice B).

    Whereas EditorTopBar (#649) renders Start Address / Read Count / Size as
    read-only display values, this control surfaces them as user-editable
    NumericUpDown inputs plus a Reload button. Intended for editors that let
    the user type a Read Start / Read Count / Read Size and click Reload to
    re-read the table from a different address (e.g. table-of-tables editors,
    debug viewers).

    Slot visibility — most editor top-bars only have Read Start + Read Count
    (no Size). Hosts toggle `ShowReadSize="False"` (or `ShowReadStart`,
    `ShowReadCount`) to collapse unused slots so the migration doesn't add
    a phantom field.

    Input editability — when `InputsEnabled="False"`, the three NumericUpDowns
    render disabled but still report values via the .ReadStartAddress / .ReadCount
    / .ReadSize CLR properties. Hosts that previously shipped
    `IsReadOnly="True"` or `IsEnabled="False"` inputs use this to preserve the
    same UX after migrating to the unified bar.
  -->
  <!--
    AutomationIds are NOT hard-coded here. Code-behind derives them from the
    host AutomationId (e.g. "MonsterItem_ReadBar" -> "MonsterItem_ReadStart_Input")
    on AttachedToVisualTree, with explicit per-slot overrides for legacy E2E
    selectors. This mirrors EditorTopBar (#649) so multiple instances in the
    same view (e.g. MonsterItemViewer's 3 tabs) don't collide.
  -->
  <!-- Layout mirrors EditorTopBar (#649): the input slots live in a
       horizontal StackPanel in column 0 (`*` so it absorbs leftover
       horizontal space), and the Reload button is pinned to the far
       right in column 1 (`Auto`). Without this Grid wrapper the StackPanel
       would arrange Reload immediately after the inputs — breaking the
       "Reload always pinned to right edge" contract that hosts depend
       on (Copilot review of #741). -->
  <!--
       Layout (#743 round 2): the inputs StackPanel lives in column 0 (`*`),
       an optional `TrailingContent` ContentPresenter occupies column 1
       (`Auto`, collapsed when empty) so hosts with extra strip controls
       (FilterCombo, ChangeType, etc.) can inject them BETWEEN the inputs
       and Reload, and the Reload button is pinned to column 2 (`Auto`)
       at the far-right edge. When `TrailingContent` is null the trailing
       column's `Auto` width collapses to 0, so the visual result is
       identical to the pre-#743 two-column layout (`*,Auto`).
       Pre-#743 migrations therefore render bit-for-bit unchanged. -->
  <Border BorderBrush="Gray" BorderThickness="1" Padding="4">
    <Grid ColumnDefinitions="*,Auto,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                  VerticalAlignment="Center">
        <TextBlock Name="ReadStartLabelBlock" Text="Read Start:" VerticalAlignment="Center" />
        <NumericUpDown Name="ReadStartInput" Width="120" FormatString="0"
                       Minimum="0" Maximum="4294967295"
                       VerticalAlignment="Center" />
        <TextBlock Name="ReadCountLabelBlock" Text="Read Count:" VerticalAlignment="Center"
                   Margin="6,0,0,0" />
        <NumericUpDown Name="ReadCountInput" Width="80" FormatString="0"
                       Minimum="0" Maximum="65535"
                       VerticalAlignment="Center" />
        <TextBlock Name="ReadSizeLabelBlock" Text="Read Size:" VerticalAlignment="Center"
                   Margin="6,0,0,0" />
        <NumericUpDown Name="ReadSizeInput" Width="80" FormatString="0"
                       Minimum="0" Maximum="65535"
                       VerticalAlignment="Center" />
      </StackPanel>
      <ContentPresenter Grid.Column="1" Name="TrailingContentPresenter"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0" />
      <Button Grid.Column="2" Name="ReloadButton" Content="Reload"
              Click="OnReloadClick"
              VerticalAlignment="Center"
              HorizontalAlignment="Right"
              Margin="8,0,0,0" />
    </Grid>
  </Border>
</UserControl>
