<services:TranslatedUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:FEBuilderGBA.Avalonia.Services"
             x:Class="FEBuilderGBA.Avalonia.Controls.AddressListControl"
             Focusable="True">
  <Grid RowDefinitions="Auto,*,Auto,Auto">
    <!-- Search bar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
      <TextBox Name="SearchBox" Watermark="Search..." />
      <Button Grid.Column="1" Content="Find" Margin="4,0,0,0" Click="Search_Click" />
    </Grid>

    <!-- List -->
    <!--
      #1687 fix (round 2): make long row names WRAP to fit the host column
      instead of clipping. The list VIRTUALIZES, so an Auto horizontal scrollbar
      never engages (the panel only ever reports the viewport width) — which is
      why the earlier Auto-scrollbar attempt still left long names silently
      clipped and overpainting the vertical scrollbar (the Map Tile Animation
      Type 1 "obscured scrollbar" report). Instead: HorizontalScrollBar=Disabled
      forces every row to the viewport width (the 250px column the consuming
      views give this control), and the row template's DockPanel (LastChildFill)
      constrains the name TextBlock to the remaining width so TextWrapping="Wrap"
      flows the full name onto multiple lines. Benefits all ~200 lists that
      consume this control.
    -->
    <ListBox Grid.Row="1" Name="AddressList" SelectionChanged="AddressList_SelectionChanged"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <DockPanel LastChildFill="True">
            <!--
              #342 follow-up (2026-05-26): the list-row preview slot is a
              fixed 32x32 box (Width="32" Height="32") so every row has the
              same vertical footprint regardless of source dimensions. With
              Stretch="Uniform" the source bitmap (16x16 / 16x24 / 32x32 class
              wait icons by animType) is fit inside that 32x32 slot with its
              aspect ratio preserved — never clipped, never squished. Sources
              smaller than 32x32 scale UP uniformly (16x16 → 32x32); taller
              sources are scaled DOWN to fit (16x24 → ~21x32). For natural-
              size, never-upscaled previews use IconPreviewControl in the
              detail panel; this list-row slot intentionally normalises the
              row height for tidy list scrolling.

              #654 fix: the icon area is ALWAYS visible so the 32x32 slot
              reserves space even when Icon is null. Previously we bound
              IsVisible to "Icon != null", which collapsed the row 0 icon
              column and shifted text left when the loader returned null
              (e.g. for prefix-ID-0 rows). WinForms reserves
              OWNER_DRAW_ICON_SIZE unconditionally; omitting the IsVisible
              binding here gives the same behaviour while keeping the #342
              Stretch="Uniform" aspect-preserving render path.

              #1687 round-2: DockPanel constrains the TextBlock to the
              remaining column width so the full name wraps instead of
              clipping. The old StackPanel had no width constraint, causing
              long names to overflow the host column.
            -->
            <Image DockPanel.Dock="Left" Source="{Binding Icon}" Width="32" Height="32"
                   Stretch="Uniform" Margin="0,0,4,0" />
            <TextBlock Text="{Binding Text}" VerticalAlignment="Center" TextWrapping="Wrap" />
          </DockPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
      <ListBox.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Copy Address" Click="CopyAddress_Click" />
          <MenuItem Header="Copy Name" Click="CopyName_Click" />
          <MenuItem Header="Copy Hex Data" Click="CopyHexData_Click" />
        </ContextMenu>
      </ListBox.ContextMenu>
    </ListBox>

    <!-- Pick-mode hint (hidden by default) -->
    <TextBlock Grid.Row="2" Name="PickHint" IsVisible="False"
               Text="Double-click or press Enter to select"
               Foreground="DodgerBlue" FontStyle="Italic" FontSize="11"
               HorizontalAlignment="Center" Margin="0,2,0,2" />

    <!-- Navigation -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
      <Button Content="&lt;" Click="Previous_Click" ToolTip.Tip="Previous" />
      <Button Content="&gt;" Click="Next_Click" ToolTip.Tip="Next" />
      <TextBlock Name="CountLabel" VerticalAlignment="Center" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</services:TranslatedUserControl>
