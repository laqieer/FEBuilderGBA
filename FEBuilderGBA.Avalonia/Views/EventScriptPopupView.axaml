<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.EventScriptPopupView"
        Title="Event Script Command Reference" Width="550" Height="480"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Event Script Command Reference" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <TextBox Name="InfoBox" AcceptsReturn="True" IsReadOnly="True"
             FontFamily="Consolas" FontSize="12"
             TextWrapping="Wrap" />
  </DockPanel>
</Window>
