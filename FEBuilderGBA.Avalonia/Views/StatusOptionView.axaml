<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.StatusOptionView"
        Title="Status Screen Options" Width="1238" Height="806"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <DockPanel Grid.Column="0" Margin="4">
      <Button AutomationProperties.AutomationId="StatusOption_ExpandList_Button" DockPanel.Dock="Top" Name="ExpandListButton" Content="リストの拡張" Margin="0,0,0,4" />
      <controls:AddressListControl AutomationProperties.AutomationId="StatusOption_Entry_List" Name="EntryList" />
    </DockPanel>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Status Screen Options" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="ID Text:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_IdTextId_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="IdTextIdBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_IdTextId_Label" Grid.Row="1" Grid.Column="2" Name="IdTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #IdTextPreview.Text}" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Name Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_NameTextId_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NameTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_NameTextId_Label" Grid.Row="2" Grid.Column="2" Name="NameTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #NameTextPreview.Text}" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Help Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_HelpTextId_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="HelpTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_HelpTextId_Label" Grid.Row="3" Grid.Column="2" Name="HelpTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #HelpTextPreview.Text}" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="X Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_PosX_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="PosXBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Y Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_PosY_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="PosYBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Selection Text 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_Sel1_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="Sel1Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Selection Text 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_Sel2_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="Sel2Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Columns:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_Columns_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="ColumnsBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Rows:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_Rows_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="RowsBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Default Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_DefaultTextId_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="DefaultTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_DefaultTextId_Label" Grid.Row="10" Grid.Column="2" Name="DefaultTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #DefaultTextPreview.Text}" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Yes Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_YesTextId_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="YesTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusOption_YesTextId_Label" Grid.Row="11" Grid.Column="2" Name="YesTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #YesTextPreview.Text}" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="Min Value:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_MinValue_Input" FormatString="0" Grid.Row="12" Grid.Column="1" Name="MinValueBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="13" Grid.Column="0" Text="Max Value:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_MaxValue_Input" FormatString="0" Grid.Row="13" Grid.Column="1" Name="MaxValueBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="14" Grid.Column="0" Text="On/Off Text 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_OnOff1_Input" FormatString="0" Grid.Row="14" Grid.Column="1" Name="OnOff1Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="15" Grid.Column="0" Text="On/Off Text 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_OnOff2_Input" FormatString="0" Grid.Row="15" Grid.Column="1" Name="OnOff2Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="16" Grid.Column="0" Text="Default Value:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_DefaultValue_Input" FormatString="0" Grid.Row="16" Grid.Column="1" Name="DefaultValueBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="17" Grid.Column="0" Text="Option Type:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_OptionType_Input" FormatString="0" Grid.Row="17" Grid.Column="1" Name="OptionTypeBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="18" Grid.Column="0" Text="Icon ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusOption_IconId_Input" FormatString="0" Grid.Row="18" Grid.Column="1" Name="IconIdBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="19" Grid.Column="0" Text="ASM Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusOption_AsmPointer_Input" Grid.Row="19" Grid.Column="1" Name="AsmPointerBox" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="StatusOption_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
