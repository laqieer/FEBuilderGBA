<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SupportUnitEditorView"
        Title="Support Unit Editor" Width="1197" Height="699">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="SupportList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Unit Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock Name="AddrLabel" FontSize="12" Foreground="Gray" />

        <!-- Partner Unit IDs (B0-B6) -->
        <TextBlock Text="Partner Unit IDs" FontWeight="SemiBold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="140,100,140,100" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="B0 Partner 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="B0Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="B1 Partner 2:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="3" Name="B1Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="B2 Partner 3:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="B2Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="2" Text="B3 Partner 4:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="3" Name="B3Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="B4 Partner 5:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B4Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="2" Text="B5 Partner 6:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="3" Name="B5Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="B6 Partner 7:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B6Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
        </Grid>

        <!-- Initial Values (B7-B13) -->
        <TextBlock Text="Initial Values" FontWeight="SemiBold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="140,100,140,100" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="B7 Init 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="B7Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="B8 Init 2:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="3" Name="B8Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="B9 Init 3:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="B9Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="2" Text="B10 Init 4:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="3" Name="B10Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="B11 Init 5:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B11Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="2" Text="B12 Init 6:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="3" Name="B12Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="B13 Init 7:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B13Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
        </Grid>

        <!-- Growth Rates (B14-B20) -->
        <TextBlock Text="Growth Rates" FontWeight="SemiBold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="140,100,140,100" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="B14 Growth 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="B14Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="B15 Growth 2:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="3" Name="B15Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="B16 Growth 3:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="B16Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="2" Text="B17 Growth 4:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="3" Name="B17Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="B18 Growth 5:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B18Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="2" Text="B19 Growth 6:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="3" Name="B19Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="B20 Growth 7:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B20Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
        </Grid>

        <!-- Count + Reserved (B21-B23) -->
        <TextBlock Text="Count / Reserved" FontWeight="SemiBold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="140,100,140,100,140,100" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="B21 Count:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="B21Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="B22:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="3" Name="B22Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="4" Text="B23:" VerticalAlignment="Center" Margin="8,2,0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="5" Name="B23Nud" Minimum="0" Maximum="255" FormatString="X2" Margin="0,2" />
        </Grid>

        <Button Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,12,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
