<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ErrorTSAErrorView"
        Title="TSA Error" Width="1071" Height="885"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="TSA Error" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ScrollViewer>
      <TextBlock Name="MessageText" TextWrapping="Wrap" Text="{Binding TsaErrorDetails}" />
    </ScrollViewer>
  </DockPanel>
</Window>
