<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolClickWriteFloatControlPanelButtonView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <Border Margin="13" Padding="5,11">
    <Grid ColumnDefinitions="128,*" RowDefinitions="Auto,Auto">
      <!-- Question icon placeholder -->
      <TextBlock Grid.Row="0" Grid.Column="0" Text="❓" FontSize="64"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Width="128" Height="128" />
      <!-- Message -->
      <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                 Margin="35,0,0,0" TextWrapping="Wrap"
                 Text="{Binding MessageText}" />
      <!-- Buttons row -->
      <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="35,12,0,0">
        <Button AutomationProperties.AutomationId="ToolClickWriteFloatControlPanelButton_Update_Button" Content="Update" Height="50" Width="435"
                Click="Update_Click" />
        <Button AutomationProperties.AutomationId="ToolClickWriteFloatControlPanelButton_New_Button" Content="Insert New" Height="50" Width="223"
                Margin="35,0,0,0" Click="New_Click" />
      </StackPanel>
    </Grid>
  </Border>
  </ScrollViewer>
</UserControl>
