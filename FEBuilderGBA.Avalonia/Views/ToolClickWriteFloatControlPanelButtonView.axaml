<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolClickWriteFloatControlPanelButtonView"
        Title="Control Panel Button" Width="400" Height="200"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Control Panel Button" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Update Existing" Width="130" Click="Update_Click" />
      <Button Content="Insert New" Width="100" Click="New_Click" />
    </StackPanel>
    <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
               Text="Which button would you like to click? Update the existing button or insert a new one?" />
  </DockPanel>
</Window>
