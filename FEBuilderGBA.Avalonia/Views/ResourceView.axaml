<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ResourceView"
        Title="Resources" Width="793" Height="620"
        WindowStartupLocation="CenterOwner">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Text="Resources" FontSize="24" FontWeight="Bold" />
      <TextBlock Text="ROM and Configuration Information" FontSize="14" Foreground="Gray" />

      <Separator Margin="0,8" />
      <TextBlock Text="ROM Information" FontSize="16" FontWeight="SemiBold" />
      <TextBox Name="RomInfoTextBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" FontSize="13"
               Text="{Binding RomInfoText}" MinHeight="160" />

      <Separator Margin="0,8" />
      <TextBlock Text="ROM Data Sections" FontSize="16" FontWeight="SemiBold" />
      <TextBox Name="RomSectionTextBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" FontSize="13"
               Text="{Binding RomSectionText}" MinHeight="120" />

      <Separator Margin="0,8" />
      <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" />
      <TextBox Name="ConfigInfoTextBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" FontSize="13"
               Text="{Binding ConfigInfoText}" MinHeight="80" />
    </StackPanel>
  </ScrollViewer>
</Window>
