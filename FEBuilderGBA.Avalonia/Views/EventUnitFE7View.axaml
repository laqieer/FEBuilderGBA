<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.EventUnitFE7View"
        Title="Event Unit (FE7)" Width="1902" Height="1047">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="6" Margin="8">
        <TextBlock Text="Event Unit (FE7)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="UnitIDBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Class ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="ClassIDBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Leader Unit ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="LeaderUnitIDBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit Info:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="UnitInfoBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Start X:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="StartXBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Start Y:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="StartYBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="End X:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="EndXBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="End Y:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="EndYBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Item 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="Item1Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Item 2:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="Item2Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Item 3:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="11" Grid.Column="1" Name="Item3Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="Item 4:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="12" Grid.Column="1" Name="Item4Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="13" Grid.Column="0" Text="AI1 Primary:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="13" Grid.Column="1" Name="AI1PrimaryBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="14" Grid.Column="0" Text="AI2 Secondary:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="14" Grid.Column="1" Name="AI2SecondaryBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="15" Grid.Column="0" Text="AI3 Target/Recovery:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="15" Grid.Column="1" Name="AI3TargetRecoveryBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="16" Grid.Column="0" Text="AI4 Retreat:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="16" Grid.Column="1" Name="AI4RetreatBox" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Write" Name="WriteBtn" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
