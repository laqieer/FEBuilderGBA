<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.TextDicView">
  <Grid ColumnDefinitions="245,*">
    <!-- Left: Address list -->
    <controls:AddressListControl AutomationProperties.AutomationId="TextDic_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <!-- Right: Editor -->
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Text Dictionary" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="12-byte records: title index, chapter index, text IDs, flags, unit/class." Foreground="Gray" TextWrapping="Wrap" />

        <Grid ColumnDefinitions="130,120,20,130,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Title Index:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_TitleIndex_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="TitleIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Chapter Index:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_ChapterIndex_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="ChapterIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Text ID 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_TextId1_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="TextId1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Preview:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="TextDic_Text1Preview_Label" Grid.Row="1" Grid.Column="4" Name="Text1PreviewLabel" VerticalAlignment="Center" TextWrapping="Wrap" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Text ID 2:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_TextId2_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="TextId2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Preview:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="TextDic_Text2Preview_Label" Grid.Row="2" Grid.Column="4" Name="Text2PreviewLabel" VerticalAlignment="Center" TextWrapping="Wrap" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Flag 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_Flag1_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="Flag1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Flag 2:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_Flag2_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="Flag2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" Margin="0,2"
                     AutomationProperties.AutomationId="TextDic_UnitId_Link"
                     Classes="Hyperlink" Name="UnitId_Link" PointerPressed="OnUnitIdLinkClick"
                     ToolTip.Tip="Click to open Unit Editor" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_UnitId_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="UnitIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Unit:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="TextDic_UnitName_Label" Grid.Row="4" Grid.Column="4" Name="UnitNameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Class ID:" VerticalAlignment="Center" Margin="0,2"
                     AutomationProperties.AutomationId="TextDic_ClassId_Link"
                     Classes="Hyperlink" Name="ClassId_Link" PointerPressed="OnClassIdLinkClick"
                     ToolTip.Tip="Click to open Class Editor" />
          <NumericUpDown AutomationProperties.AutomationId="TextDic_ClassId_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="ClassIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Class:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="TextDic_ClassName_Label" Grid.Row="5" Grid.Column="4" Name="ClassNameLabel" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="TextDic_Write_Button" Content="Write" Click="Write_Click" Width="168" Height="30" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
