<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.TextDicView"
        Title="Text Dictionary" Width="1786" Height="847"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Text Dictionary" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="Search:" VerticalAlignment="Center" />
      <TextBox Name="SearchBox" Width="300" Watermark="Enter search term..." />
      <Button Content="Search" Click="Search_Click" />
    </StackPanel>

    <!-- Editor fields with semantic labels matching WinForms TextDicForm -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="130,120,20,130,120,20,130,120"
          RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,8">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Title Index:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="0" Grid.Column="1" Name="TitleIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
      <TextBlock Grid.Row="0" Grid.Column="2" Text="" />
      <TextBlock Grid.Row="0" Grid.Column="3" Text="Chapter Index:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="0" Grid.Column="4" Name="ChapterIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
      <TextBlock Grid.Row="0" Grid.Column="5" Text="" />
      <TextBlock Grid.Row="0" Grid.Column="6" Text="Text ID 1:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="0" Grid.Column="7" Name="TextId1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Text ID 2:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="1" Grid.Column="1" Name="TextId2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
      <TextBlock Grid.Row="1" Grid.Column="2" Text="" />
      <TextBlock Grid.Row="1" Grid.Column="3" Text="Flag 1:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="1" Grid.Column="4" Name="Flag1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
      <TextBlock Grid.Row="1" Grid.Column="5" Text="" />
      <TextBlock Grid.Row="1" Grid.Column="6" Text="Flag 2:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="1" Grid.Column="7" Name="Flag2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="2" Grid.Column="1" Name="UnitIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
      <TextBlock Grid.Row="2" Grid.Column="2" Text="" />
      <TextBlock Grid.Row="2" Grid.Column="3" Text="Class ID:" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="2" Grid.Column="4" Name="ClassIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
    </Grid>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ListBox Name="ResultList" />
  </DockPanel>
</Window>
