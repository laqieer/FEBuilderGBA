<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.TextDicView"
        Title="Text Dictionary" Width="1155" Height="661"
        WindowStartupLocation="CenterOwner">
  <Grid ColumnDefinitions="245,*">
    <!-- Left: Address list -->
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <!-- Right: Editor -->
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Text Dictionary" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="12-byte records: title index, chapter index, text IDs, flags, unit/class." Foreground="Gray" TextWrapping="Wrap" />

        <Grid ColumnDefinitions="130,120,20,130,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Title Index:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="TitleIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Chapter Index:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="0" Grid.Column="4" Name="ChapterIndexBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Text ID 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="TextId1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Preview:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="4" Name="Text1PreviewLabel" VerticalAlignment="Center" TextWrapping="Wrap" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Text ID 2:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="TextId2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Preview:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="4" Name="Text2PreviewLabel" VerticalAlignment="Center" TextWrapping="Wrap" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Flag 1:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="Flag1Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Flag 2:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="4" Name="Flag2Box" Minimum="0" Maximum="65535" Width="100" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="UnitIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Unit:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="4" Grid.Column="4" Name="UnitNameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Class ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="ClassIdBox" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Class:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="5" Grid.Column="4" Name="ClassNameLabel" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Write" Click="Write_Click" Width="168" Height="30" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
