<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.PatchFilterExView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Patch Filter" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="PatchFilterEx_OK_Button" Content="OK" Width="80" Click="OK_Click" />
      <Button AutomationProperties.AutomationId="PatchFilterEx_Cancel_Button" Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <StackPanel Spacing="8">
      <TextBlock Text="Filter text:" />
      <TextBox AutomationProperties.AutomationId="PatchFilterEx_FilterText_Input" Name="FilterTextBox" Text="{Binding FilterText}" Watermark="Enter filter keywords..." />
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</UserControl>
