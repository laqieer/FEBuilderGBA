<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.WorldMapPointView"
        Title="World Map Point Editor" Width="1761" Height="778">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="World Map Point Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="X (B0|B1&lt;&lt;8):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <NumericUpDown Name="B0Box" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
            <NumericUpDown Name="B1Box" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          </StackPanel>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Y (B2|B3&lt;&lt;8):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <NumericUpDown Name="B2Box" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
            <NumericUpDown Name="B3Box" Minimum="0" Maximum="255" Width="100" Margin="0,2" />
          </StackPanel>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="W6 (u16@6):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="W6Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Name Text ID (u16@28):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="NameTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="D12 (u32@12):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="D12Box" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="D16 (u32@16):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="D16Box" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
