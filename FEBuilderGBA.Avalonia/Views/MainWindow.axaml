<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FEBuilderGBA.Avalonia.Views"
        x:Class="FEBuilderGBA.Avalonia.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Width="900" Height="700"
        SizeToContent="WidthAndHeight">
  <DockPanel>
    <!-- Menu Bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem AutomationProperties.AutomationId="Main_FileMenu_Button" Header="_File" Name="FileMenu">
        <MenuItem AutomationProperties.AutomationId="Main_OpenRomMenuItem_Button" Header="_Open ROM..." Click="OpenRom_Click" InputGesture="Ctrl+O" Name="OpenRomMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_OpenLastRomMenuItem_Button" Header="Open _Last ROM" Click="OpenLastRom_Click" Name="OpenLastRomMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_OpenDecompProjectMenuItem_Button" Header="Open _Decomp Project..." Click="OpenDecompProject_Click" Name="OpenDecompProjectMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_RecentFilesMenuItem_Button" Header="_Recent Files" Name="RecentFilesMenuItem" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_SaveMenuItem_Button" Header="_Save ROM" Click="SaveRom_Click" Name="SaveMenuItem" IsEnabled="False" InputGesture="Ctrl+S" />
        <MenuItem AutomationProperties.AutomationId="Main_SaveAsMenuItem_Button" Header="Save _As..." Click="SaveAsRom_Click" Name="SaveAsMenuItem" IsEnabled="False" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_ExitMenuItem_Button" Header="E_xit" Click="Exit_Click" Name="ExitMenuItem" />
      </MenuItem>
      <MenuItem AutomationProperties.AutomationId="Main_EditMenu_Button" Header="_Edit" Name="EditMenu">
        <MenuItem AutomationProperties.AutomationId="Main_UndoMenuItem_Button" Header="_Undo" Name="UndoMenuItem" IsEnabled="False" Click="Undo_Click" InputGesture="Ctrl+Z" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_RefreshMenuItem_Button" Header="Re_fresh" Name="RefreshMenuItem" Click="Refresh_Click" InputGesture="F5" />
      </MenuItem>
      <MenuItem AutomationProperties.AutomationId="Main_ViewMenu_Button" Header="_View" Name="ViewMenu">
        <MenuItem AutomationProperties.AutomationId="Main_EasyModeMenuItem_Button" Header="Toggle _Easy Mode" Click="ToggleEasyMode_Click" Name="EasyModeMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_CollapseAllMenuItem_Button" Header="_Collapse All Sections" Click="CollapseAll_Click" Name="CollapseAllMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_ExpandAllMenuItem_Button" Header="_Expand All Sections" Click="ExpandAll_Click" Name="ExpandAllMenuItem" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_DarkModeMenuItem_Button" Header="Toggle _Dark Mode" Click="ToggleDarkMode_Click" Name="DarkModeMenuItem" />
      </MenuItem>
      <MenuItem AutomationProperties.AutomationId="Main_ToolsMenu_Button" Header="_Tools" Name="ToolsMenu">
        <MenuItem AutomationProperties.AutomationId="Main_LintMenuItem_Button" Header="_Lint Check" Click="Lint_Click" Name="LintMenuItem" IsEnabled="False" />
        <MenuItem AutomationProperties.AutomationId="Main_DataExportMenuItem_Button" Header="_Data Export/Import..." Click="DataExport_Click" Name="DataExportMenuItem" IsEnabled="False" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_ExternalToolsMenuItem_Button" Header="_External Tools" Name="ExternalToolsMenuItem">
          <MenuItem AutomationProperties.AutomationId="Main_RunEmulatorMenuItem_Button" Header="Run _Emulator..." Click="RunEmulator_Click" Name="RunEmulatorMenuItem" />
          <MenuItem AutomationProperties.AutomationId="Main_RunEmulator2MenuItem_Button" Header="Run Emulator _2..." Click="RunEmulator2_Click" Name="RunEmulator2MenuItem" />
          <MenuItem AutomationProperties.AutomationId="Main_RunBinaryEditorMenuItem_Button" Header="Run _Binary Editor..." Click="RunBinaryEditor_Click" Name="RunBinaryEditorMenuItem" />
          <MenuItem AutomationProperties.AutomationId="Main_RunSappyMenuItem_Button" Header="Run _Sappy..." Click="RunSappy_Click" Name="RunSappyMenuItem" />
          <Separator />
          <MenuItem AutomationProperties.AutomationId="Main_RunProgram1MenuItem_Button" Header="Run Program _1..." Click="RunProgram1_Click" Name="RunProgram1MenuItem" />
          <MenuItem AutomationProperties.AutomationId="Main_RunProgram2MenuItem_Button" Header="Run Program _2..." Click="RunProgram2_Click" Name="RunProgram2MenuItem" />
          <MenuItem AutomationProperties.AutomationId="Main_RunProgram3MenuItem_Button" Header="Run Program _3..." Click="RunProgram3_Click" Name="RunProgram3MenuItem" />
        </MenuItem>
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_OptionsMenuItem_Button" Header="_Options..." Click="Options_Click" Name="OptionsMenuItem" />
      </MenuItem>
      <MenuItem AutomationProperties.AutomationId="Main_HelpMenu_Button" Header="_Help" Name="HelpMenu">
        <MenuItem AutomationProperties.AutomationId="Main_OnlineManualMenuItem_Button" Header="_Online Manual" Click="OnlineManual_Click" Name="OnlineManualMenuItem" />
        <MenuItem AutomationProperties.AutomationId="Main_DiscussionsMenuItem_Button" Header="_GitHub Discussions" Click="Discussions_Click" Name="DiscussionsMenuItem" />
        <Separator />
        <MenuItem AutomationProperties.AutomationId="Main_AboutMenuItem_Button" Header="_About" Click="About_Click" Name="AboutMenuItem" />
      </MenuItem>
    </Menu>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,4" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <TextBlock AutomationProperties.AutomationId="Main_RomSize_Label" Name="RomSizeLabel" Text="" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="Main_VersionDetection_Label" Name="VersionDetectionLabel" Text="" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock AutomationProperties.AutomationId="Main_Status_Label" Name="StatusText" Text="No ROM loaded" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Tag="NoRomLoaded" />
      </DockPanel>
    </Border>

    <!-- Toolbar with Easy Mode toggle -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}" Padding="8,4" BorderBrush="{DynamicResource ToolbarBorderBrush}" BorderThickness="0,0,0,1">
      <DockPanel>
        <ToggleButton AutomationProperties.AutomationId="Main_EasyMode_Check" Name="EasyModeToggle" Content="Easy Mode" Click="ToggleEasyMode_Click"
                      DockPanel.Dock="Right" Padding="12,4" Margin="4,0" FontSize="12" />
        <TextBlock AutomationProperties.AutomationId="Main_DecompBadge_Label" Name="DecompBadgeLabel"
                   DockPanel.Dock="Left" Text="{Binding DecompBadgeText}" IsVisible="{Binding IsDecompMode}"
                   Foreground="{DynamicResource DecompBadgeBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0" />
        <Panel /> <!-- fill remaining space -->
      </DockPanel>
    </Border>

    <!-- Decomp Build Panel (only visible in decomp mode) -->
    <Border DockPanel.Dock="Top" IsVisible="{Binding IsDecompMode}"
            Background="{DynamicResource ToolbarBackgroundBrush}" Padding="8,4"
            BorderBrush="{DynamicResource ToolbarBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Spacing="4">
        <DockPanel>
          <TextBlock Text="Decomp Build" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left" />
          <Button AutomationProperties.AutomationId="Main_DecompBuild_Button" Content="Build"
                  Click="DecompBuild_Click" DockPanel.Dock="Left" Padding="8,2" Margin="0,0,4,0" />
          <Button AutomationProperties.AutomationId="Main_DecompBuildReload_Button" Content="Build &amp; Reload"
                  Click="DecompBuildReload_Click" DockPanel.Dock="Left" Padding="8,2" Margin="0,0,4,0" />
          <TextBlock AutomationProperties.AutomationId="Main_DecompStale_Label"
                     Text="{Binding DecompStaleText}" IsVisible="{Binding DecompStale}"
                     Foreground="OrangeRed" VerticalAlignment="Center" Margin="4,0" DockPanel.Dock="Left" />
          <Panel />
        </DockPanel>
        <TextBox AutomationProperties.AutomationId="Main_DecompBuildOutput_Control"
                 Text="{Binding DecompBuildOutput}" IsReadOnly="True" AcceptsReturn="True"
                 MaxHeight="120" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 FontFamily="Courier New,monospace" FontSize="11"
                 IsVisible="{Binding DecompBuildOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>

    <!-- Main Content -->
    <Grid>
      <!-- Easy Mode Panel (hidden by default) -->
      <views:EasyModePanel Name="EasyModePanelControl" IsVisible="False" />

      <!-- Normal Mode Content -->
      <ScrollViewer Name="NormalModeContent">
      <StackPanel Margin="16" Spacing="16">
        <!-- Title -->
        <TextBlock Text="FEBuilderGBA" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock AutomationProperties.AutomationId="Main_Version_Label" Name="VersionLabel" Text="Cross-Platform Preview (Avalonia)" FontSize="14"
                   HorizontalAlignment="Center" Foreground="Gray" />

        <!-- No ROM placeholder -->
        <TextBlock AutomationProperties.AutomationId="Main_NoRom_Label" Name="NoRomLabel" Text="Open a ROM file to begin editing."
                   FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,0" />

        <!-- Search/Filter (visible when ROM loaded) -->
        <DockPanel Name="SearchPanel" IsVisible="False" Margin="0,0,0,4">
          <TextBlock AutomationProperties.AutomationId="Main_Filter_Label" Name="FilterLabel" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left" />
          <Button AutomationProperties.AutomationId="Main_ClearFilter_Button" Name="ClearFilterButton" Content="Clear" Click="ClearFilter_Click" DockPanel.Dock="Right" Margin="8,0,0,0" Padding="8,4" />
          <TextBox AutomationProperties.AutomationId="Main_FilterText_Input" Name="FilterTextBox" Watermark="Type to filter editors..." />
        </DockPanel>

        <!-- Match count label -->
        <TextBlock AutomationProperties.AutomationId="Main_FilterMatch_Label" Name="FilterMatchLabel" IsVisible="False" Foreground="Gray" FontSize="12" Margin="0,0,0,4" />

        <!-- Editor Buttons Grid (visible when ROM loaded) -->
        <StackPanel Name="EditorPanel" IsVisible="False" Spacing="4">

          <!-- Units & Classes -->
          <Expander AutomationProperties.AutomationId="Main_Characters_Expander" Header="Characters" IsExpanded="True" Name="CharactersExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_Units_Button" Name="UnitsButton" Content="Units" Click="OpenUnits_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_Classes_Button" Name="ClassesButton" Content="Classes" Click="OpenClasses_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SupportUnits_Button" Name="SupportUnitsButton" Content="Support Units" Click="OpenSupportUnits_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SupportAttribute_Button" Name="SupportAttributeButton" Content="Support Attribute" Click="OpenSupportAttribute_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SupportTalk_Button" Name="SupportTalkButton" Content="Support Talk" Click="OpenSupportTalk_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Items -->
          <Expander AutomationProperties.AutomationId="Main_Items_Expander" Header="Items" IsExpanded="True" Name="ItemsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_Items_Button" Name="ItemsButton" Content="Items" Click="OpenItems_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_CCBranch_Button" Name="CCBranchButton" Content="CC Branch" Click="OpenCCBranch_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_WeaponEffect_Button" Name="WeaponEffectButton" Content="Weapon Effect" Click="OpenItemWeaponEffect_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_StatBonuses_Button" Name="StatBonusesButton" Content="Stat Bonuses" Click="OpenItemStatBonuses_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_Effectiveness_Button" Name="EffectivenessButton" Content="Effectiveness" Click="OpenItemEffectiveness_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_Promotion_Button" Name="PromotionButton" Content="Promotion" Click="OpenItemPromotion_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_Shop_Button" Name="ShopButton" Content="Shop" Click="OpenItemShop_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_WeaponTriangle_Button" Name="WeaponTriangleButton" Content="Weapon Triangle" Click="OpenItemWeaponTriangle_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_UsagePointer_Button" Name="UsagePointerButton" Content="Usage Pointer" Click="OpenItemUsagePointer_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_EffectPointer_Button" Name="EffectPointerButton" Content="Effect Pointer" Click="OpenItemEffectPointer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Maps -->
          <Expander AutomationProperties.AutomationId="Main_Maps_Expander" Header="Maps" IsExpanded="True" Name="MapsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_MapSettings_Button" Name="MapSettingsButton" Content="Map Settings" Click="OpenMapSettings_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_TerrainNames_Button" Name="TerrainNamesButton" Content="Terrain Names" Click="OpenTerrainNames_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MoveCost_Button" Name="MoveCostButton" Content="Move Cost" Click="OpenMoveCost_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_EventConditions_Button" Name="EventConditionsButton" Content="Event Conditions" Click="OpenEventCond_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MapChanges_Button" Name="MapChangesButton" Content="Map Changes" Click="OpenMapChange_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_ExitPoints_Button" Name="ExitPointsButton" Content="Exit Points" Click="OpenMapExitPoint_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MapPointers_Button" Name="MapPointersButton" Content="Map Pointers" Click="OpenMapPointer_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_TileAnimation_Button" Name="TileAnimationButton" Content="Tile Animation" Click="OpenMapTileAnimation_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Text -->
          <Expander AutomationProperties.AutomationId="Main_Text_Expander" Header="Text" IsExpanded="True" Name="TextExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_TextViewer_Button" Name="TextViewerButton" Content="Text Viewer" Click="OpenTextViewer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Graphics -->
          <Expander AutomationProperties.AutomationId="Main_Graphics_Expander" Header="Graphics" IsExpanded="True" Name="GraphicsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_Portraits_Button" Name="PortraitsButton" Content="Portraits" Click="OpenPortraits_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SystemIcons_Button" Name="SystemIconsButton" Content="System Icons" Click="OpenSystemIcon_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_ItemIcons_Button" Name="ItemIconsButton" Content="Item Icons" Click="OpenItemIcon_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_HoverColors_Button" Name="HoverColorsButton" Content="Hover Colors" Click="OpenSystemHoverColor_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleBG_Button" Name="BattleBGButton" Content="Battle BG" Click="OpenBattleBG_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleTerrain_Button" Name="BattleTerrainButton" Content="Battle Terrain" Click="OpenBattleTerrain_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_ChapterTitle_Button" Name="ChapterTitleButton" Content="Chapter Title" Click="OpenChapterTitle_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_CGViewer_Button" Name="CGViewerButton" Content="CG Viewer" Click="OpenBigCG_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_OPClassDemo_Button" Name="OPClassDemoButton" Content="OP Class Demo" Click="OpenOPClassDemo_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_OPClassFont_Button" Name="OPClassFontButton" Content="OP Class Font" Click="OpenOPClassFont_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_OPPrologue_Button" Name="OPPrologueButton" Content="OP Prologue" Click="OpenOPPrologue_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Audio -->
          <Expander AutomationProperties.AutomationId="Main_Audio_Expander" Header="Audio" IsExpanded="True" Name="AudioExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_SongTable_Button" Name="SongTableButton" Content="Song Table" Click="OpenSongTable_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BossBGM_Button" Name="BossBGMButton" Content="Boss BGM" Click="OpenSoundBossBGM_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_Footsteps_Button" Name="FootstepsButton" Content="Footsteps" Click="OpenSoundFootSteps_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SoundRoom_Button" Name="SoundRoomButton" Content="Sound Room" Click="OpenSoundRoom_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Arena -->
          <Expander AutomationProperties.AutomationId="Main_Arena_Expander" Header="Arena" IsExpanded="True" Name="ArenaExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_ArenaClass_Button" Name="ArenaClassButton" Content="Arena Class" Click="OpenArenaClass_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_ArenaEnemyWeapon_Button" Name="ArenaEnemyWeaponButton" Content="Arena Enemy Weapon" Click="OpenArenaEnemyWeapon_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_LinkArenaDeny_Button" Name="LinkArenaDenyButton" Content="Link Arena Deny" Click="OpenLinkArenaDenyUnit_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Monsters -->
          <Expander AutomationProperties.AutomationId="Main_Monsters_Expander" Header="Monsters" IsExpanded="True" Name="MonstersExpander">
            <WrapPanel Name="MonstersPanel" Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_MonsterProbability_Button" Name="MonsterProbabilityButton" Content="Monster Probability" Click="OpenMonsterProbability_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MonsterItems_Button" Name="MonsterItemsButton" Content="Monster Items" Click="OpenMonsterItem_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_WMapProbability_Button" Name="WMapProbabilityButton" Content="WMap Probability" Click="OpenMonsterWMapProbability_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Summons -->
          <Expander AutomationProperties.AutomationId="Main_Summons_Expander" Header="Summons" IsExpanded="True" Name="SummonsExpander">
            <WrapPanel Name="SummonsPanel" Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_SummonUnit_Button" Name="SummonUnitButton" Content="Summon Unit" Click="OpenSummonUnit_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_DemonKing_Button" Name="DemonKingButton" Content="Demon King" Click="OpenSummonsDemonKing_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Items (Specialized) -->
          <Expander AutomationProperties.AutomationId="Main_ItemsSpecialized_Expander" Header="Items (Specialized)" IsExpanded="True" Name="ItemsSpecializedExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_StatBonusesSkill_Button" Name="StatBonusesSkillButton" Content="Stat Bonuses (Skill)" Click="OpenItemStatBonusesSkillSystems_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_StatBonusesVenno_Button" Name="StatBonusesVennoButton" Content="Stat Bonuses (Venno)" Click="OpenItemStatBonusesVenno_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_EffectivenessRework_Button" Name="EffectivenessReworkButton" Content="Effectiveness (Rework)" Click="OpenItemEffectivenessSkillSystemsRework_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_RandomChest_Button" Name="RandomChestButton" Content="Random Chest" Click="OpenItemRandomChest_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Menus -->
          <Expander AutomationProperties.AutomationId="Main_Menus_Expander" Header="Menus" IsExpanded="True" Name="MenusExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_MenuDefinition_Button" Name="MenuDefinitionButton" Content="Menu Definition" Click="OpenMenuDefinition_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MenuCommand_Button" Name="MenuCommandButton" Content="Menu Command" Click="OpenMenuCommand_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SplitMenuExt_Button" Name="SplitMenuExtButton" Content="Split Menu Ext" Click="OpenMenuExtendSplitMenu_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Credits -->
          <Expander AutomationProperties.AutomationId="Main_Credits_Expander" Header="Credits" IsExpanded="True" Name="CreditsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_EndingEvents_Button" Name="EndingEventsButton" Content="Ending Events" Click="OpenED_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_StaffRoll_Button" Name="StaffRollButton" Content="Staff Roll" Click="OpenEDStaffRoll_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_EDFE6_Button" Name="EDFE6Button" Content="ED (FE6)" Click="OpenEDFE6_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_EDFE7_Button" Name="EDFE7Button" Content="ED (FE7)" Click="OpenEDFE7_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_SensekiComment_Button" Name="SensekiCommentButton" Content="Senseki Comment" Click="OpenEDSensekiComment_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- World Map -->
          <Expander AutomationProperties.AutomationId="Main_WorldMap_Expander" Header="World Map" IsExpanded="True" Name="WorldMapExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_MapPoints_Button" Name="MapPointsButton" Content="Map Points" Click="OpenWorldMapPoint_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MapBGM_Button" Name="MapBGMButton" Content="Map BGM" Click="OpenWorldMapBGM_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_MapEvents_Button" Name="MapEventsButton" Content="Map Events" Click="OpenWorldMapEventPointer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Image Editors -->
          <Expander AutomationProperties.AutomationId="Main_ImageEditors_Expander" Header="Image Editors" IsExpanded="True" Name="ImageEditorsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button AutomationProperties.AutomationId="Main_PortraitEditor_Button" Name="PortraitEditorButton" Content="Portrait Editor" Click="OpenImagePortrait_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_PortraitFE6_Button" Name="PortraitFE6Button" Content="Portrait (FE6)" Click="OpenImagePortraitFE6_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_PortraitImport_Button" Name="PortraitImportButton" Content="Portrait Import" Click="OpenImagePortraitImporter_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BGEditor_Button" Name="BGEditorButton" Content="BG Editor" Click="OpenImageBG_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleAnim_Button" Name="BattleAnimButton" Content="Battle Anim" Click="OpenImageBattleAnime_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleAnimPal_Button" Name="BattleAnimPalButton" Content="Battle Anim Pal" Click="OpenImageBattleAnimePallet_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleBGEdit_Button" Name="BattleBGEditButton" Content="Battle BG Edit" Click="OpenImageBattleBG_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_BattleScreen_Button" Name="BattleScreenButton" Content="Battle Screen" Click="OpenImageBattleScreen_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_CGEditor_Button" Name="CGEditorButton" Content="CG Editor" Click="OpenImageCG_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_CGFE7U_Button" Name="CGFE7UButton" Content="CG (FE7U)" Click="OpenImageCGFE7U_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_ImgUnitPalette_Button" Name="ImgUnitPaletteButton" Content="Unit Palette" Click="OpenImageUnitPalette_Click" Margin="4" MinWidth="100" />
              <Button AutomationProperties.AutomationId="Main_WaitIcon_Button" Name="WaitIconButton" Content="Wait Icon" Click="OpenImageUnitWaitIcon_Click" Margin="4" MinWidth="100" />
