<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FEBuilderGBA.Avalonia.Views"
        x:Class="FEBuilderGBA.Avalonia.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Width="900" Height="700"
        SizeToContent="WidthAndHeight">
  <DockPanel>
    <!-- Menu Bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File" Name="FileMenu">
        <MenuItem Header="_Open ROM..." Click="OpenRom_Click" InputGesture="Ctrl+O" Name="OpenRomMenuItem" />
        <MenuItem Header="Open _Last ROM" Click="OpenLastRom_Click" Name="OpenLastRomMenuItem" />
        <MenuItem Header="_Recent Files" Name="RecentFilesMenuItem" />
        <Separator />
        <MenuItem Header="_Save ROM" Click="SaveRom_Click" Name="SaveMenuItem" IsEnabled="False" InputGesture="Ctrl+S" />
        <MenuItem Header="Save _As..." Click="SaveAsRom_Click" Name="SaveAsMenuItem" IsEnabled="False" />
        <Separator />
        <MenuItem Header="E_xit" Click="Exit_Click" Name="ExitMenuItem" />
      </MenuItem>
      <MenuItem Header="_Edit" Name="EditMenu">
        <MenuItem Header="_Undo" Name="UndoMenuItem" IsEnabled="False" Click="Undo_Click" InputGesture="Ctrl+Z" />
        <Separator />
        <MenuItem Header="Re_fresh" Name="RefreshMenuItem" Click="Refresh_Click" InputGesture="F5" />
      </MenuItem>
      <MenuItem Header="_View" Name="ViewMenu">
        <MenuItem Header="Toggle _Easy Mode" Click="ToggleEasyMode_Click" Name="EasyModeMenuItem" />
        <MenuItem Header="_Collapse All Sections" Click="CollapseAll_Click" Name="CollapseAllMenuItem" />
        <MenuItem Header="_Expand All Sections" Click="ExpandAll_Click" Name="ExpandAllMenuItem" />
        <Separator />
        <MenuItem Header="Toggle _Dark Mode" Click="ToggleDarkMode_Click" Name="DarkModeMenuItem" />
      </MenuItem>
      <MenuItem Header="_Tools" Name="ToolsMenu">
        <MenuItem Header="_Lint Check" Click="Lint_Click" Name="LintMenuItem" IsEnabled="False" />
        <MenuItem Header="_Data Export/Import..." Click="DataExport_Click" Name="DataExportMenuItem" IsEnabled="False" />
        <Separator />
        <MenuItem Header="_External Tools" Name="ExternalToolsMenuItem">
          <MenuItem Header="Run _Emulator..." Click="RunEmulator_Click" Name="RunEmulatorMenuItem" />
          <MenuItem Header="Run Emulator _2..." Click="RunEmulator2_Click" Name="RunEmulator2MenuItem" />
          <MenuItem Header="Run _Binary Editor..." Click="RunBinaryEditor_Click" Name="RunBinaryEditorMenuItem" />
          <MenuItem Header="Run _Sappy..." Click="RunSappy_Click" Name="RunSappyMenuItem" />
          <Separator />
          <MenuItem Header="Run Program _1..." Click="RunProgram1_Click" Name="RunProgram1MenuItem" />
          <MenuItem Header="Run Program _2..." Click="RunProgram2_Click" Name="RunProgram2MenuItem" />
          <MenuItem Header="Run Program _3..." Click="RunProgram3_Click" Name="RunProgram3MenuItem" />
        </MenuItem>
        <Separator />
        <MenuItem Header="_Options..." Click="Options_Click" Name="OptionsMenuItem" />
      </MenuItem>
      <MenuItem Header="_Help" Name="HelpMenu">
        <MenuItem Header="_Online Manual" Click="OnlineManual_Click" Name="OnlineManualMenuItem" />
        <MenuItem Header="_GitHub Discussions" Click="Discussions_Click" Name="DiscussionsMenuItem" />
        <Separator />
        <MenuItem Header="_About" Click="About_Click" Name="AboutMenuItem" />
      </MenuItem>
    </Menu>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,4" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <TextBlock Name="RomSizeLabel" Text="" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center" />
          <TextBlock Name="VersionDetectionLabel" Text="" Foreground="Gray" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Name="StatusText" Text="No ROM loaded" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Tag="NoRomLoaded" />
      </DockPanel>
    </Border>

    <!-- Toolbar with Easy Mode toggle -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}" Padding="8,4" BorderBrush="{DynamicResource ToolbarBorderBrush}" BorderThickness="0,0,0,1">
      <DockPanel>
        <ToggleButton Name="EasyModeToggle" Content="Easy Mode" Click="ToggleEasyMode_Click"
                      DockPanel.Dock="Right" Padding="12,4" Margin="4,0" FontSize="12" />
        <Panel /> <!-- fill remaining space -->
      </DockPanel>
    </Border>

    <!-- Main Content -->
    <Grid>
      <!-- Easy Mode Panel (hidden by default) -->
      <views:EasyModePanel Name="EasyModePanelControl" IsVisible="False" />

      <!-- Normal Mode Content -->
      <ScrollViewer Name="NormalModeContent">
      <StackPanel Margin="16" Spacing="16">
        <!-- Title -->
        <TextBlock Text="FEBuilderGBA" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Name="VersionLabel" Text="Cross-Platform Preview (Avalonia)" FontSize="14"
                   HorizontalAlignment="Center" Foreground="Gray" />

        <!-- No ROM placeholder -->
        <TextBlock Name="NoRomLabel" Text="Open a ROM file to begin editing."
                   FontSize="14" HorizontalAlignment="Center" Margin="0,20,0,0" />

        <!-- Search/Filter (visible when ROM loaded) -->
        <DockPanel Name="SearchPanel" IsVisible="False" Margin="0,0,0,4">
          <TextBlock Name="FilterLabel" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left" />
          <Button Name="ClearFilterButton" Content="Clear" Click="ClearFilter_Click" DockPanel.Dock="Right" Margin="8,0,0,0" Padding="8,4" />
          <TextBox Name="FilterTextBox" Watermark="Type to filter editors..." />
        </DockPanel>

        <!-- Match count label -->
        <TextBlock Name="FilterMatchLabel" IsVisible="False" Foreground="Gray" FontSize="12" Margin="0,0,0,4" />

        <!-- Editor Buttons Grid (visible when ROM loaded) -->
        <StackPanel Name="EditorPanel" IsVisible="False" Spacing="4">

          <!-- Units & Classes -->
          <Expander Header="Characters" IsExpanded="True" Name="CharactersExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="UnitsButton" Content="Units" Click="OpenUnits_Click" Margin="4" MinWidth="100" />
              <Button Name="ClassesButton" Content="Classes" Click="OpenClasses_Click" Margin="4" MinWidth="100" />
              <Button Name="SupportUnitsButton" Content="Support Units" Click="OpenSupportUnits_Click" Margin="4" MinWidth="100" />
              <Button Name="SupportAttributeButton" Content="Support Attribute" Click="OpenSupportAttribute_Click" Margin="4" MinWidth="100" />
              <Button Name="SupportTalkButton" Content="Support Talk" Click="OpenSupportTalk_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Items -->
          <Expander Header="Items" IsExpanded="True" Name="ItemsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="ItemsButton" Content="Items" Click="OpenItems_Click" Margin="4" MinWidth="100" />
              <Button Name="CCBranchButton" Content="CC Branch" Click="OpenCCBranch_Click" Margin="4" MinWidth="100" />
              <Button Name="WeaponEffectButton" Content="Weapon Effect" Click="OpenItemWeaponEffect_Click" Margin="4" MinWidth="100" />
              <Button Name="StatBonusesButton" Content="Stat Bonuses" Click="OpenItemStatBonuses_Click" Margin="4" MinWidth="100" />
              <Button Name="EffectivenessButton" Content="Effectiveness" Click="OpenItemEffectiveness_Click" Margin="4" MinWidth="100" />
              <Button Name="PromotionButton" Content="Promotion" Click="OpenItemPromotion_Click" Margin="4" MinWidth="100" />
              <Button Name="ShopButton" Content="Shop" Click="OpenItemShop_Click" Margin="4" MinWidth="100" />
              <Button Name="WeaponTriangleButton" Content="Weapon Triangle" Click="OpenItemWeaponTriangle_Click" Margin="4" MinWidth="100" />
              <Button Name="UsagePointerButton" Content="Usage Pointer" Click="OpenItemUsagePointer_Click" Margin="4" MinWidth="100" />
              <Button Name="EffectPointerButton" Content="Effect Pointer" Click="OpenItemEffectPointer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Maps -->
          <Expander Header="Maps" IsExpanded="True" Name="MapsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="MapSettingsButton" Content="Map Settings" Click="OpenMapSettings_Click" Margin="4" MinWidth="100" />
              <Button Name="TerrainNamesButton" Content="Terrain Names" Click="OpenTerrainNames_Click" Margin="4" MinWidth="100" />
              <Button Name="MoveCostButton" Content="Move Cost" Click="OpenMoveCost_Click" Margin="4" MinWidth="100" />
              <Button Name="EventConditionsButton" Content="Event Conditions" Click="OpenEventCond_Click" Margin="4" MinWidth="100" />
              <Button Name="MapChangesButton" Content="Map Changes" Click="OpenMapChange_Click" Margin="4" MinWidth="100" />
              <Button Name="ExitPointsButton" Content="Exit Points" Click="OpenMapExitPoint_Click" Margin="4" MinWidth="100" />
              <Button Name="MapPointersButton" Content="Map Pointers" Click="OpenMapPointer_Click" Margin="4" MinWidth="100" />
              <Button Name="TileAnimationButton" Content="Tile Animation" Click="OpenMapTileAnimation_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Text -->
          <Expander Header="Text" IsExpanded="True" Name="TextExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="TextViewerButton" Content="Text Viewer" Click="OpenTextViewer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Graphics -->
          <Expander Header="Graphics" IsExpanded="True" Name="GraphicsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="PortraitsButton" Content="Portraits" Click="OpenPortraits_Click" Margin="4" MinWidth="100" />
              <Button Name="SystemIconsButton" Content="System Icons" Click="OpenSystemIcon_Click" Margin="4" MinWidth="100" />
              <Button Name="ItemIconsButton" Content="Item Icons" Click="OpenItemIcon_Click" Margin="4" MinWidth="100" />
              <Button Name="HoverColorsButton" Content="Hover Colors" Click="OpenSystemHoverColor_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleBGButton" Content="Battle BG" Click="OpenBattleBG_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleTerrainButton" Content="Battle Terrain" Click="OpenBattleTerrain_Click" Margin="4" MinWidth="100" />
              <Button Name="ChapterTitleButton" Content="Chapter Title" Click="OpenChapterTitle_Click" Margin="4" MinWidth="100" />
              <Button Name="CGViewerButton" Content="CG Viewer" Click="OpenBigCG_Click" Margin="4" MinWidth="100" />
              <Button Name="OPClassDemoButton" Content="OP Class Demo" Click="OpenOPClassDemo_Click" Margin="4" MinWidth="100" />
              <Button Name="OPClassFontButton" Content="OP Class Font" Click="OpenOPClassFont_Click" Margin="4" MinWidth="100" />
              <Button Name="OPPrologueButton" Content="OP Prologue" Click="OpenOPPrologue_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Audio -->
          <Expander Header="Audio" IsExpanded="True" Name="AudioExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="SongTableButton" Content="Song Table" Click="OpenSongTable_Click" Margin="4" MinWidth="100" />
              <Button Name="BossBGMButton" Content="Boss BGM" Click="OpenSoundBossBGM_Click" Margin="4" MinWidth="100" />
              <Button Name="FootstepsButton" Content="Footsteps" Click="OpenSoundFootSteps_Click" Margin="4" MinWidth="100" />
              <Button Name="SoundRoomButton" Content="Sound Room" Click="OpenSoundRoom_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Arena -->
          <Expander Header="Arena" IsExpanded="True" Name="ArenaExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="ArenaClassButton" Content="Arena Class" Click="OpenArenaClass_Click" Margin="4" MinWidth="100" />
              <Button Name="ArenaEnemyWeaponButton" Content="Arena Enemy Weapon" Click="OpenArenaEnemyWeapon_Click" Margin="4" MinWidth="100" />
              <Button Name="LinkArenaDenyButton" Content="Link Arena Deny" Click="OpenLinkArenaDenyUnit_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Monsters -->
          <Expander Header="Monsters" IsExpanded="True" Name="MonstersExpander">
            <WrapPanel Name="MonstersPanel" Orientation="Horizontal">
              <Button Name="MonsterProbabilityButton" Content="Monster Probability" Click="OpenMonsterProbability_Click" Margin="4" MinWidth="100" />
              <Button Name="MonsterItemsButton" Content="Monster Items" Click="OpenMonsterItem_Click" Margin="4" MinWidth="100" />
              <Button Name="WMapProbabilityButton" Content="WMap Probability" Click="OpenMonsterWMapProbability_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Summons -->
          <Expander Header="Summons" IsExpanded="True" Name="SummonsExpander">
            <WrapPanel Name="SummonsPanel" Orientation="Horizontal">
              <Button Name="SummonUnitButton" Content="Summon Unit" Click="OpenSummonUnit_Click" Margin="4" MinWidth="100" />
              <Button Name="DemonKingButton" Content="Demon King" Click="OpenSummonsDemonKing_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Items (Specialized) -->
          <Expander Header="Items (Specialized)" IsExpanded="True" Name="ItemsSpecializedExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="StatBonusesSkillButton" Content="Stat Bonuses (Skill)" Click="OpenItemStatBonusesSkillSystems_Click" Margin="4" MinWidth="100" />
              <Button Name="StatBonusesVennoButton" Content="Stat Bonuses (Venno)" Click="OpenItemStatBonusesVenno_Click" Margin="4" MinWidth="100" />
              <Button Name="EffectivenessReworkButton" Content="Effectiveness (Rework)" Click="OpenItemEffectivenessSkillSystemsRework_Click" Margin="4" MinWidth="100" />
              <Button Name="RandomChestButton" Content="Random Chest" Click="OpenItemRandomChest_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Menus -->
          <Expander Header="Menus" IsExpanded="True" Name="MenusExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="MenuDefinitionButton" Content="Menu Definition" Click="OpenMenuDefinition_Click" Margin="4" MinWidth="100" />
              <Button Name="MenuCommandButton" Content="Menu Command" Click="OpenMenuCommand_Click" Margin="4" MinWidth="100" />
              <Button Name="SplitMenuExtButton" Content="Split Menu Ext" Click="OpenMenuExtendSplitMenu_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Credits -->
          <Expander Header="Credits" IsExpanded="True" Name="CreditsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="EndingEventsButton" Content="Ending Events" Click="OpenED_Click" Margin="4" MinWidth="100" />
              <Button Name="StaffRollButton" Content="Staff Roll" Click="OpenEDStaffRoll_Click" Margin="4" MinWidth="100" />
              <Button Name="EDFE6Button" Content="ED (FE6)" Click="OpenEDFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="EDFE7Button" Content="ED (FE7)" Click="OpenEDFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="SensekiCommentButton" Content="Senseki Comment" Click="OpenEDSensekiComment_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- World Map -->
          <Expander Header="World Map" IsExpanded="True" Name="WorldMapExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="MapPointsButton" Content="Map Points" Click="OpenWorldMapPoint_Click" Margin="4" MinWidth="100" />
              <Button Name="MapBGMButton" Content="Map BGM" Click="OpenWorldMapBGM_Click" Margin="4" MinWidth="100" />
              <Button Name="MapEventsButton" Content="Map Events" Click="OpenWorldMapEventPointer_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Image Editors -->
          <Expander Header="Image Editors" IsExpanded="True" Name="ImageEditorsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="PortraitEditorButton" Content="Portrait Editor" Click="OpenImagePortrait_Click" Margin="4" MinWidth="100" />
              <Button Name="PortraitFE6Button" Content="Portrait (FE6)" Click="OpenImagePortraitFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="PortraitImportButton" Content="Portrait Import" Click="OpenImagePortraitImporter_Click" Margin="4" MinWidth="100" />
              <Button Name="BGEditorButton" Content="BG Editor" Click="OpenImageBG_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleAnimButton" Content="Battle Anim" Click="OpenImageBattleAnime_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleAnimPalButton" Content="Battle Anim Pal" Click="OpenImageBattleAnimePallet_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleBGEditButton" Content="Battle BG Edit" Click="OpenImageBattleBG_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleScreenButton" Content="Battle Screen" Click="OpenImageBattleScreen_Click" Margin="4" MinWidth="100" />
              <Button Name="CGEditorButton" Content="CG Editor" Click="OpenImageCG_Click" Margin="4" MinWidth="100" />
              <Button Name="CGFE7UButton" Content="CG (FE7U)" Click="OpenImageCGFE7U_Click" Margin="4" MinWidth="100" />
              <Button Name="ImgUnitPaletteButton" Content="Unit Palette" Click="OpenImageUnitPalette_Click" Margin="4" MinWidth="100" />
              <Button Name="WaitIconButton" Content="Wait Icon" Click="OpenImageUnitWaitIcon_Click" Margin="4" MinWidth="100" />
              <Button Name="MoveIconButton" Content="Move Icon" Click="OpenImageUnitMoveIcon_Click" Margin="4" MinWidth="100" />
              <Button Name="SystemAreaButton" Content="System Area" Click="OpenImageSystemArea_Click" Margin="4" MinWidth="100" />
              <Button Name="GenericEnemyButton" Content="Generic Enemy" Click="OpenImageGenericEnemyPortrait_Click" Margin="4" MinWidth="100" />
              <Button Name="ROMAnimeButton" Content="ROM Anime" Click="OpenImageRomAnime_Click" Margin="4" MinWidth="100" />
              <Button Name="TSAEditorButton" Content="TSA Editor" Click="OpenImageTSAEditor_Click" Margin="4" MinWidth="100" />
              <Button Name="TSAAnimeButton" Content="TSA Anime" Click="OpenImageTSAAnime_Click" Margin="4" MinWidth="100" />
              <Button Name="TSAAnime2Button" Content="TSA Anime 2" Click="OpenImageTSAAnime2_Click" Margin="4" MinWidth="100" />
              <Button Name="PaletteButton" Content="Palette" Click="OpenImagePallet_Click" Margin="4" MinWidth="100" />
              <Button Name="MagicFEditorButton" Content="Magic FEditor" Click="OpenImageMagicFEditor_Click" Margin="4" MinWidth="100" />
              <Button Name="CSACreatorButton" Content="CSA Creator" Click="OpenImageMagicCSACreator_Click" Margin="4" MinWidth="100" />
              <Button Name="MapActionAnimButton" Content="Map Action Anim" Click="OpenImageMapActionAnimation_Click" Margin="4" MinWidth="100" />
              <Button Name="ColorReduceButton" Content="Color Reduce" Click="OpenDecreaseColorTSATool_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Event Script Editors -->
          <Expander Header="Event Scripts" IsExpanded="True" Name="EventScriptsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="EventScriptButton" Content="Event Script" Click="OpenEventScript_Click" Margin="4" MinWidth="100" />
              <Button Name="EventUnitButton" Content="Event Unit" Click="OpenEventUnit_Click" Margin="4" MinWidth="100" />
              <Button Name="EventUnitFE6Button" Content="Event Unit (FE6)" Click="OpenEventUnitFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="EventUnitFE7Button" Content="Event Unit (FE7)" Click="OpenEventUnitFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="UnitColorButton" Content="Unit Color" Click="OpenEventUnitColor_Click" Margin="4" MinWidth="100" />
              <Button Name="ItemDropButton" Content="Item Drop" Click="OpenEventUnitItemDrop_Click" Margin="4" MinWidth="100" />
              <Button Name="NewAllocButton" Content="New Alloc" Click="OpenEventUnitNewAlloc_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleTalkButton" Content="Battle Talk" Click="OpenEventBattleTalk_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleTalkFE6Button" Content="Battle Talk (FE6)" Click="OpenEventBattleTalkFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleTalkFE7Button" Content="Battle Talk (FE7)" Click="OpenEventBattleTalkFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="BattleDataFE7Button" Content="Battle Data (FE7)" Click="OpenEventBattleDataFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="HaikuButton" Content="Haiku" Click="OpenEventHaiku_Click" Margin="4" MinWidth="100" />
              <Button Name="HaikuFE6Button" Content="Haiku (FE6)" Click="OpenEventHaikuFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="HaikuFE7Button" Content="Haiku (FE7)" Click="OpenEventHaikuFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="MapChangeEvtButton" Content="Map Change Evt" Click="OpenEventMapChange_Click" Margin="4" MinWidth="100" />
              <Button Name="ForceSortieButton" Content="Force Sortie" Click="OpenEventForceSortie_Click" Margin="4" MinWidth="100" />
              <Button Name="ForceSortieFE7Button" Content="Force Sortie (FE7)" Click="OpenEventForceSortieFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="FuncPointerButton" Content="Func Pointer" Click="OpenEventFunctionPointer_Click" Margin="4" MinWidth="100" />
              <Button Name="FuncPtrFE7Button" Content="Func Ptr (FE7)" Click="OpenEventFunctionPointerFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="EventAssemblerButton" Content="Event Assembler" Click="OpenEventAssembler_Click" Margin="4" MinWidth="100" />
              <Button Name="ProcsScriptButton" Content="Procs Script" Click="OpenProcsScript_Click" Margin="4" MinWidth="100" />
              <Button Name="TemplatesButton" Content="Templates" Click="OpenEventScriptTemplate_Click" Margin="4" MinWidth="100" />
              <Button Name="Template1Button" Content="Template 1" Click="OpenEventTemplate1_Click" Margin="4" MinWidth="100" />
              <Button Name="Template2Button" Content="Template 2" Click="OpenEventTemplate2_Click" Margin="4" MinWidth="100" />
              <Button Name="Template3Button" Content="Template 3" Click="OpenEventTemplate3_Click" Margin="4" MinWidth="100" />
              <Button Name="Template4Button" Content="Template 4" Click="OpenEventTemplate4_Click" Margin="4" MinWidth="100" />
              <Button Name="Template5Button" Content="Template 5" Click="OpenEventTemplate5_Click" Margin="4" MinWidth="100" />
              <Button Name="Template6Button" Content="Template 6" Click="OpenEventTemplate6_Click" Margin="4" MinWidth="100" />
              <Button Name="FinalSerifFE7Button" Content="Final Serif (FE7)" Click="OpenEventFinalSerifFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="MoveDataFE7Button" Content="Move Data (FE7)" Click="OpenEventMoveDataFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="TalkGroupFE7Button" Content="Talk Group (FE7)" Click="OpenEventTalkGroupFE7_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- AI Script Editors -->
          <Expander Header="AI Scripts" IsExpanded="True" Name="AIScriptsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="AIScriptButton" Content="AI Script" Click="OpenAIScript_Click" Margin="4" MinWidth="100" />
              <Button Name="AIASMCallButton" Content="AI ASM Call" Click="OpenAIASMCALLTALK_Click" Margin="4" MinWidth="100" />
              <Button Name="AICoordinateButton" Content="AI Coordinate" Click="OpenAIASMCoordinate_Click" Margin="4" MinWidth="100" />
              <Button Name="AIRangeButton" Content="AI Range" Click="OpenAIASMRange_Click" Margin="4" MinWidth="100" />
              <Button Name="AIMapSettingButton" Content="AI Map Setting" Click="OpenAIMapSetting_Click" Margin="4" MinWidth="100" />
              <Button Name="AIItemButton" Content="AI Item" Click="OpenAIPerformItem_Click" Margin="4" MinWidth="100" />
              <Button Name="AIStaffButton" Content="AI Staff" Click="OpenAIPerformStaff_Click" Margin="4" MinWidth="100" />
              <Button Name="AIStealButton" Content="AI Steal" Click="OpenAIStealItem_Click" Margin="4" MinWidth="100" />
              <Button Name="AITargetButton" Content="AI Target" Click="OpenAITarget_Click" Margin="4" MinWidth="100" />
              <Button Name="AITilesButton" Content="AI Tiles" Click="OpenAITiles_Click" Margin="4" MinWidth="100" />
              <Button Name="AIUnitsButton" Content="AI Units" Click="OpenAIUnits_Click" Margin="4" MinWidth="100" />
              <Button Name="AOERangeButton" Content="AOE Range" Click="OpenAOERANGE_Click" Margin="4" MinWidth="100" />
            </WrapPanel>
          </Expander>

          <!-- Map Editors (Advanced) -->
          <Expander Header="Map Editors" IsExpanded="True" Name="MapEditorsExpander">
            <WrapPanel Orientation="Horizontal">
              <Button Name="MapEditorButton" Content="Map Editor" Click="OpenMapEditor_Click" Margin="4" MinWidth="100" />
              <Button Name="MapSettingsFE6Button" Content="Map Settings (FE6)" Click="OpenMapSettingFE6_Click" Margin="4" MinWidth="100" />
              <Button Name="MapSettingsFE7Button" Content="Map Settings (FE7)" Click="OpenMapSettingFE7_Click" Margin="4" MinWidth="100" />
              <Button Name="MapSettingsFE7UButton" Content="Map Settings (FE7U)" Click="OpenMapSettingFE7U_Click" Margin="4" MinWidth="100" />
              <Button Name="DifficultyButton" Content="Difficulty" Click="OpenMapSettingDifficulty_Click" Margin="4" MinWidth="100" />
              <Button Name="StyleEditorButton" Content="Style Editor" Click="OpenMapStyleEditor_Click" Margin="4" MinWidth="100" />
              <Button Name="TerrainBGButton" Content="Terrain BG" Click="OpenMapTerrainBGLookup_Click" Margin="4" MinWidth="100" />
              <Button Name="TerrainFloorButton" Content="Terrain Floor" Click="OpenMapTerrainFloorLookup_Click" Margin="4" MinWidth="100" />
