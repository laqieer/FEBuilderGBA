<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.PointerToolBatchInputView"
        Title="Pointer Tool - Batch Input" Width="500" Height="400"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Batch Pointer Input" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <TextBlock DockPanel.Dock="Top" Text="Enter one pointer address per line:" Margin="0,0,0,8" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <TextBox Name="BatchInputTextBox" AcceptsReturn="True"
             FontFamily="Consolas, Courier New, monospace"
             Watermark="0x08000000&#x0a;0x08000004&#x0a;..." />
  </DockPanel>
</Window>
