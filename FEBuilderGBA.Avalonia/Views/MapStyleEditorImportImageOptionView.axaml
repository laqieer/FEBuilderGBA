<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MapStyleEditorImportImageOptionView"
        Title="Map Style Editor - Import Image Options" Width="420" Height="300"
        WindowStartupLocation="CenterOwner" CanResize="False">
  <DockPanel Margin="16">
    <TextBlock Text="Import Image Options" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Select how the imported image should be applied to the map style." TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <StackPanel Spacing="8" VerticalAlignment="Top">
      <RadioButton x:Name="ReplaceOption" Content="Replace existing tileset" IsChecked="True" GroupName="ImportOption" />
      <RadioButton x:Name="AppendOption" Content="Append to existing tileset" GroupName="ImportOption" />
      <RadioButton x:Name="InsertOption" Content="Insert before current entry" GroupName="ImportOption" />
    </StackPanel>
  </DockPanel>
</Window>
