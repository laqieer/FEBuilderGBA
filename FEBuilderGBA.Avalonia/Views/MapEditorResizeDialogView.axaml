<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MapEditorResizeDialogView"
        Title="Map Editor - Resize" Width="400" Height="280"
        WindowStartupLocation="CenterOwner" CanResize="False">
  <DockPanel Margin="16">
    <TextBlock Text="Map Resize" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Enter new map dimensions in tiles." TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0" VerticalAlignment="Top">
      <TextBlock Text="New Width:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" />
      <NumericUpDown x:Name="NewWidthInput" Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="255" Value="15" Margin="0,0,0,8" />
      <TextBlock Text="New Height:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" />
      <NumericUpDown x:Name="NewHeightInput" Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="255" Value="10" />
    </Grid>
  </DockPanel>
</Window>
