<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.MainView"
             AutomationProperties.AutomationId="Android_MainView">
  <!-- #1122: Android single-activity shell. A top app bar (Back + title +
       overflow) over a content host that renders the navigation host's current
       page. The desktop multi-window MainWindow is unchanged; this view only
       exists under ISingleViewApplicationLifetime (Android). -->
  <Grid RowDefinitions="Auto,*">
    <!-- Top app bar -->
    <Border Grid.Row="0"
            Background="{DynamicResource ToolbarBackgroundBrush}"
            BorderBrush="{DynamicResource ToolbarBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <!-- Button/title text is set in code-behind via R._() (so it is
             translated and the L10n scanner sees no AXAML literal). -->
        <Button Grid.Column="0"
                Name="BackButton"
                AutomationProperties.AutomationId="Android_MainView_BackButton"
                Click="Back_Click"
                IsEnabled="False"
                Margin="0,0,8,0" />
        <TextBlock Grid.Column="1"
                   Name="TitleText"
                   AutomationProperties.AutomationId="Android_MainView_Title"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold" />
        <Button Grid.Column="2"
                Name="HomeButton"
                AutomationProperties.AutomationId="Android_MainView_HomeButton"
                Click="Home_Click" />
      </Grid>
    </Border>

    <!-- Navigation content host: renders the nav host's current top page. -->
    <ContentControl Grid.Row="1"
                    Name="NavHost"
                    AutomationProperties.AutomationId="Android_MainView_NavHost" />
  </Grid>
</UserControl>
