<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolAnimationCreatorView"
        Title="Animation Creator" Width="650" Height="500"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Animation Creator" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Create" Click="Create_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ScrollViewer>
      <StackPanel Spacing="8">
        <Grid RowDefinitions="Auto,8,Auto,8,Auto" ColumnDefinitions="Auto,8,*">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Animation Name:" VerticalAlignment="Center" />
          <TextBox Grid.Row="0" Grid.Column="2" Name="AnimationNameTextBox" Watermark="Enter animation name" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Frame Count:" VerticalAlignment="Center" />
          <TextBox Grid.Row="2" Grid.Column="2" Name="FrameCountTextBox" Watermark="e.g. 8" />
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Image Source:" VerticalAlignment="Center" />
          <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBox Name="ImageSourceTextBox" Watermark="Select source image..." HorizontalAlignment="Stretch" />
            <Button Content="Browse..." Click="BrowseImage_Click" />
          </StackPanel>
        </Grid>
        <Border BorderBrush="Gray" BorderThickness="1" Height="200" Margin="0,8,0,0">
          <TextBlock Text="Animation preview area" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" />
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
