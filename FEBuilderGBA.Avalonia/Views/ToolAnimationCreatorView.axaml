<UserControl
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolAnimationCreatorView">
  <!-- Outer ScrollViewer prevents content clipping when the window is
       resized below the natural layout size. Required by the
       AvaloniaScrollViewerTests regression suite. -->
  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Animation Creator" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

    <!-- Bottom button row: Save + Close -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="ToolAnimationCreator_Create_Button" Content="Save" Click="Create_Click" />
      <Button AutomationProperties.AutomationId="ToolAnimationCreator_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>

    <Grid ColumnDefinitions="*, 8, 360" RowDefinitions="Auto, 8, *" MinHeight="560">

      <!-- Top: animation-wide fields (name + frame count + global image picker) -->
      <Border Grid.Row="0" Grid.ColumnSpan="3" BorderBrush="Gray" BorderThickness="1" Padding="8">
        <Grid RowDefinitions="Auto,8,Auto,8,Auto" ColumnDefinitions="Auto,8,*">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Animation Name:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ToolAnimationCreator_AnimationNameText_Input"
                   Grid.Row="0" Grid.Column="2" Name="AnimationNameTextBox"
                   Text="{Binding AnimationName}" Watermark="Enter animation name" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Frame Count:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ToolAnimationCreator_FrameCountText_Input"
                   Grid.Row="2" Grid.Column="2" Name="FrameCountTextBox"
                   Text="{Binding FrameCount}" IsReadOnly="True" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Image Source:" VerticalAlignment="Center" />
          <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBox AutomationProperties.AutomationId="ToolAnimationCreator_ImageSourceText_Input"
                     Name="ImageSourceTextBox" Text="{Binding ImageSource}"
                     Watermark="Select source image..." Width="540" />
            <Button AutomationProperties.AutomationId="ToolAnimationCreator_BrowseImage_Button"
                    Content="Browse..." Click="BrowseImage_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Left: scrollable frame list -->
      <Border Grid.Row="2" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="4">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Frames" FontWeight="SemiBold" Margin="4,0,4,4" />
          <ListBox AutomationProperties.AutomationId="ToolAnimationCreator_Frames_List"
                   Name="FramesList" ItemsSource="{Binding Frames}"
                   SelectionChanged="FramesList_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <!-- Separate prefix TextBlocks (translated by
                     ViewTranslationHelper) + value TextBlocks (bound to VM)
                     so non-English UIs render the prefix in their locale —
                     Copilot CLI inline review on PR #619. Avoids the
                     StringFormat binding (translation helper does not walk
                     binding format strings). -->
                <Grid ColumnDefinitions="Auto,4,40,Auto,*,Auto,4,80">
                  <TextBlock Grid.Column="0" Text="Wait:" />
                  <TextBlock Grid.Column="2" Text="{Binding Wait}" />
                  <TextBlock Grid.Column="4" Text="{Binding ImageName}" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"
                             ToolTip.Tip="{Binding ImageName}" />
                  <TextBlock Grid.Column="5" Text="Sound:" />
                  <TextBlock Grid.Column="7" Text="{Binding Sound, StringFormat='0x{0:X}'}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Right: selected-frame editor + preview placeholder -->
      <Border Grid.Row="2" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="Selected Frame" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,8,Auto,8,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Wait:" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="0" Grid.Column="1"
                           AutomationProperties.AutomationId="ToolAnimationCreator_SelectedWait_Input"
                           Name="SelectedWaitBox" FormatString="0"
                           Value="{Binding SelectedFrame.Wait, FallbackValue=0}"
                           Minimum="0" Maximum="255"
                           IsEnabled="{Binding SelectedFrame, Converter={x:Static ObjectConverters.IsNotNull}}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Image:" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     AutomationProperties.AutomationId="ToolAnimationCreator_SelectedImage_Input"
                     Name="SelectedImageBox"
                     Text="{Binding SelectedFrame.ImageName, FallbackValue=''}"
                     IsEnabled="{Binding SelectedFrame, Converter={x:Static ObjectConverters.IsNotNull}}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Sound:" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="4" Grid.Column="1"
                           AutomationProperties.AutomationId="ToolAnimationCreator_SelectedSound_Input"
                           Name="SelectedSoundBox" FormatString="0"
                           Value="{Binding SelectedFrame.Sound, FallbackValue=0}"
                           Minimum="0" Maximum="65535"
                           IsEnabled="{Binding SelectedFrame, Converter={x:Static ObjectConverters.IsNotNull}}" />
          </Grid>

          <!-- Split into prefix + value TextBlocks so ViewTranslationHelper
               picks up "Context:" (StringFormat strings in bindings are
               ignored by the helper) — Copilot CLI inline review on PR #619. -->
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Context:" FontWeight="SemiBold" />
            <TextBlock AutomationProperties.AutomationId="ToolAnimationCreator_ContextLabel_Label"
                       Name="ContextLabel" TextWrapping="Wrap"
                       Text="{Binding FileHint}" />
          </StackPanel>

          <Border BorderBrush="Gray" BorderThickness="1" Height="120" Padding="4">
            <controls:GbaImageControl AutomationProperties.AutomationId="ToolAnimationCreator_Preview_Image"
                                      Name="MapActionPreview" Zoom="2" />
          </Border>
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
  </ScrollViewer>
</UserControl>
