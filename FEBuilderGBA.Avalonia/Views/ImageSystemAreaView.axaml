<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ImageSystemAreaView"
        Title="System Area Graphics" Width="1238" Height="604">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="System Area Graphics" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="180,200,20,180,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Address -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- Row 1: GBA Color raw value -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="GBA Color (W0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="GBAColorBox" Minimum="0" Maximum="65535" />

          <!-- Row 2: R / G -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="R:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="ColorR" Minimum="0" Maximum="255" Increment="8" IsReadOnly="True" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="G:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="4" Name="ColorG" Minimum="0" Maximum="255" Increment="8" IsReadOnly="True" />

          <!-- Row 3: B -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="B:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="ColorB" Minimum="0" Maximum="255" Increment="8" IsReadOnly="True" />

          <!-- Row 4: Color preview -->
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Preview:" VerticalAlignment="Center" />
          <Border Grid.Row="4" Grid.Column="1" Name="ColorPreview" Width="60" Height="40"
                  BorderBrush="Gray" BorderThickness="1" Margin="0,4,0,4" />

          <!-- Row 5: Write button -->
          <Button Grid.Row="5" Grid.Column="0" Content="Write" Name="WriteButton" Click="Write_Click" Margin="0,8,0,0" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
