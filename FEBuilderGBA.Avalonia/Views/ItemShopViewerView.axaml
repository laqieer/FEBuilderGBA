<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ItemShopViewerView">
  <!--
    3-region layout mirroring WinForms ItemShopForm (#369 parity):
      - Column 0: ShopList     — every shop in the ROM (hensei + worldmap + per-map)
      - Column 1: SlotList     — 2-byte item entries inside the selected shop
      - Column 2: Editor pane  — per-slot edit + slot management buttons
  -->
  <Grid ColumnDefinitions="320,280,*">

    <!-- Column 0: Shop list -->
    <DockPanel Grid.Column="0" Margin="4">
      <TextBlock DockPanel.Dock="Top" Text="Shops" FontWeight="Bold" Margin="0,0,0,4" />
      <controls:AddressListControl AutomationProperties.AutomationId="ItemShopViewer_Shop_List"
                                   Name="ShopList" />
    </DockPanel>

    <!-- Column 1: Slot list (items in selected shop) -->
    <DockPanel Grid.Column="1" Margin="4">
      <TextBlock DockPanel.Dock="Top" Text="Items in Shop" FontWeight="Bold" Margin="0,0,0,4" />
      <controls:AddressListControl AutomationProperties.AutomationId="ItemShopViewer_Slot_List"
                                   Name="SlotList" />
    </DockPanel>

    <!-- Column 2: Editor pane -->
    <ScrollViewer Grid.Column="2" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Shop Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="ItemShopViewer_ShopName_Label"
                   Name="ShopNameLabel" FontStyle="Italic" Foreground="Gray" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Shop Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemShopViewer_ShopAddr_Label"
                     Grid.Row="0" Grid.Column="1" Name="ShopAddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Slot Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemShopViewer_Addr_Label"
                     Grid.Row="1" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360 final: hyperlink TextBlock + NumericUpDown + name label → IdFieldControl.
               The standalone ItemNameLabel is removed; IdFieldControl provides
               its inline name preview (NameText). -->
          <controls:IdFieldControl AutomationProperties.AutomationId="ItemShopViewer_ItemId_Input"
                                   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Name="ItemIdBox"
                                   Label="Item ID:"
                                   Maximum="255"
                                   JumpRequested="ItemId_Jump"
                                   PickRequested="ItemId_Pick"
                                   ValueChanged="ItemId_ValueChanged" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Quantity/Uses:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemShopViewer_Quantity_Input"
                         FormatString="0" Grid.Row="3" Grid.Column="1" Name="QuantityBox"
                         Minimum="0" Maximum="255" Width="100" VerticalAlignment="Center" />
        </Grid>

        <!-- Slot management buttons (parity with WinForms expand/write/reload) -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ItemShopViewer_Write_Button"
                  Content="Write" Name="WriteButton" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="ItemShopViewer_AppendSlot_Button"
                  Content="Append Slot" Name="AppendSlotButton" Click="AppendSlot_Click"
                  ToolTip.Tip="Add a new item slot at the end of this shop's list. Will relocate the list if there is no slack." />
          <Button AutomationProperties.AutomationId="ItemShopViewer_RemoveLastSlot_Button"
                  Content="Remove Last Slot" Name="RemoveLastSlotButton" Click="RemoveLastSlot_Click" />
          <Button AutomationProperties.AutomationId="ItemShopViewer_Reload_Button"
                  Content="Reload" Name="ReloadButton" Click="Reload_Click"
                  ToolTip.Tip="Rescan the ROM for shops (use after editing events)." />
        </StackPanel>

        <TextBlock AutomationProperties.AutomationId="ItemShopViewer_Status_Label"
                   Name="StatusLabel" Margin="0,12,0,0" Foreground="DarkGreen" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
