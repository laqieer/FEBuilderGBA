<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolWorkSupport_UpdateQuestionDialogView"
        Title="Update Check" Width="450" Height="200"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Update Check" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Force Update" Width="120" Click="ForceUpdate_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Text="{Binding VersionInfo}" />
  </DockPanel>
</Window>
