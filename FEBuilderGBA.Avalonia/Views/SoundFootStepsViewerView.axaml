<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SoundFootStepsViewerView"
        Title="Footstep Sounds Editor" Width="1245" Height="636"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SoundFootStepsViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Footstep Sounds Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SoundFootStepsViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Data Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="SoundFootStepsViewer_DataPointer_Input" Grid.Row="1" Grid.Column="1" Name="DataPointerBox" Width="120" VerticalAlignment="Center" />
        </Grid>

        <!-- "Switch2 not present" notice (mirrors WinForms ERROR_NOT_FOUND).
             Shown when the per-class footstep Switch2 jump-table is absent;
             both Write and List Expansion are hidden in that state. -->
        <TextBlock AutomationProperties.AutomationId="SoundFootStepsViewer_NotFound_Label"
                   Name="NotFoundLabel" Foreground="Red" IsVisible="False"
                   TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Footstep-sound Switch2 table not found in this ROM. Editing is unavailable." />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="SoundFootStepsViewer_Write_Button"
                  Name="WriteButton" Content="Write" Click="Write_Click" />
          <!-- List Expansion (#1449): grow the per-class footstep table to cover
               all classes + apply the FE8 PlaySoundStepByClass hardcode fix.
               Mirrors WinForms SwitchListExpandsButton. -->
          <Button AutomationProperties.AutomationId="SoundFootStepsViewer_SwitchListExpands_Button"
                  Name="SwitchListExpandsButton" Content="List Expansion"
                  Click="SwitchListExpands_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
