<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SkillAssignmentClassCSkillSysView"
        Title="Skill Assignment - Class (CSkillSys)" Width="1200" Height="900"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="12" Spacing="8">

      <TextBlock Text="Skill Assignment - Class (CSkillSys)" FontSize="18" FontWeight="Bold" />

      <Border Background="{DynamicResource WarningBackgroundBrush}"
              BorderBrush="{DynamicResource WarningBorderBrush}"
              BorderThickness="1" CornerRadius="4" Padding="10"
              Name="PatchBanner">
        <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_Status_Label"
                   Name="StatusText" TextWrapping="Wrap"
                   Text="Skill Assignment - Class (CSkillSys 3.00).&#10;This editor requires the CSkillSys 3.00+ skill system patch to be installed.&#10;Use the Patch Manager to install the CSkillSys 3.00 patch first." />
      </Border>

      <!-- Top read-config bar — unified via EditorTopBarWithInputs (#743).
           Inputs stay editable (this view did NOT use the IsEnabled="False"
           pattern). Pre-migration Maximums preserved via ReadStartMaximum /
           ReadCountMaximum so the unified bar doesn't widen the accepted
           range. -->
      <controls:EditorTopBarWithInputs Name="TopBar"
                                       AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_TopBar"
                                       ReadStartLabel="Start Address:"
                                       ReadCountLabel="Read Count:"
                                       ReadStartMaximum="2147483647"
                                       ReadCountMaximum="256"
                                       ShowReadSize="False"
                                       ReadStartAutomationId="SkillAssignmentClassCSkillSys_ReadStart_Input"
                                       ReadCountAutomationId="SkillAssignmentClassCSkillSys_ReadCount_Input"
                                       ReloadAutomationId="SkillAssignmentClassCSkillSys_ReloadList_Button"
                                       ReloadRequested="OnTopBarReloadRequested" />

      <Grid ColumnDefinitions="260,*">

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="4" CornerRadius="2" Margin="0,0,8,0">
          <DockPanel>
            <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ClassList_NameFilter_Label"
                       DockPanel.Dock="Top" Text="Name" Margin="0,0,0,4" FontWeight="Bold" />
            <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ClassList_Expand_Button"
                    DockPanel.Dock="Bottom" Name="ClassListExpandButton" Content="Expand List"
                    Click="OnClassExpand" Margin="0,4,0,0" />
            <ListBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_Class_List"
                     Name="ClassListBox" Height="700" />
          </DockPanel>
        </Border>

        <StackPanel Grid.Column="1" Spacing="8">

          <Border BorderBrush="Gray" BorderThickness="1" Padding="6" CornerRadius="2">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
              <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ClassSkillLabel"
                         Grid.Row="0" Grid.Column="0" Text="Class Skill" VerticalAlignment="Center"
                         Margin="0,0,8,0" FontWeight="Bold" />
              <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ClassSkill_Input"
                             Grid.Row="0" Grid.Column="1" Name="ClassSkillBox" FormatString="0"
                             Minimum="0" Maximum="65535" Margin="0,0,8,0" />
              <Image AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SkillIcon_Image"
                     Grid.Row="0" Grid.Column="2" Name="SkillIconImage"
                     Width="32" Height="32" Margin="0,0,8,0" />
              <TextBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SkillName_Label"
                       Grid.Row="0" Grid.Column="3" Name="SkillNameTextBox" IsReadOnly="True"
                       Margin="0,0,8,0" />
              <TextBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SkillText_Label"
                       Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" Name="SkillTextTextBox"
                       IsReadOnly="True" AcceptsReturn="True" Height="60" Margin="0,4,0,0" />
            </Grid>
          </Border>

          <Border BorderBrush="Gray" BorderThickness="1" Padding="6" CornerRadius="2">
            <Grid ColumnDefinitions="Auto,140,Auto,80,Auto,140,*">
              <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_AddrLabel"
                         Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,0,8,0" />
              <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_Addr_Input"
                             Grid.Column="1" Name="AddressBox" FormatString="0" IsReadOnly="True"
                             Minimum="0" Maximum="2147483647" Margin="0,0,8,0" />
              <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SizeLabel"
                         Grid.Column="2" Text="Size:" VerticalAlignment="Center" Margin="0,0,8,0" />
              <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_BlockSize_Input"
                             Grid.Column="3" Name="BlockSizeBox" IsReadOnly="True"
                             Minimum="0" Maximum="64" Margin="0,0,8,0" />
              <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SelectAddrLabel"
                         Grid.Column="4" Text="Selected:" VerticalAlignment="Center" Margin="0,0,8,0" />
              <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_SelectedAddress_Input"
                             Grid.Column="5" Name="SelectedAddressBox" IsReadOnly="True" FormatString="0"
                             Minimum="0" Maximum="2147483647" Margin="0,0,8,0" />
              <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_Write_Button"
                      Grid.Column="6" Name="WriteButton" Content="Write" Click="OnWrite" MinWidth="100"
                      HorizontalAlignment="Left" />
            </Grid>
          </Border>

          <Border BorderBrush="Gray" BorderThickness="1" Padding="6" CornerRadius="2">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto,80,Auto">
                <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_LevelUpAddrLabel"
                           Grid.Column="0" Text="Level-up Skill Table Address"
                           VerticalAlignment="Center" FontWeight="Bold" />
                <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_LevelUpAddr_Input"
                               Grid.Column="1" Name="N1LevelUpAddrBox" FormatString="0"
                               Minimum="0" Maximum="2147483647" Margin="0,0,8,0" />
                <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_ReadCount_Input"
                               Grid.Column="2" Name="N1ReadCountBox" FormatString="0"
                               Minimum="0" Maximum="256" Margin="0,0,8,0" />
                <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_ReloadList_Button"
                        Grid.Column="3" Name="N1ReloadListButton" Content="Reload" Click="OnN1ReloadList" MinWidth="80" />
              </Grid>

              <Grid ColumnDefinitions="240,*">
                <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="4" Margin="0,0,8,0">
                  <DockPanel>
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_LabelFilter"
                               DockPanel.Dock="Top" Text="Name" FontWeight="Bold" Margin="0,0,0,4" />
                    <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_Expand_Button"
                            DockPanel.Dock="Bottom" Name="N1ExpandButton" Content="Expand List"
                            Click="OnN1Expand" Margin="0,4,0,0" />
                    <ListBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_List"
                             Name="N1ListBox" Height="220" />
                  </DockPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="6">

                  <Grid ColumnDefinitions="Auto,80,Auto,Auto,Auto">
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_LevelLabel"
                               Grid.Column="0" Text="Acquired Level" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontWeight="Bold" />
                    <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_B0_Input"
                                   Grid.Column="1" Name="N1B0Box" FormatString="0"
                                   Minimum="0" Maximum="255" Margin="0,0,8,0" />
                  </Grid>

                  <Border AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_255_Panel"
                          Name="XLv255Panel" IsVisible="False"
                          BorderBrush="Goldenrod" BorderThickness="1" Padding="6" CornerRadius="2">
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_255_Info_Label"
                               Name="XLv255InfoText" TextWrapping="Wrap"
                               Text="Level is set to 255.&#10;When a class is reached via CC from a base class, this skill cannot be obtained.&#10;Only when this class is LOADed can this skill be held." />
                  </Border>

                  <Border AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LevelAddPanel"
                          Name="XLevelAddPanel" IsVisible="False"
                          BorderBrush="LightGray" BorderThickness="1" Padding="6" CornerRadius="2">
                    <Grid ColumnDefinitions="160,Auto,80,Auto,*" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_BreakdownLabel"
                                 Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Text="Acquired Level Breakdown"
                                 TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                      <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_LevelLabel"
                                 Grid.Row="0" Grid.Column="1" Text="Level:" VerticalAlignment="Center" Margin="0,0,8,0" />
                      <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_Value_Input"
                                     Grid.Row="0" Grid.Column="2" Name="XLvValueBox" FormatString="0"
                                     Minimum="0" Maximum="31" Margin="0,0,8,0" />
                      <CheckBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_PlayerOnly_Check"
                                Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Name="XLvPlayerOnlyCheckBox"
                                Content="PlayerOnly(LV+32)" Margin="0,4,8,0" />
                      <CheckBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_EnemyOnly_Check"
                                Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Name="XLvEnemyOnlyCheckBox"
                                Content="EnemyOnly(LV+64)" Margin="0,4,8,0" />
                      <CheckBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_NormalHard_Check"
                                Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Name="XLvNormalHardCheckBox"
                                Content="Normal&amp;&amp;Hard (LV+96)" Margin="0,4,8,0" />
                      <CheckBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_X_LV_HardOnly_Check"
                                Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Name="XLvHardOnlyCheckBox"
                                Content="Hard only (LV+128)" Margin="0,4,8,0" />
                    </Grid>
                  </Border>

                  <Grid ColumnDefinitions="Auto,80,Auto,*,Auto">
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SkillLabel"
                               Grid.Column="0" Text="Skill" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontWeight="Bold" />
                    <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_B1_Input"
                                   Grid.Column="1" Name="N1B1Box" FormatString="0"
                                   Minimum="0" Maximum="255" Margin="0,0,8,0" />
                    <Image AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SkillIcon_Image"
                           Grid.Column="2" Name="N1SkillIconImage"
                           Width="32" Height="32" Margin="0,0,8,0" />
                    <TextBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SkillName_Label"
                             Grid.Column="3" Name="N1SkillNameTextBox" IsReadOnly="True"
                             Margin="0,0,8,0" />
                  </Grid>
                  <TextBox AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SkillText_Label"
                           Name="N1SkillTextTextBox" IsReadOnly="True" AcceptsReturn="True"
                           Height="60" Margin="0,4,0,0" />

                  <Grid ColumnDefinitions="Auto,140,Auto,80,Auto,140,*">
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_AddrLabel"
                               Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_Addr_Input"
                                   Grid.Column="1" Name="N1AddressBox" FormatString="0" IsReadOnly="True"
                                   Minimum="0" Maximum="2147483647" Margin="0,0,8,0" />
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SizeLabel"
                               Grid.Column="2" Text="Size:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_BlockSize_Input"
                                   Grid.Column="3" Name="N1BlockSizeBox" IsReadOnly="True"
                                   Minimum="0" Maximum="64" Margin="0,0,8,0" />
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SelectAddrLabel"
                               Grid.Column="4" Text="Selected:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <NumericUpDown AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_SelectedAddress_Input"
                                   Grid.Column="5" Name="N1SelectedAddressBox" IsReadOnly="True" FormatString="0"
                                   Minimum="0" Maximum="2147483647" Margin="0,0,8,0" />
                    <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_N1_Write_Button"
                            Grid.Column="6" Name="N1WriteButton" Content="Write" Click="OnN1Write" MinWidth="100"
                            HorizontalAlignment="Left" />
                  </Grid>

                  <Border AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ZeroPointerPanel"
                          Name="ZeroPointerPanel" IsVisible="False"
                          BorderBrush="OrangeRed" BorderThickness="1" Padding="6" CornerRadius="2">
                    <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ZeroPointer_Label"
                               TextWrapping="Wrap"
                               Text="No level-up skill area is allocated for this class.&#10;Press the &quot;Expand List&quot; button to allocate one." />
                  </Border>

                  <Border AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_IndependencePanel"
                          Name="IndependencePanel" IsVisible="False"
                          BorderBrush="Goldenrod" BorderThickness="1" Padding="6" CornerRadius="2">
                    <StackPanel Spacing="4">
                      <TextBlock AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_IndependenceNotice_Label"
                                 TextWrapping="Wrap"
                                 Text="This table is referenced by multiple classes." />
                      <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_Independence_Button"
                              Name="IndependenceButton" Content="Detach Selected Class (make independent)"
                              Click="OnIndependence" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>

                  <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_LearnInfo_Link"
                          Name="LearnInfoLink" Content="Click here for acquired level and skill details"
                          Click="OnLearnInfo" Classes="Hyperlink" HorizontalAlignment="Left" />

                  <!-- #1011: Bulk Import/Export are DISABLED for the C-SkillSys variant — WinForms
                       SkillAssignmentClassCSkillSysForm.ExportAllData/ImportAllData are empty stubs
                       (the bulk serializer exists only on the non-C SkillSystem sibling). The tooltip
                       lives on this ENABLED StackPanel because a disabled Avalonia control is not
                       hit-testable and would not surface its own ToolTip on hover. -->
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                              ToolTip.Tip="Bulk Import/Export is not available for the C-SkillSys variant (unimplemented in WinForms too).">
                    <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ImportAll_Button"
                            Name="ImportAllButton" Content="Bulk Import" IsEnabled="False" MinWidth="140" />
                    <Button AutomationProperties.AutomationId="SkillAssignmentClassCSkillSys_ExportAll_Button"
                            Name="ExportAllButton" Content="Bulk Export" IsEnabled="False" MinWidth="140" />
                  </StackPanel>

                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</Window>
