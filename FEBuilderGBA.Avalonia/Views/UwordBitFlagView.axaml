<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UwordBitFlagView"
        Title="Word Bit Flags (32-bit)" Width="1183" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="10,9,10,10">
    <!-- Top row: MESSAGE label + Apply button (WinForms MESSAGE 1146x40 + ApplyButton 181x40) -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="40" VerticalAlignment="Center">
        <TextBlock AutomationProperties.AutomationId="UwordBitFlag_MESSAGE_Label" Name="MESSAGE" Text="Word Bit Flags (32-bit)"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Button AutomationProperties.AutomationId="UwordBitFlag_Apply_Button" Grid.Column="1" Name="ApplyButton" Content="Apply" Width="181" Height="40"
              VerticalAlignment="Center"
              Margin="8,0,0,0" Click="OK_Click" />
    </Grid>
    <!-- Main panel: Four side-by-side GroupBoxes (WinForms J_40/41/42/43) -->
    <Border BorderBrush="Gray" BorderThickness="1" Padding="7,0,7,7">
      <Grid ColumnDefinitions="*,*,*,*">
        <!-- Column 0: bits 0-7 -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="0,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 0:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UwordBitFlag_B40_Input" FormatString="0" Name="B40" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit0_Check" Name="Bit0Box"  Content="Bit 0  (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit1_Check" Name="Bit1Box"  Content="Bit 1  (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit2_Check" Name="Bit2Box"  Content="Bit 2  (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit3_Check" Name="Bit3Box"  Content="Bit 3  (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit4_Check" Name="Bit4Box"  Content="Bit 4  (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit5_Check" Name="Bit5Box"  Content="Bit 5  (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit6_Check" Name="Bit6Box"  Content="Bit 6  (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit7_Check" Name="Bit7Box"  Content="Bit 7  (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 1: bits 8-15 -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 1:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UwordBitFlag_B41_Input" FormatString="0" Name="B41" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit8_Check" Name="Bit8Box"  Content="Bit 8  (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit9_Check" Name="Bit9Box"  Content="Bit 9  (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit10_Check" Name="Bit10Box" Content="Bit 10 (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit11_Check" Name="Bit11Box" Content="Bit 11 (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit12_Check" Name="Bit12Box" Content="Bit 12 (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit13_Check" Name="Bit13Box" Content="Bit 13 (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit14_Check" Name="Bit14Box" Content="Bit 14 (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit15_Check" Name="Bit15Box" Content="Bit 15 (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 2: bits 16-23 -->
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 2:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UwordBitFlag_B42_Input" FormatString="0" Name="B42" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit16_Check" Name="Bit16Box" Content="Bit 16 (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit17_Check" Name="Bit17Box" Content="Bit 17 (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit18_Check" Name="Bit18Box" Content="Bit 18 (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit19_Check" Name="Bit19Box" Content="Bit 19 (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit20_Check" Name="Bit20Box" Content="Bit 20 (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit21_Check" Name="Bit21Box" Content="Bit 21 (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit22_Check" Name="Bit22Box" Content="Bit 22 (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit23_Check" Name="Bit23Box" Content="Bit 23 (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 3: bits 24-31 -->
        <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,0,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 3:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UwordBitFlag_B43_Input" FormatString="0" Name="B43" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit24_Check" Name="Bit24Box" Content="Bit 24 (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit25_Check" Name="Bit25Box" Content="Bit 25 (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit26_Check" Name="Bit26Box" Content="Bit 26 (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit27_Check" Name="Bit27Box" Content="Bit 27 (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit28_Check" Name="Bit28Box" Content="Bit 28 (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit29_Check" Name="Bit29Box" Content="Bit 29 (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit30_Check" Name="Bit30Box" Content="Bit 30 (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UwordBitFlag_Bit31_Check" Name="Bit31Box" Content="Bit 31 (0x80)" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </DockPanel>
  </ScrollViewer>
</Window>
