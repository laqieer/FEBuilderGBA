<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UwordBitFlagView"
        Title="Word Bit Flags (32-bit)" Width="1183" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="10,9,10,10">
    <!-- Top row: MESSAGE label + Apply button (WinForms MESSAGE 1146x40 + ApplyButton 181x40) -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="40">
        <TextBlock Name="MESSAGE" Text="Word Bit Flags (32-bit)"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Button Grid.Column="1" Name="ApplyButton" Content="Apply" Width="181" Height="40"
              Margin="8,0,0,0" Click="OK_Click" />
    </Grid>
    <!-- Main panel: Four side-by-side GroupBoxes (WinForms J_40/41/42/43) -->
    <Border BorderBrush="Gray" BorderThickness="1" Padding="7,0,7,7">
      <Grid ColumnDefinitions="*,*,*,*">
        <!-- Column 0: bits 0-7 -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="0,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 0:" VerticalAlignment="Center" />
              <NumericUpDown Name="B40" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox Name="Bit0Box"  Content="Bit 0  (0x01)" />
            <CheckBox Name="Bit1Box"  Content="Bit 1  (0x02)" />
            <CheckBox Name="Bit2Box"  Content="Bit 2  (0x04)" />
            <CheckBox Name="Bit3Box"  Content="Bit 3  (0x08)" />
            <CheckBox Name="Bit4Box"  Content="Bit 4  (0x10)" />
            <CheckBox Name="Bit5Box"  Content="Bit 5  (0x20)" />
            <CheckBox Name="Bit6Box"  Content="Bit 6  (0x40)" />
            <CheckBox Name="Bit7Box"  Content="Bit 7  (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 1: bits 8-15 -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 1:" VerticalAlignment="Center" />
              <NumericUpDown Name="B41" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox Name="Bit8Box"  Content="Bit 8  (0x01)" />
            <CheckBox Name="Bit9Box"  Content="Bit 9  (0x02)" />
            <CheckBox Name="Bit10Box" Content="Bit 10 (0x04)" />
            <CheckBox Name="Bit11Box" Content="Bit 11 (0x08)" />
            <CheckBox Name="Bit12Box" Content="Bit 12 (0x10)" />
            <CheckBox Name="Bit13Box" Content="Bit 13 (0x20)" />
            <CheckBox Name="Bit14Box" Content="Bit 14 (0x40)" />
            <CheckBox Name="Bit15Box" Content="Bit 15 (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 2: bits 16-23 -->
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,2,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 2:" VerticalAlignment="Center" />
              <NumericUpDown Name="B42" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox Name="Bit16Box" Content="Bit 16 (0x01)" />
            <CheckBox Name="Bit17Box" Content="Bit 17 (0x02)" />
            <CheckBox Name="Bit18Box" Content="Bit 18 (0x04)" />
            <CheckBox Name="Bit19Box" Content="Bit 19 (0x08)" />
            <CheckBox Name="Bit20Box" Content="Bit 20 (0x10)" />
            <CheckBox Name="Bit21Box" Content="Bit 21 (0x20)" />
            <CheckBox Name="Bit22Box" Content="Bit 22 (0x40)" />
            <CheckBox Name="Bit23Box" Content="Bit 23 (0x80)" />
          </StackPanel>
        </Border>
        <!-- Column 3: bits 24-31 -->
        <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="2,0,0,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Byte 3:" VerticalAlignment="Center" />
              <NumericUpDown Name="B43" Width="70" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox Name="Bit24Box" Content="Bit 24 (0x01)" />
            <CheckBox Name="Bit25Box" Content="Bit 25 (0x02)" />
            <CheckBox Name="Bit26Box" Content="Bit 26 (0x04)" />
            <CheckBox Name="Bit27Box" Content="Bit 27 (0x08)" />
            <CheckBox Name="Bit28Box" Content="Bit 28 (0x10)" />
            <CheckBox Name="Bit29Box" Content="Bit 29 (0x20)" />
            <CheckBox Name="Bit30Box" Content="Bit 30 (0x40)" />
            <CheckBox Name="Bit31Box" Content="Bit 31 (0x80)" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </DockPanel>
  </ScrollViewer>
</Window>
