<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UwordBitFlagView"
        Title="Word Bit Flags" Width="500" Height="400"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="12">
    <TextBlock Text="Word Bit Flags" FontSize="18" FontWeight="Bold" />
    <TextBlock Text="This editor is not yet implemented." Foreground="Gray" />
  </StackPanel>
</Window>
