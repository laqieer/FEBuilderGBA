<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SongInstrumentView">
  <Grid RowDefinitions="Auto,*">

    <!-- Top read-config bar — unified via EditorTopBarWithInputs (#649).
         Editable First Address + Read Count + Reload. The extra Expand List
         button and Filter TextBox stay in a sibling Border underneath so
         the unified bar's "Reload pinned to right edge" contract holds. -->
    <StackPanel Grid.Row="0" Margin="0,0,0,4">
      <!-- ReadCountMaximum=4096 matches the pre-migration NumericUpDown limit. -->
      <controls:EditorTopBarWithInputs Name="TopBar"
                                       AutomationProperties.AutomationId="SongInstrument_TopBar"
                                       ReadStartLabel="First Address:"
                                       ReadCountLabel="Read Count:"
                                       ReadCountMaximum="4096"
                                       ReadStartAutomationId="SongInstrument_ReadStartAddress_Input"
                                       ReadCountAutomationId="SongInstrument_ReadCount_Input"
                                       ReloadAutomationId="SongInstrument_ReloadList_Button"
                                       ShowReadSize="False"
                                       ReloadRequested="OnTopBarReloadRequested" />
      <Border BorderBrush="Gray" BorderThickness="1" Padding="4" Margin="0,4,0,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button AutomationProperties.AutomationId="SongInstrument_ListExpand_Button"
                  Name="ListExpandButton" Content="Expand List" Width="100" IsEnabled="False"
                  Click="ListExpand_Click"
                  ToolTip.Tip="Grow this song's voicegroup (instrument set) to the full 128 records: relocate to free space, copy the existing instruments and fill the rest from instrument 0, then repoint every song that shares this voicegroup (#780)." />
          <TextBlock Text="Filter" VerticalAlignment="Center" Width="50" />
          <TextBox AutomationProperties.AutomationId="SongInstrument_Filter_Input"
                   Name="FilterBox" Width="150" VerticalAlignment="Center"
                   KeyDown="FilterBox_KeyDown"
                   ToolTip.Tip="Type a substring and press Enter (or click Reload) to filter the instrument list. Mirrors WF SongInstrumentForm Filter behavior." />
        </StackPanel>
      </Border>
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="280,*">
      <controls:AddressListControl AutomationProperties.AutomationId="SongInstrument_Entry_List"
                                   Grid.Column="0" Name="EntryList" Margin="4" />

      <ScrollViewer Grid.Column="1" Margin="4">
        <StackPanel Spacing="8" Margin="8">

          <!-- Master address-write bar mirrors WF AddressPanel -->
          <Border BorderBrush="Gray" BorderThickness="1" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Address" VerticalAlignment="Center" Width="70" />
              <NumericUpDown AutomationProperties.AutomationId="SongInstrument_Address_Input"
                             Name="AddressBox" Width="120" Minimum="0" Maximum="4294967295"
                             FormatString="0" VerticalAlignment="Center" IsReadOnly="True" />
              <TextBlock Text="Size:" VerticalAlignment="Center" Width="40" />
              <TextBox AutomationProperties.AutomationId="SongInstrument_BlockSize_Input"
                       Name="BlockSizeBox" Width="60" IsReadOnly="True" VerticalAlignment="Center" />
              <TextBlock Text="Selected Address:" VerticalAlignment="Center" Width="120" />
              <TextBlock AutomationProperties.AutomationId="SongInstrument_SelectedAddress_Label"
                         Name="SelectedAddressLabel" Width="120" VerticalAlignment="Center" />
              <Button AutomationProperties.AutomationId="SongInstrument_Write_Button"
                      Name="WriteButton" Content="Write" Width="160" Click="Write_Click" />
            </StackPanel>
          </Border>

          <!-- Common header bar mirrors WF panel2 -->
          <Border BorderBrush="Gray" BorderThickness="1" Padding="4">
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Type:" VerticalAlignment="Center" Width="60" />
                <ComboBox AutomationProperties.AutomationId="SongInstrument_TypeCombo_Input"
                          Name="TypeCombo" Width="280" VerticalAlignment="Center"
                          SelectionChanged="TypeCombo_SelectionChanged" />
                <TextBlock AutomationProperties.AutomationId="SongInstrument_Info_Label"
                           Name="InfoLabel" Text="Info" Foreground="Blue" TextDecorations="Underline"
                           Cursor="Hand" VerticalAlignment="Center" />
                <!-- #1057: InstExport (recursive read-only voicegroup export) +
                     InstImport (recursive ROM-mutating voicegroup import, PR2) are
                     both wired via SongInstrumentSetCore. -->
                <Button AutomationProperties.AutomationId="SongInstrument_InstExport_Button"
                        Name="InstExportButton" Content="Export Instrument" Width="160"
                        ToolTip.Tip="Export the whole instrument set (voicegroup) to a TSV index plus per-voice side files (recursive)."
                        Click="InstExport_Click" />
                <Button AutomationProperties.AutomationId="SongInstrument_InstImport_Button"
                        Name="InstImportButton" Content="Import Instrument" Width="160"
                        ToolTip.Tip="Import a whole instrument set (voicegroup) from a TSV index plus its per-voice side files (recursive), appended to free space and repointed."
                        Click="InstImport_Click" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Header Byte:" VerticalAlignment="Center" Width="100" />
                <NumericUpDown AutomationProperties.AutomationId="SongInstrument_HeaderByte_Input"
                               Name="HeaderByteBox" Minimum="0" Maximum="255" FormatString="0"
                               Width="80" VerticalAlignment="Center" />
                <TextBlock Text="More Info:" VerticalAlignment="Center" Width="80" />
                <TextBox AutomationProperties.AutomationId="SongInstrument_MoreInfo_Input"
                         Name="MoreInfoBox" Width="320" IsReadOnly="True" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Tab control with all 14 instrument tabs (UNIONTAB_N00..N80).
               Static AXAML tabs (NOT behind DataTemplate / ItemsControl) so
               ControlDensityScanner counts them — #387 plan review v1 #1. -->
          <TabControl AutomationProperties.AutomationId="SongInstrument_UnionTab_TabControl"
                      Name="UnionTab" Padding="4"
                      SelectionChanged="UnionTab_SelectionChanged">

            <!-- ============================================================
                 N00 DirectSound — B1,B2,B3 + P4 (WavePtr) + B8..B11 (ADSR)
                 + per-byte labels and supporting fields (panpot / keymap).
                 ============================================================ -->
            <TabItem AutomationProperties.AutomationId="SongInstrument_UNIONTAB_N00_Tab"
                     Name="UnionTab_N00" Header="DirectSound">
              <StackPanel Spacing="4" Margin="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_1_Label"
                             Name="N00_J_1_Label" Text="基準ノート値" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B1_Input"
                                 Name="N00_B1_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N00_KeyMap_Combo"
                            Name="N00_KeyMapCombo" Width="160" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_2_Label"
                             Name="N00_J_2_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B2_Input"
                                 Name="N00_B2_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_3_Label"
                             Name="N00_J_3_Label" Text="PAN強制" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B3_Input"
                                 Name="N00_B3_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                  <TextBlock Text="パンポット" VerticalAlignment="Center" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N00_Pan_Combo"
                            Name="N00_PanCombo" Width="100" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_PanPot_Input"
                                 Name="N00_PanPotBox" Width="60" Minimum="0" Maximum="127" FormatString="0" Value="0" />
                  <TextBlock Text="= c_v - 64" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_4_Label"
                             Name="N00_J_4_Label" Text="音データ" Width="120" Foreground="Blue"
                             TextDecorations="Underline" Cursor="Hand" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_P4_Input"
                                 Name="N00_P4_Box" Width="160" Minimum="0" Maximum="4294967295" FormatString="0" />
                  <!-- #1014: Sappy preview is Windows-only (still disabled).
                       Wave Export/Import are wired in #1057 (N00 DirectSound
                       slice) via SongDirectSoundWavCore. -->
                  <Border ToolTip.Tip="Sappy emulator playback is Windows-only (user32 P/Invoke); use the WinForms version of FEBuilderGBA.">
                    <Button AutomationProperties.AutomationId="SongInstrument_N00_Preview_Button"
                            Name="N00_PreviewButton" Content="Preview" Width="80" IsEnabled="False" />
                  </Border>
                  <Button AutomationProperties.AutomationId="SongInstrument_N00_Export_Button"
                          Name="N00_ExportButton" Content="音データ 書出" Width="120"
                          ToolTip.Tip="Export this DirectSound instrument's GBA sample to a WAV file."
                          Click="N00_Export_Click" />
                  <Button AutomationProperties.AutomationId="SongInstrument_N00_Import_Button"
                          Name="N00_ImportButton" Content="音データ 読込" Width="120"
                          ToolTip.Tip="Import a WAV file as this DirectSound instrument's GBA sample (appends to free space and repoints)."
                          Click="N00_Import_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_8_Label"
                             Name="N00_J_8_Label" Text="atk" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B8_Input"
                                 Name="N00_B8_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_9_Label"
                             Name="N00_J_9_Label" Text="dec" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B9_Input"
                                 Name="N00_B9_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_10_Label"
                             Name="N00_J_10_Label" Text="sus" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B10_Input"
                                 Name="N00_B10_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N00_J_11_Label"
                             Name="N00_J_11_Label" Text="rel" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N00_B11_Input"
                                 Name="N00_B11_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
              </StackPanel>
            </TabItem>

            <!-- ============================================================
                 N01 SquareWave1 — B1..B11 raw (B4 = squarepattern)
                 ============================================================ -->
            <TabItem AutomationProperties.AutomationId="SongInstrument_UNIONTAB_N01_Tab"
                     Name="UnionTab_N01" Header="SquareWave1">
              <StackPanel Spacing="4" Margin="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_1_Label"
                             Name="N01_J_1_Label" Text="??" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B1_Input"
                                 Name="N01_B1_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_2_Label"
                             Name="N01_J_2_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B2_Input"
                                 Name="N01_B2_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_3_Label"
                             Name="N01_J_3_Label" Text="sweep" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B3_Input"
                                 Name="N01_B3_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                  <TextBlock Text="sweeptime" VerticalAlignment="Center" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N01_SweepTime_Combo"
                            Name="N01_SweepTimeCombo" Width="100" />
                  <TextBlock Text="sweepshift" VerticalAlignment="Center" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N01_SweepShift_Combo"
                            Name="N01_SweepShiftCombo" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_4_Label"
                             Name="N01_J_4_Label" Text="squarepattern" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B4_Input"
                                 Name="N01_B4_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N01_SquarePattern_Combo"
                            Name="N01_SquarePatternCombo" Width="160" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_5_Label"
                             Name="N01_J_5_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B5_Input"
                                 Name="N01_B5_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_6_Label"
                             Name="N01_J_6_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B6_Input"
                                 Name="N01_B6_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_7_Label"
                             Name="N01_J_7_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B7_Input"
                                 Name="N01_B7_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_8_Label"
                             Name="N01_J_8_Label" Text="atk" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B8_Input"
                                 Name="N01_B8_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_9_Label"
                             Name="N01_J_9_Label" Text="dec" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B9_Input"
                                 Name="N01_B9_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_10_Label"
                             Name="N01_J_10_Label" Text="sus" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B10_Input"
                                 Name="N01_B10_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N01_J_11_Label"
                             Name="N01_J_11_Label" Text="rel" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N01_B11_Input"
                                 Name="N01_B11_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
              </StackPanel>
            </TabItem>

            <!-- ============================================================
                 N02 SquareWave2 — same shape as N01 minus sweep
                 ============================================================ -->
            <TabItem AutomationProperties.AutomationId="SongInstrument_UNIONTAB_N02_Tab"
                     Name="UnionTab_N02" Header="SquareWave2">
              <StackPanel Spacing="4" Margin="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_1_Label"
                             Name="N02_J_1_Label" Text="??" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B1_Input"
                                 Name="N02_B1_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_2_Label"
                             Name="N02_J_2_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B2_Input"
                                 Name="N02_B2_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_3_Label"
                             Name="N02_J_3_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B3_Input"
                                 Name="N02_B3_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_4_Label"
                             Name="N02_J_4_Label" Text="squarepattern" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B4_Input"
                                 Name="N02_B4_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                  <ComboBox AutomationProperties.AutomationId="SongInstrument_N02_SquarePattern_Combo"
                            Name="N02_SquarePatternCombo" Width="160" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_5_Label"
                             Name="N02_J_5_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B5_Input"
                                 Name="N02_B5_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_6_Label"
                             Name="N02_J_6_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B6_Input"
                                 Name="N02_B6_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_7_Label"
                             Name="N02_J_7_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B7_Input"
                                 Name="N02_B7_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_8_Label"
                             Name="N02_J_8_Label" Text="atk" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B8_Input"
                                 Name="N02_B8_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_9_Label"
                             Name="N02_J_9_Label" Text="dec" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B9_Input"
                                 Name="N02_B9_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_10_Label"
                             Name="N02_J_10_Label" Text="sus" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B10_Input"
                                 Name="N02_B10_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N02_J_11_Label"
                             Name="N02_J_11_Label" Text="rel" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N02_B11_Input"
                                 Name="N02_B11_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
              </StackPanel>
            </TabItem>

            <!-- ============================================================
                 N03 Wave Memory — B1,B2,B3 + P4 (WavePtr) + B8..B11 (ADSR)
                 ============================================================ -->
            <TabItem AutomationProperties.AutomationId="SongInstrument_UNIONTAB_N03_Tab"
                     Name="UnionTab_N03" Header="Wave Memory">
              <StackPanel Spacing="4" Margin="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_1_Label"
                             Name="N03_J_1_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_B1_Input"
                                 Name="N03_B1_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_2_Label"
                             Name="N03_J_2_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_B2_Input"
                                 Name="N03_B2_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_3_Label"
                             Name="N03_J_3_Label" Text="00" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_B3_Input"
                                 Name="N03_B3_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_4_Label"
                             Name="N03_J_4_Label" Text="波形データ" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_P4_Input"
                                 Name="N03_P4_Box" Width="160" Minimum="0" Maximum="4294967295" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_8_Label"
                             Name="N03_J_8_Label" Text="atk" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_B8_Input"
                                 Name="N03_B8_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock AutomationProperties.AutomationId="SongInstrument_N03_J_9_Label"
                             Name="N03_J_9_Label" Text="dec" Width="120" VerticalAlignment="Center" />
                  <NumericUpDown AutomationProperties.AutomationId="SongInstrument_N03_B9_Input"
                                 Name="N03_B9_Box" Width="80" Minimum="0" Maximum="255" FormatString="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
