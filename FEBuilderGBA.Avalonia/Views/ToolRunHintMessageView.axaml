<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolRunHintMessageView"
        Title="Test Run" Width="450" Height="300"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Test Run" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,12,0,0">
      <CheckBox Content="Do not show this message again" IsChecked="{Binding DoNotShowAgain}" />
      <Button Content="OK" Width="80" HorizontalAlignment="Right" Click="OK_Click" />
    </StackPanel>
    <TextBox Text="{Binding DetailText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" />
  </DockPanel>
</Window>
