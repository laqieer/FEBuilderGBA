<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UshortBitFlagView"
        Title="Short Bit Flags (16-bit)" Width="708" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="10,9,10,10">
    <!-- Top row: MESSAGE label + Apply button (WinForms MESSAGE 676x40 + ApplyButton 181x40) -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="40" VerticalAlignment="Center">
        <TextBlock AutomationProperties.AutomationId="UshortBitFlag_MESSAGE_Label" Name="MESSAGE" Text="Short Bit Flags (16-bit)"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Button AutomationProperties.AutomationId="UshortBitFlag_Apply_Button" Grid.Column="1" Name="ApplyButton" Content="Apply" Width="181" Height="40"
              VerticalAlignment="Center"
              Margin="8,0,0,0" Click="OK_Click" />
    </Grid>
    <!-- Main panel: Two side-by-side GroupBoxes (WinForms J_40 333x316 + J_41 333x316) -->
    <Border BorderBrush="Gray" BorderThickness="1" Padding="7,0,7,7">
      <Grid ColumnDefinitions="*,*">
        <!-- Left column: bits 0-7 -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="0,0,4,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="Low byte:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UshortBitFlag_B40_Input" FormatString="0" Name="B40" Width="80" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit0_Check" Name="Bit0Box"  Content="Bit 0  (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit1_Check" Name="Bit1Box"  Content="Bit 1  (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit2_Check" Name="Bit2Box"  Content="Bit 2  (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit3_Check" Name="Bit3Box"  Content="Bit 3  (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit4_Check" Name="Bit4Box"  Content="Bit 4  (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit5_Check" Name="Bit5Box"  Content="Bit 5  (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit6_Check" Name="Bit6Box"  Content="Bit 6  (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit7_Check" Name="Bit7Box"  Content="Bit 7  (0x80)" />
          </StackPanel>
        </Border>
        <!-- Right column: bits 8-15 -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="5,0,5,5"
                Margin="4,0,0,0">
          <StackPanel Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
              <TextBlock Text="High byte:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="UshortBitFlag_B41_Input" FormatString="0" Name="B41" Width="80" Height="25" Minimum="0" Maximum="255" Value="0" />
            </StackPanel>
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit8_Check" Name="Bit8Box"  Content="Bit 8  (0x01)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit9_Check" Name="Bit9Box"  Content="Bit 9  (0x02)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit10_Check" Name="Bit10Box" Content="Bit 10 (0x04)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit11_Check" Name="Bit11Box" Content="Bit 11 (0x08)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit12_Check" Name="Bit12Box" Content="Bit 12 (0x10)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit13_Check" Name="Bit13Box" Content="Bit 13 (0x20)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit14_Check" Name="Bit14Box" Content="Bit 14 (0x40)" />
            <CheckBox AutomationProperties.AutomationId="UshortBitFlag_Bit15_Check" Name="Bit15Box" Content="Bit 15 (0x80)" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </DockPanel>
  </ScrollViewer>
</Window>
