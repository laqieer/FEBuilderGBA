<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UshortBitFlagView"
        Title="Short Bit Flags (16-bit)" Width="360" Height="620"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="6">
    <TextBlock Text="Short Bit Flags (16-bit)" FontSize="18" FontWeight="Bold" />
    <TextBlock Name="ValueLabel" Text="Value: 0x0000" FontSize="14" FontFamily="Consolas" Margin="0,4,0,8" />
    <CheckBox Name="Bit0Box"  Content="Bit 0  (0x0001)" />
    <CheckBox Name="Bit1Box"  Content="Bit 1  (0x0002)" />
    <CheckBox Name="Bit2Box"  Content="Bit 2  (0x0004)" />
    <CheckBox Name="Bit3Box"  Content="Bit 3  (0x0008)" />
    <CheckBox Name="Bit4Box"  Content="Bit 4  (0x0010)" />
    <CheckBox Name="Bit5Box"  Content="Bit 5  (0x0020)" />
    <CheckBox Name="Bit6Box"  Content="Bit 6  (0x0040)" />
    <CheckBox Name="Bit7Box"  Content="Bit 7  (0x0080)" />
    <CheckBox Name="Bit8Box"  Content="Bit 8  (0x0100)" />
    <CheckBox Name="Bit9Box"  Content="Bit 9  (0x0200)" />
    <CheckBox Name="Bit10Box" Content="Bit 10 (0x0400)" />
    <CheckBox Name="Bit11Box" Content="Bit 11 (0x0800)" />
    <CheckBox Name="Bit12Box" Content="Bit 12 (0x1000)" />
    <CheckBox Name="Bit13Box" Content="Bit 13 (0x2000)" />
    <CheckBox Name="Bit14Box" Content="Bit 14 (0x4000)" />
    <CheckBox Name="Bit15Box" Content="Bit 15 (0x8000)" />
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
  </StackPanel>
</Window>
