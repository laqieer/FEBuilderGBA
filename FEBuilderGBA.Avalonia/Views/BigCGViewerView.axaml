<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.BigCGViewerView"
        Title="Big CG Editor" Width="1050" Height="441"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="BigCGViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Big CG Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="BigCGViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Table Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="BigCGViewer_TablePtr_Input" Grid.Row="1" Grid.Column="1" Name="TablePtrBox" Width="120" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="TSA Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="BigCGViewer_TsaPtr_Input" Grid.Row="2" Grid.Column="1" Name="TsaPtrBox" Width="120" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="BigCGViewer_PalPtr_Input" Grid.Row="3" Grid.Column="1" Name="PalPtrBox" Width="120" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="BigCGViewer_Write_Button" Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="BigCGViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="BigCGViewer_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
          <Button AutomationProperties.AutomationId="BigCGViewer_FERepo_Button" Content="FE-Repo" Click="FERepo_Click"
                  ToolTip.Tip="Import from the FE-Repo Background CGs folder" />
          <Button AutomationProperties.AutomationId="BigCGViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" />
          <Button AutomationProperties.AutomationId="BigCGViewer_ImportPal_Button" Content="Import PAL" Click="ImportPal_Click" />
        </StackPanel>
        <controls:GbaImageControl AutomationProperties.AutomationId="BigCGViewer_Image_Image" Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
