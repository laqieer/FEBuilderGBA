<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.EDStaffRollView"
        Title="Staff Roll Editor" Width="1142" Height="458">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Staff Roll Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox Grid.Row="1" Grid.Column="1" Name="ImagePtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="TSA Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox Grid.Row="2" Grid.Column="1" Name="TSAPtrBox" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
