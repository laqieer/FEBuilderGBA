<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MonsterItemViewerView"
        Title="Monster Item Editor" Width="1645" Height="935"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Monster Item Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Item ID:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="1" Name="ItemIdBox" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Drop Rate:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="1" Name="DropRateBox" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Unknown 1:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="3" Grid.Column="1" Name="Unknown1Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Unknown 2:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="4" Grid.Column="1" Name="Unknown2Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Unknown 3:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="5" Grid.Column="1" Name="Unknown3Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
