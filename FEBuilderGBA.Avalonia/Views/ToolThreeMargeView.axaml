<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolThreeMargeView"
        Title="Three-Way Merge" Width="1580" Height="946"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Three-Way Merge" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Merge" Click="Merge_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <Grid RowDefinitions="Auto,4,*,12,Auto,4,*" ColumnDefinitions="*,8,*">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Base" FontWeight="SemiBold" />
      <TextBox Grid.Row="2" Grid.Column="0" Name="BaseTextBox" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" IsReadOnly="True" />
      <TextBlock Grid.Row="0" Grid.Column="2" Text="Mine" FontWeight="SemiBold" />
      <TextBox Grid.Row="2" Grid.Column="2" Name="MineTextBox" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" IsReadOnly="True" />
      <TextBlock Grid.Row="4" Grid.Column="0" Text="Theirs" FontWeight="SemiBold" />
      <TextBox Grid.Row="6" Grid.Column="0" Name="TheirsTextBox" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" IsReadOnly="True" />
      <TextBlock Grid.Row="4" Grid.Column="2" Text="Result" FontWeight="SemiBold" />
      <TextBox Grid.Row="6" Grid.Column="2" Name="ResultTextBox" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" />
    </Grid>
  </DockPanel>
</Window>
