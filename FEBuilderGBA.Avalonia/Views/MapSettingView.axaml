<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MapSettingView"
        Title="Map Settings (Read-Only)" Width="800" Height="500">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="MapList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Map Settings (Read-Only)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Chapter Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="NameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Tileset PLIST:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="TilesetLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Map PLIST:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="MapPlistLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Palette PLIST:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="PaletteLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Weather:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="WeatherLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="OBJ Type:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="6" Grid.Column="1" Name="ObjTypeLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Chapter Name ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="7" Grid.Column="1" Name="ChapterNameIdLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
