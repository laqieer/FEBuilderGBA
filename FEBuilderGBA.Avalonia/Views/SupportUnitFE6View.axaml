<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SupportUnitFE6View"
        Title="Support Units (FE6) (Read-Only)" Width="800" Height="500">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Units (FE6) (Read-Only)" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Partner 0:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="Partner0Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Partner 1:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="Partner1Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Partner 2:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="Partner2Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Partner 3:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="Partner3Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Partner 4:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="Partner4Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Partner 5:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="6" Grid.Column="1" Name="Partner5Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Partner 6:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="7" Grid.Column="1" Name="Partner6Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Partner 7:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="8" Grid.Column="1" Name="Partner7Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Partner 8:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="9" Grid.Column="1" Name="Partner8Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Partner 9:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="10" Grid.Column="1" Name="Partner9Label" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
