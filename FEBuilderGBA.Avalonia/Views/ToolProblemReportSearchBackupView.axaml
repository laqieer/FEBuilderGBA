<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolProblemReportSearchBackupView"
        Title="Select Backup" Width="500" Height="220"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Select Backup File" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <StackPanel Spacing="8" VerticalAlignment="Center">
      <TextBlock TextWrapping="Wrap" Text="No past backups were found. Please select a backup file manually." />
      <TextBlock Text="Expected file type: backup.7z" FontStyle="Italic" Foreground="Gray" />
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Margin="8,0,0,0" Click="Browse_Click" />
        <TextBox Text="{Binding BackupFilename}" IsReadOnly="True" />
      </DockPanel>
    </StackPanel>
  </DockPanel>
</Window>
