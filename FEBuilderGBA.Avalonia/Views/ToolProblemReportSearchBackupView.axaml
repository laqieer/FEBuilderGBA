<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolProblemReportSearchBackupView"
        Title="No past backups found"
        Width="906" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="12,19,12,12">
    <!-- Info label -->
    <TextBlock TextWrapping="Wrap" Height="54"
               Text="No past backups were found. Is the backup saved under a different name? If you have a problem-free working backup, please specify its path." />
    <!-- File selection row -->
    <Grid ColumnDefinitions="157,Auto,130" Margin="0,48,0,0">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
              Height="31" VerticalAlignment="Center">
        <TextBlock Text="backup.7z" HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
      <TextBox Grid.Column="1" Text="{Binding BackupFilename}"
               Width="537" Height="25" Margin="17,0,8,0" />
      <Button Grid.Column="2" Content="Browse..." Width="130" Height="31"
              Click="Browse_Click" />
    </Grid>
  </StackPanel>
</Window>
