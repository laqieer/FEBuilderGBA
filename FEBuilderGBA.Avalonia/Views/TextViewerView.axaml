<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.TextViewerView"
        Title="Text Editor" Width="1166" Height="930">
  <Grid ColumnDefinitions="300,*">
    <controls:AddressListControl Grid.Column="0" Name="TextList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Text Editor" FontSize="18" FontWeight="Bold" />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Name="ExportButton" Content="Export All Texts (TSV)" Click="OnExportClick" />
          <Button Name="ImportButton" Content="Import Texts (TSV)" Click="OnImportClick" />
        </StackPanel>

        <TextBlock Name="TextIdLabel" Text="ID:" FontSize="14" />

        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <SelectableTextBlock Name="DecodedTextBlock" TextWrapping="Wrap" FontSize="14" />
        </Border>

        <TextBlock Text="Edit Text:" FontWeight="SemiBold" Margin="0,12,0,4" />
        <TextBox Name="EditTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="100" MaxHeight="300" />
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Name="WriteTextButton" Content="Write Text" />
          <TextBlock Name="WriteStatusLabel" VerticalAlignment="Center" Foreground="Gray" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
