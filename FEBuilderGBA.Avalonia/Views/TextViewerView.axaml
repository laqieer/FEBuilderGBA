<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.TextViewerView">
  <Grid ColumnDefinitions="300,*">
    <controls:AddressListControl AutomationProperties.AutomationId="TextViewer_Text_List" Grid.Column="0" Name="TextList" Margin="4" />

    <TabControl AutomationProperties.AutomationId="TextViewer_Tabs_TabControl" Name="EditorTabs" Grid.Column="1" Margin="4">

      <!-- Tab 1: Edit (existing behaviour + inline Pointer / Refs displays) -->
      <TabItem Header="Edit" Name="EditTab" AutomationProperties.AutomationId="TextViewer_Edit_Tab">
        <ScrollViewer Margin="4">
          <StackPanel Spacing="8" Margin="8">
            <TextBlock Text="Text Editor" FontSize="18" FontWeight="Bold" />

            <!-- Content search -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBox AutomationProperties.AutomationId="TextViewer_ContentSearch_Input" Name="ContentSearchBox" Watermark="Search in text content..." Width="300" />
              <Button AutomationProperties.AutomationId="TextViewer_SearchContentClick_Button" Content="Search Content" Click="OnSearchContentClick" />
              <Button AutomationProperties.AutomationId="TextViewer_ShowAllClick_Button" Content="Show All" Click="OnShowAllClick" />
              <TextBlock AutomationProperties.AutomationId="TextViewer_SearchResult_Label" Name="SearchResultLabel" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" />
            </StackPanel>

            <TextBlock AutomationProperties.AutomationId="TextViewer_TextId_Label" Name="TextIdLabel" Text="ID:" FontSize="14" />

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
              <SelectableTextBlock Name="DecodedTextBlock" TextWrapping="Wrap" FontSize="14" />
            </Border>

            <!-- Inline Pointer + Refs displays (mirror of WF AddressPointer + RefCountTextBox) -->
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
              <TextBlock AutomationProperties.AutomationId="TextViewer_PointerPrefix_Label"
                         Text="Pointer:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <TextBox AutomationProperties.AutomationId="TextViewer_PointerValue_Input"
                       Name="PointerValueBox" IsReadOnly="True" Width="120" />
              <TextBlock AutomationProperties.AutomationId="TextViewer_RefsPrefix_Label"
                         Text="Refs:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,0,0,0" />
              <TextBox AutomationProperties.AutomationId="TextViewer_RefsCount_Input"
                       Name="RefsCountBox" IsReadOnly="True" Width="60" />
            </StackPanel>

            <TextBlock Text="Edit Text:" FontWeight="SemiBold" Margin="0,12,0,4" />
            <TextBox AutomationProperties.AutomationId="TextViewer_EditText_Input" Name="EditTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="100" MaxHeight="300" />

            <!-- Length validation warning -->
            <TextBlock AutomationProperties.AutomationId="TextViewer_LengthWarning_Label" Name="LengthWarningLabel" Margin="0,4,0,0" FontSize="12" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
              <Button AutomationProperties.AutomationId="TextViewer_WriteText_Button" Name="WriteTextButton" Content="Write Text" />
              <Button AutomationProperties.AutomationId="TextViewer_InsertEscapeCode_Button" Name="InsertEscapeCodeButton" Content="Insert Escape Code" />
              <Button AutomationProperties.AutomationId="TextViewer_JumpToPortrait_Button" Name="JumpToPortraitButton" Content="Jump to Portrait" />
              <TextBlock AutomationProperties.AutomationId="TextViewer_WriteStatus_Label" Name="WriteStatusLabel" VerticalAlignment="Center" Foreground="Gray" />
            </StackPanel>

            <!-- Cross-references (inline preview; full list is on the References tab) -->
            <TextBlock Text="References:" FontWeight="SemiBold" Margin="0,16,0,4" />
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" MinHeight="40">
              <ItemsControl AutomationProperties.AutomationId="TextViewer_CrossRef_List" Name="CrossRefList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="12" Margin="0,1" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 2: Search Tools — address bar + free-area scan (mirror WF SearchTabPage) -->
      <TabItem Header="Search Tools" Name="SearchToolsTab" AutomationProperties.AutomationId="TextViewer_SearchTools_Tab">
        <ScrollViewer Margin="4">
          <StackPanel Spacing="10" Margin="8">
            <TextBlock Text="Search &amp; Address Tools" FontSize="16" FontWeight="Bold" />

            <!-- Filter -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_FilterPrefix_Label"
                         Text="Filter:" VerticalAlignment="Center" Width="160" />
              <TextBox AutomationProperties.AutomationId="TextViewer_FilterValue_Input"
                       Name="FilterValueBox" IsReadOnly="True" Width="240" />
            </StackPanel>

            <!-- Read Start Address -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_ReadStartAddressPrefix_Label"
                         Text="Read Start Address:" VerticalAlignment="Center" Width="160" />
              <TextBox AutomationProperties.AutomationId="TextViewer_ReadStartAddress_Input"
                       Name="ReadStartAddressBox" IsReadOnly="True" Width="240" />
            </StackPanel>

            <!-- Read Count -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_ReadCountPrefix_Label"
                         Text="Read Count:" VerticalAlignment="Center" Width="160" />
              <TextBox AutomationProperties.AutomationId="TextViewer_ReadCount_Input"
                       Name="ReadCountBox" IsReadOnly="True" Width="240" />
            </StackPanel>

            <!-- Size -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_SizePrefix_Label"
                         Text="Size:" VerticalAlignment="Center" Width="160" />
              <TextBox AutomationProperties.AutomationId="TextViewer_Size_Input"
                       Name="SizeValueBox" IsReadOnly="True" Width="240" />
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
              <Button AutomationProperties.AutomationId="TextViewer_SearchFreeArea_Button"
                      Name="SearchFreeAreaButton" Content="Search Free Area" Click="OnSearchFreeAreaClick" />
              <Button AutomationProperties.AutomationId="TextViewer_Reload_Button"
                      Name="ReloadButton" Content="Reload" Click="OnReloadClick" />
              <TextBlock AutomationProperties.AutomationId="TextViewer_FreeAreaStatus_Label"
                         Name="FreeAreaStatusLabel" VerticalAlignment="Center" Foreground="Gray" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 3: Import/Export — moved TSV buttons + filter stubs (mirror WF ImportPage) -->
      <TabItem Header="Import/Export" Name="ImportExportTab" AutomationProperties.AutomationId="TextViewer_ImportExport_Tab">
        <ScrollViewer Margin="4">
          <StackPanel Spacing="10" Margin="8">
            <TextBlock Text="Import/Export" FontSize="16" FontWeight="Bold" />

            <!-- Existing TSV buttons (logic unchanged; just relocated) -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button AutomationProperties.AutomationId="TextViewer_Export_Button" Name="ExportButton" Content="Export All Texts (TSV)" Click="OnExportClick" />
              <Button AutomationProperties.AutomationId="TextViewer_Import_Button" Name="ImportButton" Content="Import Texts (TSV)" Click="OnImportClick" />
            </StackPanel>

            <!-- Export Filter (#1028 Slice B) — filters the TSV export to a single
                 WF MakeVarsIDArray category (faithful WF parity). Index 0 = All. -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_ExportFilterPrefix_Label"
                         Text="Export Filter:" VerticalAlignment="Center" Width="140" />
              <ComboBox AutomationProperties.AutomationId="TextViewer_ExportFilter_Combo"
                        Name="ExportFilterCombo" Width="240" SelectedIndex="0"
                        ToolTip.Tip="Filter the TSV export to a single text category (WF parity)." />
            </StackPanel>

            <!-- Include AI Hints (#1028 Slice C): when checked, the TSV export
                 appends per-entry unit translate-info lines for every face the
                 text loads (WF ToolTranslateROM.AppendAIHintMessage). -->
            <CheckBox AutomationProperties.AutomationId="TextViewer_IncludeAIHints_Check"
                      Name="IncludeAIHintsCheck" Content="Include AI Hints"
                      ToolTip.Tip="Append unit translate-info hints (name/role/flags) for every face the text loads." />

            <!-- Export Limit descriptor (read-only descriptive TextBox) -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_ExportLimitPrefix_Label"
                         Text="Export Limit:" VerticalAlignment="Center" Width="140" />
              <TextBox AutomationProperties.AutomationId="TextViewer_ExportLimit_Input"
                       Name="ExportLimitBox" IsReadOnly="True" Width="240" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 4: Translate — online machine-translation of the selected text
           (mirror WF translatePage). Combos are populated + defaults selected
           in code-behind from the shared ToolTranslateROM language arrays. -->
      <TabItem Header="Translate" Name="TranslateTab" AutomationProperties.AutomationId="TextViewer_Translate_Tab">
        <ScrollViewer Margin="4">
          <StackPanel Spacing="10" Margin="8">
            <TextBlock Text="Translate" FontSize="16" FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_TranslateFromPrefix_Label"
                         Text="Translate from:" VerticalAlignment="Center" Width="160" />
              <ComboBox AutomationProperties.AutomationId="TextViewer_TranslateFrom_Combo"
                        Name="TranslateFromCombo" Width="240"
                        ToolTip.Tip="Source language of the currently-selected text" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock AutomationProperties.AutomationId="TextViewer_TranslateToPrefix_Label"
                         Text="Translate to:" VerticalAlignment="Center" Width="160" />
              <ComboBox AutomationProperties.AutomationId="TextViewer_TranslateTo_Combo"
                        Name="TranslateToCombo" Width="240"
                        ToolTip.Tip="Target language to translate the selected text into" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button AutomationProperties.AutomationId="TextViewer_Translate_Button"
                      Name="TranslateButton" Content="Translate"
                      ToolTip.Tip="Translate the selected text online; the result is placed in the Edit box for review before writing" />
              <TextBlock AutomationProperties.AutomationId="TextViewer_TranslateStatus_Label"
                         Name="TranslateStatusLabel" VerticalAlignment="Center" Foreground="Gray" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 5: References — list of cross-refs + Add Reference (mirror WF RefPage) -->
      <TabItem Header="References" Name="ReferencesTab" AutomationProperties.AutomationId="TextViewer_References_Tab">
        <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="4">
          <TextBlock Grid.Row="0" AutomationProperties.AutomationId="TextViewer_ReferencesPrefix_Label"
                     Text="References:" FontSize="16" FontWeight="Bold" Margin="4,4,4,8" />
          <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Margin="4">
            <ListBox AutomationProperties.AutomationId="TextViewer_ReferencesTab_List"
                     Name="ReferencesTabList" />
          </Border>
          <Button Grid.Row="2" AutomationProperties.AutomationId="TextViewer_AddReference_Button"
                  Name="AddReferenceButton" Content="Add Reference" IsEnabled="True"
                  Margin="4,8,4,4"
                  Click="OnAddReferenceClick" />
          <TextBlock Grid.Row="3" AutomationProperties.AutomationId="TextViewer_ReferencesTabStatus_Label"
                     Name="ReferencesTabStatusLabel" Margin="4,4,4,4" Foreground="Gray" />
        </Grid>
      </TabItem>

      <!-- Tab 6: Simple Conversation Viewer (read-only playback) -->
      <TabItem Header="Conversation Viewer" Name="ConversationTab" AutomationProperties.AutomationId="TextViewer_Conversation_Tab">
        <Grid RowDefinitions="Auto,*" Margin="4">
          <TextBlock Grid.Row="0" Text="Simple Conversation Viewer (read-only)" FontSize="16" FontWeight="Bold" Margin="4,4,4,8" />
          <ScrollViewer Grid.Row="1" Margin="4" AutomationProperties.AutomationId="TextViewer_ConversationScroll">
            <ItemsControl AutomationProperties.AutomationId="TextViewer_ConversationCards_List" Name="ConversationCardsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,4">
                    <Grid ColumnDefinitions="100,*,100">
                      <!-- Left-side portrait (left-edge / left-mid / left-side slots) -->
                      <Image Grid.Column="0" Source="{Binding SpeakerBitmap}"
                             Width="96" Height="80"
                             Stretch="Uniform"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             IsVisible="{Binding IsLeftSide}" />
                      <!-- Middle column: kind label + speaker name + bubble text -->
                      <StackPanel Grid.Column="1" Margin="8,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding KindLabel}" FontWeight="Bold" Foreground="{DynamicResource SectionHeadingBrush}" />
                          <TextBlock Text="{Binding SpeakerName}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding SlotLabel}" Foreground="Gray" />
                        </StackPanel>
                        <TextBlock Text="{Binding Bubble}" TextWrapping="Wrap" FontSize="14" Margin="0,4,0,0" />
                      </StackPanel>
                      <!-- Right-side portrait (right-side / right-mid / right-edge slots) -->
                      <Image Grid.Column="2" Source="{Binding SpeakerBitmap}"
                             Width="96" Height="80"
                             Stretch="Uniform"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             IsVisible="{Binding IsRightSide}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
