<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolSubtitleSettingDialogView"
        Title="Subtitle Settings" Width="910" Height="357"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="12,12,12,12" Spacing="8">
    <!-- Template ROM FROM (WinForms LabelSimpleTranslateFromROMFilename + TextBoxEx + BrowseButton) -->
    <Grid ColumnDefinitions="196,*,41">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="31">
        <TextBlock Text="Template ROM FROM" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <TextBox AutomationProperties.AutomationId="ToolSubtitleSettingDialog_TextBox1_Input" Grid.Column="1" Text="{Binding TranslateFromRomFilename}" Margin="4,0,4,0" />
      <Button AutomationProperties.AutomationId="ToolSubtitleSettingDialog_BrowseFromRom_Button" Grid.Column="2" Content=".." Width="41" Height="31" Click="BrowseFromRom_Click" />
    </Grid>

    <!-- Template ROM TO (WinForms LabelSimpleTranslateToROMFilename + TextBoxEx + BrowseButton) -->
    <Grid ColumnDefinitions="196,*,41">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="31">
        <TextBlock Text="Template ROM TO" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <TextBox AutomationProperties.AutomationId="ToolSubtitleSettingDialog_TextBox2_Input" Grid.Column="1" Text="{Binding TranslateToRomFilename}" Margin="4,0,4,0" />
      <Button AutomationProperties.AutomationId="ToolSubtitleSettingDialog_BrowseToRom_Button" Grid.Column="2" Content=".." Width="41" Height="31" Click="BrowseToRom_Click" />
    </Grid>

    <!-- Translation Data (WinForms LabelSimpleTranslateToTranslateDataFilename + TextBoxEx + BrowseButton) -->
    <Grid ColumnDefinitions="196,*,41">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="31">
        <TextBlock Text="Translation Data" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <TextBox AutomationProperties.AutomationId="ToolSubtitleSettingDialog_TextBox3_Input" Grid.Column="1" Text="{Binding TranslateDataFilename}" Margin="4,0,4,0" />
      <Button AutomationProperties.AutomationId="ToolSubtitleSettingDialog_BrowseTranslateData_Button" Grid.Column="2" Content=".." Width="41" Height="31" Click="BrowseTranslateData_Click" />
    </Grid>

    <!-- Show Always checkbox (WinForms ShowAlways CheckBox) -->
    <CheckBox AutomationProperties.AutomationId="ToolSubtitleSettingDialog_Showsubtitlewindowevenwhentherearenosubtitles_Check" Content="Show subtitle window even when there are no subtitles"
              IsChecked="{Binding ShowAlways}" Margin="0,12,0,0" />

    <!-- Show/Hide buttons (WinForms ShowButton / HideButton) -->
    <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
      <Button AutomationProperties.AutomationId="ToolSubtitleSettingDialog_Show_Button" Grid.Column="0" Content="Show Subtitles" Height="44" Width="238"
              HorizontalAlignment="Left" Click="Show_Click" />
      <Button AutomationProperties.AutomationId="ToolSubtitleSettingDialog_Hide_Button" Grid.Column="1" Content="Hide" Height="44" Width="238"
              HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Hide_Click" />
    </Grid>
  </StackPanel>
  </ScrollViewer>
</Window>
