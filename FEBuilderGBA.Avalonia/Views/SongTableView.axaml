<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SongTableView"
        Title="Song Table (Read-Only)" Width="1505" Height="809">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="SongList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Song Table (Read-Only)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Header Pointer:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="HeaderLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Track Count:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="TrackCountLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Priority:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="PriorityLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Reverb:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="ReverbLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
