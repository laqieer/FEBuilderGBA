<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolASMEditView"
        Title="ASM Edit" Width="700" Height="550"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="ASM Code Editor" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Compile" Click="Compile_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <TextBox Name="AsmCodeTextBox" AcceptsReturn="True"
             FontFamily="Consolas, Courier New, monospace"
             Watermark="Enter ARM/Thumb ASM code here..." />
  </DockPanel>
</Window>
