<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.WorldMapPathView"
        Title="World Map Paths" Width="1284" Height="787">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="6" Margin="8">
        <TextBlock Text="World Map Paths" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Path Data Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox Grid.Row="1" Grid.Column="1" Name="P0Box" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Start Base Point:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B4Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="End Base Point:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B5Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="00 (B6):" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="B6Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="00 (B7):" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="B7Box" Minimum="0" Maximum="255" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Path Move Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox Grid.Row="6" Grid.Column="1" Name="P8Box" Width="120" HorizontalAlignment="Left" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Write" Name="WriteBtn" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
