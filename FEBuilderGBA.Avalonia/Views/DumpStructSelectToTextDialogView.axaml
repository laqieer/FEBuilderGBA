<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.DumpStructSelectToTextDialogView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Dump Struct to Text" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" Text="File name: " VerticalAlignment="Center" />
      <TextBox AutomationProperties.AutomationId="DumpStructSelectToTextDialog_FileName_Input" Grid.Column="1" Name="FileNameBox" IsReadOnly="True" />
    </Grid>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
      <Button AutomationProperties.AutomationId="DumpStructSelectToTextDialog_Save_Button" Content="Save to File..." Click="Save_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectToTextDialog_Close_Button" Content="Close" Click="Close_Click" />
    </StackPanel>
    <TextBox AutomationProperties.AutomationId="DumpStructSelectToTextDialog_Content_Input" Name="ContentBox" AcceptsReturn="True" IsReadOnly="True"
             FontFamily="Consolas" FontSize="12"
             TextWrapping="Wrap" />
  </DockPanel>
  </ScrollViewer>
</UserControl>
