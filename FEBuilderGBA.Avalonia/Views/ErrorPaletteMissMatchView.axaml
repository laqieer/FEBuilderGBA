<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ErrorPaletteMissMatchView"
        Title="Palette Mismatch" Width="1110" Height="711"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Palette Mismatch" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ScrollViewer>
      <TextBlock Name="MessageText" TextWrapping="Wrap" Text="{Binding Details}" />
    </ScrollViewer>
  </DockPanel>
</Window>
