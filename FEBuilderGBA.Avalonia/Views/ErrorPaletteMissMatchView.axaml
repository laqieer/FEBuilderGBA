<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ErrorPaletteMissMatchView">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Palette Mismatch" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="ErrorPaletteMissMatch_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ScrollViewer>
      <TextBlock AutomationProperties.AutomationId="ErrorPaletteMissMatch_Message_Label" Name="MessageText" TextWrapping="Wrap" Text="{Binding Details}" />
    </ScrollViewer>
  </DockPanel>
</UserControl>
