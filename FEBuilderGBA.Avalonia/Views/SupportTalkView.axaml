<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SupportTalkView">
  <!-- #724: widened from 250 to 380 so support pair rows like
       "00 Eirika (0x01) & Seth (0x02)" aren't truncated. -->
  <Grid ColumnDefinitions="380,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SupportTalk_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Talk" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SupportTalk_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360 final: SupportPartner1/2 (Unit ID) — bare NumericUpDown → IdFieldControl
               with Jump+Pick to UnitEditorView and inline unit-name preview.
               This is the canonical example from the original issue body. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalk_SupportPartner1Nud_Input"
                                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="SupportPartner1Nud"
                                   Label="Support Partner 1:"
                                   Maximum="255"
                                   JumpRequested="SupportPartner1_Jump"
                                   PickRequested="SupportPartner1_Pick"
                                   ValueChanged="SupportPartner1_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalk_SupportPartner2Nud_Input"
                                   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="SupportPartner2Nud"
                                   Label="Support Partner 2:"
                                   Maximum="255"
                                   JumpRequested="SupportPartner2_Jump"
                                   PickRequested="SupportPartner2_Pick"
                                   ValueChanged="SupportPartner2_ValueChanged" />

          <!-- #360 final: TextId C/B/A — NumericUpDown + Jump → IdFieldControl
               with ShowPick=False (TextViewerView isn't pickable) and inline
               text-content preview via NameResolver.GetTextById. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalk_TextIdCNud_Input"
                                   Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextIdCNud"
                                   Label="C Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextIdC_Jump"
                                   ValueChanged="TextIdC_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalk_TextIdBNud_Input"
                                   Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextIdBNud"
                                   Label="B Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextIdB_Jump"
                                   ValueChanged="TextIdB_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalk_TextIdANud_Input"
                                   Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextIdANud"
                                   Label="A Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextIdA_Jump"
                                   ValueChanged="TextIdA_ValueChanged" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="C Support Song:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SupportTalk_SongCNud_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="SongCNud" Minimum="0" Maximum="65535" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="B Support Song:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SupportTalk_SongBNud_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="SongBNud" Minimum="0" Maximum="65535" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="A Support Song:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SupportTalk_SongANud_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="SongANud" Minimum="0" Maximum="65535" Margin="0,2" />
        </Grid>

        <Button AutomationProperties.AutomationId="SupportTalk_Write_Button" Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,12,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
