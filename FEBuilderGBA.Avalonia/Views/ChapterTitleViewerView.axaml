<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ChapterTitleViewerView"
        Title="Chapter Title Editor" Width="1224" Height="564">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Chapter Title Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Save Image Ptr:" VerticalAlignment="Center" />
          <TextBox Grid.Row="1" Grid.Column="1" Name="SaveImgBox" Width="120" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Chapter Image Ptr:" VerticalAlignment="Center" />
          <TextBox Grid.Row="2" Grid.Column="1" Name="ChapterImgBox" Width="120" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Title Image Ptr:" VerticalAlignment="Center" />
          <TextBox Grid.Row="3" Grid.Column="1" Name="TitleImgBox" Width="120" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
          <Button Content="Export PNG" Click="ExportPng_Click" />
        </StackPanel>
        <controls:GbaImageControl Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
