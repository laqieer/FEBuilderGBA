<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ChapterTitleViewerView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ChapterTitleViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Chapter Title Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ChapterTitleViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Save Image Ptr:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ChapterTitleViewer_SaveImg_Input" Grid.Row="1" Grid.Column="1" Name="SaveImgBox" Width="120" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Chapter Image Ptr:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ChapterTitleViewer_ChapterImg_Input" Grid.Row="2" Grid.Column="1" Name="ChapterImgBox" Width="120" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Title Image Ptr:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ChapterTitleViewer_TitleImg_Input" Grid.Row="3" Grid.Column="1" Name="TitleImgBox" Width="120" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ChapterTitleViewer_Write_Button" Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="ChapterTitleViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="ChapterTitleViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" />
          <Button AutomationProperties.AutomationId="ChapterTitleViewer_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
        </StackPanel>
        <controls:GbaImageControl AutomationProperties.AutomationId="ChapterTitleViewer_Image_Image" Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
