<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolWorkSupportView"
        Title="Work Support" Width="883" Height="716"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Work Support" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

    <!-- Bottom buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Reload" Width="80" Click="Reload_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="12">
        <!-- Project Info -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="Project Information" FontWeight="SemiBold" FontSize="14" />
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name}" IsReadOnly="True" Margin="0,0,0,4" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Author:" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Author}" IsReadOnly="True" Margin="0,0,0,4" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Version:" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Version}" IsReadOnly="True" Margin="0,0,0,4" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Community:" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CommunityUrl}" IsReadOnly="True" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Actions -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="Actions" FontWeight="SemiBold" FontSize="14" />
            <WrapPanel Orientation="Horizontal">
              <Button Content="Check Update" Width="120" Margin="0,0,8,4" Click="Update_Click" />
              <Button Content="Open Community" Width="130" Margin="0,0,8,4" Click="Community_Click" />
              <Button Content="Open Info File" Width="120" Margin="0,0,8,4" Click="OpenInfo_Click" />
              <Button Content="Show All Works" Width="120" Margin="0,0,8,4" Click="ShowAllWorks_Click" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <!-- Status -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="Status" FontWeight="SemiBold" FontSize="14" />
            <TextBox Text="{Binding InfoText}" IsReadOnly="True" AcceptsReturn="True" Height="80" />
            <TextBlock Text="{Binding AutoFeedbackStatus}" Foreground="Gray" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
