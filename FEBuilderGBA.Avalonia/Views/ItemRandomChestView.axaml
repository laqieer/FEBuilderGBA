<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ItemRandomChestView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ItemRandomChest_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Random Chest Items" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemRandomChest_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360: replaces "Hyperlink TextBlock + NumericUpDown" with a single
               IdFieldControl. Host Name="ItemIdBox" preserved so FindControl<>
               lookups resolve; AutomationId preserved and forwarded by
               IdFieldControl.PropagateInnerAutomationIds onto the inner
               NumericUpDown so E2E selectors keep working. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="ItemRandomChest_ItemId_Input"
                                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Name="ItemIdBox"
                                   Label="Item:"
                                   Maximum="255"
                                   JumpRequested="ItemId_Jump"
                                   PickRequested="ItemId_Pick"
                                   ValueChanged="ItemId_ValueChanged" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Probability %:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemRandomChest_Probability_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="ProbabilityBox" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ItemRandomChest_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
