<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.GraphicsToolPatchMakerView"
        Title="Graphics Tool Patch Maker" Width="572" Height="525"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="14,7,14,12">
    <!-- Header label (WinForms label1 526x31 FixedSingle border) -->
    <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" Height="31"
            Margin="0,0,0,5">
      <TextBlock Text="Patch for selected changes" HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
    </Border>
    <!-- Bottom buttons (WinForms CloseButton 192x35 + SaveButton 289x35) -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                Margin="0,7,0,0">
      <Button Name="CloseButton" Content="Close" Width="192" Height="35"
              Click="Close_Click" />
      <Button Name="SaveButton" Content="Save as File" Width="289" Height="35"
              Click="Save_Click" />
    </StackPanel>
    <!-- Patch text (WinForms PatchText 526x390 multiline) -->
    <TextBox Name="PatchText" AcceptsReturn="True" IsReadOnly="False"
             FontFamily="Consolas, Courier New, monospace" />
  </DockPanel>
</Window>
