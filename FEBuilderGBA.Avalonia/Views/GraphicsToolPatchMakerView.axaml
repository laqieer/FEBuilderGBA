<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.GraphicsToolPatchMakerView"
        Title="Graphics Tool Patch Maker" Width="600" Height="450"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Graphics Tool Patch Maker" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <Border DockPanel.Dock="Top" Background="#D1ECF1" BorderBrush="#17A2B8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
      <TextBlock TextWrapping="Wrap"
                 Text="Graphics Patch Maker creates patches from graphics changes.&#10;Workflow: Select modified graphics, compare against original ROM, generate patch file." />
    </Border>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button Content="Create Patch" Click="CreatePatch_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="12">
      <StackPanel Spacing="4">
        <TextBlock Text="Steps:" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Text="1. Open the original (clean) ROM for comparison" />
        <TextBlock Text="2. Select the graphics entries that have been modified" />
        <TextBlock Text="3. The tool detects differences automatically" />
        <TextBlock Text="4. Export as a distributable patch file" />
      </StackPanel>
    </Border>
  </DockPanel>
</Window>
