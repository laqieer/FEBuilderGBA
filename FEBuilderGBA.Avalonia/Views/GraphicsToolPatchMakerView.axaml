<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.GraphicsToolPatchMakerView"
        Title="Graphics Tool Patch Maker" Width="620" Height="580"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="14,7,14,12">
    <!-- Header label -->
    <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" Height="31"
            Margin="0,0,0,5">
      <TextBlock Text="Compare two ROMs and generate a patch of changed regions"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Border>

    <!-- ROM selection area -->
    <Grid DockPanel.Dock="Top" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto"
          Margin="0,4,0,4">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Original ROM:" VerticalAlignment="Center"
                 Margin="0,0,8,4" />
      <TextBox Grid.Row="0" Grid.Column="1" Name="OriginalRomPathBox" IsReadOnly="True"
               Text="{Binding OriginalRomPath}" Margin="0,0,4,4" />
      <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Click="BrowseOriginal_Click"
              Margin="0,0,0,4" Width="80" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Modified ROM:" VerticalAlignment="Center"
                 Margin="0,0,8,0" />
      <TextBox Grid.Row="1" Grid.Column="1" Name="ModifiedRomPathBox" IsReadOnly="True"
               Text="{Binding ModifiedRomPath}" />
      <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Click="BrowseModified_Click"
              Width="80" />
    </Grid>

    <!-- Generate button + status -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,4,0,4">
      <Button Name="GenerateButton" Content="Generate Patch" Width="140" Height="32"
              Click="Generate_Click" IsEnabled="{Binding CanGenerate}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                 TextWrapping="Wrap" />
    </StackPanel>

    <!-- Summary -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="16" Margin="0,2,0,4">
      <TextBlock VerticalAlignment="Center">
        <Run Text="Regions: " /><Run Text="{Binding DiffRegionCount}" FontWeight="Bold" />
      </TextBlock>
      <TextBlock VerticalAlignment="Center">
        <Run Text="Changed bytes: " /><Run Text="{Binding TotalChangedBytes}" FontWeight="Bold" />
      </TextBlock>
    </StackPanel>

    <!-- Bottom buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                Margin="0,7,0,0">
      <Button Name="CloseButton" Content="Close" Width="192" Height="35"
              Click="Close_Click" />
      <Button Name="SaveButton" Content="Save Patch File" Width="289" Height="35"
              Click="Save_Click" IsEnabled="{Binding CanSave}" />
    </StackPanel>

    <!-- Patch text output -->
    <TextBox Name="PatchText" AcceptsReturn="True" IsReadOnly="True"
             Text="{Binding PatchText}"
             FontFamily="Consolas, Courier New, monospace" />
  </DockPanel>
  </ScrollViewer>
</Window>
