<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SongExchangeView"
        Title="Song Exchange Tool" Width="1322" Height="601"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SongExchange_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Song Exchange Tool" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SongExchange_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
        </Grid>

        <TextBlock Text="Transplant a song from another ROM into the current ROM. Open a donor ROM, select a song from each side, then Convert."
                   TextWrapping="Wrap" Opacity="0.8" />

        <Button AutomationProperties.AutomationId="SongExchange_OpenOther_Button"
                Name="OpenOtherButton" Content="Open Other ROM..." Click="OpenOtherRom_Click"
                HorizontalAlignment="Left" />

        <TextBlock AutomationProperties.AutomationId="SongExchange_OtherRom_Label"
                   Name="OtherRomLabel" Text="Other ROM: (none loaded)" Opacity="0.8" />

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*" Margin="0,4,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Current ROM Songs (destination)" FontWeight="Bold" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="Other ROM Songs (source)" FontWeight="Bold" />

          <ListBox AutomationProperties.AutomationId="SongExchange_My_List"
                   Grid.Row="1" Grid.Column="0" Name="MyList"
                   ItemsSource="{Binding MySongDisplay}"
                   MinHeight="300" MaxHeight="420" Margin="0,2,4,0" />

          <ListBox AutomationProperties.AutomationId="SongExchange_Other_List"
                   Grid.Row="1" Grid.Column="1" Name="OtherList"
                   ItemsSource="{Binding OtherSongDisplay}"
                   MinHeight="300" MaxHeight="420" Margin="4,2,0,0" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
          <Button AutomationProperties.AutomationId="SongExchange_Convert_Button"
                  Name="ConvertButton" Content="Convert (transplant -&gt;)" Click="Convert_Click"
                  HorizontalAlignment="Left" />
          <!-- #1383: import the selected destination song from the FE-Repo-Music
               submodule. Routes through the Song Track Editor's ONE shared import
               dispatcher (no duplicate importer). Shown only when the music
               submodule exists. -->
          <Button AutomationProperties.AutomationId="SongExchange_FERepoMusic_Button"
                  Name="FERepoMusicButton" Content="FE-Repo-Music" Click="FERepoMusic_Click"
                  IsVisible="{Binding IsFERepoMusicAvailable}"
                  ToolTip.Tip="Browse the FE-Repo-Music submodule and import the selected destination song via the Song Track Editor's import (same import path as Import Music File)." />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
