<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SoundRoomViewerView"
        Title="Sound Room (Read-Only)" Width="800" Height="500">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Sound Room (Read-Only)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Song ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="SongIdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Data +4:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="Raw4Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Data +8:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="Raw8Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Text ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="TextIdLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
