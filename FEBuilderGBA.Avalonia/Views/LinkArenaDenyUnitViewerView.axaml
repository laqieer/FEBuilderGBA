<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.LinkArenaDenyUnitViewerView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="LinkArenaDenyUnitViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Link Arena Deny Unit Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="LinkArenaDenyUnitViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360: replaces "Hyperlink TextBlock + NumericUpDown" with a single
               IdFieldControl. Host Name="UnitIdBox" preserved so FindControl<>
               lookups resolve; AutomationId preserved and forwarded by
               IdFieldControl.PropagateInnerAutomationIds onto the inner
               NumericUpDown so E2E selectors keep working. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="LinkArenaDenyUnitViewer_UnitId_Input"
                                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Name="UnitIdBox"
                                   Label="Unit ID:"
                                   Maximum="255"
                                   JumpRequested="UnitId_Jump"
                                   PickRequested="UnitId_Pick"
                                   ValueChanged="UnitId_ValueChanged" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="LinkArenaDenyUnitViewer_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
