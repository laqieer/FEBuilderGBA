<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.VersionView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="12">
    <TextBox AutomationProperties.AutomationId="Version_VersionText_Input" Name="VersionTextBox"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             FontFamily="Consolas, Courier New, monospace"
             FontSize="13" />
  </DockPanel>
  </ScrollViewer>
</UserControl>
