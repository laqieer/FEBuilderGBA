<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.SomeClassListView"
        Title="Class List (Read-Only)" Width="1155" Height="661">
  <StackPanel Spacing="12" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
    <TextBlock Text="Class List (Read-Only)" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
    <TextBlock Text="This editor requires a target address." FontSize="14" HorizontalAlignment="Center" />
    <TextBlock Text="Open it from another editor (JumpTo pattern)." Foreground="Gray" HorizontalAlignment="Center" />
    <TextBlock Text="Data size: 1 byte per entry (ClassId u8). Null-terminated list." Foreground="Gray" HorizontalAlignment="Center" TextWrapping="Wrap" />
  </StackPanel>
</Window>
