<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SomeClassListView"
        Title="Class List Editor" Width="1155" Height="661"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <Grid ColumnDefinitions="245,*">
    <!-- Left: Address list -->
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <!-- Right: Editor area -->
    <StackPanel Grid.Column="1" Spacing="12" Margin="16" VerticalAlignment="Top">
      <TextBlock Text="Class List Editor" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="Null-terminated list of class IDs (1 byte per entry)." Foreground="Gray" />

      <Grid ColumnDefinitions="140,200,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Class ID (u8):" VerticalAlignment="Center" Margin="0,4" />
        <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="1" Name="B0Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />
        <TextBlock Grid.Row="1" Grid.Column="2" Name="ClassNameLabel" VerticalAlignment="Center" Margin="8,0,0,0" />
      </Grid>
      <Button Content="Write" Click="Write_Click" Width="168" Height="30" />
    </StackPanel>
  </Grid>
  </ScrollViewer>
</Window>
