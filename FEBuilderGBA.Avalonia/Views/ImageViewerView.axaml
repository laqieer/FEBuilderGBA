<UserControl
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ImageViewerView">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8">
      <TextBlock Text="Zoom:" VerticalAlignment="Center" />
      <NumericUpDown AutomationProperties.AutomationId="ImageViewer_Zoom_Input" FormatString="0" Name="ZoomBox" Minimum="1" Maximum="8" Value="1" Width="80"
                     ValueChanged="ZoomBox_ValueChanged" />
      <Button AutomationProperties.AutomationId="ImageViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" Margin="8,0,0,0" />
      <Button AutomationProperties.AutomationId="ImageViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" Margin="4,0,0,0" />
      <TextBlock Text="{Binding ImageInfo}" VerticalAlignment="Center" Margin="16,0,0,0" />
    </StackPanel>
    <ScrollViewer Margin="8">
      <controls:GbaImageControl AutomationProperties.AutomationId="ImageViewer_Image_Image" Name="ImageControl" />
    </ScrollViewer>
  </DockPanel>
</UserControl>
