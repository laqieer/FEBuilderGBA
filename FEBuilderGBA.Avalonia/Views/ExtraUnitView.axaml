<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ExtraUnitView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ExtraUnit_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="6" Margin="8">
        <TextBlock Text="Extra Unit Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="ExtraUnit_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Flag ID:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox AutomationProperties.AutomationId="ExtraUnit_FlagId_Input" Grid.Row="1" Grid.Column="1" Name="FlagIdBox" Width="120" HorizontalAlignment="Left" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit Data Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <TextBox AutomationProperties.AutomationId="ExtraUnit_P0_Input" Grid.Row="2" Grid.Column="1" Name="P0Box" Width="120" HorizontalAlignment="Left" Margin="0,2" IsReadOnly="True" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="ExtraUnit_WriteBtn_Button" Content="Write" Name="WriteBtn" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
