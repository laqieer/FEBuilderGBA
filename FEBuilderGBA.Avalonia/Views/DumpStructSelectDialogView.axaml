<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.DumpStructSelectDialogView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="12" Spacing="6">
      <TextBlock Text="Data Address Editor" FontSize="18" FontWeight="Bold" />

      <!-- Address display (matches WinForms label5 + ValueTextBox) -->
      <Grid ColumnDefinitions="100,*" Margin="0,4,0,4">
        <TextBlock Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
        <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_Addr_Label"
                   Grid.Column="1" Name="AddrLabel"
                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- =================================================================
           Group: Hex Editor (WinForms label3)
           ================================================================= -->
      <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_HexEditorGroup_Label"
                 Name="HexEditorGroupLabel" Text="Hex Editor" FontWeight="Bold" Margin="0,10,0,2" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_Binary_Button"
              Name="BinaryButton"
              Content="Open Selected Address in Hex Editor"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="BinaryButton_Click" />

      <!-- =================================================================
           Group: Clipboard (WinForms label2)
           ================================================================= -->
      <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_ClipboardGroup_Label"
                 Name="ClipboardGroupLabel" Text="Clipboard" FontWeight="Bold" Margin="0,10,0,2" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_CopyPointer_Button"
              Name="CopyPointer"
              Content="Copy as Pointer"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="CopyPointer_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_CopyClipboard_Button"
              Name="CopyClipboard"
              Content="Copy to Clipboard"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="CopyClipboard_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_CopyLittleEndian_Button"
              Name="CopyLittleEndian"
              Content="Copy as Little Endian Pointer"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="CopyLittleEndian_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_CopyNoDollGBARadBreakPoint_Button"
              Name="CopyNoDollGBARadBreakPoint"
              Content="Copy as No$GBA Read Breakpoint"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="CopyNoDollGBARadBreakPoint_Click" />

      <!-- =================================================================
           Group: Data Export Options (WinForms label1)
           ================================================================= -->
      <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_DataExportGroup_Label"
                 Name="DataExportGroupLabel" Text="Data Export Options" FontWeight="Bold" Margin="0,10,0,2" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_EAALL_Button"
              Name="EAALLButton"
              Content="Dump Displayed List to EA format"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="EAALLButton_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_CSV_Button"
              Name="CSVButton"
              Content="Dump Displayed List to CSV format"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="CSVButton_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_TSVALL_Button"
              Name="TSVALLButton"
              Content="Dump Displayed List to TSV format"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="TSVButton_Click" />

      <!-- =================================================================
           Group: Data Structure Options (WinForms label4)
           ================================================================= -->
      <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_DataStructureGroup_Label"
                 Name="DataStructureGroupLabel" Text="Data Structure Options" FontWeight="Bold" Margin="0,10,0,2" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_STRUCT_Button"
              Name="STRUCTButton"
              Content="Display Byte Structure in C"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="STRUCTButton_Click" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_NMM_Button"
              Name="NMMButton"
              Content="Create Nightmare .nmm File"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="NMMButton_Click" />

      <!-- =================================================================
           Group: Import (WinForms label6)
           ================================================================= -->
      <TextBlock AutomationProperties.AutomationId="DumpStructSelectDialog_ImportGroup_Label"
                 Name="ImportGroupLabel" Text="Import" FontWeight="Bold" Margin="0,10,0,2" />
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_Import_Button"
              Name="ImportButton"
              Content="Import Dumped Data"
              HorizontalAlignment="Stretch" Padding="6,8"
              Click="ImportButton_Click" />

      <!-- =================================================================
           Cancel (mirrors WinForms U.AddCancelButton)
           ================================================================= -->
      <Button AutomationProperties.AutomationId="DumpStructSelectDialog_Cancel_Button"
              Name="CancelButton"
              Content="Cancel"
              HorizontalAlignment="Stretch" Padding="6,8"
              Margin="0,10,0,0"
              Click="CancelButton_Click" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
