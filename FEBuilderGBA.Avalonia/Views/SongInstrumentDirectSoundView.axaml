<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SongInstrumentDirectSoundView"
        Title="Direct Sound Instruments" Width="879" Height="327"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Direct Sound Instruments" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="180,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Header:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="HeaderBox" Minimum="0" Maximum="4294967295" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Frequency Hz*1024:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="FrequencyBox" Minimum="0" Maximum="4294967295" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Loop Start Byte:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="LoopStartBox" Minimum="0" Maximum="4294967295" VerticalAlignment="Center" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Length Byte:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="LengthBox" Minimum="0" Maximum="4294967295" IsReadOnly="True" VerticalAlignment="Center" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
