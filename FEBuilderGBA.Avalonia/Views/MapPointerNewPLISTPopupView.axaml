<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MapPointerNewPLISTPopupView"
        Title="Map Pointer - New PLIST" Width="953" Height="423"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="12,9,12,12">
    <!-- Header label (WinForms label1 285x26) -->
    <TextBlock AutomationProperties.AutomationId="MapPointerNewPLISTPopup_Header_Label" DockPanel.Dock="Top" Name="HeaderLabel"
               Text="Enter the PLIST number for the new map pointer entry."
               FontWeight="SemiBold" Margin="0,0,0,8" />
    <!-- Explanation text (WinForms PLIST_EXPLAIN multi-line) -->
    <TextBlock AutomationProperties.AutomationId="MapPointerNewPLISTPopup_Explain_Label" DockPanel.Dock="Top" Name="ExplainLabel" TextWrapping="Wrap"
               IsVisible="{Binding ExplanationVisible}"
               Margin="0,0,0,8"
               Text="PLIST (Pointer List) assigns a numeric ID to each map.&#x0a;Choose an unused PLIST number to add a new map pointer entry.&#x0a;The PLIST ID is used internally to reference map data." />
    <!-- Already-extended note (WinForms AlreadyExtendsLabel, shown when PLIST already split/extended) -->
    <TextBlock AutomationProperties.AutomationId="MapPointerNewPLISTPopup_AlreadyExtends_Label" DockPanel.Dock="Top" Name="AlreadyExtendsLabel" TextWrapping="Wrap"
               IsVisible="{Binding AlreadyExtendsVisible}"
               Text="{Binding AlreadyExtendsText}" Margin="0,0,0,8" />
    <!-- Extend button (WinForms PLISTExtendsButton 430x32).
         The Avalonia split/extend editor flow is not wired, so the button is
         hidden (honestly unavailable rather than a dead enabled control, #1433).
         PLIST split/extend is performed from the Map Pointer editor. -->
    <Button AutomationProperties.AutomationId="MapPointerNewPLISTPopup_PLISTExtends_Button" DockPanel.Dock="Top" Name="PLISTExtendsButton" Content="Extend PLIST Range"
            IsVisible="{Binding ExtendVisible}"
            Width="430" Height="32" HorizontalAlignment="Left" Margin="0,0,0,8"
            Click="Extend_Click" />
    <!-- PLIST ID input row -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="PLIST ID:" VerticalAlignment="Center" />
      <NumericUpDown AutomationProperties.AutomationId="MapPointerNewPLISTPopup_PlistId_Input" FormatString="0" Name="PlistIdInput" Width="107" Height="25" Minimum="0" Maximum="{Binding PlistMaximum}" Value="0" ValueChanged="PlistId_ValueChanged" />
      <!-- Link display (WinForms LINK_PLIST 594x62 multiline read-only) -->
      <TextBox AutomationProperties.AutomationId="MapPointerNewPLISTPopup_LinkPlist_Input" Name="LinkPlistDisplay" Width="594" Height="62" IsReadOnly="True"
               Text="{Binding LinkPlistInfo, Mode=OneWay}"
               AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas, Courier New, monospace" />
    </StackPanel>
    <!-- Bottom buttons (WinForms OKButton 191x39 + MyCancelButton 191x39) -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button AutomationProperties.AutomationId="MapPointerNewPLISTPopup_MyCancel_Button" Name="MyCancelButton" Content="Cancel" Width="191" Height="39"
              Click="Cancel_Click" />
      <Button AutomationProperties.AutomationId="MapPointerNewPLISTPopup_OK_Button" Name="OKButton" Content="OK" Width="191" Height="39"
              Click="OK_Click" />
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</Window>
