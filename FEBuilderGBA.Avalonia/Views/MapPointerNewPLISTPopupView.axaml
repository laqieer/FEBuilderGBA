<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MapPointerNewPLISTPopupView"
        Title="Map Pointer - New PLIST" Width="400" Height="230"
        WindowStartupLocation="CenterOwner" CanResize="False">
  <DockPanel Margin="16">
    <TextBlock Text="New PLIST Entry" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Enter the PLIST number for the new map pointer entry." TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0" VerticalAlignment="Top">
      <TextBlock Text="PLIST ID:" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,8,0" />
      <NumericUpDown x:Name="PlistIdInput" Grid.Column="1" Minimum="0" Maximum="65535" Value="0" />
    </Grid>
  </DockPanel>
</Window>
