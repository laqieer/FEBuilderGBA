<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ItemEditorView"
        Title="Item Editor" Width="1408" Height="856">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl Grid.Row="0" Name="ItemList" Margin="4" />
      <!-- Selected item icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:GbaImageControl Name="ListPreviewImage" />
          <TextBlock Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Address -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- Row 1: W0 Name ID -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" />

          <!-- Row 2: W2 Desc ID, W4 Use Desc ID -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Desc ID (W2):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="DescIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Use Desc (W4):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="4" Name="UseDescIdBox" Minimum="0" Maximum="65535" />

          <!-- Row 3: B6 Item Number, B7 Weapon Type (ComboBox) -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Item # (B6):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="ItemNumberBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Type (B7):" VerticalAlignment="Center" />
          <ComboBox Grid.Row="3" Grid.Column="4" Name="WeaponTypeCombo" Width="200" />

          <!-- Row 4-5: Traits replaced by BitFlagPanels below the grid -->

          <!-- Row 4: P12 Stat Bonuses, P16 Effectiveness -->
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Stat Bonus (P12):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <TextBox Name="StatBonusesPtrBox" Width="120" />
            <Button Content="Jump" Click="JumpToStatBonuses_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Effective (P16):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="4" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox Name="EffectivenessPtrBox" Width="120" />
            <Button Content="Jump" Click="JumpToEffectiveness_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Row 5: B20 Uses, B21 Might -->
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Uses (B20):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="UsesBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Might (B21):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="4" Name="MightBox" Minimum="0" Maximum="255" />

          <!-- Row 6: B22 Hit, B23 Weight -->
          <TextBlock Grid.Row="6" Grid.Column="0" Text="Hit (B22):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="HitBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="6" Grid.Column="3" Text="Weight (B23):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="4" Name="WeightBox" Minimum="0" Maximum="255" />

          <!-- Row 7: B24 Crit, B25 Range -->
          <TextBlock Grid.Row="7" Grid.Column="0" Text="Crit (B24):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="CritBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="7" Grid.Column="3" Text="Range (B25):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="4" Name="RangeBox" Minimum="0" Maximum="255" />

          <!-- Row 8: W26 Price, B28 Weapon Rank -->
          <TextBlock Grid.Row="8" Grid.Column="0" Text="Price (W26):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="PriceBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="8" Grid.Column="3" Text="Rank (B28):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="4" Name="WeaponRankBox" Minimum="0" Maximum="255" />

          <!-- Row 9: B29 Icon, B30 Usage Effect -->
          <TextBlock Grid.Row="9" Grid.Column="0" Text="Icon (B29):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="IconBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="9" Grid.Column="3" Text="Use Effect (B30):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="4" Name="UsageEffectBox" Minimum="0" Maximum="255" />

          <!-- Row 10: B31 Damage Effect, B32 Weapon Exp -->
          <TextBlock Grid.Row="10" Grid.Column="0" Text="Dmg Effect (B31):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="DamageEffectBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="10" Grid.Column="3" Text="Wep Exp (B32):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="4" Name="WeaponExpBox" Minimum="0" Maximum="255" />

          <!-- Row 11: B33-B35 Unknown/Extension -->
          <TextBlock Grid.Row="11" Grid.Column="0" Text="Unk33 (B33):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="1" Name="Unk33Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="11" Grid.Column="3" Text="Unk34 (B34):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="4" Name="Unk34Box" Minimum="0" Maximum="255" />

          <!-- Row 12: B35 -->
          <TextBlock Grid.Row="12" Grid.Column="0" Text="Unk35 (B35):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="1" Name="Unk35Box" Minimum="0" Maximum="255" />

          <!-- Row 13: Shop prices (computed) -->
          <TextBlock Grid.Row="13" Grid.Column="0" Text="Buy Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock Grid.Row="13" Grid.Column="1" Name="ShopBuyPriceLabel" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock Grid.Row="13" Grid.Column="3" Text="Sell Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock Grid.Row="13" Grid.Column="4" Name="ShopSellPriceLabel" VerticalAlignment="Center" Foreground="Gray" />

          <!-- Row 14: Forge price -->
          <TextBlock Grid.Row="14" Grid.Column="0" Text="Forge Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock Grid.Row="14" Grid.Column="1" Name="ShopForgePriceLabel" VerticalAlignment="Center" Foreground="Gray" />
        </Grid>

        <!-- Null pointer warnings -->
        <TextBlock Name="AllocStatBonusesWarning" Text="Warning: Stat Bonuses pointer is null (P12=0). Consider allocating." Foreground="Orange" FontWeight="SemiBold" IsVisible="False" Margin="0,4,0,0" />
        <TextBlock Name="AllocEffectivenessWarning" Text="Warning: Effectiveness pointer is null (P16=0). Consider allocating." Foreground="Orange" FontWeight="SemiBold" IsVisible="False" Margin="0,2,0,0" />

        <!-- Stat bonus preview -->
        <Border Name="BonusPreviewBorder" BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,8,0,0" IsVisible="False">
          <StackPanel Spacing="2">
            <TextBlock Text="Stat Bonuses Preview" FontWeight="Bold" />
            <WrapPanel>
              <TextBlock Name="BonusHPLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusStrLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusSklLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusSpdLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusDefLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusResLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusLckLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusMoveLabel" Margin="0,0,12,0" />
              <TextBlock Name="BonusConLabel" Margin="0,0,12,0" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <!-- Effective Against class list -->
        <Border Name="EffectiveClassBorder" BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,8,0,0" IsVisible="False">
          <StackPanel Spacing="2">
            <TextBlock Text="Effective Against" FontWeight="Bold" />
            <ItemsControl Name="EffectiveClassListBox">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="12" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Trait Flags (BitFlagPanels) -->
        <TextBlock Text="Trait Flags" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock Text="Trait 1 (B8):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Trait1Flags" />
            <TextBlock Text="Trait 2 (B9):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Trait2Flags" />
            <TextBlock Text="Trait 3 (B10):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Trait3Flags" />
            <TextBlock Text="Trait 4 (B11):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Trait4Flags" />
          </StackPanel>
        </Border>

        <!-- Validation Warnings -->
        <Border Name="WarningsBorder" IsVisible="False"
                BorderBrush="Orange" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="#33FF8C00" Margin="0,8,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Warnings" FontWeight="Bold" Foreground="DarkOrange" />
            <ItemsControl Name="WarningsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="DarkOrange" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button Content="Export TSV" Click="ExportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export all items to a TSV file" />
          <Button Content="Import TSV" Click="ImportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import items from a TSV file" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button Content="Edit Skill Config" Click="EditSkillConfig_Click" Name="EditSkillConfigButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open skill configuration editor" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
