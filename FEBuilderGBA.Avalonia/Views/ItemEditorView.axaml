<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ItemEditorView">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl AutomationProperties.AutomationId="ItemEditor_Item_List" Grid.Row="0" Name="ItemList" Margin="4" />
      <!-- Selected item icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:IconPreviewControl AutomationProperties.AutomationId="ItemEditor_ListPreview_Image" Name="ListPreviewImage" Scale="2" MaxImageWidth="32" MaxImageHeight="32" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_ListPreviewName_Label" Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4" HorizontalScrollBarVisibility="Auto">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Editor" FontSize="18" FontWeight="Bold" />

        <!-- Address + HardCoding warning (#409 mirrors WF HardCodingWarningLabel) -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Address:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_Addr_Label" Name="AddrLabel" VerticalAlignment="Center" />
          <!-- HardCoding warning: clickable hyperlink shown only when
               CoreState.AsmMapFileAsmCache?.IsHardCodeItem(itemId) is true.
               Mirrors WF `HardCodingWarningLabel_Click` which opens the
               Patch Manager filtered by `HARDCODING_ITEM=` so the user can
               see which patches still need installing. -->
          <TextBlock AutomationProperties.AutomationId="ItemEditor_HardCodingWarning_Link"
                     Name="HardCodingWarningLink"
                     Text="[HardCoding]"
                     Classes="Hyperlink"
                     Foreground="Red"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"
                     IsVisible="False"
                     PointerPressed="OnHardCodingLink_Click"
                     ToolTip.Tip="This item is referenced by hardcoded ASM. Click to open the Patch Manager filtered on HARDCODING_ITEM=." />
        </StackPanel>

        <!-- Basic Info -->
        <Expander AutomationProperties.AutomationId="ItemEditor_BasicInfo_Expander" Header="Basic Info" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="140,340,20,140,340" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center"
                     AutomationProperties.AutomationId="ItemEditor_NameId_Link"
                     Classes="Hyperlink" Name="NameId_Link" PointerPressed="OnNameIdLinkClick"
                     ToolTip.Tip="Text ID for this item's display name (click to open Text Viewer)" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_NameId_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Name:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_Name_Label" Grid.Row="0" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Desc ID (W2):" VerticalAlignment="Center"
                     AutomationProperties.AutomationId="ItemEditor_DescId_Link"
                     Classes="Hyperlink" Name="DescId_Link" PointerPressed="OnDescIdLinkClick"
                     ToolTip.Tip="Text ID for the item description (click to open Text Viewer)" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ItemEditor_DescId_Input" FormatString="0" Name="DescIdBox" Minimum="0" Maximum="65535" Width="100" />
            <TextBlock AutomationProperties.AutomationId="ItemEditor_DescText_Label" Name="DescTextLabel" VerticalAlignment="Center" Foreground="Gray"
                       Width="160" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                       ToolTip.Tip="{Binding #DescTextLabel.Text}" />
            <Button AutomationProperties.AutomationId="ItemEditor_JumpToDesc_Button" Content="Desc" Click="JumpToDesc_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center"
                    ToolTip.Tip="Open text viewer for this description" />
          </StackPanel>
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Use Desc (W4):" VerticalAlignment="Center"
                     AutomationProperties.AutomationId="ItemEditor_UseDesc_Link"
                     Classes="Hyperlink" Name="UseDescId_Link" PointerPressed="OnUseDescIdLinkClick"
                     ToolTip.Tip="Text ID for the item usage description (click to open Text Viewer)" />
          <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ItemEditor_UseDescId_Input" FormatString="0" Name="UseDescIdBox" Minimum="0" Maximum="65535" Width="100" />
            <TextBlock AutomationProperties.AutomationId="ItemEditor_UseDescText_Label" Name="UseDescTextLabel" VerticalAlignment="Center" Foreground="Gray"
                       Width="160" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                       ToolTip.Tip="{Binding #UseDescTextLabel.Text}" />
            <Button AutomationProperties.AutomationId="ItemEditor_JumpToUseDesc_Button" Content="Desc" Click="JumpToUseDesc_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center"
                    ToolTip.Tip="Open text viewer for this usage description" />
          </StackPanel>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Item # (B6):" VerticalAlignment="Center"
                     ToolTip.Tip="Internal item number (unique ID)" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_ItemNumber_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="ItemNumberBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Type (B7):" VerticalAlignment="Center"
                     ToolTip.Tip="Weapon type (Sword, Lance, Axe, etc.)" />
          <ComboBox AutomationProperties.AutomationId="ItemEditor_WeaponType_Combo" Grid.Row="2" Grid.Column="4" Name="WeaponTypeCombo" Width="200" />
        </Grid>
        </Border>
        </Expander>

        <!-- Stats / Bonuses -->
        <Expander AutomationProperties.AutomationId="ItemEditor_StatsBonuses_Expander" Header="Stats / Bonuses" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Stat Bonus (P12):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to stat bonuses when equipped" />
          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ItemEditor_StatBonusesPtr_Input" Name="StatBonusesPtrBox" Width="120" />
            <Button AutomationProperties.AutomationId="ItemEditor_JumpToStatBonuses_Button" Content="Jump" Click="JumpToStatBonuses_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Effective (P16):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to effectiveness list (bonus vs. classes)" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ItemEditor_EffectivenessPtr_Input" Name="EffectivenessPtrBox" Width="120" />
            <Button AutomationProperties.AutomationId="ItemEditor_JumpToEffectiveness_Button" Content="Jump" Click="JumpToEffectiveness_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Uses (B20):" VerticalAlignment="Center"
                     ToolTip.Tip="Number of uses before the item breaks" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Uses_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="UsesBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Might (B21):" VerticalAlignment="Center"
                     ToolTip.Tip="Attack power" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Might_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="MightBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Hit (B22):" VerticalAlignment="Center"
                     ToolTip.Tip="Hit rate bonus" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Hit_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="HitBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Weight (B23):" VerticalAlignment="Center"
                     ToolTip.Tip="Item weight (reduces attack speed)" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Weight_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="WeightBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Crit (B24):" VerticalAlignment="Center"
                     ToolTip.Tip="Critical hit rate bonus" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Crit_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="CritBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Range (B25):" VerticalAlignment="Center"
                     ToolTip.Tip="Attack range (encoded as min-max)" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Range_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="RangeBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Price (W26):" VerticalAlignment="Center"
                     ToolTip.Tip="Base item price" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Price_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="PriceBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Rank (B28):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_WeaponRank_Input" FormatString="0" Grid.Row="4" Grid.Column="4" Name="WeaponRankBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Buy Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_ShopBuyPrice_Label" Grid.Row="5" Grid.Column="1" Name="ShopBuyPriceLabel" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Sell Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_ShopSellPrice_Label" Grid.Row="5" Grid.Column="4" Name="ShopSellPriceLabel" VerticalAlignment="Center" Foreground="Gray" />
        </Grid>
        </Border>
        </Expander>

        <!-- Weapon Properties -->
        <Expander AutomationProperties.AutomationId="ItemEditor_WeaponProperties_Expander" Header="Weapon Properties" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Icon (B29):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Icon_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="IconBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Use Effect (B30):" VerticalAlignment="Center"
                     ToolTip.Tip="Effect when using the item" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_UsageEffect_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="UsageEffectBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Dmg Effect (B31):" VerticalAlignment="Center"
                     ToolTip.Tip="Special effect applied on hit" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ItemEditor_DamageEffect_Input" FormatString="0" Name="DamageEffectBox" Minimum="0" Maximum="255" Width="100" />
            <!-- WF "間接エフェクト Jump" — opens ItemWeaponEffectViewerView
                 positioned at the entry whose B0 == currently-selected item id
                 (mirrors WF ItemWeaponEffectForm.JumpTo search by id).
                 Button label kept short ("Jump") to fit inside the 200px
                 Grid column without overflowing into the next column
                 (#651 — long "Indirect Weapon Effect" label overlapped the
                 adjacent "Wep Exp (B32):" label). The tooltip below
                 carries the full descriptive text. -->
            <Button AutomationProperties.AutomationId="ItemEditor_JumpToWeaponEffect_Button"
                    Content="Jump"
                    Click="JumpToWeaponEffect_Click"
                    FontSize="11" Padding="4,2" VerticalAlignment="Center"
                    ToolTip.Tip="Open the indirect weapon effect table at the row for this item." />
          </StackPanel>
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Wep Exp (B32):" VerticalAlignment="Center"
                     ToolTip.Tip="Weapon experience gained per use" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_WeaponExp_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="WeaponExpBox" Minimum="0" Maximum="255" />

          <TextBlock AutomationProperties.AutomationId="ItemEditor_Unk33_Label"
                     Name="Unk33Label" Grid.Row="2" Grid.Column="0" Text="Unk33 (B33):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Unk33_Input" FormatString="0" Name="Unk33Box" Minimum="0" Maximum="255" Width="100" />
            <!-- WF J_33_Click — when SkillSystem patch is present this is
                 the Debuff field; clicking opens Patch Manager filtered
                 on `defWeaponDebuffsTable`. Visible only under SkillSystem. -->
            <TextBlock AutomationProperties.AutomationId="ItemEditor_WeaponDebuffs_Link"
                       Name="WeaponDebuffsLink"
                       Text="Debuff Table"
                       Classes="Hyperlink"
                       Foreground="DodgerBlue"
                       FontSize="11"
                       VerticalAlignment="Center"
                       IsVisible="False"
                       PointerPressed="OnWeaponDebuffsLink_Click"
                       ToolTip.Tip="Open the Patch Manager filtered to the SkillSystem WeaponDebuffsTable definition." />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ItemEditor_Unk34_Label"
                     Name="Unk34Label" Grid.Row="2" Grid.Column="3" Text="Unk34 (B34):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Unk34_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="Unk34Box" Minimum="0" Maximum="255" />

          <TextBlock AutomationProperties.AutomationId="ItemEditor_Unk35_Label"
                     Name="Unk35Label" Grid.Row="3" Grid.Column="0" Text="Unk35 (B35):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemEditor_Unk35_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="Unk35Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Forge Price:" VerticalAlignment="Center" Foreground="Gray" />
          <TextBlock AutomationProperties.AutomationId="ItemEditor_ShopForgePrice_Label" Grid.Row="3" Grid.Column="4" Name="ShopForgePriceLabel" VerticalAlignment="Center" Foreground="Gray" />
        </Grid>
        </Border>
        </Expander>

        <!-- Parity notes (parent #374):
             - WF X_SIM_* labels (HP/Str/Skl/Spd/Def/Res/Lck/Move/Con preview):
               rendered as the Stat Bonuses Preview WrapPanel above.
             - WF X_VALUE_SHOP / X_VALUE_SEL / X_VALUE_SHINGEKI_SHOP:
               surfaced as the Buy Price / Sell Price / Forge Price labels.
             - WF MagicExtUnitBase: implemented (#1036) as the BonusMag row in
               the Stat Bonuses Preview below — the stat-bonus block's 10th
               value (offset +9) is read into BonusMag and the row is shown only
               on FE7U/FE8U MagicSplit ROMs (HasMagicBonus). -->


        <!-- Null pointer warnings + new-alloc buttons.
             #831: the New-alloc buttons mirror WF
             L_12_NEWALLOC_ITEMSTATBOOSTER / L_16_NEWALLOC_EFFECTIVENESS
             (InputFormRef.AllocEvent) via ItemAllocCore + the wired
             CoreState.AppendBinaryData seam (#796). Clicking allocates the
             exact WF default template + writes the pointer under undo. -->
        <StackPanel Name="AllocStatBonusesRow" Orientation="Horizontal" Spacing="8" IsVisible="False" Margin="0,4,0,0">
          <TextBlock AutomationProperties.AutomationId="ItemEditor_AllocStatBonusesWarning_Label" Name="AllocStatBonusesWarning" Text="Warning: Stat Bonuses pointer is null (P12=0). Consider allocating." Foreground="Orange" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="ItemEditor_AllocStatBonuses_Button" Content="New-alloc Stat Bonuses" Click="AllocStatBonuses_Click" FontSize="11" Padding="6,2" VerticalAlignment="Center"
                  ToolTip.Tip="Allocate a new Stat Bonuses (P12) block and write its pointer into this item (mirrors WF new-alloc)." />
        </StackPanel>
        <StackPanel Name="AllocEffectivenessRow" Orientation="Horizontal" Spacing="8" IsVisible="False" Margin="0,2,0,0">
          <TextBlock AutomationProperties.AutomationId="ItemEditor_AllocEffectivenessWarning_Label" Name="AllocEffectivenessWarning" Text="Warning: Effectiveness pointer is null (P16=0). Consider allocating." Foreground="Orange" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="ItemEditor_AllocEffectiveness_Button" Content="New-alloc Effectiveness" Click="AllocEffectiveness_Click" FontSize="11" Padding="6,2" VerticalAlignment="Center"
                  ToolTip.Tip="Allocate a new Effectiveness (P16) block and write its pointer into this item (mirrors WF new-alloc)." />
        </StackPanel>

        <!-- Stat bonus preview (#409 mirrors WF "能力補正値" + X_SIM_* labels:
             HP/攻撃/技/速さ/守備/魔防/幸運/移動/体格 + 魔力 when MagicSplit). -->
        <Border Name="BonusPreviewBorder" BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,8,0,0" IsVisible="False">
          <StackPanel Spacing="4">
            <TextBlock Text="Stat Bonuses Preview" FontWeight="Bold" />
            <!-- Caption explaining the preview is decoded from P12 (WF
                 "能力補正値"). The static caption row plus the per-stat
                 read-out below mirror the WF panel exactly. -->
            <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusCaption_Label"
                       Text="Decoded stat bonus values (read-only — edit through the Stat Bonus pointer above):"
                       FontSize="11" Foreground="Gray" />
            <WrapPanel>
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusHP_Label" Name="BonusHPLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusStr_Label" Name="BonusStrLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusSkl_Label" Name="BonusSklLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusSpd_Label" Name="BonusSpdLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusDef_Label" Name="BonusDefLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusRes_Label" Name="BonusResLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusLck_Label" Name="BonusLckLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusMove_Label" Name="BonusMoveLabel" Margin="0,0,12,0" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusCon_Label" Name="BonusConLabel" Margin="0,0,12,0" />
              <!-- Magic split base (#1036) — the stat-bonus block's 10th value
                   (offset +9). Visible only on FE7U/FE8U MagicSplit ROMs
                   (HasMagicBonus; mirrors WF MagicExtUnitBase). Stays hidden by
                   default so we do not mislead users on vanilla/FE8N/FE6 ROMs. -->
              <TextBlock AutomationProperties.AutomationId="ItemEditor_BonusMag_Label"
                         Name="BonusMagLabel"
                         Margin="0,0,12,0"
                         IsVisible="False" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <!-- Effective Against class list -->
        <Border Name="EffectiveClassBorder" BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,8,0,0" IsVisible="False">
          <StackPanel Spacing="2">
            <TextBlock Text="Effective Against" FontWeight="Bold" />
            <ItemsControl AutomationProperties.AutomationId="ItemEditor_EffectiveClassList_List" Name="EffectiveClassListBox">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="12" Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Trait Flags (BitFlagPanels) — #409 adds per-trait header labels
             and a hex-decoded value preview so the WF designer's "特性1/2/3/4"
             surface is fully replicated. -->
        <Expander AutomationProperties.AutomationId="ItemEditor_TraitFlags_Expander" Header="Trait Flags" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Trait 1 (B8):" FontWeight="SemiBold" Margin="0,2" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_Trait1Hex_Label"
                         Name="Trait1HexLabel"
                         FontSize="11"
                         Foreground="Gray"
                         Margin="0,2"
                         VerticalAlignment="Center" />
            </StackPanel>
            <controls:BitFlagPanel AutomationProperties.AutomationId="ItemEditor_Trait1_Check" Name="Trait1Flags" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Trait 2 (B9):" FontWeight="SemiBold" Margin="0,2" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_Trait2Hex_Label"
                         Name="Trait2HexLabel"
                         FontSize="11"
                         Foreground="Gray"
                         Margin="0,2"
                         VerticalAlignment="Center" />
            </StackPanel>
            <controls:BitFlagPanel AutomationProperties.AutomationId="ItemEditor_Trait2_Check" Name="Trait2Flags" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Trait 3 (B10):" FontWeight="SemiBold" Margin="0,2" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_Trait3Hex_Label"
                         Name="Trait3HexLabel"
                         FontSize="11"
                         Foreground="Gray"
                         Margin="0,2"
                         VerticalAlignment="Center" />
            </StackPanel>
            <controls:BitFlagPanel AutomationProperties.AutomationId="ItemEditor_Trait3_Check" Name="Trait3Flags" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Trait 4 (B11):" FontWeight="SemiBold" Margin="0,2" />
              <TextBlock AutomationProperties.AutomationId="ItemEditor_Trait4Hex_Label"
                         Name="Trait4HexLabel"
                         FontSize="11"
                         Foreground="Gray"
                         Margin="0,2"
                         VerticalAlignment="Center" />
            </StackPanel>
            <controls:BitFlagPanel AutomationProperties.AutomationId="ItemEditor_Trait4_Check" Name="Trait4Flags" />
          </StackPanel>
        </Border>
        </Expander>

        <!-- Validation Warnings -->
        <Border Name="WarningsBorder" IsVisible="False"
                BorderBrush="Orange" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="{DynamicResource AccentOverlayBrush}" Margin="0,8,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Warnings" FontWeight="Bold" Foreground="DarkOrange" />
            <ItemsControl AutomationProperties.AutomationId="ItemEditor_Warnings_List" Name="WarningsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="DarkOrange" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ItemEditor_Write_Button" Content="Write" Click="Write_Click" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button AutomationProperties.AutomationId="ItemEditor_ExportTSV_Button" Content="Export TSV" Click="ExportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export all items to a TSV file" />
          <Button AutomationProperties.AutomationId="ItemEditor_ImportTSV_Button" Content="Import TSV" Click="ImportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import items from a TSV file" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button AutomationProperties.AutomationId="ItemEditor_EditSkillConfig_Button" Content="Edit Skill Config" Click="EditSkillConfig_Click" Name="EditSkillConfigButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open skill configuration editor" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
