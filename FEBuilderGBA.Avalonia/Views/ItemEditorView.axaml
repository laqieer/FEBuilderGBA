<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ItemEditorView"
        Title="Item Editor" Width="1408" Height="856">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="ItemList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Address -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- Row 1: W0 Name ID -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" />

          <!-- Row 2: W2 Desc ID, W4 Use Desc ID -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Desc ID (W2):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="DescIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Use Desc (W4):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="4" Name="UseDescIdBox" Minimum="0" Maximum="65535" />

          <!-- Row 3: B6 Item Number, B7 Weapon Type -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Item # (B6):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="ItemNumberBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Type (B7):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="4" Name="WeaponTypeBox" Minimum="0" Maximum="255" />

          <!-- Row 4: B8 Trait1, B9 Trait2 -->
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Trait 1 (B8):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="Trait1Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Trait 2 (B9):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="4" Name="Trait2Box" Minimum="0" Maximum="255" />

          <!-- Row 5: B10 Trait3, B11 Trait4 -->
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Trait 3 (B10):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="Trait3Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Trait 4 (B11):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="4" Name="Trait4Box" Minimum="0" Maximum="255" />

          <!-- Row 6: P12 Stat Bonuses, P16 Effectiveness -->
          <TextBlock Grid.Row="6" Grid.Column="0" Text="Stat Bonus (P12):" VerticalAlignment="Center" />
          <TextBox Grid.Row="6" Grid.Column="1" Name="StatBonusesPtrBox" Width="120" />
          <TextBlock Grid.Row="6" Grid.Column="3" Text="Effective (P16):" VerticalAlignment="Center" />
          <TextBox Grid.Row="6" Grid.Column="4" Name="EffectivenessPtrBox" Width="120" />

          <!-- Row 7: B20 Uses, B21 Might -->
          <TextBlock Grid.Row="7" Grid.Column="0" Text="Uses (B20):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="UsesBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="7" Grid.Column="3" Text="Might (B21):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="4" Name="MightBox" Minimum="0" Maximum="255" />

          <!-- Row 8: B22 Hit, B23 Weight -->
          <TextBlock Grid.Row="8" Grid.Column="0" Text="Hit (B22):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="HitBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="8" Grid.Column="3" Text="Weight (B23):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="4" Name="WeightBox" Minimum="0" Maximum="255" />

          <!-- Row 9: B24 Crit, B25 Range -->
          <TextBlock Grid.Row="9" Grid.Column="0" Text="Crit (B24):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="CritBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="9" Grid.Column="3" Text="Range (B25):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="4" Name="RangeBox" Minimum="0" Maximum="255" />

          <!-- Row 10: W26 Price, B28 Weapon Rank -->
          <TextBlock Grid.Row="10" Grid.Column="0" Text="Price (W26):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="PriceBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="10" Grid.Column="3" Text="Rank (B28):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="4" Name="WeaponRankBox" Minimum="0" Maximum="255" />

          <!-- Row 11: B29 Icon, B30 Usage Effect -->
          <TextBlock Grid.Row="11" Grid.Column="0" Text="Icon (B29):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="1" Name="IconBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="11" Grid.Column="3" Text="Use Effect (B30):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="4" Name="UsageEffectBox" Minimum="0" Maximum="255" />

          <!-- Row 12: B31 Damage Effect, B32 Weapon Exp -->
          <TextBlock Grid.Row="12" Grid.Column="0" Text="Dmg Effect (B31):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="1" Name="DamageEffectBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="12" Grid.Column="3" Text="Wep Exp (B32):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="4" Name="WeaponExpBox" Minimum="0" Maximum="255" />

          <!-- Row 13: B33-B35 Unknown/Extension -->
          <TextBlock Grid.Row="13" Grid.Column="0" Text="Unk33 (B33):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="1" Name="Unk33Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="13" Grid.Column="3" Text="Unk34 (B34):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="4" Name="Unk34Box" Minimum="0" Maximum="255" />

          <!-- Row 14: B35 -->
          <TextBlock Grid.Row="14" Grid.Column="0" Text="Unk35 (B35):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="14" Grid.Column="1" Name="Unk35Box" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
