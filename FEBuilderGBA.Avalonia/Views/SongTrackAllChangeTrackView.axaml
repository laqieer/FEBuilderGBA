<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SongTrackAllChangeTrackView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SongTrackAllChangeTrack_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Bulk Track Change" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SongTrackAllChangeTrack_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
        </Grid>

        <TextBlock Text="Reassign every instrument voice used across all tracks of this song, and/or nudge the song-wide Volume, Pan, and Tempo. Set the targets/deltas, then Apply."
                   TextWrapping="Wrap" Opacity="0.8" />

        <!-- Column captions for the voice-remap list. -->
        <Grid ColumnDefinitions="80,120,*" Margin="0,4,0,0">
          <TextBlock Grid.Column="0" Text="Voice" FontWeight="Bold" />
          <TextBlock Grid.Column="1" Text="Target Voice" FontWeight="Bold" />
          <TextBlock Grid.Column="2" Text="Instrument" FontWeight="Bold" />
        </Grid>

        <ListBox AutomationProperties.AutomationId="SongTrackAllChangeTrack_Voice_List"
                 Name="VoiceList" ItemsSource="{Binding Rows}"
                 MinHeight="240" MaxHeight="420">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="80,120,*">
                <TextBlock Grid.Column="0" Text="{Binding From}" VerticalAlignment="Center" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="127" Increment="1"
                               Value="{Binding To, Mode=TwoWay}"
                               FormatString="0" Margin="0,1" />
                <TextBlock Grid.Column="2" Text="{Binding InstrumentName}"
                           VerticalAlignment="Center" TextWrapping="NoWrap" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Song-wide Vol / Pan / Tempo / Velocity nudge inputs (applied to every
             track: VOL(0xBE) clamp 0..127, PAN(0xBF) clamp 0..127,
             TEMPO(0xBB) clamp 0..255). -->
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Volume delta:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SongTrackAllChangeTrack_Vol_Input"
                         Grid.Row="0" Grid.Column="1" Name="VolInput"
                         Minimum="-127" Maximum="127" Increment="1" FormatString="0"
                         Value="{Binding DVol, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="120" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Pan delta:" VerticalAlignment="Center" Margin="0,4,0,0" />
          <NumericUpDown AutomationProperties.AutomationId="SongTrackAllChangeTrack_Pan_Input"
                         Grid.Row="1" Grid.Column="1" Name="PanInput"
                         Minimum="-127" Maximum="127" Increment="1" FormatString="0"
                         Value="{Binding DPan, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="120" Margin="0,4,0,0" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Tempo delta:" VerticalAlignment="Center" Margin="0,4,0,0" />
          <NumericUpDown AutomationProperties.AutomationId="SongTrackAllChangeTrack_Tempo_Input"
                         Grid.Row="2" Grid.Column="1" Name="TempoInput"
                         Minimum="-255" Maximum="255" Increment="1" FormatString="0"
                         Value="{Binding DTempo, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="120" Margin="0,4,0,0" />

          <CheckBox AutomationProperties.AutomationId="SongTrackAllChangeTrack_Velocity_Check"
                    Grid.Row="3" Grid.Column="1" Name="VelocityCheck"
                    Content="Also nudge note velocities by Volume delta"
                    IsChecked="{Binding ChangeVelocity, Mode=TwoWay}" Margin="0,6,0,0" />
        </Grid>

        <Button AutomationProperties.AutomationId="SongTrackAllChangeTrack_Apply_Button"
                Name="ApplyButton" Content="Apply" Click="Apply_Click"
                HorizontalAlignment="Left" MinWidth="120" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
