<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.HexEditorSearchView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="13,25,13,10">
    <!-- Search label + ComboBox row -->
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
      <TextBlock Text="Search:" Width="99" Height="18"
                 VerticalAlignment="Center" />
      <AutoCompleteBox AutomationProperties.AutomationId="HexEditorSearch_Addr_Input" x:Name="AddrComboBox" Width="337" Height="26"
                       FilterMode="None" />
    </StackPanel>
    <!-- Reverse search checkbox -->
    <CheckBox AutomationProperties.AutomationId="HexEditorSearch_RevCheck_Check" x:Name="RevCheckBox" Content="Reverse search"
              Margin="3,0,0,8" />
    <!-- Little Endian checkbox -->
    <CheckBox AutomationProperties.AutomationId="HexEditorSearch_LittleEndianCheck_Check" x:Name="LittleEndianCheckBox" Content="Little Endian"
              Margin="3,0,0,8" />
    <!-- 4-byte aligned checkbox + Search button row -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,15">
      <CheckBox AutomationProperties.AutomationId="HexEditorSearch_Align4Check_Check" x:Name="Align4CheckBox" Content="4-byte aligned"
                Grid.Column="0" Margin="3,0,0,0" />
      <Button AutomationProperties.AutomationId="HexEditorSearch_OK_Button" Content="Search" Width="180" Height="39"
              Grid.Column="1" Click="OK_Click" />
    </Grid>
    <!-- Help text -->
    <TextBlock Text="* Wildcards: use '??' for any single byte (e.g. FF ?? 00)"
               TextWrapping="Wrap" Foreground="Gray" FontSize="11" />
  </StackPanel>
  </ScrollViewer>
</UserControl>
