<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.PointerToolView"
        Title="Pointer Tool" Width="800" Height="500"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Pointer Tool" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="Address:" VerticalAlignment="Center" />
      <TextBox Name="AddressTextBox" Width="200" Watermark="e.g. 0x08000000" />
      <Button Content="Search" Click="Search_Click" />
    </StackPanel>
    <TextBlock DockPanel.Dock="Top" Text="Search Results:" FontWeight="SemiBold" Margin="0,4,0,4" />
    <ScrollViewer>
      <TextBox Name="ResultsTextBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" />
    </ScrollViewer>
  </DockPanel>
</Window>
