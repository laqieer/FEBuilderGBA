<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MainSimpleMenuEventErrorIgnoreErrorView"
        Title="Ignore Error" Width="480" Height="280"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Hide This Error?" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <StackPanel Spacing="8">
      <TextBlock Text="Error Details:" FontWeight="SemiBold" />
      <TextBox IsReadOnly="True" Text="{Binding ErrorText}" Height="60" />
      <TextBlock Text="Reason for hiding:" FontWeight="SemiBold" />
      <TextBox Text="{Binding Comment}" Watermark="Enter reason (optional)" Height="60" />
    </StackPanel>
  </DockPanel>
</Window>
