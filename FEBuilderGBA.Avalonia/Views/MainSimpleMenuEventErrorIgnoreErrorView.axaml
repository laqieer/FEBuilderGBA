<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MainSimpleMenuEventErrorIgnoreErrorView"
        Title="Hide this error"
        Width="820" Height="355"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="16,13,12,12">
    <!-- Question label -->
    <TextBlock Text="Do you want to hide this error?" Margin="0,0,0,14" />
    <!-- Error details textbox (readonly, multiline) -->
    <TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
             Text="{Binding ErrorText}" Height="121" />
    <!-- Reason label -->
    <TextBlock Text="Reason for hiding:" Margin="0,19,0,8" />
    <!-- Comment textbox -->
    <TextBox Text="{Binding Comment}" Watermark="Reason for hiding" Height="25" />
    <!-- Buttons -->
    <Grid ColumnDefinitions="188,*,213" Margin="0,24,0,0">
      <Button Grid.Column="0" Content="Cancel" Height="45"
              HorizontalAlignment="Stretch" Click="Cancel_Click" />
      <Button Grid.Column="2" Content="Hide this error" Height="45"
              HorizontalAlignment="Stretch" Click="OK_Click" />
    </Grid>
  </StackPanel>
  </ScrollViewer>
</Window>
