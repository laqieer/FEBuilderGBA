<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.TextCharCodeView"
        Title="Text Character Code Table" Width="1172" Height="519"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Character Code Table" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <TextBlock DockPanel.Dock="Top" Text="Lists all character codes in the ROM's text encoding table." Foreground="Gray" Margin="0,0,0,8" />

    <!-- Editor panel with semantic field labels -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,8">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Char Code (ASCII):" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="0" Grid.Column="1" Name="CharCodeBox" Minimum="0" Maximum="65535" Width="120" Margin="0,2" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Terminator (FFFF):" VerticalAlignment="Center" Margin="0,2" />
      <NumericUpDown Grid.Row="1" Grid.Column="1" Name="TerminatorBox" Minimum="0" Maximum="65535" Width="120" Margin="0,2" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Character Display:" VerticalAlignment="Center" Margin="0,2" />
      <TextBlock Grid.Row="2" Grid.Column="1" Name="CharDisplayLabel" VerticalAlignment="Center" Margin="0,2" />
    </Grid>

    <!-- Font glyph preview panels -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="24" Margin="0,0,0,8">
      <StackPanel Spacing="4">
        <TextBlock Text="Item Font" FontWeight="SemiBold" />
        <Border Background="#FF6888A8" Padding="4" CornerRadius="2">
          <Image Name="ItemFontImage" Width="64" Height="64" Stretch="Uniform"
                 RenderOptions.BitmapInterpolationMode="None" />
        </Border>
        <TextBlock Name="ItemFontWidthLabel" Foreground="Gray" FontSize="11" />
      </StackPanel>
      <StackPanel Spacing="4">
        <TextBlock Text="Serif Font" FontWeight="SemiBold" />
        <Border Background="#FFE0E0E0" Padding="4" CornerRadius="2">
          <Image Name="SerifFontImage" Width="64" Height="64" Stretch="Uniform"
                 RenderOptions.BitmapInterpolationMode="None" />
        </Border>
        <TextBlock Name="SerifFontWidthLabel" Foreground="Gray" FontSize="11" />
      </StackPanel>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ListBox Name="CharCodeList" />
  </DockPanel>
  </ScrollViewer>
</Window>
