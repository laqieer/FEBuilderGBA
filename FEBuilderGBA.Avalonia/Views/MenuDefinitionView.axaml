<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MenuDefinitionView"
        Title="Menu Definition Editor" Width="1257" Height="604">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Menu Definition Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="B0 (u8@0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="B0Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="B1 (u8@1):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B1Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="B2 (u8@2):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B2Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="B3 (u8@3):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="B3Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="D4 (u32@4):" VerticalAlignment="Center" />
          <TextBox Grid.Row="5" Grid.Column="1" Name="D4Box" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Handler Ptr (u32@8):" VerticalAlignment="Center" />
          <TextBox Grid.Row="6" Grid.Column="1" Name="HandlerPtrBox" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="P12 (u32@12):" VerticalAlignment="Center" />
          <TextBox Grid.Row="7" Grid.Column="1" Name="P12Box" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="P16 (u32@16):" VerticalAlignment="Center" />
          <TextBox Grid.Row="8" Grid.Column="1" Name="P16Box" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="P20 (u32@20):" VerticalAlignment="Center" />
          <TextBox Grid.Row="9" Grid.Column="1" Name="P20Box" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="P24 (u32@24):" VerticalAlignment="Center" />
          <TextBox Grid.Row="10" Grid.Column="1" Name="P24Box" Width="120" Margin="0,2" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="P28 (u32@28):" VerticalAlignment="Center" />
          <TextBox Grid.Row="11" Grid.Column="1" Name="P28Box" Width="120" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
