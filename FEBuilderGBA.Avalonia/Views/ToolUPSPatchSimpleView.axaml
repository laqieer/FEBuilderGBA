<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolUPSPatchSimpleView">
  <ScrollViewer Margin="8">
    <StackPanel Spacing="12" Margin="8">
      <TextBlock Text="UPS Patch Creator" FontSize="18" FontWeight="Bold" />
      <TextBlock TextWrapping="Wrap" Opacity="0.8"
                 Text="Create a UPS patch that turns the original (unmodified) ROM into the currently-loaded ROM." />

      <TextBlock Text="Original (unmodified) ROM:" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0" AutomationProperties.AutomationId="ToolUPSPatchSimple_Original_Input"
                 Name="OriginalRomTextBox" Watermark="Path to the clean ROM" />
        <Button Grid.Column="1" AutomationProperties.AutomationId="ToolUPSPatchSimple_Select_Button"
                Name="SelectButton" Content="Select…" Click="Select_Click" Margin="6,0,0,0" />
      </Grid>

      <Button AutomationProperties.AutomationId="ToolUPSPatchSimple_Make_Button" Name="MakeButton"
              Content="Create UPS patch…" Click="Make_Click" />

      <TextBlock AutomationProperties.AutomationId="ToolUPSPatchSimple_Status_Label" Name="StatusText"
                 TextWrapping="Wrap" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
