<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ImageCGFE7UView"
        Title="CG Editor (FE7U)" Width="774" Height="337">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="CG Editor (FE7U)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Address -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" Margin="0,2" />

          <!-- Row 1: Image Type (B0) -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Type:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="ImageTypeLabel" VerticalAlignment="Center" Margin="0,2" />

          <!-- Row 2: Reserved (B1-B3) -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Reserved (B1-B3):" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="ReservedLabel" VerticalAlignment="Center" Margin="0,2" />

          <!-- Row 3: 10-Split Image (P4) -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="10-Split Image:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="SplitImagePtrLabel" VerticalAlignment="Center" Margin="0,2" />

          <!-- Row 4: TSA (P8) -->
          <TextBlock Grid.Row="4" Grid.Column="0" Text="TSA:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="TSAPtrLabel" VerticalAlignment="Center" Margin="0,2" />

          <!-- Row 5: Palette (P12) -->
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Palette:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="PalettePtrLabel" VerticalAlignment="Center" Margin="0,2" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Import PNG" Click="ImportPng_Click" />
          <Button Content="Export PNG" Click="ExportPng_Click" />
          <Button Content="Export PAL" Click="ExportPal_Click" />
          <Button Content="Import PAL" Click="ImportPal_Click" />
        </StackPanel>
        <controls:GbaImageControl Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
