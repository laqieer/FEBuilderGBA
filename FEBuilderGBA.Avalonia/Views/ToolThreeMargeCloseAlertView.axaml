<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolThreeMargeCloseAlertView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="13">
    <TextBlock TextWrapping="Wrap" Height="140"
               Text="{Binding AlertMessage}" />
    <Button AutomationProperties.AutomationId="ToolThreeMargeCloseAlert_Cancel_Button" Content="Continue merging without closing." Height="42"
            HorizontalAlignment="Stretch" Margin="0,3,0,0" Click="Cancel_Click" />
    <Button AutomationProperties.AutomationId="ToolThreeMargeCloseAlert_No_Button" Content="Abort merge. Cancel all merge changes." Height="42"
            HorizontalAlignment="Stretch" Margin="0,17,0,0" Click="No_Click" />
    <Button AutomationProperties.AutomationId="ToolThreeMargeCloseAlert_Yes_Button" Content="Force close with current results." Height="42"
            HorizontalAlignment="Stretch" Margin="0,39,0,0" Click="Yes_Click" />
  </StackPanel>
  </ScrollViewer>
</UserControl>
