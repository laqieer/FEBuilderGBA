<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.OPPrologueViewerView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="OPPrologueViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="OP Prologue Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="OPPrologueViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="OPPrologueViewer_ImgPtr_Input" Grid.Row="1" Grid.Column="1" Name="ImgPtrBox" Width="120" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="TSA Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="OPPrologueViewer_TsaPtr_Input" Grid.Row="2" Grid.Column="1" Name="TsaPtrBox" Width="120" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="OPPrologueViewer_PalAddr_Label" Grid.Row="3" Grid.Column="1" Name="PalAddrLabel" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="OPPrologueViewer_Write_Button" Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="OPPrologueViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="OPPrologueViewer_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
          <Button AutomationProperties.AutomationId="OPPrologueViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" />
          <Button AutomationProperties.AutomationId="OPPrologueViewer_ImportPal_Button" Content="Import PAL" Click="ImportPal_Click" />
        </StackPanel>
        <controls:GbaImageControl AutomationProperties.AutomationId="OPPrologueViewer_Image_Image" Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
