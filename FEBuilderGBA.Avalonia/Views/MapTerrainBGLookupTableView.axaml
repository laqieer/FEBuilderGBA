<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MapTerrainBGLookupTableView"
        Title="Terrain BG Lookup Table" Width="1253" Height="742"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">

    <!-- Top filter / read-config bar (mirrors the WinForms panel3) -->
    <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
        <Label Content="Condition:" VerticalAlignment="Center" />
        <ComboBox AutomationProperties.AutomationId="MapTerrainBGLookupTable_Filter_Combo"
                  Name="FilterComboBox" Width="320" VerticalAlignment="Center" />
        <Label Content="Hex Address" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="MapTerrainBGLookupTable_ReadStart_Input"
                       FormatString="0" Name="ReadStartAddressBox" Width="120"
                       Minimum="0" Maximum="65535999"
                       IsEnabled="False" VerticalAlignment="Center" />
        <Label Content="Count" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="MapTerrainBGLookupTable_ReadCount_Input"
                       FormatString="0" Name="ReadCountBox" Width="80"
                       Minimum="0" Maximum="256"
                       IsEnabled="False" VerticalAlignment="Center" />
        <Button AutomationProperties.AutomationId="MapTerrainBGLookupTable_ReloadList_Button"
                Name="ReloadListButton" Content="Reload" Click="ReloadList_Click" />
      </StackPanel>
    </Border>

    <controls:AddressListControl AutomationProperties.AutomationId="MapTerrainBGLookupTable_Entry_List"
                                 Grid.Row="1" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <Label Content="Terrain BG Lookup Table" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto">
          <Label Grid.Row="0" Grid.Column="0" Content="Address:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MapTerrainBGLookupTable_Item_Address_Input"
                         FormatString="0" Grid.Row="0" Grid.Column="1"
                         Name="ItemAddressBox" Minimum="0" Maximum="65535999"
                         IsEnabled="False" VerticalAlignment="Center" />

          <Label Grid.Row="1" Grid.Column="0" Content="Selection:" VerticalAlignment="Center" />
          <Label AutomationProperties.AutomationId="MapTerrainBGLookupTable_Addr_Label"
                 Grid.Row="1" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <Label Grid.Row="2" Grid.Column="0" Content="Battle BG:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MapTerrainBGLookupTable_BattleBG_Input"
                         FormatString="0" Grid.Row="2" Grid.Column="1"
                         Name="BattleBGBox" Minimum="0" Maximum="255"
                         VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MapTerrainBGLookupTable_Write_Button"
                  Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="MapTerrainBGLookupTable_JumpToFloor_Button"
                  Name="JumpToFloorButton" Content="Jump to the floor of battle animation" Click="JumpToFloor_Click" />
          <Button AutomationProperties.AutomationId="MapTerrainBGLookupTable_PatchInstall_Button"
                  Name="PatchInstallButton" Content="Install Patch" Click="PatchInstall_Click"
                  Foreground="Red" IsVisible="False" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
