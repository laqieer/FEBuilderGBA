<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SkillConfigFE8NSkillView"
        Title="Skill Configuration (FE8N)" Width="1189" Height="898"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,Auto,*">

    <!-- Row 0: top read-config bar — unified via EditorTopBarWithInputs (#743 round 2).
         The FE8N Page (FilterCombo) + ChangeType combos live in the `TrailingContent`
         slot, positioned between the inputs and the Reload button.
         InputsEnabled="False" preserves the pre-migration "disabled-as-display" UX,
         and the legacy AutomationId overrides keep existing E2E selectors. -->
    <controls:EditorTopBarWithInputs Grid.Row="0" Grid.ColumnSpan="2" Name="TopBar"
                                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_TopBar"
                                     ReadStartLabel="Start Address:"
                                     ReadCountLabel="Read Count:"
                                     ReadCountMaximum="1024"
                                     InputsEnabled="False"
                                     ShowReadSize="False"
                                     ReadStartAutomationId="SkillConfigFE8NSkill_ReadStart_Input"
                                     ReadCountAutomationId="SkillConfigFE8NSkill_ReadCount_Input"
                                     ReloadAutomationId="SkillConfigFE8NSkill_ReloadList_Button"
                                     ReloadRequested="OnTopBarReloadRequested">
      <controls:EditorTopBarWithInputs.TrailingContent>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Label Content="FE8N Page:" VerticalAlignment="Center" />
          <ComboBox AutomationProperties.AutomationId="SkillConfigFE8NSkill_FilterCombo_Combo"
                    Name="FilterComboBox" Width="160"
                    SelectionChanged="FilterComboBox_SelectionChanged" />
          <Label Content="Change Type:" VerticalAlignment="Center" />
          <ComboBox AutomationProperties.AutomationId="SkillConfigFE8NSkill_ChangeType_Combo"
                    Name="ChangeTypeComboBox" Width="120"
                    SelectionChanged="ChangeTypeComboBox_SelectionChanged">
            <ComboBoxItem><TextBlock Text="Unit" /></ComboBoxItem>
            <ComboBoxItem><TextBlock Text="Class" /></ComboBoxItem>
            <ComboBoxItem><TextBlock Text="Item" /></ComboBoxItem>
            <ComboBoxItem><TextBlock Text="Other" /></ComboBoxItem>
          </ComboBox>
        </StackPanel>
      </controls:EditorTopBarWithInputs.TrailingContent>
    </controls:EditorTopBarWithInputs>

    <!-- Row 1: selection bar (mirrors WF panel5: アドレス / Size: / 選択アドレス / 書き込み). -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4,0,4,0">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
        <Label Content="Address:" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="SkillConfigFE8NSkill_Address_Input"
                       FormatString="0" Name="AddressBox" Width="120"
                       Minimum="0" Maximum="4294967295"
                       IsEnabled="False" VerticalAlignment="Center" />
        <Label Content="Size:" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="SkillConfigFE8NSkill_BlockSize_Input"
                       FormatString="0" Name="BlockSizeBox" Width="50"
                       Minimum="0" Maximum="65535"
                       IsEnabled="False" VerticalAlignment="Center" Value="32" />
        <Label Content="Selected Address:" VerticalAlignment="Center" />
        <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_SelectedAddress_Label"
               Name="SelectedAddressLabel" Width="100" VerticalAlignment="Center"
               FontFamily="Consolas" />
        <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_Write_Button"
                Name="WriteButton" Content="Write" Click="WriteButton_Click" />
      </StackPanel>
    </Border>

    <!-- Row 2 col 0: Filter Name + AddressList + List Expand. -->
    <Border Grid.Row="2" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="4">
      <DockPanel>
        <Label DockPanel.Dock="Top"
               AutomationProperties.AutomationId="SkillConfigFE8NSkill_FilterName_Label"
               Content="Filter Name" HorizontalAlignment="Stretch" />
        <!-- #997: List expansion is not yet implemented for the skill-config tables
             (multi-table / multi-pointer per patch variant). The button is disabled
             with the explanation on this ENABLED Border, since a disabled Avalonia
             control won't surface its own tooltip on hover. -->
        <Border DockPanel.Dock="Bottom"
                ToolTip.Tip="List expansion is not yet implemented for the skill-config tables (multi-table / multi-pointer per patch variant).">
          <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_ListExpand_Button"
                  Name="ListExpandButton" Content="List Expand"
                  HorizontalAlignment="Stretch" IsEnabled="False" />
        </Border>
        <controls:AddressListControl
            AutomationProperties.AutomationId="SkillConfigFE8NSkill_Entry_List"
            Name="EntryList" />
      </DockPanel>
    </Border>

    <!-- Row 2 col 1: edit panel (TabControl with Main + 5 sub-list tabs). -->
    <TabControl AutomationProperties.AutomationId="SkillConfigFE8NSkill_Main_TabControl"
                Name="MainTabControl"
                Grid.Row="2" Grid.Column="1" Margin="4" SelectedIndex="0">

      <!-- Tab 1: Main skill row editor (functional). -->
      <TabItem AutomationProperties.AutomationId="SkillConfigFE8NSkill_SkillDetail_Tab"
               Header="Skill Detail">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Label Content="Skill Configuration (FE8N)" FontSize="18" FontWeight="Bold" />

            <Border Background="{DynamicResource WarningBackgroundBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12">
              <TextBlock AutomationProperties.AutomationId="SkillConfigFE8NSkill_Status_Label"
                         TextWrapping="Wrap" Name="StatusText"
                         Text="Skill system editors require a compatible skill patch to be installed.&#13;&#10;Use the Patch Manager to install a skill system patch first.&#13;&#10;&#13;&#10;Supported skill systems: CSkillSys, FE8N Skill System" />
            </Border>

            <!-- Icon row: label + image preview + Import/Export buttons + IconAddr. -->
            <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_IconHeader_Label"
                     Content="Icon" VerticalAlignment="Center" />
              <Border Grid.Column="1" BorderBrush="DarkGray" BorderThickness="1"
                      HorizontalAlignment="Left" Padding="2" Width="48" Height="48">
                <Image AutomationProperties.AutomationId="SkillConfigFE8NSkill_Icon_Image"
                       Name="IconImage" Width="40" Height="40" Stretch="Uniform" />
              </Border>
              <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_ImageImport_Button"
                        Name="ImageImportButton" Content="Image Import" Margin="0,0,8,4"
                        IsEnabled="False"
                        Click="ImageImport_Click"
                        ToolTip.Tip="FE8N Ver1 has no icon import/export — WinForms SkillConfigFE8NSkillForm is render-only, and this variant's icon address lacks the 0x100 page offset v2/v3 use. Disabled by design (#1008)." />
                <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_ImageExport_Button"
                        Name="ImageExportButton" Content="Image Export" Margin="0,0,8,4"
                        IsEnabled="False"
                        Click="ImageExport_Click"
                        ToolTip.Tip="FE8N Ver1 has no icon import/export — WinForms SkillConfigFE8NSkillForm is render-only, and this variant's icon address lacks the 0x100 page offset v2/v3 use. Disabled by design (#1008)." />
                <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_IconAddr_Label"
                       Name="IconAddrLabel" VerticalAlignment="Center" Margin="0,0,8,4"
                       FontFamily="Consolas" />
              </WrapPanel>
            </Grid>

            <!-- Icon ID row (W0): label + NumericUpDown. -->
            <Grid ColumnDefinitions="140,80,*" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_IconId_Label"
                     Content="Icon ID" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_IconId_Input"
                             FormatString="0" Name="IconIdBox"
                             Minimum="0" Maximum="65535" />
              <TextBlock Grid.Column="2"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_IconHint_Label"
                         Text="W0 - icon address = iconBase + 128 * IconId"
                         VerticalAlignment="Center" Margin="8,0,0,0"
                         FontStyle="Italic" Foreground="Gray" />
            </Grid>

            <!-- Text Detail row (W2): label + NumericUpDown + read-only resolved name. -->
            <Grid ColumnDefinitions="140,80,*" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_TextDetail_Label"
                     Content="Skill Name" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_TextDetail_Input"
                             FormatString="0" Name="TextDetailBox"
                             Minimum="0" Maximum="65535" />
              <TextBox Grid.Column="2"
                       AutomationProperties.AutomationId="SkillConfigFE8NSkill_TextDetailText_Input"
                       Name="TextDetailTextBox" IsReadOnly="True" AcceptsReturn="True"
                       Margin="8,0,0,0" MinHeight="40" />
            </Grid>

            <!-- Description hint row: split-string parsed name. -->
            <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_Description_Label"
                     Content="Description" VerticalAlignment="Center" />
              <TextBox Grid.Column="1"
                       AutomationProperties.AutomationId="SkillConfigFE8NSkill_SplitString_Input"
                       Name="SplitStringTextBox" IsReadOnly="True"
                       Margin="8,0,0,0" />
            </Grid>

            <!-- Icon display condition header. -->
            <Border BorderBrush="DarkGray" BorderThickness="1" Padding="4" Margin="0,8,0,0">
              <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondHeader_Label"
                     Content="Icon Display Condition"
                     FontWeight="Bold" />
            </Border>

            <!-- Condition caution note. -->
            <Border Background="{DynamicResource WarningBackgroundBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8">
              <TextBlock AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondCaution_Label"
                         TextWrapping="Wrap"
                         Text="Caution: the icon display condition only controls whether the icon shows in the menu - it does NOT enable the skill itself. The condition fields hold a Unit ID, a Class ID, a stat (1-4), or an Item ID depending on the patch flavour. Layout varies between FE8N patch versions; there is no unified specification." />
            </Border>

            <!-- Unit condition row (B4..B7). -->
            <Grid ColumnDefinitions="100,80,80,80,80" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitCond_Label"
                     Content="Unit" VerticalAlignment="Center" FontWeight="SemiBold" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondUnit1_Input"
                             FormatString="0" Name="CondUnit1Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="2"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondUnit2_Input"
                             FormatString="0" Name="CondUnit2Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="3"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondUnit3_Input"
                             FormatString="0" Name="CondUnit3Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="4"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondUnit4_Input"
                             FormatString="0" Name="CondUnit4Box"
                             Minimum="0" Maximum="255" />
            </Grid>

            <!-- Class condition row (B8..B11). -->
            <Grid ColumnDefinitions="100,80,80,80,80" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassCond_Label"
                     Content="Class" VerticalAlignment="Center" FontWeight="SemiBold" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondClass1_Input"
                             FormatString="0" Name="CondClass1Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="2"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondClass2_Input"
                             FormatString="0" Name="CondClass2Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="3"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondClass3_Input"
                             FormatString="0" Name="CondClass3Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="4"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondClass4_Input"
                             FormatString="0" Name="CondClass4Box"
                             Minimum="0" Maximum="255" />
            </Grid>

            <!-- Item condition row (B12..B15). -->
            <Grid ColumnDefinitions="100,80,80,80,80" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemCond_Label"
                     Content="Item" VerticalAlignment="Center" FontWeight="SemiBold" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondItem1_Input"
                             FormatString="0" Name="CondItem1Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="2"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondItem2_Input"
                             FormatString="0" Name="CondItem2Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="3"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondItem3_Input"
                             FormatString="0" Name="CondItem3Box"
                             Minimum="0" Maximum="255" />
              <NumericUpDown Grid.Column="4"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_CondItem4_Input"
                             FormatString="0" Name="CondItem4Box"
                             Minimum="0" Maximum="255" />
            </Grid>

            <!-- Animation row: pointer + Import/Export buttons + JumpToEditor. -->
            <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto">
              <Label Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigFE8NSkill_Animation_Label"
                     Content="Animation" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_AnimationPointer_Input"
                             FormatString="0" Name="AnimationPointerBox"
                             Minimum="0" Maximum="4294967295" IsEnabled="False" />
              <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_AnimationImport_Button"
                        Name="AnimationImportButton" Content="Animation Import" Margin="0,0,8,4"
                        IsEnabled="False"
                        Click="AnimationImport_Click"
                        ToolTip.Tip="FE8N Ver1 has no animation pointer or animation I/O in WinForms (render-only). Disabled by design (#1008)." />
                <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_AnimationExport_Button"
                        Name="AnimationExportButton" Content="Animation Export" Margin="0,0,8,4"
                        IsEnabled="False"
                        Click="AnimationExport_Click"
                        ToolTip.Tip="FE8N Ver1 has no animation pointer or animation I/O in WinForms (render-only). Disabled by design (#1008)." />
                <Button AutomationProperties.AutomationId="SkillConfigFE8NSkill_JumpToEditor_Button"
                        Name="JumpToEditorButton" Content="Editor" Margin="0,0,8,4"
                        Click="JumpToEditor_Click"
                        ToolTip.Tip="Pending Core extraction - tracked by #500." />
              </WrapPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 2: Unit Skill List — editable ext-bytes B16..B31 (#790).
           FE8N v1's N00..N03 sub-tabs all union onto the SAME 16 row bytes
           (offsets 16..31); editing this one tab is faithful + complete. -->
      <TabItem AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitSkillList_Tab"
               Header="Unit Skill List">
        <ScrollViewer>
          <StackPanel Margin="16" Spacing="8">
            <Label Content="Unit Skill Sub-list — Ext Bytes (B16..B31)"
                   FontSize="16" FontWeight="Bold" />
            <Border Background="{DynamicResource WarningBackgroundBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock TextWrapping="Wrap"
                           AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitTab_StatusL1_Label"
                           Text="The 16 ext-bytes B16..B31 are an additional per-skill data block whose meaning varies by FE8N patch flavour." />
                <TextBlock TextWrapping="Wrap"
                           AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitTab_StatusL2_Label"
                           Text="Edit a value, then press Write to persist it (in-place, undoable). The N00..N03 sub-tabs in WinForms all map to these same 16 bytes." />
                <TextBlock TextWrapping="Wrap"
                           AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitTab_StatusL3_Label"
                           Text="Each byte is treated as a one-based unit ID and shows the resolved unit name next to it, mirroring the WinForms N00 (Unit) decoration. A value of 0 shows no name. Class/Item/Other decorations are deferred." />
              </StackPanel>
            </Border>
            <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitTab_BaseAddr_Label"
                   Name="UnitTabBaseAddrLabel" Content="Sub-list base: -" FontFamily="Consolas" />
            <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_UnitTab_Count_Label"
                   Name="UnitTabCountLabel" Content="Entry count: -" FontFamily="Consolas" />

            <!-- 2-byte-per-row grid of the 16 ext-bytes B16..B31. Each byte is
                 Label ("Bnn") + editable NumericUpDown + a READ-ONLY unit-name
                 preview TextBlock (#793 — WF N00 decoration parity: the ext-byte
                 holds a one-based unit ID, and WF's N00 sub-list shows that
                 unit's name, so the Avalonia Unit tab decorates each byte with
                 the resolved unit name). The NUDs are x:Name-only (no AXAML
                 binding): values are pushed from the VM's Ext0..Ext15 in
                 code-behind UpdateUI() and pulled back in WriteButton_Click() —
                 same mechanism as the editor's other fields. Offset = 16 + index.
                 The preview labels are refreshed live on every NUD ValueChanged
                 from the BOX's CURRENT value (NOT the VM prop, which only updates
                 on Write), and cleared when no entry is loaded.
                 Scope (#793): Unit-tab / N00 decoration only; the N01..N03
                 (Class/Item/Other) decorations + icons are deferred. -->
            <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtByteHeader_Label"
                   Content="Ext Bytes" FontWeight="SemiBold" Margin="0,8,0,0" />
            <!-- NOTE: Avalonia 11.2.3 Grid has no ColumnSpacing/RowSpacing —
                 gaps are applied via per-cell Margin instead. -->
            <Grid ColumnDefinitions="Auto,80,160,Auto,80,160"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <!-- Row 0: B16 | B17 -->
              <Label Grid.Row="0" Grid.Column="0" Content="B16" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB16_Input"
                             FormatString="0" Name="ExtB16Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB16Name_Label"
                         Name="ExtB16NameLabel"
                         ToolTip.Tip="{Binding #ExtB16NameLabel.Text}" />
              <Label Grid.Row="0" Grid.Column="3" Content="B17" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="0" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB17_Input"
                             FormatString="0" Name="ExtB17Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="0" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB17Name_Label"
                         Name="ExtB17NameLabel"
                         ToolTip.Tip="{Binding #ExtB17NameLabel.Text}" />
              <!-- Row 1: B18 | B19 -->
              <Label Grid.Row="1" Grid.Column="0" Content="B18" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB18_Input"
                             FormatString="0" Name="ExtB18Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB18Name_Label"
                         Name="ExtB18NameLabel"
                         ToolTip.Tip="{Binding #ExtB18NameLabel.Text}" />
              <Label Grid.Row="1" Grid.Column="3" Content="B19" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="1" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB19_Input"
                             FormatString="0" Name="ExtB19Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="1" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB19Name_Label"
                         Name="ExtB19NameLabel"
                         ToolTip.Tip="{Binding #ExtB19NameLabel.Text}" />
              <!-- Row 2: B20 | B21 -->
              <Label Grid.Row="2" Grid.Column="0" Content="B20" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB20_Input"
                             FormatString="0" Name="ExtB20Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB20Name_Label"
                         Name="ExtB20NameLabel"
                         ToolTip.Tip="{Binding #ExtB20NameLabel.Text}" />
              <Label Grid.Row="2" Grid.Column="3" Content="B21" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="2" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB21_Input"
                             FormatString="0" Name="ExtB21Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="2" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB21Name_Label"
                         Name="ExtB21NameLabel"
                         ToolTip.Tip="{Binding #ExtB21NameLabel.Text}" />
              <!-- Row 3: B22 | B23 -->
              <Label Grid.Row="3" Grid.Column="0" Content="B22" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB22_Input"
                             FormatString="0" Name="ExtB22Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB22Name_Label"
                         Name="ExtB22NameLabel"
                         ToolTip.Tip="{Binding #ExtB22NameLabel.Text}" />
              <Label Grid.Row="3" Grid.Column="3" Content="B23" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="3" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB23_Input"
                             FormatString="0" Name="ExtB23Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="3" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB23Name_Label"
                         Name="ExtB23NameLabel"
                         ToolTip.Tip="{Binding #ExtB23NameLabel.Text}" />
              <!-- Row 4: B24 | B25 -->
              <Label Grid.Row="4" Grid.Column="0" Content="B24" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="4" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB24_Input"
                             FormatString="0" Name="ExtB24Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="4" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB24Name_Label"
                         Name="ExtB24NameLabel"
                         ToolTip.Tip="{Binding #ExtB24NameLabel.Text}" />
              <Label Grid.Row="4" Grid.Column="3" Content="B25" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="4" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB25_Input"
                             FormatString="0" Name="ExtB25Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="4" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB25Name_Label"
                         Name="ExtB25NameLabel"
                         ToolTip.Tip="{Binding #ExtB25NameLabel.Text}" />
              <!-- Row 5: B26 | B27 -->
              <Label Grid.Row="5" Grid.Column="0" Content="B26" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="5" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB26_Input"
                             FormatString="0" Name="ExtB26Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="5" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB26Name_Label"
                         Name="ExtB26NameLabel"
                         ToolTip.Tip="{Binding #ExtB26NameLabel.Text}" />
              <Label Grid.Row="5" Grid.Column="3" Content="B27" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="5" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB27_Input"
                             FormatString="0" Name="ExtB27Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="5" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB27Name_Label"
                         Name="ExtB27NameLabel"
                         ToolTip.Tip="{Binding #ExtB27NameLabel.Text}" />
              <!-- Row 6: B28 | B29 -->
              <Label Grid.Row="6" Grid.Column="0" Content="B28" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="6" Grid.Column="1" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB28_Input"
                             FormatString="0" Name="ExtB28Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="6" Grid.Column="2" Margin="0,0,16,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB28Name_Label"
                         Name="ExtB28NameLabel"
                         ToolTip.Tip="{Binding #ExtB28NameLabel.Text}" />
              <Label Grid.Row="6" Grid.Column="3" Content="B29" VerticalAlignment="Center" Margin="0,0,4,6" />
              <NumericUpDown Grid.Row="6" Grid.Column="4" Margin="0,0,8,6"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB29_Input"
                             FormatString="0" Name="ExtB29Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="6" Grid.Column="5" Margin="0,0,0,6" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB29Name_Label"
                         Name="ExtB29NameLabel"
                         ToolTip.Tip="{Binding #ExtB29NameLabel.Text}" />
              <!-- Row 7: B30 | B31 -->
              <Label Grid.Row="7" Grid.Column="0" Content="B30" VerticalAlignment="Center" Margin="0,0,4,0" />
              <NumericUpDown Grid.Row="7" Grid.Column="1" Margin="0,0,8,0"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB30_Input"
                             FormatString="0" Name="ExtB30Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="7" Grid.Column="2" Margin="0,0,16,0" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB30Name_Label"
                         Name="ExtB30NameLabel"
                         ToolTip.Tip="{Binding #ExtB30NameLabel.Text}" />
              <Label Grid.Row="7" Grid.Column="3" Content="B31" VerticalAlignment="Center" Margin="0,0,4,0" />
              <NumericUpDown Grid.Row="7" Grid.Column="4" Margin="0,0,8,0"
                             AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB31_Input"
                             FormatString="0" Name="ExtB31Box" Minimum="0" Maximum="255"
                             ValueChanged="ExtByteBox_ValueChanged" />
              <TextBlock Grid.Row="7" Grid.Column="5" Margin="0,0,0,0" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="Gray"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ExtB31Name_Label"
                         Name="ExtB31NameLabel"
                         ToolTip.Tip="{Binding #ExtB31NameLabel.Text}" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 3: Class Skill List placeholder (N01 - KnownGap #374). -->
      <TabItem AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassSkillList_Tab"
               Header="Class Skill List">
        <StackPanel Margin="16" Spacing="8">
          <Label Content="Class Skill Sub-list" FontSize="16" FontWeight="Bold" />
          <Border Background="{DynamicResource WarningBackgroundBrush}"
                  BorderBrush="{DynamicResource WarningBorderBrush}"
                  BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassTab_StatusL1_Label"
                         Text="The FE8N Ver1 Class/Item/Other tabs are the SAME shared 16 ext-bytes (B16..B31) already edited on the Unit tab — not a separate per-skill array." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassTab_StatusL2_Label"
                         Text="WinForms shows them as 4 tabs of the same 16 bytes; Avalonia surfaces all 16 editable on the Unit tab. Edit them there (#930)." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassTab_StatusL3_Label"
                         Text="The editable per-skill sub-list arrays live in FE8N Ver2/Ver3 (Unit/Class/Item/Item2/Composite), not Ver1." />
            </StackPanel>
          </Border>
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassTab_BaseAddr_Label"
                 Name="ClassTabBaseAddrLabel" Content="Sub-list base: -" FontFamily="Consolas" />
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_ClassTab_Count_Label"
                 Name="ClassTabCountLabel" Content="Entry count: -" FontFamily="Consolas" />
        </StackPanel>
      </TabItem>

      <!-- Tab 4: Item Skill List placeholder (N02 - KnownGap #374). -->
      <TabItem AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemSkillList_Tab"
               Header="Item Skill List">
        <StackPanel Margin="16" Spacing="8">
          <Label Content="Item Skill Sub-list" FontSize="16" FontWeight="Bold" />
          <Border Background="{DynamicResource WarningBackgroundBrush}"
                  BorderBrush="{DynamicResource WarningBorderBrush}"
                  BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemTab_StatusL1_Label"
                         Text="The FE8N Ver1 Class/Item/Other tabs are the SAME shared 16 ext-bytes (B16..B31) already edited on the Unit tab — not a separate per-skill array." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemTab_StatusL2_Label"
                         Text="WinForms shows them as 4 tabs of the same 16 bytes; Avalonia surfaces all 16 editable on the Unit tab. Edit them there (#930)." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemTab_StatusL3_Label"
                         Text="The editable per-skill sub-list arrays live in FE8N Ver2/Ver3 (Unit/Class/Item/Item2/Composite), not Ver1." />
            </StackPanel>
          </Border>
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemTab_BaseAddr_Label"
                 Name="ItemTabBaseAddrLabel" Content="Sub-list base: -" FontFamily="Consolas" />
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_ItemTab_Count_Label"
                 Name="ItemTabCountLabel" Content="Entry count: -" FontFamily="Consolas" />
        </StackPanel>
      </TabItem>

      <!-- Tab 5: Other Skill List placeholder (N03 - KnownGap #374). -->
      <TabItem AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherSkillList_Tab"
               Header="Other Skill List">
        <StackPanel Margin="16" Spacing="8">
          <Label Content="Other Skill Sub-list" FontSize="16" FontWeight="Bold" />
          <Border Background="{DynamicResource WarningBackgroundBrush}"
                  BorderBrush="{DynamicResource WarningBorderBrush}"
                  BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherTab_StatusL1_Label"
                         Text="The FE8N Ver1 Class/Item/Other tabs are the SAME shared 16 ext-bytes (B16..B31) already edited on the Unit tab — not a separate per-skill array." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherTab_StatusL2_Label"
                         Text="The N03 sub-tab in WF holds 16 generic bytes (B16..B31) with no fixed semantics, shown there as unlabeled NumericUpDowns. Avalonia surfaces all 16 editable on the Unit tab; edit them there (#930)." />
              <TextBlock TextWrapping="Wrap"
                         AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherTab_StatusL3_Label"
                         Text="The editable per-skill sub-list arrays live in FE8N Ver2/Ver3 (Unit/Class/Item/Item2/Composite), not Ver1." />
            </StackPanel>
          </Border>
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherTab_BaseAddr_Label"
                 Name="OtherTabBaseAddrLabel" Content="Sub-list base: -" FontFamily="Consolas" />
          <Label AutomationProperties.AutomationId="SkillConfigFE8NSkill_OtherTab_Count_Label"
                 Name="OtherTabCountLabel" Content="Entry count: -" FontFamily="Consolas" />
        </StackPanel>
      </TabItem>

    </TabControl>
  </Grid>
</Window>
