<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.SkillConfigFE8NSkillView"
        Title="Skill Configuration (FE8N)" Width="1189" Height="898">
  <StackPanel Margin="16" Spacing="12">
    <TextBlock Text="Skill Configuration (FE8N)" FontSize="18" FontWeight="Bold" />
    <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="4" Padding="12">
      <TextBlock TextWrapping="Wrap" Name="StatusText"
                 Text="Skill system editors require a compatible skill patch to be installed.&#10;Use the Patch Manager to install a skill system patch first.&#10;&#10;Supported skill systems: CSkillSys, FE8N Skill System" />
    </Border>

    <Grid ColumnDefinitions="180,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" IsVisible="False" Name="FieldsPanel">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
      <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Icon:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="1" Grid.Column="1" Name="IconBox" Minimum="0" Maximum="65535" FormatString="X4" Margin="0,4" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="2" Grid.Column="1" Name="DescriptionBox" Minimum="0" Maximum="65535" FormatString="X4" Margin="0,4" />

      <TextBlock Grid.Row="3" Grid.Column="0" Text="Condition Unit 1:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="3" Grid.Column="1" Name="ConditionUnit1Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="4" Grid.Column="0" Text="Condition Unit 2:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="4" Grid.Column="1" Name="ConditionUnit2Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="5" Grid.Column="0" Text="Condition Unit 3:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="5" Grid.Column="1" Name="ConditionUnit3Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="6" Grid.Column="0" Text="Condition Unit 4:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="6" Grid.Column="1" Name="ConditionUnit4Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="7" Grid.Column="0" Text="Condition Class 1:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="7" Grid.Column="1" Name="ConditionClass1Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="8" Grid.Column="0" Text="Condition Class 2:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="8" Grid.Column="1" Name="ConditionClass2Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="9" Grid.Column="0" Text="Condition Class 3:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="9" Grid.Column="1" Name="ConditionClass3Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="10" Grid.Column="0" Text="Condition Class 4:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="10" Grid.Column="1" Name="ConditionClass4Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="11" Grid.Column="0" Text="Condition Item 1:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="11" Grid.Column="1" Name="ConditionItem1Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="12" Grid.Column="0" Text="Condition Item 2:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="12" Grid.Column="1" Name="ConditionItem2Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="13" Grid.Column="0" Text="Condition Item 3:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="13" Grid.Column="1" Name="ConditionItem3Box" Minimum="0" Maximum="255" Margin="0,4" />

      <TextBlock Grid.Row="14" Grid.Column="0" Text="Condition Item 4:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="14" Grid.Column="1" Name="ConditionItem4Box" Minimum="0" Maximum="255" Margin="0,4" />
    </Grid>

    <Button Name="WriteButton" Content="Write" HorizontalAlignment="Right" Margin="0,8" IsVisible="False" />
  </StackPanel>
</Window>
