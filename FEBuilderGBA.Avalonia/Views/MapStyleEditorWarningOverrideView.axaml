<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.MapStyleEditorWarningOverrideView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock Text="Warning" FontSize="18" FontWeight="Bold" Foreground="OrangeRed" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock AutomationProperties.AutomationId="MapStyleEditorWarningOverride_Warning_Label" x:Name="WarningText" Text="Overriding map style data may cause visual artifacts. Are you sure?" TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,16" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <Button AutomationProperties.AutomationId="MapStyleEditorWarningOverride_OK_Button" Content="Override" Width="100" Click="OK_Click" />
      <Button AutomationProperties.AutomationId="MapStyleEditorWarningOverride_Cancel_Button" Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</UserControl>
