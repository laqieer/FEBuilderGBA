<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FEBuilderGBA.Avalonia.ViewModels"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolUndoView"
        Title="Undo History Viewer" Width="900" Height="700"
        SizeToContent="Manual">
  <DockPanel Margin="12">
    <!-- Header (WinForms label30 "履歴(上が最新)") -->
    <TextBlock DockPanel.Dock="Top" Text="Undo History (newest on top)"
               FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
               HorizontalAlignment="Center" />

    <!-- Action buttons (WinForms testplayButton + rollbackButton) -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,8,Auto" Margin="0,8,0,0">
      <Button AutomationProperties.AutomationId="ToolUndo_TestPlay_Button" Grid.Column="0"
              Name="TestPlayButton" Content="Test Play This Version in Emulator"
              Height="36" HorizontalAlignment="Stretch" Click="TestPlay_Click" />
      <Button AutomationProperties.AutomationId="ToolUndo_Rollback_Button" Grid.Column="2"
              Name="RollbackButton" Content="Revert to This Version"
              Height="36" Width="280" Click="Rollback_Click" />
    </Grid>

    <!-- History list -->
    <ListBox AutomationProperties.AutomationId="ToolUndo_Entry_List"
             Name="EntryList" ItemsSource="{Binding Entries}"
             SelectionChanged="EntryList_SelectionChanged"
             DoubleTapped="EntryList_DoubleTapped">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:UndoEntryRowViewModel">
          <Grid ColumnDefinitions="24,*,Auto" Margin="0,2">
            <!-- Current-position marker (WinForms "->" prefix) -->
            <TextBlock Grid.Column="0" Text="▶" VerticalAlignment="Center"
                       FontWeight="Bold" Foreground="DodgerBlue"
                       IsVisible="{Binding IsCurrent}" />
            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                       VerticalAlignment="Center" TextWrapping="NoWrap" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                       FontSize="11" Foreground="Gray"
                       Text="{Binding ChangeCountText}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
