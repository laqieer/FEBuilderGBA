<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.EventUnitNewAllocView">
  <!-- Modal count-picker (mirrors WF EventUnitNewAllocForm:
       NumericUpDown Min=1/Max=50/Value=1 + OK/Cancel). The chosen
       count is returned from ShowDialog<uint?> (null on Cancel/close). -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="16" Spacing="12" MinWidth="280">
      <TextBlock AutomationProperties.AutomationId="EventUnitNewAlloc_Prompt_Label"
                 Name="PromptLabel" Text="How many units?"
                 FontWeight="Bold" VerticalAlignment="Center" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock AutomationProperties.AutomationId="EventUnitNewAlloc_CountText_Label"
                   Name="CountLabel" Text="Count:" Width="90"
                   VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="EventUnitNewAlloc_Count_Input"
                       x:Name="AllocCountBox" Width="160"
                       Minimum="1" Maximum="50" Value="1" Increment="1"
                       FormatString="0" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button AutomationProperties.AutomationId="EventUnitNewAlloc_OK_Button"
                Name="OKButton" Content="OK" Width="90" Click="OK_Click"
                IsDefault="True" />
        <Button AutomationProperties.AutomationId="EventUnitNewAlloc_Cancel_Button"
                Name="CancelButton" Content="Cancel" Width="90" Click="Cancel_Click"
                IsCancel="True" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
