<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.StatusRMenuView">
  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">
    <!-- Table switcher (mirrors WinForms StatusRMenuForm FilterComboBox):
         status params / items held / weapon level / battle forecast 1 / 2
         / (FE8) status screen — six independent RMenu tables (#1459). -->
    <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4,4,4,0">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
        <Label Content="RMenu Table:" VerticalAlignment="Center" />
        <ComboBox AutomationProperties.AutomationId="StatusRMenu_Filter_Combo"
                  Name="FilterComboBox" Width="280" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <controls:AddressListControl AutomationProperties.AutomationId="StatusRMenu_Entry_List" Grid.Row="1" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Status R-Menu Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="StatusRMenu_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Up RMenuPointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_UpPtr_Input" Grid.Row="1" Grid.Column="1" Name="UpPtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Down RMenuPointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_DownPtr_Input" Grid.Row="2" Grid.Column="1" Name="DownPtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Left RMenuPointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_LeftPtr_Input" Grid.Row="3" Grid.Column="1" Name="LeftPtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Right RMenuPointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_RightPtr_Input" Grid.Row="4" Grid.Column="1" Name="RightPtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="X Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusRMenu_PosX_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="PosXBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Y Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusRMenu_PosY_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="PosYBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Text ID (TID):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusRMenu_TextId_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="TextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusRMenu_TextId_Label" Grid.Row="7" Grid.Column="2" Name="TextIdPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #TextIdPreview.Text}" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Loop Routine:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_Loop_Input" Grid.Row="8" Grid.Column="1" Name="LoopBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Getter Routine:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="StatusRMenu_Getter_Input" Grid.Row="9" Grid.Column="1" Name="GetterBox" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="StatusRMenu_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
