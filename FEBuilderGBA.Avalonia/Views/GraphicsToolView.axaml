<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.GraphicsToolView"
        Title="Graphics Tool" Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Graphics Tool" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <Border DockPanel.Dock="Top" Background="#D1ECF1" BorderBrush="#17A2B8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
      <TextBlock TextWrapping="Wrap"
                 Text="Graphics Tool browser. Select images from the categorized list.&#10;Browse and manage all graphical assets in the ROM." />
    </Border>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <Border Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="12">
      <StackPanel Spacing="4">
        <TextBlock Text="Categories:" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Text="- Portraits (character face graphics)" />
        <TextBlock Text="- Battle Animations (combat sprites)" />
        <TextBlock Text="- Map Sprites (overworld unit icons)" />
        <TextBlock Text="- Item Icons (weapon/item graphics)" />
        <TextBlock Text="- CGs (full-screen illustrations)" />
        <TextBlock Text="- Title Screen / UI Graphics" />
        <TextBlock Text="- Map Tilesets (terrain graphics)" />
        <TextBlock Text="- Battle Backgrounds" />
        <TextBlock Text="- Magic Effects / Spell Animations" />
      </StackPanel>
    </Border>
  </DockPanel>
  </ScrollViewer>
</Window>
