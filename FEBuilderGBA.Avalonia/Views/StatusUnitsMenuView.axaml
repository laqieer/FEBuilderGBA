<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.StatusUnitsMenuView"
        Title="Status Units Menu Editor" Width="1238" Height="806">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Status Units Menu Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Order (u32@0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="OrderBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Text ID (u32@4):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="TextIdBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="D8 (u32@8):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="D8Box" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Text ID 2 (u32@12):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="TextId2Box" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
