<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.StatusUnitsMenuView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="StatusUnitsMenu_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Status Units Menu Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="StatusUnitsMenu_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Order:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusUnitsMenu_Order_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="OrderBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Item Name Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusUnitsMenu_ItemNameTextId_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="ItemNameTextIdBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusUnitsMenu_ItemNameTextId_Label" Grid.Row="2" Grid.Column="2" Name="ItemNameTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #ItemNameTextPreview.Text}" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Reference Data:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusUnitsMenu_ReferenceData_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="ReferenceDataBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="RMenu Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="StatusUnitsMenu_RMenuTextId_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="RMenuTextIdBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="StatusUnitsMenu_RMenuTextId_Label" Grid.Row="4" Grid.Column="2" Name="RMenuTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #RMenuTextPreview.Text}" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="StatusUnitsMenu_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
