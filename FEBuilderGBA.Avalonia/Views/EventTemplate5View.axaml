<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.EventTemplate5View"
        Title="Event Template 5" Width="760" Height="560"
        SizeToContent="Manual">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="8" MinHeight="520">
      <TextBlock Grid.Row="0" Text="Event Template 5" FontSize="18" FontWeight="Bold" Margin="0,0,0,6" />

      <WrapPanel AutomationProperties.AutomationId="EventTemplate5_Buttons_Control"
                 Grid.Row="1" Name="ButtonPanel" Orientation="Horizontal" />

      <TextBox AutomationProperties.AutomationId="EventTemplate5_Preview_Input"
               Grid.Row="2" Name="PreviewBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" FontSize="12"
               TextWrapping="NoWrap" Margin="0,8,0,0" MinHeight="240"
               VerticalContentAlignment="Top"
               Text="{Binding Preview}" />

      <TextBlock AutomationProperties.AutomationId="EventTemplate5_Status_Label"
                 Grid.Row="3" Name="StatusLabel" Margin="0,6,0,0"
                 Text="{Binding Status}" />

      <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0" Spacing="6">
        <Button AutomationProperties.AutomationId="EventTemplate5_CopyHex_Button"
                Name="CopyHexButton" Content="Copy generated hex" Click="CopyHex_Click"
                IsEnabled="{Binding HasGenerated}" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Window>
