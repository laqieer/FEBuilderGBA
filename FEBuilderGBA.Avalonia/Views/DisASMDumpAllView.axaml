<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.DisASMDumpAllView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock Text="Disassembly Dump All" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Select an output format and run the disassembly dump." TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />
    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <RadioButton AutomationProperties.AutomationId="DisASMDumpAll_DisASMOption_Check" x:Name="DisASMOption" Content="DisASM" IsChecked="True" GroupName="DumpAction" />
      <RadioButton AutomationProperties.AutomationId="DisASMDumpAll_IDAOption_Check" x:Name="IDAOption" Content="IDA MAP" GroupName="DumpAction" />
      <RadioButton AutomationProperties.AutomationId="DisASMDumpAll_NoCashOption_Check" x:Name="NoCashOption" Content="No$GBA SYM" GroupName="DumpAction" />
      <RadioButton AutomationProperties.AutomationId="DisASMDumpAll_RangeOption_Check" x:Name="RangeOption" Content="Address Range" GroupName="DumpAction" />
    </StackPanel>
    <StackPanel x:Name="AddressPanel" Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <TextBlock Text="Address:" VerticalAlignment="Center" />
      <TextBox AutomationProperties.AutomationId="DisASMDumpAll_Address_Input" x:Name="AddressBox" Width="140" Watermark="0x08000000" Text="{Binding AddressInput}" />
      <TextBlock Text="Length:" VerticalAlignment="Center" />
      <TextBox AutomationProperties.AutomationId="DisASMDumpAll_Length_Input" x:Name="LengthBox" Width="100" Watermark="0x100" Text="{Binding LengthInput}" />
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <Button AutomationProperties.AutomationId="DisASMDumpAll_Run_Button" Content="Run Dump" Width="100" Click="Run_Click" />
      <Button AutomationProperties.AutomationId="DisASMDumpAll_Close_Button" Content="Close" Width="80" Click="Close_Click" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="Gray" />
    </StackPanel>
    <TextBox AutomationProperties.AutomationId="DisASMDumpAll_Output_Input" x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True"
             FontFamily="Consolas, Courier New, monospace" FontSize="12"
             TextWrapping="NoWrap" />
  </DockPanel>
  </ScrollViewer>
</UserControl>
