<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.DisASMDumpAllView"
        Title="Disassembly Dump All" Width="695" Height="721"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock Text="Disassembly Dump All" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Select an output format and run the disassembly dump." TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />
    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <RadioButton x:Name="DisASMOption" Content="DisASM" IsChecked="True" GroupName="DumpAction" />
      <RadioButton x:Name="IDAOption" Content="IDA MAP" GroupName="DumpAction" />
      <RadioButton x:Name="NoCashOption" Content="No$GBA SYM" GroupName="DumpAction" />
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <Button Content="Run Dump" Width="100" Click="Run_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True"
             FontFamily="Consolas, Courier New, monospace" FontSize="12"
             TextWrapping="NoWrap" />
  </DockPanel>
</Window>
