<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SummonsDemonKingViewerView"
        Title="Demon King Summon (Read-Only)" Width="800" Height="500">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Demon King Summon (Read-Only)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="UnitIdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Class ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="ClassIdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Unknown:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="UnknownLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Unit Grow:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="UnitGrowLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Level:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="LevelLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
