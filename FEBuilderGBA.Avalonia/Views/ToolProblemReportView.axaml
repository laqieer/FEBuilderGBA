<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolProblemReportView"
        Title="Problem Reporter" Width="720" Height="560"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual">
  <DockPanel Margin="12">
    <TextBlock AutomationProperties.AutomationId="ToolProblemReport_Header_Label"
               DockPanel.Dock="Top" Name="HeaderLabel"
               Text="Problem Reporter"
               FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />
    <TextBlock AutomationProperties.AutomationId="ToolProblemReport_Hint_Label"
               DockPanel.Dock="Top" Name="HintLabel"
               Text="Describe the problem, then create a report to attach when you ask for help. The report includes a diagnostic log and your editor settings (no save data is collected)."
               Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,12" />

    <!-- About-report URL link -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Spacing="6" Margin="0,12,0,0">
      <TextBlock AutomationProperties.AutomationId="ToolProblemReport_Status_Label"
                 Name="StatusLabel" Foreground="Gray" TextWrapping="Wrap" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock AutomationProperties.AutomationId="ToolProblemReport_About_Label"
                   Name="AboutLabel" Text="About report.7z:" VerticalAlignment="Center" />
        <Button AutomationProperties.AutomationId="ToolProblemReport_AboutUrl_Button"
                Name="AboutUrlButton" Click="AboutUrl_Click" />
      </StackPanel>
    </StackPanel>

    <!-- Create button -->
    <Button DockPanel.Dock="Bottom"
            AutomationProperties.AutomationId="ToolProblemReport_Create_Button"
            Name="CreateButton" Click="Create_Click"
            Content="Create Report"
            HorizontalAlignment="Left" Margin="0,12,0,0" />

    <!-- Problem description -->
    <TextBlock AutomationProperties.AutomationId="ToolProblemReport_Problem_Label"
               DockPanel.Dock="Top" Name="ProblemLabel" Text="Problem description" Margin="0,0,0,4" />
    <TextBox AutomationProperties.AutomationId="ToolProblemReport_Problem_Input"
             Name="ProblemTextBox"
             AcceptsReturn="True" TextWrapping="Wrap"
             VerticalContentAlignment="Top"
             Text="{Binding ProblemText}" />
  </DockPanel>
</Window>
