<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.StatusParamView"
        Title="Status Parameters Editor" Width="1238" Height="604"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <StackPanel Grid.Column="0" Margin="4">
      <ComboBox Name="TableFilterCombo" Margin="0,0,0,4" HorizontalAlignment="Stretch" />
      <controls:AddressListControl Name="EntryList" />
    </StackPanel>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Status Parameters Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="StatusMenuTextStruct:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="1" Grid.Column="1" Name="MenuTextStructBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Bitmap:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="2" Grid.Column="1" Name="BitmapBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Color:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="3" Grid.Column="1" Name="ColorTypeBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Indent:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="4" Grid.Column="1" Name="IndentBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="B10:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="5" Grid.Column="1" Name="B10Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="B11:" VerticalAlignment="Center" />
          <NumericUpDown FormatString="0" Grid.Row="6" Grid.Column="1" Name="B11Box" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="String Pointer:" VerticalAlignment="Center" />
          <TextBox Grid.Row="7" Grid.Column="1" Name="StringPointerBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="String Text:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="8" Grid.Column="1" Name="StringLabel" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
