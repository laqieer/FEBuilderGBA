<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.WorldMapImageView">
  <!-- Six-tab parity raise (#395) - mirrors WF WorldMapImageForm.WMTabControl.
       tabPage1 / Main:      4 main-map pointers (image / palette / dark / palettemap)
       tabPage2 / Event:     3 pointers (image / palette / TSA)
       tabPage3 / Mini:      2 pointers (image / palette)
       WMPointIconTabPage:   3 image pointers (Point1 / Point2 / Road) +
                             shared icon palette
       tabPage4 / Border:    pointer-backed AddressList + 4 NUDs (P0 / P4 / W8 / W10)
       tabPage5 / IconData:  pointer-backed AddressList + 12 NUDs
                             (B0..B3 / P4 / B8..B13 / W14)

       Heavy graphics flows (LZ77 import/export, dark-map preview,
       decrease-color tool, border bitmap rendering, source-file
       resource cache) are KnownGap-marked - disabled buttons with
       ToolTip.Tip referencing the architectural blocker. No follow-up
       issues per task scope discipline.

       Per Copilot CLI plan-review v1 -> v2:
         C1 - ONE top-level Write-Pointers button writes all 13 pointer
              slots in one undo scope (mirrors WF AllWriteButton semantics).
         C3 - No per-tab Undo controls (WinForms has none); exactly one
              top-level Undo button. -->

  <DockPanel>
    <!-- ==================== Top global panel ==================== -->
    <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" Padding="6" Margin="4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button AutomationProperties.AutomationId="WorldMapImage_WriteAll_Button"
                Name="WriteAllButton" Content="Write Pointers"
                Click="WriteAll_Click" />
        <Button AutomationProperties.AutomationId="WorldMapImage_Undo_Button"
                Name="UndoButton" Content="Undo"
                Click="Undo_Click" />
      </StackPanel>
    </Border>

    <!-- ==================== Six tabs ==================== -->
    <TabControl AutomationProperties.AutomationId="WorldMapImage_TabControl">

      <!-- ============================================================
           Tab 1 - Main field map (WF tabPage1 "メインフィールドマップ")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_Main_Tab" Header="Main Field Map">
        <Grid RowDefinitions="*" ColumnDefinitions="320,*">

          <!-- Col 0: 4 hex pointer NUDs + 7 buttons -->
          <StackPanel Grid.Column="0" Margin="6" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Main_Image_Label"
                     Content="Image" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Main_Image_Input"
                             FormatString="0" Name="MainImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Main_Palette_Label"
                     Content="Palette" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Main_Palette_Input"
                             FormatString="0" Name="MainPaletteBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Main_DarkPalette_Label"
                     Content="Dark Palette" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Main_DarkPalette_Input"
                             FormatString="0" Name="MainDarkPaletteBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Main_PaletteMap_Label"
                     Content="Palette Map" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Main_PaletteMap_Input"
                             FormatString="0" Name="MainPaletteMapBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>

            <!-- #875: Main Import — enabled on FE8 (CanImportMain gate); disabled on FE6/FE7. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_Import_Button"
                    Name="MainImportButton" Content="Import Image"
                    IsEnabled="{Binding CanImportMain}"
                    Click="MainImport_Click" />
            <!-- #1064 PR1: legacy "Export Image" — wired to the same read-only full
                 main field-map export path as Export PNG (CanExportMain gate). -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_Export_Button"
                    Content="Export Image"
                    IsEnabled="{Binding CanExportMain}"
                    Click="MainExport_Click"
                    ToolTip.Tip="Export the main field-map preview to PNG." />
            <!-- #846: read-only Export PNG of the live main field-map preview
                 (mirrors the Event/Mini tabs' read-only export). Enabled only
                 after a successful FE8 render. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_ExportPng_Button"
                    Name="MainFieldMapExportButton" Content="Export PNG"
                    IsEnabled="{Binding CanExportMain}"
                    Click="MainExport_Click" />

            <Label AutomationProperties.AutomationId="WorldMapImage_Main_DarkSection_Label"
                   Content="Dark Map" FontWeight="SemiBold" Margin="0,8,0,0" />
            <!-- #875: Dark Import — enabled on FE8 (CanImportDark gate). -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_DarkImport_Button"
                    Name="DarkImportButton" Content="Dark Map Import (Palette)"
                    IsEnabled="{Binding CanImportDark}"
                    Click="DarkImport_Click" />
            <!-- #875: Dark Export — enabled after a successful TryRenderDarkFieldMap. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_DarkExport_Button"
                    Name="DarkExportButton" Content="Dark Map Export"
                    IsEnabled="{Binding CanExportDark}"
                    Click="DarkExport_Click" />
            <!-- Col 1 dark preview (no panel — just export). -->

            <Button AutomationProperties.AutomationId="WorldMapImage_Main_DecreaseColor_Button"
                    Content="Decrease Color Tool"
                    Click="MainDecreaseColor_Click" />
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_OpenSource_Button"
                    Content="Open Source File"
                    IsVisible="{Binding IsSourceFileAvailable}"
                    Click="OpenSource_Click" />
            <Button AutomationProperties.AutomationId="WorldMapImage_Main_SelectSource_Button"
                    Content="Open Source Folder"
                    IsVisible="{Binding IsSourceFileAvailable}"
                    Click="SelectSource_Click" />
          </StackPanel>

          <!-- Col 1: live main field-map preview (#846 NV5b — FE8-only, 480x320)
               via ImageWorldMapCore.TryRenderMainFieldMap. The new pure
               primitive ByteToImage16TilePaletteMap decodes the 4bpp tiles with
               a per-tile sub-palette selected by the LZ77-decompressed
               palette-map (image + palette RAW). FE6/FE7 or incomplete regions
               render blank (null). -->
          <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="6">
            <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_Main_Preview_Image"
                                      Name="MainFieldMapPreview" MinWidth="480" MinHeight="320" />
          </Border>
        </Grid>
      </TabItem>

      <!-- ============================================================
           Tab 2 - Event (WF tabPage2 "イベント用")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_Event_Tab" Header="Event">
        <Grid RowDefinitions="*" ColumnDefinitions="320,*">

          <StackPanel Grid.Column="0" Margin="6" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Event_Image_Label"
                     Content="Image" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Event_Image_Input"
                             FormatString="0" Name="EventImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Event_Palette_Label"
                     Content="Palette" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Event_Palette_Input"
                             FormatString="0" Name="EventPaletteBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Event_TSA_Label"
                     Content="TSA" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Event_TSA_Input"
                             FormatString="0" Name="EventTsaBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>

            <!-- #1064 PR1: Event two-stream import (ZIMAGE + ZHEADERTSA + 64-color
                 4-bank palette). Enabled on FE8 with all three event pointers set
                 (CanImportEvent gate); the Core ImportEvent re-validates. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Event_Import_Button"
                    Content="Import Image"
                    IsEnabled="{Binding CanImportEvent}"
                    Click="EventImport_Click"
                    ToolTip.Tip="Import a 240x160 event image (auto-reduced to World Map (event) / 4 palettes)." />
            <!-- #843: read-only Export PNG of the live event preview (mirrors WF
                 ImageFormRef OnExportButton — decode + save). Enabled only after
                 a successful render. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Event_Export_Button"
                    Name="EventExportButton" Content="Export PNG"
                    IsEnabled="{Binding CanExportEvent}"
                    Click="EventExport_Click" />
            <Button AutomationProperties.AutomationId="WorldMapImage_Event_DecreaseColor_Button"
                    Content="Decrease Color Tool"
                    Click="EventDecreaseColor_Click" />
          </StackPanel>

          <!-- #843: live event preview (32x20 tiles = 256x160) via
               ImageWorldMapCore.TryRenderEvent (two LZ77 streams + 64-color
               4-sub-palette). -->
          <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="6">
            <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_Event_Preview_Image"
                                      Name="EventPreviewImage" MinWidth="256" MinHeight="160" />
          </Border>
        </Grid>
      </TabItem>

      <!-- ============================================================
           Tab 3 - Mini Map (WF tabPage3 "ミニマップ")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_Mini_Tab" Header="Mini Map">
        <Grid RowDefinitions="*" ColumnDefinitions="320,*">

          <StackPanel Grid.Column="0" Margin="6" Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Mini_Image_Label"
                     Content="Image" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Mini_Image_Input"
                             FormatString="0" Name="MiniImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label AutomationProperties.AutomationId="WorldMapImage_Mini_Palette_Label"
                     Content="Palette" Width="120" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Mini_Palette_Input"
                             FormatString="0" Name="MiniPaletteBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
            </StackPanel>

            <!-- #1000: Mini strip import — single LZ77 image + 16-color palette;
                 image-only (shared palette untouched). FE8-only via CanImportMini. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Mini_Import_Button"
                    Content="Import Image"
                    IsEnabled="{Binding CanImportMini}"
                    Click="MiniImport_Click" />
            <!-- #843: read-only Export PNG of the live mini-map preview. -->
            <Button AutomationProperties.AutomationId="WorldMapImage_Mini_Export_Button"
                    Name="MiniExportButton" Content="Export PNG"
                    IsEnabled="{Binding CanExportMini}"
                    Click="MiniExport_Click" />
          </StackPanel>

          <!-- #843: live mini-map preview (8x8 tiles = 64x64) via
               ImageWorldMapCore.TryRenderMini (single LZ77 + 16-color palette). -->
          <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="6">
            <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_Mini_Preview_Image"
                                      Name="MiniPreviewImage" MinWidth="64" MinHeight="64" />
          </Border>
        </Grid>
      </TabItem>

      <!-- ============================================================
           Tab 4 - Point Icon (WF WMPointIconTabPage "拠点アイコン")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_PointIcon_Tab" Header="Point Icon">
        <Grid RowDefinitions="*" ColumnDefinitions="380,*">

          <StackPanel Grid.Column="0" Margin="6" Spacing="6">
            <!-- Point 1 -->
            <Label AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point1Image_Label"
                   Content="Point Image 1" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point1Image_Input"
                             FormatString="0" Name="Point1ImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
              <!-- #1000: Point1 strip import — image-only (shared icon palette untouched). -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point1Import_Button"
                      Content="Import"
                      IsEnabled="{Binding CanImportPoint1}"
                      Click="Point1Import_Click" />
              <!-- #843: read-only Export PNG of the live point-1 preview. -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point1Export_Button"
                      Name="Point1ExportButton" Content="Export PNG"
                      IsEnabled="{Binding CanExportPoint1}"
                      Click="Point1Export_Click" />
            </StackPanel>

            <!-- Point 2 -->
            <Label AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point2Image_Label"
                   Content="Point Image 2" FontWeight="SemiBold" Margin="0,6,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point2Image_Input"
                             FormatString="0" Name="Point2ImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
              <!-- #1000: Point2 strip import — image-only (shared icon palette untouched). -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point2Import_Button"
                      Content="Import"
                      IsEnabled="{Binding CanImportPoint2}"
                      Click="Point2Import_Click" />
              <!-- #843: read-only Export PNG of the live point-2 preview. -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point2Export_Button"
                      Name="Point2ExportButton" Content="Export PNG"
                      IsEnabled="{Binding CanExportPoint2}"
                      Click="Point2Export_Click" />
            </StackPanel>

            <!-- Road -->
            <Label AutomationProperties.AutomationId="WorldMapImage_PointIcon_RoadImage_Label"
                   Content="Road Image" FontWeight="SemiBold" Margin="0,6,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_PointIcon_RoadImage_Input"
                             FormatString="0" Name="RoadImageBox" Width="170"
                             Minimum="0" Maximum="4294967295" />
              <!-- #1000: Road strip import — image-only (shared icon palette untouched). -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_RoadImport_Button"
                      Content="Import"
                      IsEnabled="{Binding CanImportRoad}"
                      Click="RoadImport_Click" />
              <!-- #843: read-only Export PNG of the live road preview. -->
              <Button AutomationProperties.AutomationId="WorldMapImage_PointIcon_RoadExport_Button"
                      Name="RoadExportButton" Content="Export PNG"
                      IsEnabled="{Binding CanExportRoad}"
                      Click="RoadExport_Click" />
            </StackPanel>

            <!-- Shared icon palette -->
            <Label AutomationProperties.AutomationId="WorldMapImage_PointIcon_IconPalette_Label"
                   Content="Icon Palette" FontWeight="SemiBold" Margin="0,8,0,0" />
            <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_PointIcon_IconPalette_Input"
                           FormatString="0" Name="IconPaletteBox" Width="170"
                           Minimum="0" Maximum="4294967295" />
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="6" Spacing="4">
            <!-- #843: live previews via ImageWorldMapCore (single LZ77 + shared
                 16-color icon palette). Point1 = 32x8 tiles (256x64), Point2 =
                 12x4 tiles (96x32), Road = 1x15 tiles (8x120). -->
            <Label Content="Point 1 Preview" FontWeight="SemiBold" />
            <Border BorderBrush="Gray" BorderThickness="1" MinHeight="80">
              <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point1Preview_Image"
                                        Name="Point1PreviewImage" MinWidth="256" MinHeight="64" />
            </Border>
            <Label Content="Point 2 Preview" FontWeight="SemiBold" />
            <Border BorderBrush="Gray" BorderThickness="1" MinHeight="80">
              <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_PointIcon_Point2Preview_Image"
                                        Name="Point2PreviewImage" MinWidth="96" MinHeight="32" />
            </Border>
            <Label Content="Road Preview" FontWeight="SemiBold" />
            <Border BorderBrush="Gray" BorderThickness="1" MinHeight="120">
              <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_PointIcon_RoadPreview_Image"
                                        Name="RoadPreviewImage" MinWidth="8" MinHeight="120" />
            </Border>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- ============================================================
           Tab 5 - Border (WF tabPage4 "国境")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_Border_Tab" Header="Border">
        <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="240,*">

          <!-- Row 0: Read-config bar (mirrors WF panel4).
               #668: start address / count / reload migrated to unified
               EditorTopBar control. The List Expand button stays external
               (not a standard top-bar slot) — Grid keeps EditorTopBar
               stretched and pins List Expand to the right. -->
          <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="4"
                ColumnDefinitions="*,Auto">
            <controls:EditorTopBar Grid.Column="0"
                                   Name="Border_TopBar"
                                   AutomationProperties.AutomationId="WorldMapImage_Border_TopBar"
                                   ShowSize="False"
                                   StartAddressLabel="Start Address:"
                                   ReadCountLabel="Read Count:"
                                   StartAddressAutomationId="WorldMapImage_Border_ReadStartAddress_Label"
                                   ReadCountAutomationId="WorldMapImage_Border_ReadCount_Label"
                                   ReloadAutomationId="WorldMapImage_Border_Reload_Button"
                                   ReloadRequested="OnBorderTopBarReloadRequested" />
            <Button Grid.Column="1"
                    AutomationProperties.AutomationId="WorldMapImage_Border_AddressListExpand_Button"
                    Name="Border_AddressListExpandButton" Content="List Expand"
                    Click="BorderListExpand_Click"
                    Margin="4,0,0,0" VerticalAlignment="Center"
                    ToolTip.Tip="Grow the border table by N rows (ExpandTableTo + RepointAllReferences)." />
          </Grid>

          <!-- Row 1: Selection bar (mirrors WF AddressPanel) -->
          <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4,0,4,4">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
              <Label Content="Address" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_Border_Address_Input"
                             Name="Border_AddressBox" FormatString="0"
                             Minimum="0" Maximum="4294967295" Width="130"
                             IsEnabled="False" VerticalAlignment="Center" />
              <Label Content="Size:" VerticalAlignment="Center" />
              <Label AutomationProperties.AutomationId="WorldMapImage_Border_BlockSize_Label"
                     Name="Border_BlockSizeLabel"
                     Content="12" VerticalAlignment="Center" />
              <Label Content="Selected Address:" VerticalAlignment="Center" />
              <Label AutomationProperties.AutomationId="WorldMapImage_Border_SelectAddress_Label"
                     Name="Border_SelectAddressLabel"
                     Width="130" VerticalAlignment="Center"
                     FontFamily="Consolas" />
              <Button AutomationProperties.AutomationId="WorldMapImage_Border_Write_Button"
                      Name="Border_WriteButton" Content="Write"
                      Click="BorderWrite_Click" />
            </StackPanel>
          </Border>

          <!-- Row 2 Col 0: AddressList -->
          <controls:AddressListControl AutomationProperties.AutomationId="WorldMapImage_Border_Entry_List"
                                       Grid.Row="2" Grid.Column="0"
                                       Name="Border_EntryList" Margin="4" />

          <!-- Row 2 Col 1: Border fields + preview -->
          <ScrollViewer Grid.Row="2" Grid.Column="1" Margin="4">
            <StackPanel Spacing="6" Margin="6">
              <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">

                <Label Grid.Row="0" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_Border_P0_Label"
                       Content="Image" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_Border_P0_Input"
                               Name="Border_P0Box" FormatString="0"
                               Minimum="0" Maximum="4294967295" Width="170" Margin="0,2" />

                <Label Grid.Row="1" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_Border_P4_Label"
                       Content="AP" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_Border_P4_Input"
                               Name="Border_P4Box" FormatString="0"
                               Minimum="0" Maximum="4294967295" Width="170" Margin="0,2" />

                <Label Grid.Row="2" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_Border_W8_Label"
                       Content="X" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_Border_W8_Input"
                               Name="Border_W8Box" FormatString="0"
                               Minimum="0" Maximum="65535" Width="100" Margin="0,2" />

                <Label Grid.Row="3" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_Border_W10_Label"
                       Content="Y" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="3" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_Border_W10_Input"
                               Name="Border_W10Box" FormatString="0"
                               Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
              </Grid>

              <Label AutomationProperties.AutomationId="WorldMapImage_Border_DrawSample_Label"
                     Content="Draw Example" FontWeight="SemiBold" Margin="0,6,0,0" />
              <Border BorderBrush="Gray" BorderThickness="1" MinHeight="120">
                <controls:GbaImageControl AutomationProperties.AutomationId="WorldMapImage_Border_DrawSample_Image"
                                          Name="BorderDrawSampleImage" />
              </Border>

              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                <Button AutomationProperties.AutomationId="WorldMapImage_Border_Import_Button"
                        Name="BorderImportButton"
                        Content="Import Image"
                        IsEnabled="{Binding CanImportBorder}"
                        Click="BorderImport_Click"
                        ToolTip.Tip="Import a county border image (assembles OAM/AP). Requires a companion _NAME image in the same folder." />
                <Button AutomationProperties.AutomationId="WorldMapImage_Border_Export_Button"
                        Name="BorderExportButton"
                        Content="Export Image"
                        IsEnabled="{Binding CanExportBorder}"
                        Click="BorderExport_Click"
                        ToolTip.Tip="Export the border AP preview to PNG." />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- ============================================================
           Tab 6 - Icon Data (WF tabPage5 "アイコン用のデータ")
           ============================================================ -->
      <TabItem AutomationProperties.AutomationId="WorldMapImage_IconData_Tab" Header="Icon Data">
        <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="240,*">

          <!-- Row 0: Read-config bar.
               #668: migrated to unified EditorTopBar control. List Expand
               kept external. -->
          <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="4"
                ColumnDefinitions="*,Auto">
            <controls:EditorTopBar Grid.Column="0"
                                   Name="IconData_TopBar"
                                   AutomationProperties.AutomationId="WorldMapImage_IconData_TopBar"
                                   ShowSize="False"
                                   StartAddressLabel="Start Address:"
                                   ReadCountLabel="Read Count:"
                                   StartAddressAutomationId="WorldMapImage_IconData_ReadStartAddress_Label"
                                   ReadCountAutomationId="WorldMapImage_IconData_ReadCount_Label"
                                   ReloadAutomationId="WorldMapImage_IconData_Reload_Button"
                                   ReloadRequested="OnIconDataTopBarReloadRequested" />
            <Button Grid.Column="1"
                    AutomationProperties.AutomationId="WorldMapImage_IconData_AddressListExpand_Button"
                    Name="IconData_AddressListExpandButton" Content="List Expand"
                    Click="IconDataListExpand_Click"
                    Margin="4,0,0,0" VerticalAlignment="Center"
                    ToolTip.Tip="Grow the icon-data table by N rows (ExpandTableTo + RepointAllReferences)." />
          </Grid>

          <!-- Row 1: Selection bar -->
          <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4,0,4,4">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
              <Label Content="Address" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="WorldMapImage_IconData_Address_Input"
                             Name="IconData_AddressBox" FormatString="0"
                             Minimum="0" Maximum="4294967295" Width="130"
                             IsEnabled="False" VerticalAlignment="Center" />
              <Label Content="Size:" VerticalAlignment="Center" />
              <Label AutomationProperties.AutomationId="WorldMapImage_IconData_BlockSize_Label"
                     Name="IconData_BlockSizeLabel"
                     Content="16" VerticalAlignment="Center" />
              <Label Content="Selected Address:" VerticalAlignment="Center" />
              <Label AutomationProperties.AutomationId="WorldMapImage_IconData_SelectAddress_Label"
                     Name="IconData_SelectAddressLabel"
                     Width="130" VerticalAlignment="Center"
                     FontFamily="Consolas" />
              <Button AutomationProperties.AutomationId="WorldMapImage_IconData_Write_Button"
                      Name="IconData_WriteButton" Content="Write"
                      Click="IconWrite_Click" />
            </StackPanel>
          </Border>

          <!-- Row 2 Col 0: AddressList -->
          <controls:AddressListControl AutomationProperties.AutomationId="WorldMapImage_IconData_Entry_List"
                                       Grid.Row="2" Grid.Column="0"
                                       Name="IconData_EntryList" Margin="4" />

          <!-- Row 2 Col 1: 12 NUDs with their unique WF row labels -->
          <ScrollViewer Grid.Row="2" Grid.Column="1" Margin="4">
            <StackPanel Spacing="4" Margin="6">
              <Grid ColumnDefinitions="180,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- B0: image sheet number (画像シート番号) -->
                <Label Grid.Row="0" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B0_Label"
                       Content="Image Sheet Number" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="0" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B0_Input"
                               Name="IconData_B0Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B1: 00 Padding (alias for B0..B3 secondary byte) -->
                <Label Grid.Row="1" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B1_Label"
                       Content="00 Padding" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="1" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B1_Input"
                               Name="IconData_B1Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B2: 00 Padding -->
                <Label Grid.Row="2" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B2_Label"
                       Content="00 Padding" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B2_Input"
                               Name="IconData_B2Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B3: 00 Padding -->
                <Label Grid.Row="3" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B3_Label"
                       Content="00 Padding" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="3" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B3_Input"
                               Name="IconData_B3Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- P4: OAMTable entry -->
                <Label Grid.Row="4" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_P4_Label"
                       Content="OAMTable entry" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="4" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_P4_Input"
                               Name="IconData_P4Box" FormatString="0"
                               Minimum="0" Maximum="4294967295" Width="170" Margin="0,2" />

                <!-- B8: Center X -->
                <Label Grid.Row="5" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B8_Label"
                       Content="Center X" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="5" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B8_Input"
                               Name="IconData_B8Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B9: Center Y -->
                <Label Grid.Row="6" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B9_Label"
                       Content="Center Y" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="6" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B9_Input"
                               Name="IconData_B9Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B10: Width -->
                <Label Grid.Row="7" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B10_Label"
                       Content="Width" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="7" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B10_Input"
                               Name="IconData_B10Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B11: Height -->
                <Label Grid.Row="8" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B11_Label"
                       Content="Height" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="8" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B11_Input"
                               Name="IconData_B11Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B12: tcs params?? -->
                <Label Grid.Row="9" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B12_Label"
                       Content="tcs params??" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="9" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B12_Input"
                               Name="IconData_B12Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- B13: ?? -->
                <Label Grid.Row="10" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_B13_Label"
                       Content="??" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="10" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_B13_Input"
                               Name="IconData_B13Box" FormatString="0"
                               Minimum="0" Maximum="255" Width="100" Margin="0,2" />

                <!-- W14: 00 Padding (alias) -->
                <Label Grid.Row="11" Grid.Column="0"
                       AutomationProperties.AutomationId="WorldMapImage_IconData_W14_Label"
                       Content="00 Padding" VerticalAlignment="Center" />
                <NumericUpDown Grid.Row="11" Grid.Column="1"
                               AutomationProperties.AutomationId="WorldMapImage_IconData_W14_Input"
                               Name="IconData_W14Box" FormatString="0"
                               Minimum="0" Maximum="65535" Width="100" Margin="0,2" />
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

    </TabControl>
  </DockPanel>
</UserControl>
