<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.UnitFE7View"
        Title="Units (FE7) (Read-Only)" Width="800" Height="600">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Units (FE7) (Read-Only)" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="NameIdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Decoded Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="DecodedNameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Level:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="LevelLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Base Stats:" VerticalAlignment="Center" FontWeight="Bold" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="BaseStatsLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="HP / STR / SKL:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="StatsLine1Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="SPD / DEF / RES:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="6" Grid.Column="1" Name="StatsLine2Label" VerticalAlignment="Center" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="LCK:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="7" Grid.Column="1" Name="LckLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Growth Rates:" VerticalAlignment="Center" FontWeight="Bold" />
          <TextBlock Grid.Row="8" Grid.Column="1" Text="" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="HP/STR/SKL/SPD:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="9" Grid.Column="1" Name="GrowLine1Label" VerticalAlignment="Center" />
        </Grid>
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="DEF/RES/LCK:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="GrowLine2Label" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
