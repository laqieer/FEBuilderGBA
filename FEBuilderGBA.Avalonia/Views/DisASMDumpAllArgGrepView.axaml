<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.DisASMDumpAllArgGrepView"
        Title="Disassembly Argument Grep" Width="891" Height="757"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock Text="Disassembly Argument Grep" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8" />
    <TextBlock Text="Find where a register is set up just before a call to the target function, and dump the argument-setup block."
               TextWrapping="Wrap" DockPanel.Dock="Top" Margin="0,0,0,12" />

    <Grid DockPanel.Dock="Top" Margin="0,0,0,12" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
      <!-- Target function -->
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Target function:" VerticalAlignment="Center" Margin="0,0,8,6" />
      <TextBox Grid.Row="0" Grid.Column="1"
               AutomationProperties.AutomationId="DisASMDumpAllArgGrep_TargetFunction_Input"
               x:Name="TargetFunctionInput" Width="350" Margin="0,0,0,6"
               HorizontalAlignment="Left"
               Watermark="m4aSongNumStart  or  D01FC" />

      <!-- Register to search -->
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Register to find:" VerticalAlignment="Center" Margin="0,0,8,6" />
      <ComboBox Grid.Row="1" Grid.Column="1"
                AutomationProperties.AutomationId="DisASMDumpAllArgGrep_SearchRegister_Combo"
                x:Name="SearchRegisterCombo" Width="120" Margin="0,0,0,6"
                HorizontalAlignment="Left"
                ItemsSource="{Binding RegisterItems}"
                SelectedIndex="{Binding SearchRegisterIndex}" />

      <!-- Allowed rows -->
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Allowed rows:" VerticalAlignment="Center" Margin="0,0,8,6" />
      <NumericUpDown Grid.Row="2" Grid.Column="1"
                     AutomationProperties.AutomationId="DisASMDumpAllArgGrep_AllowedRows_Input"
                     x:Name="AllowedRowsInput" Width="120" Margin="0,0,0,6"
                     HorizontalAlignment="Left"
                     FormatString="0"
                     Minimum="{Binding AllowedRowsMinimum}"
                     Maximum="{Binding AllowedRowsMaximum}"
                     Value="{Binding AllowedRows}" />
    </Grid>

    <StackPanel Orientation="Vertical" Spacing="4" DockPanel.Dock="Top" Margin="0,0,0,8">
      <CheckBox AutomationProperties.AutomationId="DisASMDumpAllArgGrep_HideFunctionCalls_Check"
                x:Name="HideFunctionCallsCheck"
                IsChecked="{Binding HideFunctionCalls}"
                Content="Do not include the function-call line in the results" />
      <CheckBox AutomationProperties.AutomationId="DisASMDumpAllArgGrep_HideUnknownArgs_Check"
                x:Name="HideUnknownArgsCheck"
                IsChecked="{Binding HideUnknownArgs}"
                Content="Show only calls whose argument purpose is unknown" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Top" Margin="0,0,0,8">
      <Button AutomationProperties.AutomationId="DisASMDumpAllArgGrep_Search_Button" Content="Search" Width="80" Click="Search_Click" />
      <Button AutomationProperties.AutomationId="DisASMDumpAllArgGrep_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>

    <TextBox AutomationProperties.AutomationId="DisASMDumpAllArgGrep_Results_Input" x:Name="ResultsBox" IsReadOnly="True" AcceptsReturn="True"
             FontFamily="Consolas, Courier New, monospace" FontSize="12"
             TextWrapping="NoWrap" />
  </DockPanel>
  </ScrollViewer>
</Window>
