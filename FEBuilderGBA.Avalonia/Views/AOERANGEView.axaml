<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.AOERANGEView"
        Title="Area of Effect Range" Width="800" Height="450">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Area of Effect Range" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Width:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="WidthBox" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Height:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="HeightBox" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Center X:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="CenterXBox" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Center Y:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="CenterYBox" Minimum="0" Maximum="255" Margin="0,4" />
        </Grid>

        <TextBlock Text="Specifies the AoE attack range mask. Center point is where the attack detonates. Set attacked tiles to 1, others to 0." TextWrapping="Wrap" Foreground="Gray" Margin="0,8" />

        <Button Name="WriteButton" Content="Write" HorizontalAlignment="Right" Margin="0,8" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
