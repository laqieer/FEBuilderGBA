<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.OpenLastSelectedFileView"
        Title="Open Last Selected File" Width="760" Height="240"
        SizeToContent="Manual">
  <ScrollViewer Margin="8">
    <StackPanel Spacing="12" Margin="8">
      <TextBlock Text="Open Last Selected File" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="Last selected file:" />
      <TextBox AutomationProperties.AutomationId="OpenLastSelectedFile_Path_Input" Name="PathTextBox"
               IsReadOnly="True" Watermark="(no file selected)" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button AutomationProperties.AutomationId="OpenLastSelectedFile_Open_Button" Name="OpenButton"
                Content="Open file" Click="Open_Click" IsEnabled="False" />
        <Button AutomationProperties.AutomationId="OpenLastSelectedFile_Folder_Button" Name="FolderButton"
                Content="Open containing folder" Click="Folder_Click" IsEnabled="False" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
