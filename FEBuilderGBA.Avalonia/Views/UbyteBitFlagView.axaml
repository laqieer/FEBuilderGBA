<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UbyteBitFlagView"
        Title="Byte Bit Flags (8-bit)" Width="340" Height="380"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="8">
    <TextBlock Text="Byte Bit Flags (8-bit)" FontSize="18" FontWeight="Bold" />
    <TextBlock Name="ValueLabel" Text="Value: 0x00" FontSize="14" FontFamily="Consolas" Margin="0,4,0,8" />
    <CheckBox Name="Bit0Box" Content="Bit 0 (0x01)" />
    <CheckBox Name="Bit1Box" Content="Bit 1 (0x02)" />
    <CheckBox Name="Bit2Box" Content="Bit 2 (0x04)" />
    <CheckBox Name="Bit3Box" Content="Bit 3 (0x08)" />
    <CheckBox Name="Bit4Box" Content="Bit 4 (0x10)" />
    <CheckBox Name="Bit5Box" Content="Bit 5 (0x20)" />
    <CheckBox Name="Bit6Box" Content="Bit 6 (0x40)" />
    <CheckBox Name="Bit7Box" Content="Bit 7 (0x80)" />
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
  </StackPanel>
</Window>
