<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.UbyteBitFlagView"
        Title="Byte Bit Flags (8-bit)" Width="708" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="10,9,10,10">
    <!-- Top row: MESSAGE label + Apply button (WinForms MESSAGE 676x40 + ApplyButton 181x40) -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Height="40">
        <TextBlock Name="MESSAGE" Text="Byte Bit Flags (8-bit)"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Button Grid.Column="1" Name="ApplyButton" Content="Apply" Width="181" Height="40"
              Margin="8,0,0,0" Click="OK_Click" />
    </Grid>
    <!-- Main panel: GroupBox with hex NumericUpDown + 8 checkboxes (WinForms panel8 674x317) -->
    <Border BorderBrush="Gray" BorderThickness="1" Padding="7,0,7,7">
      <StackPanel Spacing="2">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
          <TextBlock Text="Hex:" VerticalAlignment="Center" />
          <NumericUpDown Name="B40" Width="80" Height="25" Minimum="0" Maximum="255" Value="0" />
        </StackPanel>
        <CheckBox Name="Bit0Box" Content="Bit 0 (0x01)" />
        <CheckBox Name="Bit1Box" Content="Bit 1 (0x02)" />
        <CheckBox Name="Bit2Box" Content="Bit 2 (0x04)" />
        <CheckBox Name="Bit3Box" Content="Bit 3 (0x08)" />
        <CheckBox Name="Bit4Box" Content="Bit 4 (0x10)" />
        <CheckBox Name="Bit5Box" Content="Bit 5 (0x20)" />
        <CheckBox Name="Bit6Box" Content="Bit 6 (0x40)" />
        <CheckBox Name="Bit7Box" Content="Bit 7 (0x80)" />
      </StackPanel>
    </Border>
  </DockPanel>
  </ScrollViewer>
</Window>
