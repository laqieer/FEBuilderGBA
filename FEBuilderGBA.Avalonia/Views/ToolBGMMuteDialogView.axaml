<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolBGMMuteDialogView"
        Title="BGM Mute Settings"
        Width="583" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="15,20,15,15">
    <!-- Track info label -->
    <TextBlock Text="{Binding TrackInfoText}" TextWrapping="Wrap"
               Margin="0,0,0,20" />
    <!-- Toggle mute button -->
    <Button Content="{Binding ToggleButtonText}" Height="42"
            HorizontalAlignment="Stretch" Click="Toggle_Click" />
    <!-- Play only this track button -->
    <Button Content="Play only this track" Height="42"
            HorizontalAlignment="Stretch" Margin="0,19,0,0"
            Click="OnlyPlay_Click" />
    <!-- Play all tracks button -->
    <Button Content="Play all tracks" Height="42"
            HorizontalAlignment="Stretch" Margin="0,19,0,0"
            Click="PlayAll_Click" />
  </StackPanel>
  </ScrollViewer>
</Window>
