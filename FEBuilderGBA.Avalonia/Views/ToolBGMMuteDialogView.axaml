<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolBGMMuteDialogView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="15,20,15,15">
    <!-- Track info label -->
    <TextBlock Text="{Binding TrackInfoText}" TextWrapping="Wrap"
               Margin="0,0,0,20" />
    <!-- Toggle mute button -->
    <Button AutomationProperties.AutomationId="ToolBGMMuteDialog_Toggle_Button" Content="{Binding ToggleButtonText}" Height="42"
            HorizontalAlignment="Stretch" Click="Toggle_Click" />
    <!-- Play only this track button -->
    <Button AutomationProperties.AutomationId="ToolBGMMuteDialog_lyPlay_Button" Content="Play only this track" Height="42"
            HorizontalAlignment="Stretch" Margin="0,19,0,0"
            Click="OnlyPlay_Click" />
    <!-- Play all tracks button -->
    <Button AutomationProperties.AutomationId="ToolBGMMuteDialog_PlayAll_Button" Content="Play all tracks" Height="42"
            HorizontalAlignment="Stretch" Margin="0,19,0,0"
            Click="PlayAll_Click" />
  </StackPanel>
  </ScrollViewer>
</UserControl>
