<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SupportTalkFE6View">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SupportTalkFE6_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Talk (FE6)" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SupportTalkFE6_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360 final: SupportPartner1/2 (Unit ID) — IdFieldControl with FE6
               unit-name resolver. The canonical original-issue example. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalkFE6_SupportPartner1Nud_Input"
                                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="SupportPartner1Nud"
                                   Label="Support Partner 1:"
                                   Maximum="255"
                                   JumpRequested="SupportPartner1_Jump"
                                   PickRequested="SupportPartner1_Pick"
                                   ValueChanged="SupportPartner1_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalkFE6_SupportPartner2Nud_Input"
                                   Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="SupportPartner2Nud"
                                   Label="Support Partner 2:"
                                   Maximum="255"
                                   JumpRequested="SupportPartner2_Jump"
                                   PickRequested="SupportPartner2_Pick"
                                   ValueChanged="SupportPartner2_ValueChanged" />

          <!-- #360 final: TextId C/B/A — IdFieldControl ShowPick=False + inline preview. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalkFE6_TextCNud_Input"
                                   Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextCNud"
                                   Label="C Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextC_Jump"
                                   ValueChanged="TextC_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalkFE6_TextBNud_Input"
                                   Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextBNud"
                                   Label="B Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextB_Jump"
                                   ValueChanged="TextB_ValueChanged" />

          <controls:IdFieldControl AutomationProperties.AutomationId="SupportTalkFE6_TextANud_Input"
                                   Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                   Margin="0,2"
                                   Name="TextANud"
                                   Label="A Support Text:"
                                   Maximum="65535"
                                   ShowPick="False"
                                   JumpRequested="TextA_Jump"
                                   ValueChanged="TextA_ValueChanged" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Padding 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SupportTalkFE6_Padding1Nud_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="Padding1Nud" Minimum="0" Maximum="255" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Padding 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SupportTalkFE6_Padding2Nud_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="Padding2Nud" Minimum="0" Maximum="255" Margin="0,2" />
        </Grid>

        <Button AutomationProperties.AutomationId="SupportTalkFE6_Write_Button" Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,12,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
