<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SupportTalkFE6View"
        Title="Support Talk (FE6)" Width="1279" Height="600">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Talk (FE6)" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="B0 Unit 1 ID:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="Unit1IdNud" Minimum="0" Maximum="255" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="B1 Unit 2 ID:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="Unit2IdNud" Minimum="0" Maximum="255" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="W4 Text C:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="TextCNud" Minimum="0" Maximum="65535" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="W8 Text B:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="TextBNud" Minimum="0" Maximum="65535" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="W12 Text A:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="TextANud" Minimum="0" Maximum="65535" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="00:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="B14Nud" Minimum="0" Maximum="255" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="00:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="B15Nud" Minimum="0" Maximum="255" Margin="0,2" />
        </Grid>

        <Button Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,12,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
