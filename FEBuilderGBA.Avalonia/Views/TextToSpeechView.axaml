<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.TextToSpeechView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Text to Speech" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <TextBlock DockPanel.Dock="Top" Text="Enter or paste text to have it read aloud using the system TTS engine." Foreground="Gray" Margin="0,0,0,8" />
    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,8,0,0">
      <TextBlock AutomationProperties.AutomationId="TextToSpeech_Status_Label" Name="StatusLabel" Text="Ready" Foreground="Gray" />
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button AutomationProperties.AutomationId="TextToSpeech_Speak_Button" Content="Speak" Width="80" Click="Speak_Click" />
        <Button AutomationProperties.AutomationId="TextToSpeech_Close_Button" Content="Close" Width="80" Click="Close_Click" />
      </StackPanel>
    </StackPanel>
    <TextBox AutomationProperties.AutomationId="TextToSpeech_InputText_Input" Name="InputTextBox" AcceptsReturn="True" Watermark="Enter text here..." />
  </DockPanel>
  </ScrollViewer>
</UserControl>
