<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolWorkSupport_SelectUPSView"
        Title="Open UPS"
        Width="1190" Height="255"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Border Margin="10" BorderBrush="Gray" BorderThickness="1" Padding="10">
    <StackPanel>
      <!-- Instruction label -->
      <TextBlock Text="Select an unmodified ROM to open the UPS patch." Height="29"
                 VerticalAlignment="Center" />
      <!-- ROM selection row -->
      <Grid ColumnDefinitions="196,*,130" Margin="0,12,0,0">
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
                Height="31" VerticalAlignment="Center">
          <TextBlock Text="Vanilla ROM" HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
        <TextBox Grid.Column="1" Text="{Binding OriginalFilename}"
                 Height="25" Margin="8,0,8,0" />
        <Button Grid.Column="2" Content="Select File" Width="130" Height="31"
                Click="Browse_Click" />
      </Grid>
      <!-- Apply button -->
      <Button Content="Open UPS Patch" Height="32"
              HorizontalAlignment="Stretch" Margin="0,16,0,0"
              Click="ApplyUPS_Click" />
    </StackPanel>
  </Border>
</Window>
