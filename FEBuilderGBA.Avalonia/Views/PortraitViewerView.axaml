<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.PortraitViewerView"
        Title="Portrait Editor" Width="789" Height="700"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="PortraitViewer_Portrait_List" Grid.Column="0" Name="PortraitList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Portrait Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="PortraitViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="PortraitViewer_ImgPtr_Input" Grid.Row="1" Grid.Column="1" Name="ImgPtrBox" Width="120" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Map Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="PortraitViewer_MapPtr_Input" Grid.Row="2" Grid.Column="1" Name="MapPtrBox" Width="120" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="PortraitViewer_PalPtr_Input" Grid.Row="3" Grid.Column="1" Name="PalPtrBox" Width="120" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Mouth:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="PortraitViewer_D12_Input" Grid.Row="4" Grid.Column="1" Name="D12Box" Width="120" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Class Card:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="PortraitViewer_D16_Input" Grid.Row="5" Grid.Column="1" Name="D16Box" Width="120" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Mouth X:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B20_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="B20Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Mouth Y:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B21_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="B21Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Eye X:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B22_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="B22Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Eye Y:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B23_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="B23Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="State:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B24_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="B24Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Padding (B25):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B25_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="B25Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="Padding (B26):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B26_Input" FormatString="0" Grid.Row="12" Grid.Column="1" Name="B26Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="13" Grid.Column="0" Text="Padding (B27):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="PortraitViewer_B27_Input" FormatString="0" Grid.Row="13" Grid.Column="1" Name="B27Box" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="PortraitViewer_Write_Button" Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="PortraitViewer_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
          <Button AutomationProperties.AutomationId="PortraitViewer_FERepo_Button" Content="FE-Repo" Click="FERepo_Click"
                  ToolTip.Tip="Import from the FE-Repo Portrait Repository folder" />
          <Button AutomationProperties.AutomationId="PortraitViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="PortraitViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" />
          <Button AutomationProperties.AutomationId="PortraitViewer_ImportPal_Button" Content="Import PAL" Click="ImportPal_Click" />
        </StackPanel>

        <Grid ColumnDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
          <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="Main Portrait" FontWeight="SemiBold" Margin="0,0,0,4" />
            <controls:GbaImageControl AutomationProperties.AutomationId="PortraitViewer_MainPortrait_Image" Name="MainPortraitImage" />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,16,0">
            <TextBlock Text="Mini Portrait" FontWeight="SemiBold" Margin="0,0,0,4" />
            <controls:GbaImageControl AutomationProperties.AutomationId="PortraitViewer_MapPortrait_Image" Name="MapPortraitImage" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Class Card" FontWeight="SemiBold" Margin="0,0,0,4" />
            <controls:GbaImageControl AutomationProperties.AutomationId="PortraitViewer_ClassPortrait_Image" Name="ClassPortraitImage" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
