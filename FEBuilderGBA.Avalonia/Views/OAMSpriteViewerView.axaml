<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.OAMSpriteViewerView"
        Title="OAM Sprite Viewer" Width="1100" Height="750"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <!-- Address list -->
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="OAM Sprite Viewer" FontSize="18" FontWeight="Bold" />
        <TextBlock Name="StatusLabel" Text="Select an animation to view OAM sprites."
                   Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap" />

        <!-- Section selector -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
          <TextBlock Text="Section:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <ComboBox Name="SectionCombo" Width="280" />
        </StackPanel>

        <!-- Frame navigation -->
        <Border Name="FrameNavPanel" IsVisible="False"
                BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4"
                Margin="0,4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Frame:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <NumericUpDown FormatString="0" Name="FrameUpDown" Minimum="0" Maximum="0" Value="0" Width="100" />
              <Button Content="Prev" Click="PrevFrame_Click" Padding="8,4" />
              <Button Content="Next" Click="NextFrame_Click" Padding="8,4" />
            </StackPanel>
            <TextBlock Name="FrameInfoLabel" FontSize="12" Foreground="Gray" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Rendered frame -->
        <TextBlock Text="Rendered Frame:" FontWeight="SemiBold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="4" CornerRadius="4"
                Background="#20000000" MinHeight="160" MinWidth="240">
          <controls:GbaImageControl Name="FrameImageControl" />
        </Border>

        <!-- Tile sheet reference -->
        <TextBlock Text="Tile Sheet (Reference):" FontWeight="SemiBold" Margin="0,12,0,2" />
        <TextBlock Name="TileSheetInfoLabel" FontSize="12" Foreground="Gray" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="4" CornerRadius="4"
                Background="#20000000" Name="TileSheetPanel" IsVisible="False">
          <controls:GbaImageControl Name="TileSheetImage" />
        </Border>

        <!-- Export -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
          <Button Content="Export Frame PNG" Click="ExportFrame_Click" Padding="8,4" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
