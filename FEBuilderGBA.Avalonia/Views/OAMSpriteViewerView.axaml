<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.OAMSpriteViewerView">
  <Grid ColumnDefinitions="250,*">
    <!-- Address list -->
    <controls:AddressListControl AutomationProperties.AutomationId="OAMSpriteViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="OAM Sprite Viewer" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="OAMSpriteViewer_Status_Label" Name="StatusLabel" Text="Select an animation to view OAM sprites."
                   Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap" />

        <!-- Section selector -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
          <TextBlock Text="Section:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <ComboBox AutomationProperties.AutomationId="OAMSpriteViewer_Section_Combo" Name="SectionCombo" Width="280" />
        </StackPanel>

        <!-- Frame navigation -->
        <Border Name="FrameNavPanel" IsVisible="False"
                BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4"
                Margin="0,4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Frame:" VerticalAlignment="Center" FontWeight="SemiBold" />
              <NumericUpDown AutomationProperties.AutomationId="OAMSpriteViewer_FrameUpDown_Input" FormatString="0" Name="FrameUpDown" Minimum="0" Maximum="0" Value="0" Width="100" />
              <Button AutomationProperties.AutomationId="OAMSpriteViewer_PrevFrame_Button" Content="Prev" Click="PrevFrame_Click" Padding="8,4" />
              <Button AutomationProperties.AutomationId="OAMSpriteViewer_NextFrame_Button" Content="Next" Click="NextFrame_Click" Padding="8,4" />
            </StackPanel>
            <TextBlock AutomationProperties.AutomationId="OAMSpriteViewer_FrameInfo_Label" Name="FrameInfoLabel" FontSize="12" Foreground="Gray" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Rendered frame -->
        <TextBlock Text="Rendered Frame:" FontWeight="SemiBold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="4" CornerRadius="4"
                Background="#20000000" MinHeight="160" MinWidth="240">
          <controls:GbaImageControl AutomationProperties.AutomationId="OAMSpriteViewer_FrameImage_Image" Name="FrameImageControl" />
        </Border>

        <!-- Tile sheet reference -->
        <TextBlock Text="Tile Sheet (Reference):" FontWeight="SemiBold" Margin="0,12,0,2" />
        <TextBlock AutomationProperties.AutomationId="OAMSpriteViewer_TileSheetInfo_Label" Name="TileSheetInfoLabel" FontSize="12" Foreground="Gray" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="4" CornerRadius="4"
                Background="#20000000" Name="TileSheetPanel" IsVisible="False">
          <controls:GbaImageControl AutomationProperties.AutomationId="OAMSpriteViewer_TileSheet_Image" Name="TileSheetImage" />
        </Border>

        <!-- Export -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
          <Button AutomationProperties.AutomationId="OAMSpriteViewer_ExportFrame_Button" Content="Export Frame PNG" Click="ExportFrame_Click" Padding="8,4" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
