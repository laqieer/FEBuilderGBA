<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.RAMRewriteToolView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="RAM Rewrite Tool" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="RAMRewriteTool_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel Spacing="12">
      <Border BorderBrush="Orange" BorderThickness="2" Padding="16" Background="{DynamicResource EmulatorWarningBackgroundBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="Platform Notice" FontWeight="Bold" FontSize="14" Foreground="DarkOrange" />
          <TextBlock TextWrapping="Wrap"
                     Text="RAM rewriting requires Windows P/Invoke to access emulator process memory and is not available in the cross-platform Avalonia version." />
          <TextBlock TextWrapping="Wrap" Foreground="Gray"
                     Text="Please use the Windows (WinForms) version of FEBuilderGBA for this functionality." />
        </StackPanel>
      </Border>
      <Grid RowDefinitions="Auto,8,Auto" ColumnDefinitions="Auto,8,*" IsEnabled="False">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
        <TextBox AutomationProperties.AutomationId="RAMRewriteTool_AddressText_Input" Grid.Row="0" Grid.Column="2" Name="AddressTextBox" Watermark="e.g. 0x02000000" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Value:" VerticalAlignment="Center" />
        <TextBox AutomationProperties.AutomationId="RAMRewriteTool_ValueText_Input" Grid.Row="2" Grid.Column="2" Name="ValueTextBox" Watermark="e.g. 0xFF" />
      </Grid>
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</UserControl>
