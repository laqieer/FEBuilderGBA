<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.UnitCustomBattleAnimeView"
        Title="Custom Battle Animation" Width="1314" Height="521"
        SizeToContent="WidthAndHeight">
  <!--
    #1412: TWO-level pointer-table navigation mirroring WinForms UnitCustomBattleAnimeForm.
      - Column 0: ClassList — the FE7 pointer TABLE (one u32 pointer per class)
      - Column 1: EntryList — the inner weapon-anime records (4 bytes: B0/B1/W2) of the
                  selected class, reached by a SECOND p32 dereference
      - Column 2: Editor pane — per-record edit (writes ONLY inner records, never a table slot)
  -->
  <Grid ColumnDefinitions="280,250,*">

    <!-- Column 0: pointer table (one entry per class) -->
    <DockPanel Grid.Column="0" Margin="4">
      <TextBlock DockPanel.Dock="Top" Text="Class (pointer table)" FontWeight="Bold" Margin="0,0,0,4" />
      <controls:AddressListControl AutomationProperties.AutomationId="UnitCustomBattleAnime_Class_List"
                                   Name="ClassList" />
    </DockPanel>

    <!-- Column 1: inner weapon-anime records for the selected class -->
    <DockPanel Grid.Column="1" Margin="4">
      <TextBlock DockPanel.Dock="Top" Text="Weapon Animations" FontWeight="Bold" Margin="0,0,0,4" />
      <controls:AddressListControl AutomationProperties.AutomationId="UnitCustomBattleAnime_Entry_List"
                                   Name="EntryList" />
    </DockPanel>

    <ScrollViewer Grid.Column="2" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Custom Battle Animation" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="UnitCustomBattleAnime_ClassName_Label"
                   Name="ClassNameLabel" FontStyle="Italic" Foreground="Gray" />

        <Grid ColumnDefinitions="160,200" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="UnitCustomBattleAnime_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Weapon Type:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="UnitCustomBattleAnime_WeaponType_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="WeaponTypeBox" Minimum="0" Maximum="255" Width="180" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Special:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="UnitCustomBattleAnime_Special_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="SpecialBox" Minimum="0" Maximum="255" Width="180" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Animation Number:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown AutomationProperties.AutomationId="UnitCustomBattleAnime_AnimeNumber_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="AnimeNumberBox" Minimum="0" Maximum="65535" Width="180" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="UnitCustomBattleAnime_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>

        <TextBlock AutomationProperties.AutomationId="UnitCustomBattleAnime_Status_Label"
                   Name="StatusLabel" Margin="0,12,0,0" Foreground="Gray" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
