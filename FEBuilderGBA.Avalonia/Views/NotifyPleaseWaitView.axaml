<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.NotifyPleaseWaitView"
        Title="{Binding Title}"
        Width="420" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        SizeToContent="WidthAndHeight">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="24,20,24,16">
    <!-- Title -->
    <TextBlock Grid.Row="0" Text="{Binding Title}"
               FontSize="16" FontWeight="SemiBold"
               Margin="0,0,0,12" />

    <!-- Progress bar -->
    <ProgressBar Grid.Row="1"
                 IsIndeterminate="{Binding IsIndeterminate}"
                 Value="{Binding PercentComplete}"
                 Minimum="0" Maximum="100"
                 Height="20"
                 Margin="0,0,0,8" />

    <!-- Status message -->
    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
               TextWrapping="Wrap"
               Foreground="Gray"
               Margin="0,0,0,12" />

    <!-- Cancel button -->
    <Button Grid.Row="3" Content="Cancel"
            HorizontalAlignment="Right"
            IsVisible="{Binding IsCancelVisible}"
            Click="Cancel_Click"
            MinWidth="80" />
  </Grid>
</Window>
