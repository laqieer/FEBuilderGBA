<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SupportTalkFE7View"
        Title="Support Talk (FE7) (Read-Only)" Width="1279" Height="708">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Support Talk (FE7) (Read-Only)" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Unit 1 ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="Unit1IdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit 2 ID:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="Unit2IdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Text C:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="TextCLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Text B:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="TextBLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Text A:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="5" Grid.Column="1" Name="TextALabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Extra:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="6" Grid.Column="1" Name="ExtraLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
