<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.MapEditorView">
  <Grid Name="MapEditorRootGrid" ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="MapEditor_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <!-- #1998: the right column is a viewport-constrained 2-row grid — an upper
         Auto row holding a bounded (horizontally + vertically) Auto ScrollViewer
         for the info/toolbars/palette/tile-editor controls, and a remaining "*"
         row pinning MapCanvasPanel (with its own independent inner scroller) at
         >= 240px. MapEditorView.axaml.cs caps MapUpperControlsScroller.MaxHeight
         from the arranged height of this grid so a compact browser viewport
         scrolls the controls instead of pushing the map canvas off-screen or
         shrinking it below a usable size. -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="4" Name="MapEditorRightColumnGrid">
      <ScrollViewer Grid.Row="0" Name="MapUpperControlsScroller"
                    HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <StackPanel Name="MapUpperControlsPanel">
      <!-- Info panel -->
      <StackPanel Name="MapEditorInfoPanel" Spacing="4" Margin="8,4,8,4">
        <TextBlock Text="Visual Map Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="MapEditor_MapInfo_Label" Name="MapInfoLabel" TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace" FontSize="12" />
        <StackPanel Orientation="Horizontal" Spacing="8" Name="MapNavigationToolbar">
          <TextBlock Text="Zoom:" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="MapEditor_ZoomInBtn_Button" Name="ZoomInBtn" Content="+" Width="30" />
          <TextBlock AutomationProperties.AutomationId="MapEditor_Zoom_Label" Name="ZoomLabel" Text="1x" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="MapEditor_ZoomOutBtn_Button" Name="ZoomOutBtn" Content="-" Width="30" />
          <CheckBox AutomationProperties.AutomationId="MapEditor_PaintMode_Check" Name="PaintModeCheck" Content="Paint Mode" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0" />
          <TextBlock Text="(click palette to pick a chipset, then click map to paint)" VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
        </StackPanel>
        <StackPanel Spacing="4" Name="MapCommandToolbar">
          <StackPanel Orientation="Horizontal" Spacing="8" Name="MapCsvCommandToolbar">
            <Button AutomationProperties.AutomationId="MapEditor_ExportCsv_Button"
                    Name="ExportCsvButton"
                    Content="Export Map (CSV)"
                    VerticalAlignment="Center" />
            <Button AutomationProperties.AutomationId="MapEditor_ImportCsv_Button"
                    Name="ImportCsvButton"
                    Content="Import Map (CSV)"
                    VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Name="MapTmxCommandToolbar">
            <Button AutomationProperties.AutomationId="MapEditor_ExportTmx_Button"
                    Name="ExportTmxButton"
                    Content="Export Map (Tiled)"
                    ToolTip.Tip="Export the map as a Tiled project (.tmx XML or .tmj JSON) plus its .tsx tileset and chipset .png"
                    VerticalAlignment="Center" />
            <Button AutomationProperties.AutomationId="MapEditor_ImportTmx_Button"
                    Name="ImportTmxButton"
                    Content="Import Map (Tiled)"
                    ToolTip.Tip="Import a Tiled map (.tmx XML or .tmj JSON) onto the current map"
                    VerticalAlignment="Center" />
            <Button AutomationProperties.AutomationId="MapEditor_ResizeMap_Button"
                    Name="ResizeMapButton"
                    Content="Resize Map…"
                    VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Name="MapRandomCommandToolbar">
            <Button AutomationProperties.AutomationId="MapEditor_GenerateRandomMap_Button"
                    Name="GenerateRandomMapButton"
                    Content="Generate Random Map"
                    VerticalAlignment="Center" />
            <Button AutomationProperties.AutomationId="MapEditor_CancelRandomMap_Button"
                    Name="CancelRandomMapButton"
                    Content="Cancel"
                    IsEnabled="False"
                    VerticalAlignment="Center" />
            <Button AutomationProperties.AutomationId="MapEditor_MapTileset_Button"
                    Name="MapTilesetButton"
                    Content="Map Tileset…"
                    ToolTip.Tip="Map the current tileset to an external FEMapCreator tileset for one-click random-map generation"
                    VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Name="MapRandomSeedToolbar">
            <Label AutomationProperties.AutomationId="MapEditor_RandomMapSeed_Label"
                   Name="RandomMapSeedLabel"
                   Content="Seed:"
                   Target="{Binding #RandomMapSeedTextBox}"
                   Padding="0"
                   VerticalAlignment="Center" />
            <TextBox AutomationProperties.AutomationId="MapEditor_RandomMapSeedText_Input"
                     Name="RandomMapSeedTextBox"
                     Width="110"
                     FontFamily="Consolas,Courier New,monospace" />
            <Button AutomationProperties.AutomationId="MapEditor_RandomizeSeedBtn_Button"
                    Name="RandomizeSeedButton"
                    Content="Randomize"
                    VerticalAlignment="Center" />
            <TextBlock AutomationProperties.AutomationId="MapEditor_RandomMapStatus_Label"
                       Name="RandomMapStatusLabel"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="11"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="Gray" />
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- Chipset palette panel (first slice of #658) -->
      <Border Name="TilePalettePanel" BorderBrush="Gray" BorderThickness="1" Margin="8,4,8,4" Padding="8"
              Background="{DynamicResource MapEditorToolbarBrush}" CornerRadius="4">
        <ThemeVariantScope Name="TilePaletteThemeScope" RequestedThemeVariant="Dark">
          <ThemeVariantScope.Styles>
            <Style Selector="TextBlock">
              <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            </Style>
          </ThemeVariantScope.Styles>
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Tile Palette" FontWeight="SemiBold" VerticalAlignment="Center" />
              <TextBlock AutomationProperties.AutomationId="MapEditor_ChipsetInfo_Label" Name="ChipsetInfoLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12" VerticalAlignment="Center" Text="No chipset selected" />
            </StackPanel>
            <Border BorderBrush="Gray" BorderThickness="1" Background="{DynamicResource MapEditorCanvasBrush}" Height="180">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <!-- Border with transparent background catches pointer events
                     anywhere over the palette grid, even on transparent chipset pixels. -->
                <Border Background="Transparent" Name="TilePaletteHitArea">
                  <Image AutomationProperties.AutomationId="MapEditor_TilePalette_Image"
                         Name="TilePaletteImage"
                         Stretch="None"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         RenderOptions.BitmapInterpolationMode="None" />
                </Border>
              </ScrollViewer>
            </Border>
          </StackPanel>
        </ThemeVariantScope>
      </Border>

      <!-- Tile editing panel -->
      <Border Name="TileEditorPanel" BorderBrush="Gray" BorderThickness="1" Margin="8,4,8,4" Padding="8"
              Background="{DynamicResource MapEditorToolbarBrush}" CornerRadius="4">
        <ThemeVariantScope Name="TileEditorThemeScope" RequestedThemeVariant="Dark">
          <ThemeVariantScope.Styles>
            <Style Selector="TextBlock">
              <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            </Style>
          </ThemeVariantScope.Styles>
          <StackPanel Spacing="4">
            <TextBlock Text="Tile Editor (click on map to select)" FontWeight="SemiBold" />
            <TextBlock AutomationProperties.AutomationId="MapEditor_TileInfo_Label" Name="TileInfoLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12"
                       Text="No tile selected" />
            <StackPanel Orientation="Horizontal" Spacing="8" Name="TileEditPanel" IsVisible="false">
              <TextBlock Text="Tile ID (hex):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapEditor_TileIdText_Input" Name="TileIdTextBox" Width="80" FontFamily="Consolas,Courier New,monospace" />
              <Button AutomationProperties.AutomationId="MapEditor_WriteTileBtn_Button" Name="WriteTileBtn" Content="Write Tile" />
              <Button AutomationProperties.AutomationId="MapEditor_RefreshMapBtn_Button" Name="RefreshMapBtn" Content="Refresh Map" />
            </StackPanel>
          </StackPanel>
        </ThemeVariantScope>
      </Border>
      </StackPanel>
      </ScrollViewer>

      <!-- Map image in scrollable area -->
      <Border Grid.Row="1" Name="MapCanvasPanel" MinHeight="240" BorderBrush="Gray" BorderThickness="1"
              Background="{DynamicResource MapEditorCanvasBrush}" Margin="8,0,8,8">
        <ThemeVariantScope Name="MapCanvasThemeScope" RequestedThemeVariant="Dark">
          <ScrollViewer Name="MapCanvasScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <controls:GbaImageControl AutomationProperties.AutomationId="MapEditor_MapImage_Image"
                                      Name="MapImageControl" />
          </ScrollViewer>
        </ThemeVariantScope>
      </Border>
    </Grid>
  </Grid>
</UserControl>
