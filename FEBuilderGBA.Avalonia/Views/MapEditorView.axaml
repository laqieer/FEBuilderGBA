<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MapEditorView"
        Title="Visual Map Editor" Width="1100" Height="750"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="4">
      <!-- Info panel -->
      <StackPanel Grid.Row="0" Spacing="4" Margin="8,4,8,4">
        <TextBlock Text="Visual Map Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock Name="MapInfoLabel" TextWrapping="Wrap" FontFamily="Consolas,Courier New,monospace" FontSize="12" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Zoom:" VerticalAlignment="Center" />
          <Button Name="ZoomInBtn" Content="+" Width="30" />
          <TextBlock Name="ZoomLabel" Text="1x" VerticalAlignment="Center" />
          <Button Name="ZoomOutBtn" Content="-" Width="30" />
        </StackPanel>
      </StackPanel>

      <!-- Tile editing panel -->
      <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="8,4,8,4" Padding="8"
              Background="#FF2A2A2A" CornerRadius="4">
        <StackPanel Spacing="4">
          <TextBlock Text="Tile Editor (click on map to select)" FontWeight="SemiBold" />
          <TextBlock Name="TileInfoLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12"
                     Text="No tile selected" />
          <StackPanel Orientation="Horizontal" Spacing="8" Name="TileEditPanel" IsVisible="false">
            <TextBlock Text="Tile ID (hex):" VerticalAlignment="Center" />
            <TextBox Name="TileIdTextBox" Width="80" FontFamily="Consolas,Courier New,monospace" />
            <Button Name="WriteTileBtn" Content="Write Tile" />
            <Button Name="RefreshMapBtn" Content="Refresh Map" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Map image in scrollable area -->
      <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Background="#FF202020" Margin="8,0,8,8">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <controls:GbaImageControl Name="MapImageControl" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
