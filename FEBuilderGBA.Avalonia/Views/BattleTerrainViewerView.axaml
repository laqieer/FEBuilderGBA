<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.BattleTerrainViewerView"
        Title="Battle Terrain Editor" Width="1251" Height="811">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Battle Terrain Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Terrain Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="TerrainNameLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Byte 0:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B0Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Byte 1:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B1Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Byte 2:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="B2Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Byte 3:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="B3Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="6" Grid.Column="0" Text="Byte 4:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="B4Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="7" Grid.Column="0" Text="Byte 5:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="B5Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="8" Grid.Column="0" Text="Byte 6:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="B6Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="9" Grid.Column="0" Text="Byte 7:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="B7Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="10" Grid.Column="0" Text="Byte 8:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="B8Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="11" Grid.Column="0" Text="Byte 9:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="1" Name="B9Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="12" Grid.Column="0" Text="Byte 10:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="1" Name="B10Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="13" Grid.Column="0" Text="Byte 11:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="1" Name="B11Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="14" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="14" Grid.Column="1" Name="ImgPtrBox" Minimum="0" Maximum="4294967295" />
          <TextBlock Grid.Row="15" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="15" Grid.Column="1" Name="PalPtrBox" Minimum="0" Maximum="4294967295" />
          <TextBlock Grid.Row="16" Grid.Column="0" Text="D20:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="16" Grid.Column="1" Name="D20Box" Minimum="0" Maximum="4294967295" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
        <controls:GbaImageControl Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
