<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MapSettingFE7View"
        Title="Map Settings (FE7JP)" Width="1773" Height="1038"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <DockPanel Grid.Column="0" Margin="4">
      <Button AutomationProperties.AutomationId="MapSettingFE7_ExpandList_Button" DockPanel.Dock="Top" Name="ExpandListButton" Content="Data Expansion" Margin="2" />
      <controls:AddressListControl AutomationProperties.AutomationId="MapSettingFE7_Entry_List" Name="EntryList" />
    </DockPanel>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="Map Settings (FE7JP)" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="MapSettingFE7_Addr_Label" Name="AddrLabel" FontSize="12" Foreground="Gray" />

        <!-- Section 1: CP / Pointer (D0) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="CP / Pointer" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="D0: CP" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapSettingFE7_ND0_Input" Grid.Row="0" Grid.Column="1" Name="ND0" Width="120" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 2: Map Style / PLIST (W4, B6-B11) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Map Style / PLIST" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="W4: Object type (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW4_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NW4" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="B6: Palette (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB6_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NB6" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="B7: Chipset config (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB7_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NB7" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="B8: Map pointer (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB8_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NB8" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="B9: Tile animation 1 (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB9_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NB9" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="B10: Tile animation 2 (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB10_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NB10" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="B11: Map change (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB11_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NB11" Minimum="0" Maximum="255" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 3: Map Properties (B12-B19) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Map Properties" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B12: Fog level" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB12_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB12" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="B13: Battle preparation" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB13_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NB13" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="B14: Chapter title image" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB14_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NB14" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="B15: Chapter title image 2" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB15_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NB15" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="B16: Initial X coordinate" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB16_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NB16" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="B17: Initial Y coordinate" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB17_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NB17" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="B18: Weather" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB18_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NB18" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="7" Grid.Column="0" Text="B19: Battle BG lookup" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB19_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="NB19" Minimum="0" Maximum="255" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 4: BGM / Music (W20-W42) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="BGM / Music" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="W20: Difficulty adjustment" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW20_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NW20" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="W22: Player phase BGM" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW22_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NW22" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="W24: Enemy phase BGM" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW24_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NW24" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="W26: NPC phase BGM" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW26_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NW26" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="W28: Player phase BGM 2" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW28_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NW28" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="W30: Enemy phase BGM 2" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW30_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NW30" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="W32: NPC phase BGM 2" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW32_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NW32" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="7" Grid.Column="0" Text="W34: Player phase BGM flag 4" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW34_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="NW34" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="8" Grid.Column="0" Text="W36: Enemy phase BGM flag 4" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW36_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="NW36" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="9" Grid.Column="0" Text="W38: ???" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW38_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="NW38" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="10" Grid.Column="0" Text="W40: ???" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW40_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="NW40" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="11" Grid.Column="0" Text="W42: ???" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW42_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="NW42" Minimum="0" Maximum="65535" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 5: Breakable Wall HP + Difficulty Ratings -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Breakable Wall HP / Difficulty Ratings" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B44: Breakable wall HP" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB44_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB44" Minimum="0" Maximum="255" />
            </Grid>
            <TextBlock Text="B61: Unknown" FontStyle="Italic" Margin="0,4,0,2" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B61: ??" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB61_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB61" Minimum="0" Maximum="255" />
            </Grid>
            <TextBlock Text="W94: Unknown" FontStyle="Italic" Margin="0,4,0,2" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="W94: ??" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW94_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NW94" Minimum="0" Maximum="65535" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 6: Pointers (D96-D108) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Difficulty Pointers (D96-D108)" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,180" RowDefinitions="Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Eliwood Normal (D96):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapSettingFE7_ND96_Input" Grid.Row="0" Grid.Column="1" Name="ND96" Width="120" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Eliwood Hard (D100):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapSettingFE7_ND100_Input" Grid.Row="1" Grid.Column="1" Name="ND100" Width="120" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Hector Normal (D104):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapSettingFE7_ND104_Input" Grid.Row="2" Grid.Column="1" Name="ND104" Width="120" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Hector Hard (D108):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="MapSettingFE7_ND108_Input" Grid.Row="3" Grid.Column="1" Name="ND108" Width="120" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 7: Map Name Text IDs (W112, W114) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Map Name Text IDs" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120,10,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="W112: Map name 1" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW112_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NW112" Minimum="0" Maximum="65535" />
              <TextBlock AutomationProperties.AutomationId="MapSettingFE7_W112Text_Label" Grid.Row="0" Grid.Column="3" Name="W112TextLabel" VerticalAlignment="Center" Foreground="Blue" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="W114: Map name 2" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW114_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NW114" Minimum="0" Maximum="65535" />
              <TextBlock AutomationProperties.AutomationId="MapSettingFE7_W114Text_Label" Grid.Row="1" Grid.Column="3" Name="W114TextLabel" VerticalAlignment="Center" Foreground="Blue" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 8: Event / Fortune Teller (B116-B127) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Event / Fortune Teller" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B116: Event ID (PLIST)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB116_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB116" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="B117: World map auto event" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB117_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NB117" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="W118: Fortune text (opening)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW118_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NW118" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="W120: Fortune text (Eliwood)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW120_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NW120" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="W122: Fortune text (Hector)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW122_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NW122" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="W124: Fortune text (confirm)" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW124_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NW124" Minimum="0" Maximum="65535" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="B126: Fortune portrait" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB126_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NB126" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="7" Grid.Column="0" Text="B127: Fortune fee" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB127_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="NB127" Minimum="0" Maximum="255" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 9: Chapter / Transporter / Victory (B128-B135) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Chapter / Transporter / Victory" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B128: Chapter number" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB128_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB128" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="B129: Prep screen Ch no. 1" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB129_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NB129" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="B130: Transporter Eliwood X" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB130_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NB130" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="B131: Transporter Hector X" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB131_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NB131" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="B132: Transporter Eliwood Y" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB132_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NB132" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="B133: Transporter Hector Y" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB133_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NB133" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="B134: Victory BGM enemy count" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB134_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NB134" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="7" Grid.Column="0" Text="B135: Blackout before start" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB135_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="NB135" Minimum="0" Maximum="255" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 10: Clear Conditions (W136, W138) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Clear Conditions" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120,10,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="W136: Clear condition text" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW136_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NW136" Minimum="0" Maximum="65535" />
              <TextBlock AutomationProperties.AutomationId="MapSettingFE7_W136Text_Label" Grid.Row="0" Grid.Column="3" Name="W136TextLabel" VerticalAlignment="Center" Foreground="Blue" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="W138: Detail clear condition" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NW138_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NW138" Minimum="0" Maximum="65535" />
              <TextBlock AutomationProperties.AutomationId="MapSettingFE7_W138Text_Label" Grid.Row="1" Grid.Column="3" Name="W138TextLabel" VerticalAlignment="Center" Foreground="Blue" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Section 11: Display Flags (B140-B147) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,4">
          <StackPanel Spacing="4">
            <TextBlock Text="Display Flags (B140-B147)" FontWeight="Bold" FontSize="14" />
            <Grid ColumnDefinitions="220,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="B140: Special display" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB140_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NB140" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="B141: Turn count display" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB141_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NB141" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="B142: Defense unit mark" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB142_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NB142" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="B143: Escape marker X" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB143_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="NB143" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="4" Grid.Column="0" Text="B144: Escape marker Y" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB144_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="NB144" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="5" Grid.Column="0" Text="B145: ??" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB145_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="NB145" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="6" Grid.Column="0" Text="B146: ??" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB146_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="NB146" Minimum="0" Maximum="255" />
              <TextBlock Grid.Row="7" Grid.Column="0" Text="B147: ??" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="MapSettingFE7_NB147_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="NB147" Minimum="0" Maximum="255" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Write Button -->
        <Button AutomationProperties.AutomationId="MapSettingFE7_Write_Button" Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,8" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
