<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.MapTerrainFloorLookupTableView">
  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">

    <!-- Top filter / read-config bar — unified via EditorTopBar (#649).
         Condition ComboBox stays in its own Border above the unified bar. -->
    <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
      <Border BorderBrush="Gray" BorderThickness="1" Margin="4,4,4,0">
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
          <Label Content="Condition:" VerticalAlignment="Center" />
          <ComboBox AutomationProperties.AutomationId="MapTerrainFloorLookupTable_Filter_Combo"
                    Name="FilterComboBox" Width="320" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
      <controls:EditorTopBar Margin="4,4,4,0"
                             Name="TopBar"
                             AutomationProperties.AutomationId="MapTerrainFloorLookupTable_TopBar"
                             StartAddressLabel="Address (decimal):"
                             ReadCountLabel="Count:"
                             StartAddressAutomationId="MapTerrainFloorLookupTable_ReadStartAddress_Label"
                             ReadCountAutomationId="MapTerrainFloorLookupTable_ReadCount_Label"
                             ReloadAutomationId="MapTerrainFloorLookupTable_ReloadList_Button"
                             ShowSize="False"
                             ReloadRequested="OnTopBarReloadRequested" />
    </StackPanel>

    <controls:AddressListControl AutomationProperties.AutomationId="MapTerrainFloorLookupTable_Entry_List"
                                 Grid.Row="1" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <Label Content="Terrain Floor Lookup Table" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto">
          <Label Grid.Row="0" Grid.Column="0" Content="Address:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MapTerrainFloorLookupTable_Item_Address_Input"
                         FormatString="0" Grid.Row="0" Grid.Column="1"
                         Name="ItemAddressBox" Minimum="0" Maximum="65535999"
                         IsEnabled="False" VerticalAlignment="Center" />

          <Label Grid.Row="1" Grid.Column="0" Content="Selection:" VerticalAlignment="Center" />
          <Label AutomationProperties.AutomationId="MapTerrainFloorLookupTable_Addr_Label"
                 Grid.Row="1" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <Label Grid.Row="2" Grid.Column="0" Content="Terrain Battle Floor:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MapTerrainFloorLookupTable_TerrainBattleFloor_Input"
                         FormatString="0" Grid.Row="2" Grid.Column="1"
                         Name="TerrainBattleFloorBox" Minimum="0" Maximum="255"
                         VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MapTerrainFloorLookupTable_Write_Button"
                  Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="MapTerrainFloorLookupTable_JumpToBG_Button"
                  Name="JumpToBGButton" Content="Jump to the background of battle animation" Click="JumpToBG_Click" />
          <Button AutomationProperties.AutomationId="MapTerrainFloorLookupTable_PatchInstall_Button"
                  Name="PatchInstallButton" Content="Install Patch" Click="PatchInstall_Click"
                  Foreground="Red" IsVisible="False" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
