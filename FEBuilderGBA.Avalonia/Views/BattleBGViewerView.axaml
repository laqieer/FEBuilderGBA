<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.BattleBGViewerView"
        Title="Battle Background Editor" Width="853" Height="441">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Battle Background Editor" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="ImgPtrBox" Minimum="0" Maximum="4294967295" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="TSA Pointer:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="TsaPtrBox" Minimum="0" Maximum="4294967295" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="PalPtrBox" Minimum="0" Maximum="4294967295" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
        <controls:GbaImageControl Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
