<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolLZ77View">
  <DockPanel Margin="12">
    <TextBlock DockPanel.Dock="Top" Text="LZ77 Compression Tool" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

    <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,4" BorderBrush="LightGray" BorderThickness="1" CornerRadius="2">
      <TextBlock AutomationProperties.AutomationId="ToolLZ77_Status_Label" Text="{Binding StatusText}" TextWrapping="Wrap" />
    </Border>

    <TabControl AutomationProperties.AutomationId="ToolLZ77_TabControl" Name="MainTabs">

      <TabItem Header="Decompress" AutomationProperties.AutomationId="ToolLZ77_Decompress_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="140,8,*,8,Auto" RowDefinitions="Auto,8,Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="SRC:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_DecompressSrc_Input" Grid.Row="0" Grid.Column="2" Text="{Binding DecompressSrcPath}" Watermark="&lt;&lt;THIS ROM&gt;&gt;" />
              <Button AutomationProperties.AutomationId="ToolLZ77_DecompressSrcBrowse_Button" Grid.Row="0" Grid.Column="4" Content="Browse..." Click="DecompressSrcBrowse_Click" Width="100" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="SRC Address:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_DecompressAddress_Input" Grid.Row="2" Grid.Column="2" Text="{Binding DecompressAddressText}" Watermark="0x0" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="DEST:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_DecompressDest_Input" Grid.Row="4" Grid.Column="2" Text="{Binding DecompressDestPath}" />
              <Button AutomationProperties.AutomationId="ToolLZ77_DecompressDestBrowse_Button" Grid.Row="4" Grid.Column="4" Content="Browse..." Click="DecompressDestBrowse_Click" Width="100" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolLZ77_DecompressFire_Button" Content="Decompress" Click="DecompressFire_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <TextBlock Text="Extracts LZ77-compressed data from the loaded ROM (when SRC is &lt;&lt;THIS ROM&gt;&gt;) or from a file, and writes the raw bytes to DEST. Debug feature."
                         TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Compress" AutomationProperties.AutomationId="ToolLZ77_Compress_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="140,8,*,8,Auto" RowDefinitions="Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="SRC:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_CompressSrc_Input" Grid.Row="0" Grid.Column="2" Text="{Binding CompressSrcPath}" />
              <Button AutomationProperties.AutomationId="ToolLZ77_CompressSrcBrowse_Button" Grid.Row="0" Grid.Column="4" Content="Browse..." Click="CompressSrcBrowse_Click" Width="100" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="DEST:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_CompressDest_Input" Grid.Row="2" Grid.Column="2" Text="{Binding CompressDestPath}" />
              <Button AutomationProperties.AutomationId="ToolLZ77_CompressDestBrowse_Button" Grid.Row="2" Grid.Column="4" Content="Browse..." Click="CompressDestBrowse_Click" Width="100" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolLZ77_CompressFire_Button" Content="Compress" Click="CompressFire_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <TextBlock Text="Compresses a file using LZ77 and writes the compressed bytes to DEST. Debug feature."
                         TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Erase" AutomationProperties.AutomationId="ToolLZ77_Erase_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="140,8,*" RowDefinitions="Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="FROM:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_ZeroClearFrom_Input" Grid.Row="0" Grid.Column="2" Text="{Binding ZeroClearFromText}" Watermark="0x0" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="TO:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_ZeroClearTo_Input" Grid.Row="2" Grid.Column="2" Text="{Binding ZeroClearToText}" Watermark="0x0" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolLZ77_ZeroClear_Button" Content="Zero Clear This Region" Click="ZeroClear_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <TextBlock Text="Fills the specified ROM range with zero bytes. Dangerous — low-address writes require confirmation. Undo is tracked."
                         TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Base64" AutomationProperties.AutomationId="ToolLZ77_Base64_Tab">
        <DockPanel Margin="8">
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button AutomationProperties.AutomationId="ToolLZ77_Base64TextToFile_Button" Content="Base64 Text to File" Click="Base64TextToFile_Click" Width="200" />
            <Button AutomationProperties.AutomationId="ToolLZ77_FileToBase64Text_Button" Content="File to Base64 Text" Click="FileToBase64Text_Click" Width="200" />
          </StackPanel>
          <TextBox AutomationProperties.AutomationId="ToolLZ77_Base64Text_Input" Name="Base64TextEdit" Text="{Binding Base64Text}"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   Watermark="Paste base64 text, or use 'File to Base64 Text' to encode a file."
                   VerticalAlignment="Stretch" />
        </DockPanel>
      </TabItem>

      <TabItem Header="Move" AutomationProperties.AutomationId="ToolLZ77_Move_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="140,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="FROM:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_MoveFrom_Input" Grid.Row="0" Grid.Column="2" Text="{Binding MoveFromText}" Watermark="0x0 (source offset)" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="TO:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_MoveTo_Input" Grid.Row="2" Grid.Column="2" Text="{Binding MoveToText}" Watermark="0x0 (destination, 0 = auto-allocate)" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="LENGTH:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolLZ77_MoveLength_Input" Grid.Row="4" Grid.Column="2" Text="{Binding MoveLengthText}" Watermark="length in bytes (hex)" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolLZ77_Move_Button" Content="Move This Region" Click="Move_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <StackPanel Spacing="4">
                <TextBlock Text="Move arbitrary binary data (LZ77 or otherwise) to a new address. TO = 0 auto-allocates from free space (or appends to end). Pointer references are rewritten."
                           TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
                <TextBlock Text="Limitation: event-script-aware pointer search is not included (WinForms-only). If your data is referenced from event scripts or struct pointer tables, perform Move in WinForms."
                           TextWrapping="Wrap" FontSize="11" Foreground="DarkOrange" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Recompress" AutomationProperties.AutomationId="ToolLZ77_Recompress_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <StackPanel Spacing="4">
                <TextBlock Text="LZ77 Recompress (since 2026)" FontWeight="Bold" />
                <TextBlock Text="Walks ROM for LZ77-compressed entries and re-compresses each with the current encoder. Any savings can be reclaimed via Rebuild later. Process takes several minutes for a full ROM scan."
                           TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
                <TextBlock Text="Heuristic scan: this tool does NOT use WinForms MakeAllStructPointersList — it may miss entries referenced only from event scripts or struct pointer tables. For best coverage, run Recompress in WinForms."
                           TextWrapping="Wrap" FontSize="11" Foreground="DarkOrange" />
              </StackPanel>
            </Border>

            <Button AutomationProperties.AutomationId="ToolLZ77_Recompress_Button" Content="Run LZ77 Recompress" Click="Recompress_Click" Height="36" HorizontalAlignment="Stretch" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>
  </DockPanel>
</UserControl>