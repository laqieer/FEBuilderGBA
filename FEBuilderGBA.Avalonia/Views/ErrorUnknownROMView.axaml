<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ErrorUnknownROMView"
        Title="Unknown ROM Version"
        Width="866" Height="820"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="17,32,12,15">
    <!-- Red header label -->
    <TextBlock Text="Unknown ROM Version" FontSize="14" FontWeight="Bold"
               Foreground="Red" Margin="0,0,0,17" />
    <!-- ROM version info -->
    <TextBlock Text="{Binding VersionInfoText}" Margin="0,0,0,13" />
    <!-- Info message box with border -->
    <Border BorderBrush="Gray" BorderThickness="1" Height="86" Margin="0,0,0,22">
      <TextBlock Text="{Binding DetailMessage}"
                 TextWrapping="Wrap" Margin="4" VerticalAlignment="Center" />
    </Border>
    <!-- Cancel button -->
    <Button Content="Cancel" Height="66" HorizontalAlignment="Stretch"
            Click="Cancel_Click" Margin="0,0,0,15" />
    <!-- FE8U button -->
    <Button Content="Load as FE8U (Sacred Stones - US)" Height="66"
            HorizontalAlignment="Stretch" Click="FE8U_Click" Margin="0,0,0,6" />
    <!-- FE8J button -->
    <Button Content="Load as FE8J (Sacred Stones - Japan)" Height="66"
            HorizontalAlignment="Stretch" Click="FE8J_Click" Margin="0,0,0,6" />
    <!-- FE7U button -->
    <Button Content="Load as FE7U (Blazing Blade - US)" Height="66"
            HorizontalAlignment="Stretch" Click="FE7U_Click" Margin="0,0,0,6" />
    <!-- FE7J button -->
    <Button Content="Load as FE7J (Blazing Blade - Japan)" Height="66"
            HorizontalAlignment="Stretch" Click="FE7J_Click" Margin="0,0,0,6" />
    <!-- FE6 button -->
    <Button Content="Load as FE6 (Binding Blade - Japan)" Height="66"
            HorizontalAlignment="Stretch" Click="FE6_Click" Margin="0,0,0,6" />
    <!-- FE0 / Unknown button -->
    <Button Content="Load as Other (Unknown)" Height="66"
            HorizontalAlignment="Stretch" Click="Unknown_Click" />
  </StackPanel>
</Window>
