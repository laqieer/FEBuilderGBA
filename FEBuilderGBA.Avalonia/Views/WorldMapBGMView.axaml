<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.WorldMapBGMView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="WorldMapBGM_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="World Map BGM Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="WorldMapBGM_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Song ID 1 (u16@0):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="WorldMapBGM_SongId1_Input" FormatString="0" Name="SongId1Box" Minimum="0" Maximum="65535" Width="160" Margin="0,2" />
            <Button AutomationProperties.AutomationId="WorldMapBGM_JumpToSong1_Button" Content="Jump" Click="JumpToSong1_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Song ID 2 (u16@2):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="WorldMapBGM_SongId2_Input" FormatString="0" Name="SongId2Box" Minimum="0" Maximum="65535" Width="160" Margin="0,2" />
            <Button AutomationProperties.AutomationId="WorldMapBGM_JumpToSong2_Button" Content="Jump" Click="JumpToSong2_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="WorldMapBGM_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
