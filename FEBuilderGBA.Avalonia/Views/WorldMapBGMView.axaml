<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.WorldMapBGMView"
        Title="World Map BGM Editor" Width="1163" Height="778"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="World Map BGM Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Song ID 1 (u16@0):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown Name="SongId1Box" Minimum="0" Maximum="65535" Width="160" Margin="0,2" />
            <Button Content="Jump" Click="JumpToSong1_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Song ID 2 (u16@2):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown Name="SongId2Box" Minimum="0" Maximum="65535" Width="160" Margin="0,2" />
            <Button Content="Jump" Click="JumpToSong2_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
