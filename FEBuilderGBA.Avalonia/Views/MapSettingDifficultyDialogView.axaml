<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.MapSettingDifficultyDialogView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="12,12,12,10">
    <!-- GroupBox: Difficulty adjustment (WinForms customColorGroupBox1 528x161) -->
    <Border BorderBrush="Gray" BorderThickness="1" Padding="7,10,7,10"
            Margin="0,0,0,10">
      <StackPanel Spacing="10">
        <!-- Hard Boost (WinForms J_HardBoost 311x32 + HardBoost 76x25) -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border BorderBrush="Gray" BorderThickness="1" Width="311" Height="32">
            <TextBlock Text="Hard Boost" HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <NumericUpDown AutomationProperties.AutomationId="MapSettingDifficultyDialog_HardBoost_Input" FormatString="0" x:Name="HardBoostInput" Width="76" Height="25"
                         Minimum="0" Maximum="15" Value="0" />
        </StackPanel>
        <!-- Normal Penalty (WinForms J_NormalPenalty 311x32 + NormalPenalty 76x25) -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border BorderBrush="Gray" BorderThickness="1" Width="311" Height="32">
            <TextBlock Text="Normal Mode Penalty" HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <NumericUpDown AutomationProperties.AutomationId="MapSettingDifficultyDialog_NormalPenalty_Input" FormatString="0" x:Name="NormalPenaltyInput" Width="76" Height="25"
                         Minimum="0" Maximum="15" Value="0" />
        </StackPanel>
        <!-- Easy Penalty (WinForms J_EasyPenalty 311x32 + EasyPenalty 76x25) -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border BorderBrush="Gray" BorderThickness="1" Width="311" Height="32">
            <TextBlock Text="Easy Mode Penalty" HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <NumericUpDown AutomationProperties.AutomationId="MapSettingDifficultyDialog_EasyPenalty_Input" FormatString="0" x:Name="EasyPenaltyInput" Width="76" Height="25"
                         Minimum="0" Maximum="15" Value="0" />
        </StackPanel>
      </StackPanel>
    </Border>
    <!-- Difficulty value row (WinForms panel1 378x32 + DifficultyValue 95x25) -->
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Border BorderBrush="Gray" BorderThickness="1" Width="378" Height="32">
        <TextBlock Text="Difficulty Value" HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
      <NumericUpDown AutomationProperties.AutomationId="MapSettingDifficultyDialog_DifficultyValue_Input" FormatString="0" x:Name="DifficultyValueInput" Width="95" Height="25"
                     Minimum="0" Maximum="65535" Value="0" />
    </StackPanel>
    <!-- Help text (WinForms textBox1 527x121 ReadOnly). Use SelectableTextBlock
         so the user can still highlight + copy the help text (parity with the
         WinForms ReadOnly TextBox), while the ViewTranslationHelper picks up
         the Text property via TextBlock's translation path (SelectableTextBlock
         inherits from TextBlock). TextBox.Text was intentionally excluded from
         the helper to protect bound output fields. -->
    <SelectableTextBlock AutomationProperties.AutomationId="MapSettingDifficultyDialog_TextBox1_Input" Height="121" TextWrapping="Wrap"
               Text="Set the difficulty adjustment value.&#x0a;Hard Boost increases enemy stats in Hard mode.&#x0a;Penalties reduce enemy stats in Normal and Easy modes.&#x0a;&#x0a;Reference: feuniverse.us difficulty stat changes"
               Margin="0,0,0,10" />
    <!-- OK button (WinForms OKButton 272x43 right-aligned) -->
    <Button AutomationProperties.AutomationId="MapSettingDifficultyDialog_OK_Button" Content="Apply" Width="272" Height="43"
            HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="OK_Click" />
  </StackPanel>
  </ScrollViewer>
</UserControl>
