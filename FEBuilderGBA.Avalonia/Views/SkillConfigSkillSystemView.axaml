<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SkillConfigSkillSystemView"
        Title="Skill Config (SkillSystem)" Width="980" Height="700"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,Auto,*">

    <!-- Row 0: top read-config bar — unified via EditorTopBarWithInputs (#743).
         The InputsEnabled="False" + legacy AutomationId overrides preserve the
         pre-migration "disabled-as-display" UX and existing E2E selectors. -->
    <controls:EditorTopBarWithInputs Grid.Row="0" Grid.ColumnSpan="2" Name="TopBar"
                                     AutomationProperties.AutomationId="SkillConfigSkillSystem_TopBar"
                                     ReadStartLabel="Start Address:"
                                     ReadCountLabel="Read Count:"
                                     ReadCountMaximum="1024"
                                     InputsEnabled="False"
                                     ShowReadSize="False"
                                     ReadStartAutomationId="SkillConfigSkillSystem_ReadStart_Input"
                                     ReadCountAutomationId="SkillConfigSkillSystem_ReadCount_Input"
                                     ReloadAutomationId="SkillConfigSkillSystem_ReloadList_Button"
                                     ReloadRequested="OnTopBarReloadRequested" />

    <!-- Row 1: selection bar (mirrors WF panel5: アドレス / Size: / 選択アドレス / 書き込み) -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4,0,4,0">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
        <Label Content="Address:" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="SkillConfigSkillSystem_Address_Input"
                       FormatString="0" Name="AddressBox" Width="120"
                       Minimum="0" Maximum="4294967295"
                       IsEnabled="False" VerticalAlignment="Center" />
        <Label Content="Size:" VerticalAlignment="Center" />
        <NumericUpDown AutomationProperties.AutomationId="SkillConfigSkillSystem_BlockSize_Input"
                       FormatString="0" Name="BlockSizeBox" Width="50"
                       Minimum="0" Maximum="65535"
                       IsEnabled="False" VerticalAlignment="Center" Value="2" />
        <Label Content="Selected Address:" VerticalAlignment="Center" />
        <Label AutomationProperties.AutomationId="SkillConfigSkillSystem_SelectedAddress_Label"
               Name="SelectedAddressLabel" Width="100" VerticalAlignment="Center"
               FontFamily="Consolas" />
        <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_Write_Button"
                Name="WriteButton" Content="Write" Click="WriteButton_Click" />
      </StackPanel>
    </Border>

    <!-- Row 2 col 0: AddressList + Filter Name + List Expand -->
    <Border Grid.Row="2" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="4">
      <DockPanel>
        <Label DockPanel.Dock="Top"
               AutomationProperties.AutomationId="SkillConfigSkillSystem_FilterName_Label"
               Content="Filter Name" HorizontalAlignment="Stretch" />
        <!-- #997: List expansion is not yet implemented for the skill-config tables
             (multi-table / multi-pointer per patch variant). The button is disabled
             with the explanation on this ENABLED Border, since a disabled Avalonia
             control won't surface its own tooltip on hover. -->
        <Border DockPanel.Dock="Bottom"
                ToolTip.Tip="List expansion is not yet implemented for the skill-config tables (multi-table / multi-pointer per patch variant).">
          <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_ListExpand_Button"
                  Name="ListExpandButton" Content="List Expand"
                  HorizontalAlignment="Stretch" IsEnabled="False" />
        </Border>
        <controls:AddressListControl
            AutomationProperties.AutomationId="SkillConfigSkillSystem_Entry_List"
            Name="EntryList" />
      </DockPanel>
    </Border>

    <!-- Row 2 col 1: edit panel -->
    <ScrollViewer Grid.Row="2" Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <Label Content="Skill Config (SkillSystem)" FontSize="18" FontWeight="Bold" />

        <Border Background="{DynamicResource WarningBackgroundBrush}"
                BorderBrush="{DynamicResource WarningBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12">
          <TextBlock AutomationProperties.AutomationId="SkillConfigSkillSystem_Status_Label"
                     TextWrapping="Wrap" Name="StatusText"
                     Text="Skill system editors require the SkillSystems patch to be installed.&#10;Use the Patch Manager to install it first." />
        </Border>

        <!-- Icon row: label + image + image import/export buttons + IconAddr label -->
        <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto">
          <Label Grid.Column="0"
                 AutomationProperties.AutomationId="SkillConfigSkillSystem_Icon_Label"
                 Content="Icon" VerticalAlignment="Center" />
          <Border Grid.Column="1" BorderBrush="DarkGray" BorderThickness="1"
                  HorizontalAlignment="Left" Padding="2" Width="48" Height="48">
            <Image AutomationProperties.AutomationId="SkillConfigSkillSystem_Icon_Image"
                   Name="IconImage" Width="40" Height="40" Stretch="Uniform" />
          </Border>
          <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_ImageImport_Button"
                    Name="ImageImportButton" Content="Image Import" Margin="0,0,8,4"
                    Click="ImageImport_Click"
                    ToolTip.Tip="Import a 16x16 skill icon (128 raw 4bpp bytes, in-place, undoable)." />
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_ImageExport_Button"
                    Name="ImageExportButton" Content="Image Export" Margin="0,0,8,4"
                    Click="ImageExport_Click"
                    ToolTip.Tip="Export the 16x16 skill icon as a PNG." />
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_FERepo_Button"
                    Name="FERepoButton" Content="FE-Repo" Margin="0,0,8,4"
                    Click="FERepo_Click"
                    ToolTip.Tip="Import a 16x16 skill icon from the FE-Repo Skill Icons folder." />
            <Label AutomationProperties.AutomationId="SkillConfigSkillSystem_IconAddr_Label"
                   Name="IconAddrLabel" VerticalAlignment="Center" Margin="0,0,8,4"
                   FontFamily="Consolas" />
          </WrapPanel>
        </Grid>

        <!-- Text Detail row: text id + read-only resolved text TextBox (multiline) -->
        <Grid ColumnDefinitions="120,80,*" RowDefinitions="Auto">
          <Label Grid.Column="0"
                 AutomationProperties.AutomationId="SkillConfigSkillSystem_TextDetail_Label"
                 Content="Description:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Column="1"
                         AutomationProperties.AutomationId="SkillConfigSkillSystem_TextDetail_Input"
                         FormatString="0" Name="TextDetailBox"
                         Minimum="0" Maximum="65535" />
          <TextBox Grid.Column="2"
                   AutomationProperties.AutomationId="SkillConfigSkillSystem_TextDetailText_Input"
                   Name="TextDetailTextBox" IsReadOnly="True" AcceptsReturn="True"
                   Margin="8,0,0,0" MinHeight="60" />
        </Grid>

        <!-- Animation row: label + animation pointer + animation import/export buttons -->
        <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto">
          <Label Grid.Column="0"
                 AutomationProperties.AutomationId="SkillConfigSkillSystem_Animation_Label"
                 Content="Animation" VerticalAlignment="Center" />
          <!-- AnimationPointer holds a ROM OFFSET (e.g. 0x01000000), not a raw
               GBA pointer (e.g. 0x09000000). The WF `Program.ROM.p32`/`write_p32`
               round-trip strips/re-adds the 0x08000000 high bit. The Maximum
               must still accommodate the full 32-bit range so the binding
               doesn't clamp during typing or when transient pointer-like
               values are pasted in. -->
          <NumericUpDown Grid.Column="1"
                         AutomationProperties.AutomationId="SkillConfigSkillSystem_AnimationPointer_Input"
                         FormatString="0" Name="AnimationPointerBox"
                         Minimum="0" Maximum="4294967295" />
          <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_AnimationImport_Button"
                    Name="AnimationImportButton" Content="Animation Import" Margin="0,0,8,4"
                    Click="AnimationImport_Click"
                    ToolTip.Tip="Pending Core extraction - tracked by #500." />
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_AnimationExport_Button"
                    Name="AnimationExportButton" Content="Animation Export" Margin="0,0,8,4"
                    Click="AnimationExport_Click"
                    ToolTip.Tip="Pending Core extraction - tracked by #500." />
          </WrapPanel>
        </Grid>

        <!-- Animation preview panel - visible only when the animation pointer resolves safely -->
        <Border Name="AnimationPanel" BorderBrush="Gray" BorderThickness="1" Padding="8" IsVisible="False">
          <StackPanel Spacing="6">
            <Label AutomationProperties.AutomationId="SkillConfigSkillSystem_DisplayExample_Label"
                   Content="Display example" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
              <Label Grid.Row="0" Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigSkillSystem_Zoom_Label"
                     Content="Zoom" VerticalAlignment="Center" />
              <!-- Wrap the option text in TextBlock so ViewTranslationHelper
                   picks them up (ComboBoxItem.Content is NOT translated by
                   the helper - same pattern as PR #516). -->
              <ComboBox Grid.Row="0" Grid.Column="1"
                        AutomationProperties.AutomationId="SkillConfigSkillSystem_ShowZoom_Combo"
                        Name="ShowZoomComboBox" Width="160"
                        SelectionChanged="ShowZoomComboBox_SelectionChanged">
                <ComboBoxItem><TextBlock Text="Zoomed" /></ComboBoxItem>
                <ComboBoxItem><TextBlock Text="Original size" /></ComboBoxItem>
              </ComboBox>
              <Label Grid.Row="1" Grid.Column="0"
                     AutomationProperties.AutomationId="SkillConfigSkillSystem_Frame_Label"
                     Content="Frame" VerticalAlignment="Center" />
              <NumericUpDown Grid.Row="1" Grid.Column="1"
                             AutomationProperties.AutomationId="SkillConfigSkillSystem_ShowFrame_Input"
                             FormatString="0" Name="ShowFrameUpDown" Width="80"
                             Minimum="0" Maximum="255" ValueChanged="ShowFrameUpDown_ValueChanged" />
            </Grid>
            <Border BorderBrush="DarkGray" BorderThickness="1" HorizontalAlignment="Left" Padding="2">
              <Image AutomationProperties.AutomationId="SkillConfigSkillSystem_Preview_Image"
                     Name="PreviewImage" Width="160" Height="120" Stretch="Uniform" />
            </Border>
            <TextBox AutomationProperties.AutomationId="SkillConfigSkillSystem_BinInfo_Label"
                     Name="BinInfoBox" IsReadOnly="True" FontFamily="Consolas" />
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_JumpToEditor_Button"
                    Name="JumpToEditorButton" Content="Editor"
                    HorizontalAlignment="Left" Click="JumpToEditor_Click"
                    ToolTip.Tip="Pending Core extraction - tracked by #500." />
          </StackPanel>
        </Border>

        <!-- Bulk import/export pair (mirrors WF panel2). -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_BulkImport_Button"
                    Name="BulkImportButton" Content="Bulk Import"
                    Click="BulkImport_Click"
                    ToolTip.Tip="Pending Core extraction - tracked by #500." />
            <Button AutomationProperties.AutomationId="SkillConfigSkillSystem_BulkExport_Button"
                    Name="BulkExportButton" Content="Bulk Export"
                    Click="BulkExport_Click"
                    ToolTip.Tip="Pending Core extraction - tracked by #500." />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
