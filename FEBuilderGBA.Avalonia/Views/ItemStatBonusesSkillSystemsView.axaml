<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ItemStatBonusesSkillSystemsView"
        Title="Stat Bonuses (Skill Systems)" Width="1291" Height="587"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Stat Bonuses (Skill Systems)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
        </Grid>

        <!-- Stat Bonuses Row -->
        <TextBlock Text="Stat Bonuses" FontWeight="Bold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="HP" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="Str/Mag" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="Skill" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Speed" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="4" Text="Defense" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="5" Text="Resistance" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="6" Text="Luck" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="7" Text="Move" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="8" Text="Con" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="9" Text="Magic/??" Width="70" Margin="2" HorizontalAlignment="Center" />

          <NumericUpDown Grid.Row="1" Grid.Column="0" Name="HPBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="StrBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="2" Name="SkillBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="3" Name="SpeedBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="4" Name="DefBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="5" Name="ResBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="6" Name="LuckBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="7" Name="MoveBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="8" Name="ConBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="9" Name="MagicOrUnknownBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
        </Grid>

        <!-- Growth Rate Bonuses Row -->
        <TextBlock Text="Growth Rate Bonuses" FontWeight="Bold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="HP" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="Str/Mag" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="Skill" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Speed" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="4" Text="Defense" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="5" Text="Resistance" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="6" Text="Luck" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="7" Text="??" Width="70" Margin="2" HorizontalAlignment="Center" />

          <NumericUpDown Grid.Row="1" Grid.Column="0" Name="GrowHPBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="GrowStrBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="2" Name="GrowSkillBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="3" Name="GrowSpeedBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="4" Name="GrowDefBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="5" Name="GrowResBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="6" Name="GrowLuckBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="7" Name="GrowUnknownBox" Minimum="-128" Maximum="127" Width="70" Margin="2" />
        </Grid>

        <!-- Padding Row -->
        <TextBlock Text="Padding" FontWeight="Bold" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="??" Width="70" Margin="2" HorizontalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="??" Width="70" Margin="2" HorizontalAlignment="Center" />

          <NumericUpDown Grid.Row="1" Grid.Column="0" Name="Padding1Box" Minimum="-128" Maximum="127" Width="70" Margin="2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="Padding2Box" Minimum="-128" Maximum="127" Width="70" Margin="2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
