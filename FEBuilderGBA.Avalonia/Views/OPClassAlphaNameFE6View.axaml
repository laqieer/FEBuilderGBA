<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.OPClassAlphaNameFE6View">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="OPClassAlphaNameFE6_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="OP Class Alpha Name (FE6) Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock AutomationProperties.AutomationId="OPClassAlphaNameFE6_Unavailable_Label" Name="UnavailableLabel" Text="" Foreground="Orange" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="OPClassAlphaNameFE6_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="OPClassAlphaNameFE6_NamePointer_Input" Grid.Row="1" Grid.Column="1" Name="NamePointerBox" Width="120" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Alpha Name:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="OPClassAlphaNameFE6_AlphaName_Label" Grid.Row="2" Grid.Column="1" Name="AlphaNameLabel" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="OPClassAlphaNameFE6_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
