<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MonsterProbabilityViewerView"
        Title="Monster Probability Editor" Width="1203" Height="552"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="MonsterProbabilityViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Monster Probability Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="MonsterProbabilityViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Class ID 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_ClassId1_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="ClassId1Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Class ID 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_ClassId2_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="ClassId2Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Class ID 3:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_ClassId3_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="ClassId3Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Class ID 4:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_ClassId4_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="ClassId4Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Class ID 5:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_ClassId5_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="ClassId5Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Probability 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Prob1_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="Prob1Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Probability 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Prob2_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="Prob2Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Probability 3:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Prob3_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="Prob3Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Probability 4:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Prob4_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="Prob4Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Probability 5:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Prob5_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="Prob5Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Unknown 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Unknown1_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="Unknown1Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="Unknown 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MonsterProbabilityViewer_Unknown2_Input" FormatString="0" Grid.Row="12" Grid.Column="1" Name="Unknown2Box" Minimum="0" Maximum="255" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MonsterProbabilityViewer_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
