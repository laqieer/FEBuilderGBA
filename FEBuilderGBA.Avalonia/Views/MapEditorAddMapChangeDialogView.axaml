<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.MapEditorAddMapChangeDialogView"
        Title="Add Map Change"
        Width="831" Height="512"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="WidthAndHeight">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <StackPanel Margin="12,9,12,15">
    <!-- Bold question label (like WinForms labelEx1 at 82,9 717x58 Bold 11F) -->
    <TextBlock Text="Do you want to create additional map changes?"
               FontSize="14" FontWeight="Bold" TextWrapping="Wrap"
               Margin="70,0,0,15" Height="58" />
    <!-- New button (WinForms MyNewButton 787x42) -->
    <Button Content="Assign new map change" Height="42"
            HorizontalAlignment="Stretch" Click="New_Click" />
    <!-- Instruction text between buttons (WinForms label2 786x95) -->
    <TextBlock Text="Assign a new map change ID. A new PLIST entry will be allocated automatically."
               TextWrapping="Wrap" Height="95" Margin="0,7,0,0" />
    <!-- Edit button (WinForms EditButton 787x42) -->
    <Button Content="Open map change settings" Height="42"
            HorizontalAlignment="Stretch" Click="Edit_Click" />
    <!-- Instruction text (WinForms label1 786x95) -->
    <TextBlock Text="Open the map change configuration screen to edit existing map change entries."
               TextWrapping="Wrap" Height="95" Margin="0,7,0,0" />
    <!-- Cancel button (WinForms MyCancelButton 787x42) -->
    <Button Content="Cancel" Height="42"
            HorizontalAlignment="Stretch" Click="Cancel_Click" />
  </StackPanel>
  </ScrollViewer>
</Window>
