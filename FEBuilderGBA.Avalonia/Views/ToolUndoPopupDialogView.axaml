<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolUndoPopupDialogView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <Grid ColumnDefinitions="Auto,*" Margin="12,22,12,12">
    <!-- Icon (WinForms FormIcon 80x80 at 12,22) -->
    <Border Grid.Column="0" Width="80" Height="80" VerticalAlignment="Top"
            Background="{DynamicResource UndoInfoBackgroundBrush}" BorderBrush="{DynamicResource UndoInfoBorderBrush}" BorderThickness="1"
            Margin="0,0,12,0">
      <TextBlock Text="↩" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Border>
    <!-- Right side: Info + buttons -->
    <StackPanel Grid.Column="1" Spacing="6">
      <!-- Info textbox (WinForms Info 629x117 readonly multiline) -->
      <TextBox AutomationProperties.AutomationId="ToolUndoPopupDialog_InfoText_Input" Name="InfoTextBox" Height="117" IsReadOnly="True" AcceptsReturn="True"
               Text="{Binding InfoText}" FontFamily="Consolas, Courier New, monospace" />
      <!-- TestPlay button (WinForms TestPlayButton 629x41) -->
      <Button AutomationProperties.AutomationId="ToolUndoPopupDialog_TestPlay_Button" Name="TestPlayButton" Content="Test Play in Emulator" Height="41"
              HorizontalAlignment="Stretch" Click="TestPlay_Click" />
      <!-- RunUndo button (WinForms RunUndoButton 629x36) -->
      <Button AutomationProperties.AutomationId="ToolUndoPopupDialog_RunUndo_Button" Name="RunUndoButton" Content="Revert to This Version" Height="36"
              HorizontalAlignment="Stretch" Click="RunUndo_Click" />
      <!-- Cancel button (WinForms MyCancelButton 629x35) -->
      <Button AutomationProperties.AutomationId="ToolUndoPopupDialog_MyCancel_Button" Name="MyCancelButton" Content="Cancel" Height="35"
              HorizontalAlignment="Stretch" Click="Cancel_Click" />
    </StackPanel>
  </Grid>
  </ScrollViewer>
</UserControl>
