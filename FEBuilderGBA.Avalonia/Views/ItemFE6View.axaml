<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ItemFE6View"
        Title="Item Editor (FE6)" Width="1408" Height="856"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl AutomationProperties.AutomationId="ItemFE6_Entry_List" Grid.Row="0" Name="EntryList" Margin="4" />
      <!-- Selected item icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:GbaImageControl AutomationProperties.AutomationId="ItemFE6_ListPreview_Image" Name="ListPreviewImage" />
          <TextBlock AutomationProperties.AutomationId="ItemFE6_ListPreviewName_Label" Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Editor (FE6)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,200,20,140,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Address -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemFE6_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Name:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemFE6_Name_Label" Grid.Row="0" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" />

          <!-- Row 1: W0 Name ID, W2 Desc ID -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_NameId_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Desc ID (W2):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_DescId_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="DescIdBox" Minimum="0" Maximum="65535" />

          <!-- Row 2: W4 Use Desc ID, B6 Item Number -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Use Desc (W4):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_UseDescId_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="UseDescIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Item # (B6):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_ItemNumber_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="ItemNumberBox" Minimum="0" Maximum="255" />

          <!-- Row 3: B7 Weapon Type, B8 Trait1 -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Type (B7):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_WeaponType_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="WeaponTypeBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Trait 1 (B8):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Trait1_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="Trait1Box" Minimum="0" Maximum="255" />

          <!-- Row 4: B9 Trait2, B10 Trait3 -->
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Trait 2 (B9):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Trait2_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="Trait2Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Trait 3 (B10):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Trait3_Input" FormatString="0" Grid.Row="4" Grid.Column="4" Name="Trait3Box" Minimum="0" Maximum="255" />

          <!-- Row 5: B11 Trait4, P12 Stat Bonuses -->
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Trait 4 (B11):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Trait4_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="Trait4Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="5" Grid.Column="3" Text="Stat Bonus (P12):" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ItemFE6_StatBonusesPtr_Input" Grid.Row="5" Grid.Column="4" Name="StatBonusesPtrBox" Width="120" />

          <!-- Row 6: P16 Effectiveness -->
          <TextBlock Grid.Row="6" Grid.Column="0" Text="Effective (P16):" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ItemFE6_EffectivenessPtr_Input" Grid.Row="6" Grid.Column="1" Name="EffectivenessPtrBox" Width="120" />

          <!-- Row 7: B20 Uses, B21 Might -->
          <TextBlock Grid.Row="7" Grid.Column="0" Text="Uses (B20):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Uses_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="UsesBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="7" Grid.Column="3" Text="Might (B21):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Might_Input" FormatString="0" Grid.Row="7" Grid.Column="4" Name="MightBox" Minimum="0" Maximum="255" />

          <!-- Row 8: B22 Hit, B23 Weight -->
          <TextBlock Grid.Row="8" Grid.Column="0" Text="Hit (B22):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Hit_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="HitBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="8" Grid.Column="3" Text="Weight (B23):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Weight_Input" FormatString="0" Grid.Row="8" Grid.Column="4" Name="WeightBox" Minimum="0" Maximum="255" />

          <!-- Row 9: B24 Crit, B25 Range -->
          <TextBlock Grid.Row="9" Grid.Column="0" Text="Crit (B24):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Crit_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="CritBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="9" Grid.Column="3" Text="Range (B25):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Range_Input" FormatString="0" Grid.Row="9" Grid.Column="4" Name="RangeBox" Minimum="0" Maximum="255" />

          <!-- Row 10: W26 Price, B28 Weapon Rank -->
          <TextBlock Grid.Row="10" Grid.Column="0" Text="Price (W26):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Price_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="PriceBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="10" Grid.Column="3" Text="Rank (B28):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_WeaponRank_Input" FormatString="0" Grid.Row="10" Grid.Column="4" Name="WeaponRankBox" Minimum="0" Maximum="255" />

          <!-- Row 11: B29 Icon, B30 Usage Effect -->
          <TextBlock Grid.Row="11" Grid.Column="0" Text="Icon (B29):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_Icon_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="IconBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="11" Grid.Column="3" Text="Use Effect (B30):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_UsageEffect_Input" FormatString="0" Grid.Row="11" Grid.Column="4" Name="UsageEffectBox" Minimum="0" Maximum="255" />

          <!-- Row 12: B31 Damage Effect -->
          <TextBlock Grid.Row="12" Grid.Column="0" Text="Dmg Effect (B31):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemFE6_DamageEffect_Input" FormatString="0" Grid.Row="12" Grid.Column="1" Name="DamageEffectBox" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ItemFE6_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
