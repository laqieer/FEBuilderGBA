<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.OPClassDemoFE7UView"
        Title="OP Class Demo (FE7U) (Read-Only)" Width="1554" Height="924">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="OP Class Demo (FE7U) (Read-Only)" FontSize="18" FontWeight="Bold" />
        <TextBlock Name="UnavailableLabel" Text="" Foreground="Orange" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Class ID (u8@11):" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="ClassIdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Animation Type (u8@12):" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="AnimTypeLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Battle Anime (u8@13):" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="BattleAnimeLabel" VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
