<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.OPClassDemoFE7UView"
        Title="OP Class Demo (FE7U) Editor" Width="1554" Height="924">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="OP Class Demo (FE7U) Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock Name="UnavailableLabel" Text="" Foreground="Orange" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" Margin="0,2" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="English Name Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="EnglishNamePtrBox" Minimum="0" Maximum="4294967295" FormatString="X8" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Description Text ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="DescTextIdBox" Minimum="0" Maximum="65535" FormatString="X4" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Japanese Name Length:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="JpNameLenBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Class ID:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="ClassIdBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Ally/Enemy Color:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="AllyEnemyColorBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Battle Anime:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="BattleAnimeBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Magic Effect:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="MagicEffectBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Terrain Left:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="TerrainLeftBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Terrain Right:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="TerrainRightBox" Minimum="0" Maximum="255" FormatString="X2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Anime Pointer:" VerticalAlignment="Center" Margin="0,2" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="AnimePtrBox" Minimum="0" Maximum="4294967295" FormatString="X8" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
