<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FEBuilderGBA.Avalonia.ViewModels"
        x:Class="FEBuilderGBA.Avalonia.Views.PatchManagerView"
        Title="Patch Manager" Width="1100" Height="650"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="400,*" Margin="8">
    <!-- Left panel: search + patch list -->
    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*" Margin="0,0,4,0">
      <!-- Search box -->
      <TextBox AutomationProperties.AutomationId="PatchManager_Search_Input" Grid.Row="0" Name="SearchBox" Watermark="Filter patches by name, tag, or author..."
               Margin="0,0,0,4" />

      <!-- Summary -->
      <TextBlock AutomationProperties.AutomationId="PatchManager_Summary_Label" Grid.Row="1" Name="SummaryLabel" Margin="0,0,0,4" FontSize="12"
                 Foreground="Gray" />

      <!-- In-app patch2 Initialize / Update (#1817). Always visible so a user with an empty
           config/patch2 can fetch the database without selecting a patch first. -->
      <Button AutomationProperties.AutomationId="PatchManager_InitUpdatePatch2_Button" Grid.Row="2" Name="InitUpdatePatch2Button"
              Content="Initialize Patch Database" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              Margin="0,0,0,4" />

      <!-- Patch list -->
      <ListBox AutomationProperties.AutomationId="PatchManager_PatchList_List" Grid.Row="3" Name="PatchListBox" SelectionMode="Single">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:PatchEntry">
            <Grid ColumnDefinitions="*,Auto" Margin="2">
              <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center"
                         ToolTip.Tip="{Binding Name}" />
              <Border Grid.Column="1" Padding="6,2" CornerRadius="4" Margin="4,0,0,0"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" FontSize="11" />
              </Border>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Right panel: patch details -->
    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12" Margin="4,0,0,0">
      <ScrollViewer>
        <StackPanel Name="DetailsPanel" Spacing="8">
          <TextBlock Text="Patch Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

          <!-- Name -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Name:" FontWeight="SemiBold" VerticalAlignment="Top" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailName_Label" Grid.Column="1" Name="DetailName" TextWrapping="Wrap" />
          </Grid>

          <!-- Status -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailStatus_Label" Grid.Column="1" Name="DetailStatus" />
          </Grid>

          <!-- Author -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Author:" FontWeight="SemiBold" VerticalAlignment="Top" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailAuthor_Label" Grid.Column="1" Name="DetailAuthor" TextWrapping="Wrap" />
          </Grid>

          <!-- Type -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Type:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailType_Label" Grid.Column="1" Name="DetailType" />
          </Grid>

          <!-- Tags -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Tags:" FontWeight="SemiBold" VerticalAlignment="Top" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailTags_Label" Grid.Column="1" Name="DetailTags" TextWrapping="Wrap" />
          </Grid>

          <!-- Directory -->
          <Grid ColumnDefinitions="100,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Directory:" FontWeight="SemiBold" VerticalAlignment="Top" />
            <TextBlock AutomationProperties.AutomationId="PatchManager_DetailDirectory_Label" Grid.Column="1" Name="DetailDirectory" TextWrapping="Wrap" FontSize="11"
                       Foreground="Gray" />
          </Grid>

          <!-- Dependencies Warning -->
          <Border Name="DependencyWarningBorder" IsVisible="False"
                  Background="{DynamicResource DependencyWarningBackgroundBrush}" BorderBrush="{DynamicResource DependencyWarningBorderBrush}" BorderThickness="1"
                  CornerRadius="4" Padding="8" Margin="0,0,0,4">
            <StackPanel Spacing="4">
              <TextBlock Text="Unmet Dependencies" FontWeight="SemiBold" Foreground="{DynamicResource WarningTextBrush}" />
              <TextBlock AutomationProperties.AutomationId="PatchManager_DependencyWarning_Label" Name="DependencyWarningText" TextWrapping="Wrap" FontSize="12"
                         Foreground="{DynamicResource WarningTextSecondaryBrush}" />
            </StackPanel>
          </Border>

          <!-- Separator -->
          <Separator Margin="0,4" />

          <!-- Action Buttons -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button AutomationProperties.AutomationId="PatchManager_Install_Button" Name="InstallButton" Content="Install Patch" IsEnabled="False"
                    Padding="12,6" FontWeight="SemiBold" />
            <Button AutomationProperties.AutomationId="PatchManager_ForceInstall_Button" Name="ForceInstallButton" Content="Install Anyway" IsEnabled="False"
                    IsVisible="False" Padding="12,6" />
            <Button AutomationProperties.AutomationId="PatchManager_Uninstall_Button" Name="UninstallButton" Content="Uninstall Patch" IsEnabled="False"
                    Padding="12,6" />
          </StackPanel>

          <!-- Status Message -->
          <TextBlock AutomationProperties.AutomationId="PatchManager_StatusMessage_Label" Name="StatusMessageLabel" TextWrapping="Wrap" FontSize="12"
                     Foreground="Gray" Margin="0,0,0,8" />

          <!-- Separator -->
          <Separator Margin="0,4" />

          <!-- Description -->
          <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
          <TextBlock AutomationProperties.AutomationId="PatchManager_DetailDescription_Label" Name="DetailDescription" TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
