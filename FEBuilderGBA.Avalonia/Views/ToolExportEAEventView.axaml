<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolExportEAEventView"
        Title="Export EA Event" Width="700" Height="500"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Export Event Assembler Script" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Export" Click="Export_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="Output Path:" VerticalAlignment="Center" />
      <TextBox Name="OutputPathTextBox" Width="400" Watermark="Select output file..." />
      <Button Content="Browse..." Click="Browse_Click" />
    </StackPanel>
    <TextBlock DockPanel.Dock="Top" Text="Event Script Preview:" FontWeight="SemiBold" Margin="0,4,0,4" />
    <ScrollViewer>
      <TextBox Name="EventScriptTextBox" IsReadOnly="True" AcceptsReturn="True"
               FontFamily="Consolas, Courier New, monospace" />
    </ScrollViewer>
  </DockPanel>
</Window>
