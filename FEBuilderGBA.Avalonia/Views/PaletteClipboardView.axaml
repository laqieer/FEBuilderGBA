<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.PaletteClipboardView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Palette Clipboard" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <Border DockPanel.Dock="Top" Background="{DynamicResource InfoBannerBackgroundBrush}" BorderBrush="{DynamicResource InfoBannerBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
      <TextBlock TextWrapping="Wrap"
                 Text="Palette Clipboard Manager stores and retrieves palette data.&#10;Copy palettes between different graphics entries or save them for later use." />
    </Border>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="PaletteClipboard_Copy_Button" Content="Copy Current" Click="Copy_Click" />
      <Button AutomationProperties.AutomationId="PaletteClipboard_Paste_Button" Content="Paste" Click="Paste_Click" />
      <Button AutomationProperties.AutomationId="PaletteClipboard_Clear_Button" Content="Clear" Click="Clear_Click" />
      <Button AutomationProperties.AutomationId="PaletteClipboard_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel Spacing="8">
      <TextBlock Text="Clipboard Contents:" FontWeight="SemiBold" />
      <Border Background="{DynamicResource SubtlePanelBackgroundBrush}" BorderBrush="{DynamicResource SubtlePanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" MinHeight="60">
        <TextBlock AutomationProperties.AutomationId="PaletteClipboard_ClipboardStatus_Label" Name="ClipboardStatusLabel" Text="[No palette data in clipboard]" Foreground="Gray" />
      </Border>
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</UserControl>
