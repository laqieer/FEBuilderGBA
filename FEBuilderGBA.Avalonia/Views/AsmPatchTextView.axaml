<UserControl
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.AsmPatchTextView">
  <!-- Make-Patch text dialog for the Add-via-ASM/C tool (WF
       GraphicsToolPatchMakerForm). Displays the redistributable patch-definition
       text generated by AsmCompileCore.MakePatchText for the last successful
       compile, and lets the user save it as PATCH_(NAME).txt. Read-only display +
       Save + Close — it reads no ROM bytes. -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="14">
    <TextBlock DockPanel.Dock="Top" Text="Make Patch" FontSize="18" FontWeight="Bold"
               Margin="0,0,0,6" />
    <TextBlock DockPanel.Dock="Top"
               Text="A redistributable patch definition for the compiled result. Save it as a PATCH_(NAME).txt file to share the patch."
               TextWrapping="Wrap" Margin="0,0,0,8" />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
      <Button AutomationProperties.AutomationId="AsmPatchText_Save_Button"
              Name="SaveButton" Content="Save..." Width="160" Click="Save_Click" />
      <Button AutomationProperties.AutomationId="AsmPatchText_Close_Button"
              Name="CloseButton" Content="Close" Width="120" Click="Close_Click" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Name="StatusText"
               AutomationProperties.AutomationId="AsmPatchText_Status_Label"
               Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0" />

    <TextBox AutomationProperties.AutomationId="AsmPatchText_Patch_Input"
             Name="PatchTextBox" AcceptsReturn="True" IsReadOnly="True"
             Text="{Binding PatchText}"
             FontFamily="Consolas, Courier New, monospace" FontSize="12"
             TextWrapping="NoWrap"
             VerticalContentAlignment="Top" />
  </DockPanel>
  </ScrollViewer>
</UserControl>
