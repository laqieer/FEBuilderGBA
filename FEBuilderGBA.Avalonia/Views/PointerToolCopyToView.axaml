<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.PointerToolCopyToView"
        Title="Pointer Tool - Copy To" Width="450" Height="250"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Copy Pointer Data" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="OK" Width="80" Click="OK_Click" />
      <Button Content="Cancel" Width="80" Click="Cancel_Click" />
    </StackPanel>
    <Grid RowDefinitions="Auto,8,Auto" ColumnDefinitions="Auto,8,*">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Address:" VerticalAlignment="Center" />
      <TextBox Grid.Row="0" Grid.Column="2" Name="SourceAddressTextBox" Watermark="e.g. 0x08000000" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Dest Address:" VerticalAlignment="Center" />
      <TextBox Grid.Row="2" Grid.Column="2" Name="DestAddressTextBox" Watermark="e.g. 0x08100000" />
    </Grid>
  </DockPanel>
</Window>
