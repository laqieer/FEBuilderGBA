<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ItemPromotionViewerView"
        Title="Item Promotion Editor" Width="1180" Height="720"
        SizeToContent="WidthAndHeight">
  <!--
    Issue #368: CC-item-driven master/detail layout that mirrors the WinForms
    ItemPromotionForm. Outer EntryList = the fixed set of CC items (Hero Crest,
    Knight Crest, ... Sun Bracelet for FE7+); InnerList = the class IDs that
    item promotes; the right pane edits one class slot at a time. When the
    IER patch is installed, X_IER_Patch warns the user that the table is
    superseded and offers a deep-link to Patch Manager.
  -->
  <Grid ColumnDefinitions="320,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ItemPromotionViewer_Entry_List"
                                 Grid.Column="0" Name="EntryList" Margin="4" />

    <Grid Grid.Column="1" Margin="8" RowDefinitions="Auto,Auto,Auto,*">
      <!-- Header -->
      <StackPanel Grid.Row="0" Spacing="4">
        <TextBlock Text="Item Promotion Editor" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="Promotion target classes per CC item" FontSize="12" Foreground="Gray" />
      </StackPanel>

      <!-- IER patch warning (visible only when the patch is installed) -->
      <Grid Grid.Row="1" Name="X_IER_PatchPanel" IsVisible="False"
            RowDefinitions="Auto,Auto" Margin="0,8,0,0">
        <TextBlock Grid.Row="0" Name="X_IER_Patch"
                   AutomationProperties.AutomationId="ItemPromotionViewer_IER_Patch_Label"
                   Foreground="Red" TextWrapping="Wrap"
                   Text="IER patch is installed. Promotion targets must be configured via Patch Manager." />
        <Button Grid.Row="1" Name="OpenPatchManagerButton"
                AutomationProperties.AutomationId="ItemPromotionViewer_OpenPatchManager_Button"
                Content="Open Patch Manager" Click="OpenPatchManager_Click"
                HorizontalAlignment="Left" Margin="0,4,0,0" />
      </Grid>

      <!-- Address + Block-size + Selection metadata (mirrors WinForms panel5) -->
      <Grid Grid.Row="2" Margin="0,8,0,8"
            ColumnDefinitions="100,160,100,160,*"
            RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="1" Name="AddressLabel"
                   AutomationProperties.AutomationId="ItemPromotionViewer_Address_Label"
                   VerticalAlignment="Center" FontFamily="Consolas,Courier New" />
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Size:" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="3" Name="BlockSizeLabel"
                   AutomationProperties.AutomationId="ItemPromotionViewer_BlockSize_Label"
                   VerticalAlignment="Center" Text="1" />
        <Button Grid.Row="0" Grid.Column="4" Name="ReloadListButton"
                AutomationProperties.AutomationId="ItemPromotionViewer_ReloadList_Button"
                Content="Reload" Click="ReloadList_Click" HorizontalAlignment="Right" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Selected:" VerticalAlignment="Center" />
        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Name="SelectAddressLabel"
                   AutomationProperties.AutomationId="ItemPromotionViewer_SelectAddress_Label"
                   VerticalAlignment="Center" FontFamily="Consolas,Courier New" />
      </Grid>

      <!-- Two-pane content: inner class list + right edit panel -->
      <Grid Grid.Row="3" ColumnDefinitions="320,*">
        <!-- Inner list of classes for the selected CC item -->
        <Grid Grid.Column="0" Margin="0,0,8,0" RowDefinitions="Auto,*,Auto">
          <TextBlock Grid.Row="0" Text="Promotes (classes)" FontWeight="Bold" />
          <ListBox Grid.Row="1" Name="InnerList"
                   AutomationProperties.AutomationId="ItemPromotionViewer_Inner_List"
                   SelectionChanged="InnerList_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Image Source="{Binding Icon}" Width="32" Height="32"
                         IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                         Stretch="Fill" />
                  <TextBlock Text="{Binding Text}" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Button Grid.Row="2" Name="ListExpandsButton"
                  AutomationProperties.AutomationId="ItemPromotionViewer_ListExpands_Button"
                  Content="Expand List (+1 slot)" Click="ListExpands_Click"
                  HorizontalAlignment="Stretch" Margin="0,4,0,0" />
        </Grid>

        <!-- Right edit panel (per-class fields). Wrapped in a ScrollViewer
             so the controls stay reachable when the window is shrunk. -->
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto">
          <!-- Class edit row (mirrors WinForms label3/B0/L_0_CLASS/L_0_CLASSICON) -->
          <Grid Grid.Row="0" Margin="0,0,0,8"
                ColumnDefinitions="100,120,80,*,40"
                RowDefinitions="Auto">
            <TextBlock Grid.Column="0" Text="Class:" VerticalAlignment="Center"
                       AutomationProperties.AutomationId="ItemPromotionViewer_ClassId_Link"
                       Classes="Hyperlink" Name="ClassId_Link"
                       PointerPressed="OnClassIdLinkClick"
                       ToolTip.Tip="Click to open Class Editor" />
            <NumericUpDown Grid.Column="1" Name="ClassIdInput"
                           AutomationProperties.AutomationId="ItemPromotionViewer_ClassId_Input"
                           FormatString="0" Minimum="0" Maximum="255" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="Name:" VerticalAlignment="Center" />
            <TextBlock Grid.Column="3" Name="ClassNameLabel"
                       AutomationProperties.AutomationId="ItemPromotionViewer_ClassName_Label"
                       VerticalAlignment="Center" />
            <Image Grid.Column="4" Name="ClassIconImage"
                   AutomationProperties.AutomationId="ItemPromotionViewer_ClassIcon_Image"
                   Width="32" Height="32" Stretch="Fill" />
          </Grid>

          <!-- Write button -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Name="WriteButton"
                    AutomationProperties.AutomationId="ItemPromotionViewer_Write_Button"
                    Content="Write" Click="Write_Click" />
          </StackPanel>
        </Grid>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
