<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ClassEditorView">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl AutomationProperties.AutomationId="ClassEditor_Class_List" Grid.Row="0" Name="ClassList" Margin="4" />
      <!-- Selected class wait icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:IconPreviewControl AutomationProperties.AutomationId="ClassEditor_ListPreview_Image" Name="ListPreviewImage" Scale="2" MaxImageWidth="32" MaxImageHeight="32" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_ListPreviewName_Label" Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4" HorizontalScrollBarVisibility="Auto">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="Class Editor" FontSize="18" FontWeight="Bold" />

        <!-- Address/Name + address-bar infra (gap-sweep #406) -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock AutomationProperties.AutomationId="ClassEditor_SelectedAddressPrefix_Label"
                     Name="SelectedAddressPrefixLabel"
                     Text="Address:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_Addr_Label" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Text="Name:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,0,0" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_Name_Label" Name="NameLabel" VerticalAlignment="Center" />
          <!-- HardCoding warning hyperlink (parity with WF ClassForm.HardCodingWarningLabel) -->
          <TextBlock AutomationProperties.AutomationId="ClassEditor_HardCoding_Warning_Label"
                     Name="HardCodingWarningLabel"
                     Text="[HardCoding]"
                     Classes="Hyperlink"
                     Foreground="OrangeRed"
                     FontWeight="Bold"
                     IsVisible="False"
                     VerticalAlignment="Center"
                     Margin="16,0,0,0"
                     PointerPressed="HardCodingWarning_Click"
                     ToolTip.Tip="This class is referenced by hardcoded ASM. Click to view related patches." />
        </StackPanel>

        <!-- Read-table infra row (parity with WF ClassForm.ReadStartAddress / ReadCount / ReloadListButton / BlockSize).
             #649: migrated to unified EditorTopBar control. -->
        <controls:EditorTopBar Margin="0,2,0,0"
                               Name="TopBar"
                               AutomationProperties.AutomationId="ClassEditor_TopBar"
                               StartAddressLabel="Read Start Address:"
                               StartAddressAutomationId="ClassEditor_ReadStartAddress_Label"
                               ReadCountAutomationId="ClassEditor_ReadCount_Label"
                               SizeAutomationId="ClassEditor_Size_Label"
                               ReloadAutomationId="ClassEditor_Reload_Button"
                               ReloadRequested="OnTopBarReloadRequested" />

        <!-- Class Card Preview (issue #357): mirrors WinForms ClassForm top-right
             block — L_8_PORTRAIT_CLASS (face portrait) + L_5_CLASS (name) +
             L_6_CLASSICONSRC (map wait icon). Updates live as PortraitIdBox /
             WaitIconBox change in code-behind.UpdateClassCard(). -->
        <Border AutomationProperties.AutomationId="ClassEditor_ClassCard_Control"
                Name="ClassCardBorder" IsVisible="False"
                BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                Margin="0,4,0,2">
          <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
            <controls:IconPreviewControl
                AutomationProperties.AutomationId="ClassEditor_CardPortrait_Image"
                Name="CardPortraitImage" Grid.Column="0"
                Scale="2" MaxImageWidth="80" MaxImageHeight="80" Margin="0,0,12,0" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
              <TextBlock Text="Class Card" FontWeight="Bold" FontSize="14" />
              <TextBlock AutomationProperties.AutomationId="ClassEditor_CardName_Label"
                         Name="CardNameLabel" FontSize="13"
                         TextWrapping="Wrap" />
              <TextBlock AutomationProperties.AutomationId="ClassEditor_CardId_Label"
                         Name="CardIdLabel" Foreground="Gray" FontSize="11" />
            </StackPanel>
            <controls:IconPreviewControl
                AutomationProperties.AutomationId="ClassEditor_CardWaitIcon_Image"
                Name="CardWaitIconImage" Grid.Column="2"
                Scale="2" MaxImageWidth="32" MaxImageHeight="32"
                VerticalAlignment="Center" />
          </Grid>
        </Border>

        <!-- Identity / Misc -->
        <Expander AutomationProperties.AutomationId="ClassEditor_IdentityMisc_Expander" Header="Identity / Misc" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,380" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center"
                       AutomationProperties.AutomationId="ClassEditor_NameId_Link"
                       Classes="Hyperlink" Name="NameId_Link" PointerPressed="OnNameIdLinkClick"
                       ToolTip.Tip="Text ID for this class's display name (click to open Text Viewer)" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_NameId_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Desc ID (W2):" VerticalAlignment="Center"
                       AutomationProperties.AutomationId="ClassEditor_DescId_Link"
                       Classes="Hyperlink" Name="DescId_Link" PointerPressed="OnDescIdLinkClick"
                       ToolTip.Tip="Text ID for this class's description (click to open Text Viewer)" />
            <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
              <NumericUpDown AutomationProperties.AutomationId="ClassEditor_DescId_Input" FormatString="0" Name="DescIdBox" Minimum="0" Maximum="65535" Width="100" />
              <TextBlock AutomationProperties.AutomationId="ClassEditor_DescText_Label" Name="DescTextLabel" VerticalAlignment="Center" Foreground="Gray"
                         MaxWidth="200" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                         ToolTip.Tip="{Binding #DescTextLabel.Text}" />
              <Button AutomationProperties.AutomationId="ClassEditor_JumpToDesc_Button" Content="Desc" Click="JumpToDesc_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center"
                      ToolTip.Tip="Open text viewer for this description" />
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Class # (B4):" VerticalAlignment="Center"
                       ToolTip.Tip="Internal class number" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_ClassNumber_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="ClassNumberBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Promo Lv (B5):" VerticalAlignment="Center"
                       ToolTip.Tip="Level required for promotion (0=unpromoted)" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromotionLevel_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="PromotionLevelBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Wait Icon (B6):" VerticalAlignment="Center"
                       ToolTip.Tip="Map sprite index when idle" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WaitIcon_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="WaitIconBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Walk Spd (B7):" VerticalAlignment="Center"
                       ToolTip.Tip="Walking speed on the map" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WalkSpeed_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="WalkSpeedBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Portrait (W8):" VerticalAlignment="Center"
                       AutomationProperties.AutomationId="ClassEditor_Portrait_Link"
                       Classes="Hyperlink" Name="Portrait_Link" PointerPressed="OnPortraitLinkClick"
                       ToolTip.Tip="Portrait graphic index (click to open Portrait Viewer)" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PortraitId_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="PortraitIdBox" Minimum="0" Maximum="65535" />
            <TextBlock Grid.Row="3" Grid.Column="3" Text="Sort Order (B10):" VerticalAlignment="Center"
                       ToolTip.Tip="Sort order for class list" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_SortOrder_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="SortOrderBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Base Stats -->
        <Expander AutomationProperties.AutomationId="ClassEditor_BaseStats_Expander" Header="Base Stats" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (B11):" VerticalAlignment="Center"
                       ToolTip.Tip="Base HP for this class" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="BaseHpBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (B12):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="BaseStrBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skl (B13):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="BaseSklBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Spd (B14):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="BaseSpdBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def (B15):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="BaseDefBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Res (B16):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="BaseResBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Con (B17):" VerticalAlignment="Center"
                       ToolTip.Tip="Base constitution" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseCon_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="BaseConBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="3" Grid.Column="3" Text="Mov (B18):" VerticalAlignment="Center"
                       ToolTip.Tip="Base movement range" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseMov_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="BaseMovBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Stat Caps -->
        <Expander AutomationProperties.AutomationId="ClassEditor_StatCaps_Expander" Header="Stat Caps (Max Values)" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Max HP (B19):" VerticalAlignment="Center"
                       ToolTip.Tip="Maximum HP stat cap for this class" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="MaxHpBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Max Str (B20):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="MaxStrBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Skl (B21):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="MaxSklBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Max Spd (B22):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="MaxSpdBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Def (B23):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="MaxDefBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Max Res (B24):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="MaxResBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Max Con (B25):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_MaxCon_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="MaxConBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="3" Grid.Column="3" Text="Power (B26):" VerticalAlignment="Center"
                       ToolTip.Tip="Class power / EXP correction value" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_ClassPower_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="ClassPowerBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Growth Rates -->
        <Expander AutomationProperties.AutomationId="ClassEditor_GrowthRates_Expander" Header="Growth Rates" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (B27):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="GrowHpBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (B28):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="GrowStrBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skl (B29):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="GrowSklBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Spd (B30):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="GrowSpdBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def (B31):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="GrowDefBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Res (B32):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="GrowResBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Lck (B33):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowLck_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="GrowLckBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Promotion Gains / CC Bonus -->
        <Expander AutomationProperties.AutomationId="ClassEditor_PromotionGains_Expander" Header="Promotion Gains (CC Bonus)" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (b34):" VerticalAlignment="Center"
                       ToolTip.Tip="HP bonus gained on class change" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="PromoHpBox" Minimum="-128" Maximum="127" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (b35):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="PromoStrBox" Minimum="-128" Maximum="127" />

            <!-- FE6 has no Skl/Spd/Def/Res promotion gains; these rows are hidden for FE6 -->
            <TextBlock AutomationProperties.AutomationId="ClassEditor_PromoSklLabel_Label" Grid.Row="1" Grid.Column="0" Name="PromoSklLabel" Text="Skl (b36):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="PromoSklBox" Minimum="-128" Maximum="127" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_PromoSpdLabel_Label" Grid.Row="1" Grid.Column="3" Name="PromoSpdLabel" Text="Spd (b37):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="PromoSpdBox" Minimum="-128" Maximum="127" />

            <TextBlock AutomationProperties.AutomationId="ClassEditor_PromoDefLabel_Label" Grid.Row="2" Grid.Column="0" Name="PromoDefLabel" Text="Def (b38):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="PromoDefBox" Minimum="-128" Maximum="127" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_PromoResLabel_Label" Grid.Row="2" Grid.Column="3" Name="PromoResLabel" Text="Res (b39):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromoRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="PromoResBox" Minimum="-128" Maximum="127" />
          </Grid>
        </Border>
        </Expander>

        <!-- Ability Flags -->
        <Expander AutomationProperties.AutomationId="ClassEditor_AbilityFlags_Expander" Header="Ability Flags" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText1_Label" Name="AbilityHeaderText1" Text="Ability 1 (B40):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability1_Check" Name="Ability1Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText2_Label" Name="AbilityHeaderText2" Text="Ability 2 (B41):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability2_Check" Name="Ability2Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText3_Label" Name="AbilityHeaderText3" Text="Ability 3 (B42):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability3_Check" Name="Ability3Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText4_Label" Name="AbilityHeaderText4" Text="Ability 4 (B43):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability4_Check" Name="Ability4Flags" />
          </StackPanel>
        </Border>
        </Expander>

        <!-- Weapon Rank Levels -->
        <Expander AutomationProperties.AutomationId="ClassEditor_WeaponRankLevelsB44B51_Expander" Name="WepRankExpander" Header="Weapon Rank Levels (B44-B51)" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankSwordLabel_Label" Grid.Row="0" Grid.Column="0" Name="WepRankSwordLabel" Text="Sword (B44):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B44_Input" FormatString="0" Name="B44Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B44Rank_Label" Name="B44RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankLanceLabel_Label" Grid.Row="0" Grid.Column="3" Name="WepRankLanceLabel" Text="Lance (B45):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B45_Input" FormatString="0" Name="B45Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B45Rank_Label" Name="B45RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankAxeLabel_Label" Grid.Row="1" Grid.Column="0" Name="WepRankAxeLabel" Text="Axe (B46):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B46_Input" FormatString="0" Name="B46Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B46Rank_Label" Name="B46RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankBowLabel_Label" Grid.Row="1" Grid.Column="3" Name="WepRankBowLabel" Text="Bow (B47):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B47_Input" FormatString="0" Name="B47Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B47Rank_Label" Name="B47RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankStaffLabel_Label" Grid.Row="2" Grid.Column="0" Name="WepRankStaffLabel" Text="Staff (B48):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B48_Input" FormatString="0" Name="B48Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B48Rank_Label" Name="B48RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankAnimaLabel_Label" Grid.Row="2" Grid.Column="3" Name="WepRankAnimaLabel" Text="Anima (B49):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B49_Input" FormatString="0" Name="B49Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B49Rank_Label" Name="B49RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankLightLabel_Label" Grid.Row="3" Grid.Column="0" Name="WepRankLightLabel" Text="Light (B50):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B50_Input" FormatString="0" Name="B50Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B50Rank_Label" Name="B50RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankDarkLabel_Label" Grid.Row="3" Grid.Column="3" Name="WepRankDarkLabel" Text="Dark (B51):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="3" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B51_Input" FormatString="0" Name="B51Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B51Rank_Label" Name="B51RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
        </Border>
        </Expander>

        <!-- Movement / Terrain -->
        <Expander AutomationProperties.AutomationId="ClassEditor_PointersMovementTerrain_Expander" Header="Pointers / Movement / Terrain" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="160,175,20,160,175" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock AutomationProperties.AutomationId="ClassEditor_BattleAnimeLabel_Label" Grid.Row="0" Grid.Column="0" Name="BattleAnimeLabel" Text="Battle Anime (P52):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to battle animation data" />
          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr52_Input" Name="Ptr52Box" Width="120" />
            <Button AutomationProperties.AutomationId="ClassEditor_JumpToBattleAnime_Button" Content="Jump" Click="JumpToBattleAnime_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostLabel_Label" Grid.Row="0" Grid.Column="3" Name="MoveCostLabel" Text="Move Cost (P56):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to terrain movement cost table" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr56_Input" Name="Ptr56Box" Width="120" />
            <Button AutomationProperties.AutomationId="ClassEditor_JumpToMoveCost_Button" Content="Jump" Click="JumpToMoveCost_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostRainLabel_Label" Grid.Row="1" Grid.Column="0" Name="MoveCostRainLabel" Text="Move Cost Rain (P60):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr60_Input" Name="Ptr60Box" Width="120" />
            <Button AutomationProperties.AutomationId="ClassEditor_JumpToPtr60_Button" Content="Jump" Click="JumpToPtr60_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostSnowLabel_Label" Grid.Row="1" Grid.Column="3" Name="MoveCostSnowLabel" Text="Move Cost Snow (P64):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr64_Input" Name="Ptr64Box" Width="120" />
            <Button AutomationProperties.AutomationId="ClassEditor_JumpToPtr64_Button" Content="Jump" Click="JumpToPtr64_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Terrain pointers row (shows Avoid+Def for FE7/8, Res only for FE6) -->
          <StackPanel Name="TerrainRow" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="0">
            <Grid ColumnDefinitions="160,175,20,160,175" RowDefinitions="Auto">
              <TextBlock AutomationProperties.AutomationId="ClassEditor_TerrainAvoid_Label" Grid.Row="0" Grid.Column="0" Name="TerrainAvoidLabel" Text="Terrain Avoid (P68):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr68_Input" Name="Ptr68Box" Width="120" />
                <Button AutomationProperties.AutomationId="ClassEditor_JumpToPtr68_Button" Content="Jump" Click="JumpToPtr68_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock AutomationProperties.AutomationId="ClassEditor_TerrainDef_Label" Grid.Row="0" Grid.Column="3" Name="TerrainDefLabel" Text="Terrain Def (P72):" VerticalAlignment="Center" />
              <StackPanel Name="Ptr72Wrapper" Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
                <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr72_Input" Name="Ptr72Box" Width="120" />
                <Button AutomationProperties.AutomationId="ClassEditor_JumpToPtr72_Button" Name="JumpToPtr72Button" Content="Jump" Click="JumpToPtr72_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- D80 / Terrain Res row (FE7/8 only; hidden for FE6 which has no D80) -->
          <StackPanel Name="D80Row" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Margin="0">
            <Grid ColumnDefinitions="160,175,20,160,175" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Terrain Res (P76):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr76_Input" Name="Ptr76Box" Width="120" />
                <Button AutomationProperties.AutomationId="ClassEditor_JumpToPtr76_Button" Content="Jump" Click="JumpToPtr76_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Row="0" Grid.Column="3" Text="??? (D80):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ClassEditor_D80_Input" Grid.Row="0" Grid.Column="4" Name="D80Box" Width="120" />
            </Grid>
          </StackPanel>
        </Grid>
        </Border>
        </Expander>

        <!-- Growth Simulator -->
        <Expander AutomationProperties.AutomationId="ClassEditor_GrowthSimulator_Expander" Header="Growth Simulator" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button AutomationProperties.AutomationId="ClassEditor_CalculateGrowth_Button" Content="Calculate Growth" Click="CalculateGrowth_Click" />
              <TextBlock Text="Sim Level:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="ClassEditor_SimLevel_Input" FormatString="0" Name="SimLevelBox" Minimum="1" Maximum="99" Value="20" Width="90" />
            </StackPanel>
            <TextBlock AutomationProperties.AutomationId="ClassEditor_GrowthSim_Label" Name="GrowthSimLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        </Expander>

        <!-- Validation Warnings -->
        <Border Name="WarningsBorder" IsVisible="False"
                BorderBrush="Orange" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="{DynamicResource AccentOverlayBrush}" Margin="0,8,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Warnings" FontWeight="Bold" Foreground="DarkOrange" />
            <ItemsControl AutomationProperties.AutomationId="ClassEditor_Warnings_List" Name="WarningsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="DarkOrange" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Export/Import Options panel (parity with WF ClassForm CSV checkbox bank — gap-sweep #406) -->
        <Expander AutomationProperties.AutomationId="ClassEditor_ExportImportOptions_Expander"
                  Header="Export/Import Options" IsExpanded="False" Margin="0,8,0,0">
          <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
              <!-- Defaults match WF ClassForm: UseClipboard=false, all 7 others=true -->
              <CheckBox AutomationProperties.AutomationId="ClassEditor_UseClipboard_Check"
                        Grid.Row="0" Grid.Column="0" Name="UseClipboardCheck" Content="Use Clipboard" Margin="0,2" IsChecked="False" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeHeader_Check"
                        Grid.Row="0" Grid.Column="1" Name="IncludeHeaderCheck" Content="Include Header" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeUID_Check"
                        Grid.Row="1" Grid.Column="0" Name="IncludeUIDCheck" Content="Include UID" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeName_Check"
                        Grid.Row="1" Grid.Column="1" Name="IncludeNameCheck" Content="Include Name" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeBaseStats_Check"
                        Grid.Row="2" Grid.Column="0" Name="IncludeBaseStatsCheck" Content="Include Base Stats" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeGrowths_Check"
                        Grid.Row="2" Grid.Column="1" Name="IncludeGrowthsCheck" Content="Include Growths" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_IncludeWepLevel_Check"
                        Grid.Row="3" Grid.Column="0" Name="IncludeWepLevelCheck" Content="Include Wep Level" Margin="0,2" IsChecked="True" />
              <CheckBox AutomationProperties.AutomationId="ClassEditor_GrowthsAsDecimal_Check"
                        Grid.Row="3" Grid.Column="1" Name="GrowthsAsDecimalCheck" Content="Growths as Decimal" Margin="0,2" IsChecked="True" />
            </Grid>
          </Border>
        </Expander>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ClassEditor_Write_Button" Content="Write" Click="Write_Click" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <!-- 4 CSV buttons (parity with WF ClassForm Export/Import All/Selected — gap-sweep #406) -->
          <Button AutomationProperties.AutomationId="ClassEditor_ExportAll_Button" Content="Export All" Click="ExportAll_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export all classes to a CSV file or clipboard" />
          <Button AutomationProperties.AutomationId="ClassEditor_ExportSelected_Button" Content="Export Selected" Click="ExportSelected_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export the selected class to a CSV file or clipboard" />
          <Button AutomationProperties.AutomationId="ClassEditor_ImportAll_Button" Content="Import All" Click="ImportAll_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import all classes from a CSV file or clipboard" />
          <Button AutomationProperties.AutomationId="ClassEditor_ImportSelected_Button" Content="Import Selected" Click="ImportSelected_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import the selected class from a CSV file or clipboard" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <!-- CC Branch jump (FE8 only — parity with WF ClassForm.J_5_Click) -->
          <Button AutomationProperties.AutomationId="ClassEditor_JumpToCCBranch_Button" Content="CC Branch" Click="JumpToCCBranch_Click" Name="JumpToCCBranchButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open the class-change branch editor for this class (FE8 only)" />
          <Button AutomationProperties.AutomationId="ClassEditor_EditSkills_Button" Content="Edit Skills" Click="EditSkills_Click" Name="EditSkillsButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open skill assignment editor for this class" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
