<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ClassEditorView"
        Title="Class Editor" Width="1200" Height="900"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl AutomationProperties.AutomationId="ClassEditor_Class_List" Grid.Row="0" Name="ClassList" Margin="4" />
      <!-- Selected class wait icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:GbaImageControl AutomationProperties.AutomationId="ClassEditor_ListPreview_Image" Name="ListPreviewImage" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_ListPreviewName_Label" Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="Class Editor" FontSize="18" FontWeight="Bold" />

        <!-- Address/Name -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Address:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_Addr_Label" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Text="Name:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,0,0" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_Name_Label" Name="NameLabel" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Identity / Misc -->
        <Expander AutomationProperties.AutomationId="ClassEditor_IdentityMisc_Expander" Header="Identity / Misc" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center"
                       ToolTip.Tip="Text ID for this class's display name" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_NameId_Input" FormatString="X4" Grid.Row="0" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Desc ID (W2):" VerticalAlignment="Center"
                       ToolTip.Tip="Text ID for this class's description" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_DescId_Input" FormatString="X4" Grid.Row="0" Grid.Column="4" Name="DescIdBox" Minimum="0" Maximum="65535" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Class # (B4):" VerticalAlignment="Center"
                       ToolTip.Tip="Internal class number" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_ClassNumber_Input" FormatString="X2" Grid.Row="1" Grid.Column="1" Name="ClassNumberBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Promo Lv (B5):" VerticalAlignment="Center"
                       ToolTip.Tip="Level required for promotion (0=unpromoted)" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PromotionLevel_Input" FormatString="X2" Grid.Row="1" Grid.Column="4" Name="PromotionLevelBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Wait Icon (B6):" VerticalAlignment="Center"
                       ToolTip.Tip="Map sprite index when idle" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WaitIcon_Input" FormatString="X2" Grid.Row="2" Grid.Column="1" Name="WaitIconBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Walk Spd (B7):" VerticalAlignment="Center"
                       ToolTip.Tip="Walking speed on the map" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WalkSpeed_Input" FormatString="X2" Grid.Row="2" Grid.Column="4" Name="WalkSpeedBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Portrait (W8):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_PortraitId_Input" FormatString="X4" Grid.Row="3" Grid.Column="1" Name="PortraitIdBox" Minimum="0" Maximum="65535" />
            <TextBlock Grid.Row="3" Grid.Column="3" Text="Build (B10):" VerticalAlignment="Center"
                       ToolTip.Tip="Constitution/Build stat" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BuildStat_Input" FormatString="X2" Grid.Row="3" Grid.Column="4" Name="BuildStatBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Base Stats -->
        <Expander AutomationProperties.AutomationId="ClassEditor_BaseStats_Expander" Header="Base Stats" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (B11):" VerticalAlignment="Center"
                       ToolTip.Tip="Base HP for this class" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="BaseHpBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (B12):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="BaseStrBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skl (B13):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="BaseSklBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Spd (B14):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="BaseSpdBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def (B15):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="BaseDefBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Res (B16):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_BaseRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="BaseResBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Mov (B17):" VerticalAlignment="Center"
                       ToolTip.Tip="Base movement range" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_Mov_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="MovBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="3" Grid.Column="3" Text="Con (B18):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_Con_Input" FormatString="0" Grid.Row="3" Grid.Column="4" Name="ConBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Weapon Levels -->
        <Expander AutomationProperties.AutomationId="ClassEditor_WeaponLevels_Expander" Header="Weapon Levels" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="2">
            <TextBlock Text="HP Cap (B19):" FontWeight="SemiBold" Margin="0,0,0,4" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_ClassStat19_Input" FormatString="0" Name="ClassStat19Box" Minimum="0" Maximum="255" Width="170" HorizontalAlignment="Left" />
            <TextBlock Text="Base Weapon Levels (B20-B26):" FontWeight="SemiBold" Margin="0,6,0,2" />
            <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Sword (B20):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepSword_Input" FormatString="0" Name="WepSwordBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepSwordRank_Label" Name="WepSwordRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Row="0" Grid.Column="3" Text="Lance (B21):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepLance_Input" FormatString="0" Name="WepLanceBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepLanceRank_Label" Name="WepLanceRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Axe (B22):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepAxe_Input" FormatString="0" Name="WepAxeBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepAxeRank_Label" Name="WepAxeRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Row="1" Grid.Column="3" Text="Bow (B23):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepBow_Input" FormatString="0" Name="WepBowBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepBowRank_Label" Name="WepBowRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Staff (B24):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepStaff_Input" FormatString="0" Name="WepStaffBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepStaffRank_Label" Name="WepStaffRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Grid.Row="2" Grid.Column="3" Text="Anima (B25):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepAnima_Input" FormatString="0" Name="WepAnimaBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepAnimaRank_Label" Name="WepAnimaRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="130,170" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Light (B26):" VerticalAlignment="Center" />
              <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <NumericUpDown AutomationProperties.AutomationId="ClassEditor_WepLight_Input" FormatString="0" Name="WepLightBox" Minimum="0" Maximum="255" Width="120" />
                <TextBlock AutomationProperties.AutomationId="ClassEditor_WepLightRank_Label" Name="WepLightRankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
        </Expander>

        <!-- Growth Rates -->
        <Expander AutomationProperties.AutomationId="ClassEditor_GrowthRates_Expander" Header="Growth Rates" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (B27):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="GrowHpBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (B28):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="GrowStrBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skl (B29):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="GrowSklBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Spd (B30):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="GrowSpdBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def (B31):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="GrowDefBox" Minimum="0" Maximum="255" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Res (B32):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="GrowResBox" Minimum="0" Maximum="255" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Lck (B33):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_GrowLck_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="GrowLckBox" Minimum="0" Maximum="255" />
          </Grid>
        </Border>
        </Expander>

        <!-- Growth Caps / Promotion Bonuses -->
        <Expander AutomationProperties.AutomationId="ClassEditor_GrowthCapsPromotionBonuses_Expander" Header="Growth Caps / Promotion Bonuses" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP (b34):" VerticalAlignment="Center"
                       ToolTip.Tip="Stat cap or promotion bonus for HP" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapHp_Input" FormatString="0" Grid.Row="0" Grid.Column="1" Name="CapHpBox" Minimum="-128" Maximum="127" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str (b35):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapStr_Input" FormatString="0" Grid.Row="0" Grid.Column="4" Name="CapStrBox" Minimum="-128" Maximum="127" />

            <!-- FE6 has no Skl/Spd/Def/Res caps; these rows are hidden for FE6 -->
            <TextBlock AutomationProperties.AutomationId="ClassEditor_CapSklLabel_Label" Grid.Row="1" Grid.Column="0" Name="CapSklLabel" Text="Skl (b36):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapSkl_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="CapSklBox" Minimum="-128" Maximum="127" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_CapSpdLabel_Label" Grid.Row="1" Grid.Column="3" Name="CapSpdLabel" Text="Spd (b37):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapSpd_Input" FormatString="0" Grid.Row="1" Grid.Column="4" Name="CapSpdBox" Minimum="-128" Maximum="127" />

            <TextBlock AutomationProperties.AutomationId="ClassEditor_CapDefLabel_Label" Grid.Row="2" Grid.Column="0" Name="CapDefLabel" Text="Def (b38):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapDef_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="CapDefBox" Minimum="-128" Maximum="127" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_CapResLabel_Label" Grid.Row="2" Grid.Column="3" Name="CapResLabel" Text="Res (b39):" VerticalAlignment="Center" />
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_CapRes_Input" FormatString="0" Grid.Row="2" Grid.Column="4" Name="CapResBox" Minimum="-128" Maximum="127" />
          </Grid>
        </Border>
        </Expander>

        <!-- Ability Flags -->
        <Expander AutomationProperties.AutomationId="ClassEditor_AbilityFlags_Expander" Header="Ability Flags" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText1_Label" Name="AbilityHeaderText1" Text="Ability 1 (B40):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability1_Check" Name="Ability1Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText2_Label" Name="AbilityHeaderText2" Text="Ability 2 (B41):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability2_Check" Name="Ability2Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText3_Label" Name="AbilityHeaderText3" Text="Ability 3 (B42):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability3_Check" Name="Ability3Flags" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_AbilityHeaderText4_Label" Name="AbilityHeaderText4" Text="Ability 4 (B43):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel AutomationProperties.AutomationId="ClassEditor_Ability4_Check" Name="Ability4Flags" />
          </StackPanel>
        </Border>
        </Expander>

        <!-- Weapon Rank Levels -->
        <Expander AutomationProperties.AutomationId="ClassEditor_WeaponRankLevelsB44B51_Expander" Name="WepRankExpander" Header="Weapon Rank Levels (B44-B51)" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankSwordLabel_Label" Grid.Row="0" Grid.Column="0" Name="WepRankSwordLabel" Text="Sword (B44):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B44_Input" FormatString="0" Name="B44Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B44Rank_Label" Name="B44RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankLanceLabel_Label" Grid.Row="0" Grid.Column="3" Name="WepRankLanceLabel" Text="Lance (B45):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B45_Input" FormatString="0" Name="B45Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B45Rank_Label" Name="B45RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankAxeLabel_Label" Grid.Row="1" Grid.Column="0" Name="WepRankAxeLabel" Text="Axe (B46):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B46_Input" FormatString="0" Name="B46Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B46Rank_Label" Name="B46RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankBowLabel_Label" Grid.Row="1" Grid.Column="3" Name="WepRankBowLabel" Text="Bow (B47):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B47_Input" FormatString="0" Name="B47Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B47Rank_Label" Name="B47RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankStaffLabel_Label" Grid.Row="2" Grid.Column="0" Name="WepRankStaffLabel" Text="Staff (B48):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B48_Input" FormatString="0" Name="B48Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B48Rank_Label" Name="B48RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankAnimaLabel_Label" Grid.Row="2" Grid.Column="3" Name="WepRankAnimaLabel" Text="Anima (B49):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B49_Input" FormatString="0" Name="B49Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B49Rank_Label" Name="B49RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankLightLabel_Label" Grid.Row="3" Grid.Column="0" Name="WepRankLightLabel" Text="Light (B50):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B50_Input" FormatString="0" Name="B50Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B50Rank_Label" Name="B50RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock AutomationProperties.AutomationId="ClassEditor_WepRankDarkLabel_Label" Grid.Row="3" Grid.Column="3" Name="WepRankDarkLabel" Text="Dark (B51):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="3" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <NumericUpDown AutomationProperties.AutomationId="ClassEditor_B51_Input" FormatString="0" Name="B51Box" Minimum="0" Maximum="255" Width="120" />
            <TextBlock AutomationProperties.AutomationId="ClassEditor_B51Rank_Label" Name="B51RankText" Text="-" FontWeight="Bold" FontSize="14" MinWidth="20" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
        </Border>
        </Expander>

        <!-- Movement / Terrain -->
        <Expander AutomationProperties.AutomationId="ClassEditor_PointersMovementTerrain_Expander" Header="Pointers / Movement / Terrain" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
        <Grid ColumnDefinitions="130,200,20,130,200" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock AutomationProperties.AutomationId="ClassEditor_BattleAnimeLabel_Label" Grid.Row="0" Grid.Column="0" Name="BattleAnimeLabel" Text="Battle Anime (P52):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to battle animation data" />
          <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr52_Input" Grid.Row="0" Grid.Column="1" Name="Ptr52Box" Width="120" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostLabel_Label" Grid.Row="0" Grid.Column="3" Name="MoveCostLabel" Text="Move Cost (P56):" VerticalAlignment="Center"
                     ToolTip.Tip="Pointer to terrain movement cost table" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr56_Input" Name="Ptr56Box" Width="120" />
            <Button AutomationProperties.AutomationId="ClassEditor_JumpToMoveCost_Button" Content="Jump" Click="JumpToMoveCost_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostRainLabel_Label" Grid.Row="1" Grid.Column="0" Name="MoveCostRainLabel" Text="Move Cost Rain (P60):" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr60_Input" Grid.Row="1" Grid.Column="1" Name="Ptr60Box" Width="120" />
          <TextBlock AutomationProperties.AutomationId="ClassEditor_MoveCostSnowLabel_Label" Grid.Row="1" Grid.Column="3" Name="MoveCostSnowLabel" Text="Move Cost Snow (P64):" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr64_Input" Grid.Row="1" Grid.Column="4" Name="Ptr64Box" Width="120" />

          <!-- Terrain pointers row (FE7/8 only, hidden for FE6) -->
          <StackPanel Name="TerrainRow" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="0">
            <Grid ColumnDefinitions="130,200,20,130,200" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Terrain Avoid (P68):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr68_Input" Grid.Row="0" Grid.Column="1" Name="Ptr68Box" Width="120" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="Terrain Def (P72):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr72_Input" Grid.Row="0" Grid.Column="4" Name="Ptr72Box" Width="120" />
            </Grid>
          </StackPanel>

          <!-- D80 / Terrain Res row (FE7/8 only, hidden for FE6) -->
          <StackPanel Name="D80Row" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Margin="0">
            <Grid ColumnDefinitions="130,200,20,130,200" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Terrain Res (P76):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ClassEditor_Ptr76_Input" Grid.Row="0" Grid.Column="1" Name="Ptr76Box" Width="120" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="??? (D80):" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ClassEditor_D80_Input" Grid.Row="0" Grid.Column="4" Name="D80Box" Width="120" />
            </Grid>
          </StackPanel>
        </Grid>
        </Border>
        </Expander>

        <!-- Growth Simulator -->
        <Expander AutomationProperties.AutomationId="ClassEditor_GrowthSimulator_Expander" Header="Growth Simulator" IsExpanded="True" Margin="0,4,0,2">
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button AutomationProperties.AutomationId="ClassEditor_CalculateGrowth_Button" Content="Calculate Growth" Click="CalculateGrowth_Click" />
              <TextBlock Text="Sim Level:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="ClassEditor_SimLevel_Input" FormatString="0" Name="SimLevelBox" Minimum="1" Maximum="99" Value="20" Width="90" />
            </StackPanel>
            <TextBlock AutomationProperties.AutomationId="ClassEditor_GrowthSim_Label" Name="GrowthSimLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        </Expander>

        <!-- Validation Warnings -->
        <Border Name="WarningsBorder" IsVisible="False"
                BorderBrush="Orange" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="{DynamicResource AccentOverlayBrush}" Margin="0,8,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Warnings" FontWeight="Bold" Foreground="DarkOrange" />
            <ItemsControl AutomationProperties.AutomationId="ClassEditor_Warnings_List" Name="WarningsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="DarkOrange" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ClassEditor_Write_Button" Content="Write" Click="Write_Click" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button AutomationProperties.AutomationId="ClassEditor_ExportTSV_Button" Content="Export TSV" Click="ExportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export all classes to a TSV file" />
          <Button AutomationProperties.AutomationId="ClassEditor_ImportTSV_Button" Content="Import TSV" Click="ImportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import classes from a TSV file" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button AutomationProperties.AutomationId="ClassEditor_EditSkills_Button" Content="Edit Skills" Click="EditSkills_Click" Name="EditSkillsButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open skill assignment editor for this class" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
