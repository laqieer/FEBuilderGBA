<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ClassEditorView"
        Title="Class Editor" Width="1200" Height="900">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List with icon preview -->
    <Grid Grid.Column="0" RowDefinitions="*,Auto">
      <controls:AddressListControl Grid.Row="0" Name="ClassList" Margin="4" />
      <!-- Selected class wait icon preview -->
      <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
              HorizontalAlignment="Center" Margin="4,2,4,4" Padding="4"
              CornerRadius="4" BorderBrush="Gray" BorderThickness="1"
              Name="ListPreviewBorder" IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <controls:GbaImageControl Name="ListPreviewImage" />
          <TextBlock Name="ListPreviewName" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" />
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="Class Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <!-- Identity -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID (W0):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Desc ID (W2):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="4" Name="DescIdBox" Minimum="0" Maximum="65535" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Class # (B4):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="ClassNumberBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Promo Lv (B5):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="4" Name="PromotionLevelBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Wait Icon (B6):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="WaitIconBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Walk Spd (B7):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="4" Name="WalkSpeedBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Portrait (W8):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="PortraitIdBox" Minimum="0" Maximum="65535" />
          <TextBlock Grid.Row="4" Grid.Column="3" Text="Build (B10):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="4" Grid.Column="4" Name="BuildStatBox" Minimum="0" Maximum="255" />

          <!-- Base Stats -->
          <TextBlock Grid.Row="5" Grid.Column="0" Text="--- Base Stats ---" FontWeight="SemiBold" Grid.ColumnSpan="5" Margin="0,6,0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="HP (B11):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="BaseHpBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="6" Grid.Column="3" Text="Str (B12):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="4" Name="BaseStrBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Skl (B13):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="BaseSklBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="7" Grid.Column="3" Text="Spd (B14):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="4" Name="BaseSpdBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Def (B15):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="BaseDefBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="8" Grid.Column="3" Text="Res (B16):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="4" Name="BaseResBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Mov (B17):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="MovBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="9" Grid.Column="3" Text="Con (B18):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="4" Name="ConBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="HP Cap (B19):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="ClassStat19Box" Minimum="0" Maximum="255" />

          <!-- Weapon Levels -->
          <TextBlock Grid.Row="11" Grid.Column="0" Text="--- Weapons ---" FontWeight="SemiBold" Grid.ColumnSpan="5" Margin="0,6,0,2" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="Sword (B20):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="1" Name="WepSwordBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="12" Grid.Column="3" Text="Lance (B21):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="12" Grid.Column="4" Name="WepLanceBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="13" Grid.Column="0" Text="Axe (B22):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="1" Name="WepAxeBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="13" Grid.Column="3" Text="Bow (B23):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="4" Name="WepBowBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="14" Grid.Column="0" Text="Staff (B24):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="14" Grid.Column="1" Name="WepStaffBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="14" Grid.Column="3" Text="Anima (B25):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="14" Grid.Column="4" Name="WepAnimaBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="15" Grid.Column="0" Text="Light (B26):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="15" Grid.Column="1" Name="WepLightBox" Minimum="0" Maximum="255" />

          <!-- Growth Rates -->
          <TextBlock Grid.Row="16" Grid.Column="0" Text="--- Growth Rates ---" FontWeight="SemiBold" Grid.ColumnSpan="5" Margin="0,6,0,2" />

          <TextBlock Grid.Row="17" Grid.Column="0" Text="HP (B27):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="17" Grid.Column="1" Name="GrowHpBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="17" Grid.Column="3" Text="Str (B28):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="17" Grid.Column="4" Name="GrowStrBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="18" Grid.Column="0" Text="Skl (B29):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="18" Grid.Column="1" Name="GrowSklBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="18" Grid.Column="3" Text="Spd (B30):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="18" Grid.Column="4" Name="GrowSpdBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="19" Grid.Column="0" Text="Def (B31):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="19" Grid.Column="1" Name="GrowDefBox" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="19" Grid.Column="3" Text="Res (B32):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="19" Grid.Column="4" Name="GrowResBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="20" Grid.Column="0" Text="Lck (B33):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="20" Grid.Column="1" Name="GrowLckBox" Minimum="0" Maximum="255" />

          <!-- Stat Caps / Promotion Bonuses -->
          <TextBlock Grid.Row="21" Grid.Column="0" Text="--- Caps/Promo ---" FontWeight="SemiBold" Grid.ColumnSpan="5" Margin="0,6,0,2" />

          <TextBlock Grid.Row="22" Grid.Column="0" Text="HP (b34):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="22" Grid.Column="1" Name="CapHpBox" Minimum="-128" Maximum="127" />
          <TextBlock Grid.Row="22" Grid.Column="3" Text="Str (b35):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="22" Grid.Column="4" Name="CapStrBox" Minimum="-128" Maximum="127" />

          <TextBlock Grid.Row="23" Grid.Column="0" Text="Skl (b36):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="23" Grid.Column="1" Name="CapSklBox" Minimum="-128" Maximum="127" />
          <TextBlock Grid.Row="23" Grid.Column="3" Text="Spd (b37):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="23" Grid.Column="4" Name="CapSpdBox" Minimum="-128" Maximum="127" />

          <TextBlock Grid.Row="24" Grid.Column="0" Text="Def (b38):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="24" Grid.Column="1" Name="CapDefBox" Minimum="-128" Maximum="127" />
          <TextBlock Grid.Row="24" Grid.Column="3" Text="Res (b39):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="24" Grid.Column="4" Name="CapResBox" Minimum="-128" Maximum="127" />

          <!-- Ability Flags -->
          <TextBlock Grid.Row="25" Grid.Column="0" Text="--- Abilities ---" FontWeight="SemiBold" Grid.ColumnSpan="5" Margin="0,6,0,2" />
        </Grid>

        <!-- Ability BitFlag Panels (outside the inner grid for full width) -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock Text="Ability 1 (B40):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability1Flags" />
            <TextBlock Text="Ability 2 (B41):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability2Flags" />
            <TextBlock Text="Ability 3 (B42):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability3Flags" />
            <TextBlock Text="Ability 4 (B43):" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability4Flags" />
          </StackPanel>
        </Border>

        <!-- Weapon Rank Levels -->
        <TextBlock Text="--- Weapon Rank Levels ---" FontWeight="SemiBold" Margin="0,6,0,2" />
        <Grid ColumnDefinitions="130,170,20,130,170" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Sword (B44):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Name="B44Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Lance (B45):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="0" Grid.Column="4" Name="B45Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Axe (B46):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="B46Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Bow (B47):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="4" Name="B47Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Staff (B48):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="B48Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Anima (B49):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="2" Grid.Column="4" Name="B49Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Light (B50):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="B50Box" Minimum="0" Maximum="255" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="Dark (B51):" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="4" Name="B51Box" Minimum="0" Maximum="255" />
        </Grid>

        <!-- Pointers & D80 -->
        <TextBlock Text="--- Pointers ---" FontWeight="SemiBold" Margin="0,6,0,2" />
        <Grid ColumnDefinitions="130,200,20,130,200" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Battle Anime (P52):" VerticalAlignment="Center" />
          <TextBox Grid.Row="0" Grid.Column="1" Name="Ptr52Box" Width="120" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="Move Cost (P56):" VerticalAlignment="Center" />
          <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="4">
            <TextBox Name="Ptr56Box" Width="120" />
            <Button Content="Jump" Click="JumpToMoveCost_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
          </StackPanel>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Move Cost Rain (P60):" VerticalAlignment="Center" />
          <TextBox Grid.Row="1" Grid.Column="1" Name="Ptr60Box" Width="120" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="Move Cost Snow (P64):" VerticalAlignment="Center" />
          <TextBox Grid.Row="1" Grid.Column="4" Name="Ptr64Box" Width="120" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Terrain Avoid (P68):" VerticalAlignment="Center" />
          <TextBox Grid.Row="2" Grid.Column="1" Name="Ptr68Box" Width="120" />
          <TextBlock Grid.Row="2" Grid.Column="3" Text="Terrain Def (P72):" VerticalAlignment="Center" />
          <TextBox Grid.Row="2" Grid.Column="4" Name="Ptr72Box" Width="120" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Terrain Res (P76):" VerticalAlignment="Center" />
          <TextBox Grid.Row="3" Grid.Column="1" Name="Ptr76Box" Width="120" />
          <TextBlock Grid.Row="3" Grid.Column="3" Text="??? (D80):" VerticalAlignment="Center" />
          <TextBox Grid.Row="3" Grid.Column="4" Name="D80Box" Width="120" />
        </Grid>

        <!-- Growth Simulator -->
        <TextBlock Text="--- Growth Simulator ---" FontWeight="SemiBold" Margin="0,6,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Calculate Growth" Click="CalculateGrowth_Click" />
              <TextBlock Text="Sim Level:" VerticalAlignment="Center" />
              <NumericUpDown Name="SimLevelBox" Minimum="1" Maximum="99" Value="20" Width="90" />
            </StackPanel>
            <TextBlock Name="GrowthSimLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Validation Warnings -->
        <Border Name="WarningsBorder" IsVisible="False"
                BorderBrush="Orange" BorderThickness="1" Padding="8" CornerRadius="4"
                Background="#33FF8C00" Margin="0,8,0,0">
          <StackPanel Spacing="2">
            <TextBlock Text="Warnings" FontWeight="Bold" Foreground="DarkOrange" />
            <ItemsControl Name="WarningsList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="DarkOrange" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button Content="Export TSV" Click="ExportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Export all classes to a TSV file" />
          <Button Content="Import TSV" Click="ImportTSV_Click" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Import classes from a TSV file" />
          <Border Width="1" Background="Gray" Margin="4,2" />
          <Button Content="Edit Skills" Click="EditSkills_Click" Name="EditSkillsButton"
                  IsVisible="False" FontSize="11" Padding="8,4"
                  ToolTip.Tip="Open skill assignment editor for this class" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
