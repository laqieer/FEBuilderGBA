<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ClassEditorView"
        Title="Class Editor" Width="800" Height="650">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="ClassList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Class Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name ID:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="NameLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Class Number:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="ClassNumberBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="--- Base Stats ---" FontWeight="SemiBold" Grid.ColumnSpan="2" Margin="0,8,0,4" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Base HP:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="5" Grid.Column="1" Name="BaseHpBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Base Str:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="6" Grid.Column="1" Name="BaseStrBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Base Skl:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="7" Grid.Column="1" Name="BaseSklBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Base Spd:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="8" Grid.Column="1" Name="BaseSpdBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Base Def:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="9" Grid.Column="1" Name="BaseDefBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Base Res:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="10" Grid.Column="1" Name="BaseResBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Movement:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="11" Grid.Column="1" Name="MovBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="12" Grid.Column="0" Text="--- Growth Rates ---" FontWeight="SemiBold" Grid.ColumnSpan="2" Margin="0,8,0,4" />

          <TextBlock Grid.Row="13" Grid.Column="0" Text="Growth HP:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="13" Grid.Column="1" Name="GrowHpBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="14" Grid.Column="0" Text="Growth Str:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="14" Grid.Column="1" Name="GrowStrBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="15" Grid.Column="0" Text="Growth Skl:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="15" Grid.Column="1" Name="GrowSklBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="16" Grid.Column="0" Text="Growth Spd:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="16" Grid.Column="1" Name="GrowSpdBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="17" Grid.Column="0" Text="Growth Def:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="17" Grid.Column="1" Name="GrowDefBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="18" Grid.Column="0" Text="Growth Res:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="18" Grid.Column="1" Name="GrowResBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="19" Grid.Column="0" Text="Growth Lck:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="19" Grid.Column="1" Name="GrowLckBox" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
