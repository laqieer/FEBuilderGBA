<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.UnitEditorView"
        Title="Unit Editor" Width="934" Height="661">
  <Grid ColumnDefinitions="250,*">
    <!-- Address List -->
    <controls:AddressListControl Grid.Column="0" Name="UnitList" Margin="4" />

    <!-- Editor Panel -->
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="6" Margin="8">
        <TextBlock Text="Unit Editor" FontSize="18" FontWeight="Bold" />

        <!-- Address -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Address:" VerticalAlignment="Center" FontWeight="SemiBold" />
          <TextBlock Name="AddrLabel" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Identity Section with Portrait -->
        <TextBlock Text="Identity" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="*,Auto">
            <!-- Fields -->
            <Grid Grid.Column="0" ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Name ID:" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="0" Grid.Column="1" Name="NameIdBox" Minimum="0" Maximum="65535" Margin="0,2" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="Name:" VerticalAlignment="Center" Margin="0,2" />
              <TextBlock Grid.Row="0" Grid.Column="4" Name="NameLabel" VerticalAlignment="Center" Margin="0,2" />
              <TextBlock Grid.Row="0" Grid.Column="6" Text="Desc ID:" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="0" Grid.Column="7" Name="DescIdBox" Minimum="0" Maximum="65535" Margin="0,2" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Unit ID:" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="1" Grid.Column="1" Name="UnitIdBox" Minimum="0" Maximum="255" Margin="0,2" />
              <TextBlock Grid.Row="1" Grid.Column="3" Text="Class ID:" VerticalAlignment="Center" Margin="0,2" />
              <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" Spacing="4">
                <ComboBox Name="ClassIdCombo" Width="200" Margin="0,2" />
                <Button Content="Jump" Click="JumpToClass_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
                <Button Content="Pick..." Click="PickClass_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" ToolTip.Tip="Pick class from editor" />
              </StackPanel>
              <TextBlock Grid.Row="1" Grid.Column="6" Text="Portrait:" VerticalAlignment="Center" Margin="0,2" />
              <StackPanel Grid.Row="1" Grid.Column="7" Orientation="Horizontal" Spacing="4">
                <NumericUpDown Name="PortraitIdBox" Minimum="0" Maximum="65535" Margin="0,2" Width="80" />
                <TextBlock Name="PortraitNameLabel" VerticalAlignment="Center" Foreground="Gray" />
                <Button Content="Jump" Click="JumpToPortrait_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" />
                <Button Content="Pick..." Click="PickPortrait_Click" FontSize="11" Padding="4,2" VerticalAlignment="Center" ToolTip.Tip="Pick portrait from editor" />
              </StackPanel>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Map Face:" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="2" Grid.Column="1" Name="MapFaceBox" Minimum="0" Maximum="255" Margin="0,2" />
              <TextBlock Grid.Row="2" Grid.Column="3" Text="Affinity:" VerticalAlignment="Center" Margin="0,2" />
              <ComboBox Grid.Row="2" Grid.Column="4" Name="AffinityCombo" Width="200" Margin="0,2" />
              <TextBlock Grid.Row="2" Grid.Column="6" Text="Sort:" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="2" Grid.Column="7" Name="SortOrderBox" Minimum="0" Maximum="255" Margin="0,2" />
            </Grid>
            <!-- Portrait Image -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    Margin="8,0,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
              <controls:GbaImageControl Name="PortraitImage" />
            </Border>
          </Grid>
        </Border>

        <!-- Base Stats Section -->
        <TextBlock Text="Base Stats" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="LV:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="1" Name="LevelBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="HP:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="4" Name="HPBox" Minimum="-128" Maximum="127" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Str:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="7" Name="StrBox" Minimum="-128" Maximum="127" Margin="0,2" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skl:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Name="SklBox" Minimum="-128" Maximum="127" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Spd:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="4" Name="SpdBox" Minimum="-128" Maximum="127" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="6" Text="Def:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="7" Name="DefBox" Minimum="-128" Maximum="127" Margin="0,2" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Res:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="1" Name="ResBox" Minimum="-128" Maximum="127" Margin="0,2" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Lck:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="4" Name="LckBox" Minimum="-128" Maximum="127" Margin="0,2" />
            <TextBlock Grid.Row="2" Grid.Column="6" Text="Con:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="7" Name="ConBox" Minimum="-128" Maximum="127" Margin="0,2" />
          </Grid>
        </Border>

        <!-- Weapon Levels Section -->
        <TextBlock Text="Weapon Levels" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sword:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="1" Name="WepSwordBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Lance:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="4" Name="WepLanceBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Axe:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="7" Name="WepAxeBox" Minimum="0" Maximum="255" Margin="0,2" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Bow:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Name="WepBowBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Staff:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="4" Name="WepStaffBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="6" Text="Anima:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="7" Name="WepAnimaBox" Minimum="0" Maximum="255" Margin="0,2" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Light:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="1" Name="WepLightBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="Dark:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="4" Name="WepDarkBox" Minimum="0" Maximum="255" Margin="0,2" />
          </Grid>
        </Border>

        <!-- Growth Rates Section -->
        <TextBlock Text="Growth Rates (%)" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <Grid ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="1" Name="GrowHPBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Str:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="4" Name="GrowStrBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Skl:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="0" Grid.Column="7" Name="GrowSklBox" Minimum="0" Maximum="255" Margin="0,2" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Spd:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="1" Name="GrowSpdBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Def:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="4" Name="GrowDefBox" Minimum="0" Maximum="255" Margin="0,2" />
            <TextBlock Grid.Row="1" Grid.Column="6" Text="Res:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="1" Grid.Column="7" Name="GrowResBox" Minimum="0" Maximum="255" Margin="0,2" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Lck:" VerticalAlignment="Center" Margin="0,2" />
            <NumericUpDown Grid.Row="2" Grid.Column="1" Name="GrowLckBox" Minimum="0" Maximum="255" Margin="0,2" />
          </Grid>
        </Border>

        <!-- Growth Simulator -->
        <TextBlock Text="Growth Simulator" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <Button Content="Calculate Growth" Click="CalculateGrowth_Click" />
            <TextBlock Name="GrowthSimLabel" FontFamily="Consolas,Courier New,monospace" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Ability Flags Section -->
        <TextBlock Text="Ability Flags" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock Text="Byte 1:" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability1Flags" />
            <TextBlock Text="Byte 2:" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability2Flags" />
            <TextBlock Text="Byte 3:" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability3Flags" />
            <TextBlock Text="Byte 4:" FontWeight="SemiBold" Margin="0,2" />
            <controls:BitFlagPanel Name="Ability4Flags" />
          </StackPanel>
        </Border>

        <!-- Support & Other Section -->
        <TextBlock Text="Support &amp; Other" FontWeight="Bold" Margin="0,8,0,2" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
          <StackPanel Spacing="4">
            <Grid ColumnDefinitions="Auto,180" RowDefinitions="Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Support Ptr:" VerticalAlignment="Center" Margin="0,2,8,2" />
              <TextBox Grid.Row="0" Grid.Column="1" Name="SupportPtrBox" Margin="0,2" />
            </Grid>

            <!-- Unknown bytes 35-39 -->
            <Grid ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="??" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="0" Grid.Column="1" Name="Unk35Box" Minimum="0" Maximum="255" Margin="0,2" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="??" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="0" Grid.Column="4" Name="Unk36Box" Minimum="0" Maximum="255" Margin="0,2" />
              <TextBlock Grid.Row="0" Grid.Column="6" Text="??" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="0" Grid.Column="7" Name="Unk37Box" Minimum="0" Maximum="255" Margin="0,2" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="??" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="1" Grid.Column="1" Name="Unk38Box" Minimum="0" Maximum="255" Margin="0,2" />
              <TextBlock Grid.Row="1" Grid.Column="3" Text="??" VerticalAlignment="Center" Margin="0,2" />
              <NumericUpDown Grid.Row="1" Grid.Column="4" Name="Unk39Box" Minimum="0" Maximum="255" Margin="0,2" />
            </Grid>

            <!-- FE7/8 only fields -->
            <StackPanel Name="FE78Panel" Spacing="4">
              <Grid ColumnDefinitions="Auto,120,16,Auto,120,16,Auto,120" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Talk:" VerticalAlignment="Center" Margin="0,2" />
                <NumericUpDown Grid.Row="0" Grid.Column="1" Name="TalkGroupBox" Minimum="0" Maximum="255" Margin="0,2" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="??" VerticalAlignment="Center" Margin="0,2" />
                <NumericUpDown Grid.Row="0" Grid.Column="4" Name="Unk49Box" Minimum="0" Maximum="255" Margin="0,2" />
                <TextBlock Grid.Row="0" Grid.Column="6" Text="??" VerticalAlignment="Center" Margin="0,2" />
                <NumericUpDown Grid.Row="0" Grid.Column="7" Name="Unk50Box" Minimum="0" Maximum="255" Margin="0,2" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="??" VerticalAlignment="Center" Margin="0,2" />
                <NumericUpDown Grid.Row="1" Grid.Column="1" Name="Unk51Box" Minimum="0" Maximum="255" Margin="0,2" />
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
          <Button Content="Write" Click="Write_Click" Name="WriteButton" />
          <Button Content="Undo" Click="Undo_Click" Name="UndoButton" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
