<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.VennouWeaponLockView"
        Title="Weapon Lock (Vennou) Editor" Width="1155" Height="661">
  <StackPanel Spacing="12" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
    <TextBlock Text="Weapon Lock (Vennou) Editor" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
    <TextBlock Text="This editor requires a target address." FontSize="14" HorizontalAlignment="Center" />
    <TextBlock Text="Open it from another editor (JumpTo pattern)." Foreground="Gray" HorizontalAlignment="Center" />
    <TextBlock Text="First byte = type (0=Soft char, 1=Hard char, 2=Soft class, 3=Hard class), rest are unit/class IDs. Null-terminated." Foreground="Gray" HorizontalAlignment="Center" TextWrapping="Wrap" />
    <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Center">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
      <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Lock Type / ID:" VerticalAlignment="Center" Margin="0,4" />
      <NumericUpDown Grid.Row="1" Grid.Column="1" Name="LockTypeBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Linked Name:" VerticalAlignment="Center" Margin="0,4" />
      <TextBlock Grid.Row="2" Grid.Column="1" Name="LinkedNameLabel" VerticalAlignment="Center" />
      <TextBlock Grid.Row="3" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,4" />
      <TextBox Grid.Row="3" Grid.Column="1" Name="ExplanationBox" IsReadOnly="True" Width="400" Height="80"
               TextWrapping="Wrap" AcceptsReturn="True" Margin="0,2" />
    </Grid>
    <Button Content="Write" Click="Write_Click" HorizontalAlignment="Center" />
  </StackPanel>
</Window>
