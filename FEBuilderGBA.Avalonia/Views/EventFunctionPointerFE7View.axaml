<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.EventFunctionPointerFE7View"
        Title="Event Function Pointer (FE7)" Width="1185" Height="658"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Event Command Function Pointer Table (FE7)" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="240,200" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Event Command Function Pointer:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="FuncPointerUpDown" Minimum="0" Maximum="4294967295"
                         Margin="0,4" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Unknown (offset 4):" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="Unknown4UpDown" Minimum="0" Maximum="4294967295"
                         Margin="0,4" />
        </Grid>

        <Button Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,8" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
