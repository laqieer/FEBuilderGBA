<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ItemWeaponEffectViewerView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ItemWeaponEffectViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Item Weapon Effect Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ItemWeaponEffectViewer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <!-- #360: replaces "Hyperlink TextBlock + NumericUpDown" with a single
               IdFieldControl. Host Name="ItemIdBox" preserved so FindControl<>
               lookups resolve; AutomationId preserved and forwarded by
               IdFieldControl.PropagateInnerAutomationIds onto the inner
               NumericUpDown so E2E selectors keep working. -->
          <controls:IdFieldControl AutomationProperties.AutomationId="ItemWeaponEffectViewer_ItemId_Input"
                                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Name="ItemIdBox"
                                   Label="Item ID:"
                                   Maximum="255"
                                   JumpRequested="ItemId_Jump"
                                   PickRequested="ItemId_Pick"
                                   ValueChanged="ItemId_ValueChanged" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Anim Type:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_AnimType_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="AnimTypeBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Effect ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_EffectId_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="EffectIdBox" Minimum="0" Maximum="65535" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Map Effect Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ItemWeaponEffectViewer_MapEffect_Input" Grid.Row="4" Grid.Column="1" Name="MapEffectBox" Width="120" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Damage Effect:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_DamageEffect_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="DamageEffectBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Motion:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_Motion_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="MotionBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Hit Color:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_HitColor_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="HitColorBox" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Unknown (byte 1):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_Unknown1_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="Unknown1Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Unknown (byte 3):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_Unknown3_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="Unknown3Box" Minimum="0" Maximum="255" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Unknown (bytes 6-7):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_Unknown6_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="Unknown6Box" Minimum="0" Maximum="65535" />

          <TextBlock Grid.Row="11" Grid.Column="0" Text="Unknown (byte 15):" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ItemWeaponEffectViewer_Unknown15_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="Unknown15Box" Minimum="0" Maximum="255" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="ItemWeaponEffectViewer_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
