<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.PaletteChangeColorsView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Palette Change Colors" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <Border DockPanel.Dock="Top" Background="{DynamicResource InfoBannerBackgroundBrush}" BorderBrush="{DynamicResource InfoBannerBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
      <TextBlock TextWrapping="Wrap"
                 Text="Palette Color Editor allows editing individual colors in a 16-color GBA palette.&#10;Select a palette slot to modify its RGB values." />
    </Border>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button AutomationProperties.AutomationId="PaletteChangeColors_Apply_Button" Content="Apply" Width="80" Click="Apply_Click" />
      <Button AutomationProperties.AutomationId="PaletteChangeColors_Close_Button" Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel Spacing="8">
      <TextBlock Text="Color Grid (16 colors):" FontWeight="SemiBold" />
      <Border Background="{DynamicResource SubtlePanelBackgroundBrush}" BorderBrush="{DynamicResource SubtlePanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" MinHeight="80">
        <TextBlock Text="[Palette color grid - 16 color slots]" Foreground="Gray" />
      </Border>
      <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" Margin="0,4,0,0">
        <TextBlock Text="R:" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,4,0" />
        <NumericUpDown AutomationProperties.AutomationId="PaletteChangeColors_Red_Input" FormatString="0" Grid.Column="1" Name="RedInput" Minimum="0" Maximum="31" Value="0" Margin="0,0,8,0" />
        <TextBlock Text="G:" VerticalAlignment="Center" Grid.Column="2" Margin="0,0,4,0" />
        <NumericUpDown AutomationProperties.AutomationId="PaletteChangeColors_Green_Input" FormatString="0" Grid.Column="3" Name="GreenInput" Minimum="0" Maximum="31" Value="0" Margin="0,0,8,0" />
        <TextBlock Text="B:" VerticalAlignment="Center" Grid.Column="4" Margin="0,0,4,0" />
        <NumericUpDown AutomationProperties.AutomationId="PaletteChangeColors_Blue_Input" FormatString="0" Grid.Column="5" Name="BlueInput" Minimum="0" Maximum="31" Value="0" />
      </Grid>
    </StackPanel>
  </DockPanel>
  </ScrollViewer>
</UserControl>
