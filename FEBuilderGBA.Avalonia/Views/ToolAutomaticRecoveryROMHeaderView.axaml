<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolAutomaticRecoveryROMHeaderView"
        Title="Automatic Recovery ROM Header" Width="550" Height="350"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Automatic Recovery ROM Header" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Recover" Click="Recover_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <StackPanel Spacing="8">
      <TextBlock Text="This tool scans and recovers corrupted ROM header data." TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8" />
      <TextBlock Text="Status:" FontWeight="SemiBold" />
      <Border BorderBrush="Gray" BorderThickness="1" Padding="8" MinHeight="100">
        <TextBlock Name="StatusTextBlock" Text="Ready to scan ROM header for issues." TextWrapping="Wrap" />
      </Border>
    </StackPanel>
  </DockPanel>
</Window>
