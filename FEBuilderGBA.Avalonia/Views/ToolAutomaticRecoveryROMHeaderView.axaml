<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolAutomaticRecoveryROMHeaderView"
        Title="Automatic Recovery ROM Header" Width="1193" Height="298"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Border Margin="12,12,12,12" BorderBrush="Gray" BorderThickness="1" Padding="7,10,7,10">
    <StackPanel Spacing="12">
      <!-- File select row (WinForms label2 + OrignalSelectButton + OrignalFilename) -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border BorderBrush="Gray" BorderThickness="1" Width="196" Height="31">
          <TextBlock Text="Unmodified ROM" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Button Content="Select File" Width="130" Height="31"
                Click="SelectFile_Click" />
        <TextBox Text="{Binding OriginalFilename}" Width="801" Height="25" />
      </StackPanel>
      <!-- Explanation (WinForms label1) -->
      <TextBlock Text="{Binding ExplanationText}" Margin="196,0,0,0" />
      <!-- Recovery status -->
      <TextBlock Text="{Binding RecoveryStatus}" Margin="196,0,0,0" Foreground="Blue" />
      <!-- Apply button (WinForms ApplyButton) -->
      <Button Content="Recover ROM Header" Width="939" Height="32"
              HorizontalAlignment="Left" Margin="196,0,0,0" Click="Recover_Click" />
    </StackPanel>
  </Border>
</Window>
