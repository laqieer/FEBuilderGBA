<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ImageBattleBGView"
        Title="Battle Background Editor" Width="1024" Height="560"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*,Auto">

    <!-- Top read-config bar — unified via EditorTopBar (#649).
         Previously had IsEnabled="False" NumericUpDown displays; the
         read-only EditorTopBar renders them as TextBlocks, so legacy
         `_Input` AutomationIds are renamed to `_Label` to reflect the
         actual UIAutomation control type (Text, not Spinner). -->
    <controls:EditorTopBar Grid.Row="0" Grid.ColumnSpan="2" Margin="4"
                           Name="TopBar"
                           AutomationProperties.AutomationId="ImageBattleBG_TopBar"
                           StartAddressLabel="Read Start Address:"
                           StartAddressAutomationId="ImageBattleBG_ReadStartAddress_Label"
                           ReadCountAutomationId="ImageBattleBG_ReadCount_Label"
                           ReloadAutomationId="ImageBattleBG_ReloadList_Button"
                           ShowSize="False"
                           ReloadRequested="OnTopBarReloadRequested" />

    <!-- AddressList + Expand List button (mirrors WinForms panel6) -->
    <Grid Grid.Row="1" Grid.Column="0" Margin="4" RowDefinitions="*,Auto">
      <controls:AddressListControl AutomationProperties.AutomationId="ImageBattleBG_Entry_List"
                                   Grid.Row="0" Name="EntryList" />
      <Button AutomationProperties.AutomationId="ImageBattleBG_ListExpands_Button"
              Grid.Row="1" Name="ListExpandsButton"
              HorizontalAlignment="Stretch" Margin="0,4,0,0"
              Content="Expand List (+1 slot)" Click="ListExpands_Click" />
    </Grid>

    <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Battle Background Editor" FontSize="18" FontWeight="Bold" />

        <!-- AddressPanel mirrors WinForms AddressPanel: Address / Size
             (BlockSize) / Selected Address / Write -->
        <Grid ColumnDefinitions="120,140,120,140,Auto" RowDefinitions="Auto">
          <Label Grid.Row="0" Grid.Column="0" Content="Size:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_BlockSize_Input"
                   Grid.Row="0" Grid.Column="1" Name="BlockSizeBox"
                   IsReadOnly="True" VerticalAlignment="Center" />
          <Label Grid.Row="0" Grid.Column="2" Content="Selected Address:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_SelectedAddr_Input"
                   Grid.Row="0" Grid.Column="3" Name="SelectedAddressBox"
                   IsReadOnly="True" VerticalAlignment="Center" />
          <Button AutomationProperties.AutomationId="ImageBattleBG_Write_Button"
                  Grid.Row="0" Grid.Column="4"
                  Content="Write" Click="Write_Click" Margin="8,0,0,0" />
        </Grid>

        <!-- Main detail panel: per-pointer rows, Comment, X_REF list,
             source-file affordance, BG preview -->
        <Grid ColumnDefinitions="120,200,16,300" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <!-- Row 0: Image (D0) -->
          <Label Grid.Row="0" Grid.Column="0" Content="Image" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_ImagePointer_Input"
                   Grid.Row="0" Grid.Column="1" Name="ImagePointerBox" Width="160" />

          <!-- Row 1: TSA (D4) -->
          <Label Grid.Row="1" Grid.Column="0" Content="TSA" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_TSAPointer_Input"
                   Grid.Row="1" Grid.Column="1" Name="TSAPointerBox" Width="160" />

          <!-- Row 2: Palette (D8) -->
          <Label Grid.Row="2" Grid.Column="0" Content="Palette" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_PalettePointer_Input"
                   Grid.Row="2" Grid.Column="1" Name="PalettePointerBox" Width="160" />

          <!-- Row 3: Comment -->
          <Label Grid.Row="3" Grid.Column="0" Content="Comment" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="ImageBattleBG_Comment_Input"
                   Grid.Row="3" Grid.Column="1" Name="CommentBox" Width="160" />

          <!-- Right column: References list spanning all rows -->
          <Label Grid.Row="0" Grid.Column="3" Content="References" VerticalAlignment="Top" />
          <ListBox AutomationProperties.AutomationId="ImageBattleBG_References_List"
                   Grid.Row="1" Grid.Column="3" Grid.RowSpan="4" Name="XRefList"
                   Height="180" />
        </Grid>

        <!-- BG preview image -->
        <Border BorderBrush="Gray" BorderThickness="1" Margin="0,8,0,0"
                MinHeight="160" MinWidth="240">
          <controls:GbaImageControl AutomationProperties.AutomationId="ImageBattleBG_Preview_Image"
                                    Name="BgPreviewImage" />
        </Border>

        <!-- Source-file affordance (mirrors WinForms OpenSourceButton +
             SelectSourceButton — only visible when a source path is recorded
             AND the file exists on disk) -->
        <StackPanel Name="SourceFilePanel" Orientation="Horizontal" Spacing="8"
                    Margin="0,8,0,0" IsVisible="False">
          <Button AutomationProperties.AutomationId="ImageBattleBG_OpenSource_Button"
                  Content="Open Source File" Click="OpenSource_Click" />
          <Button AutomationProperties.AutomationId="ImageBattleBG_SelectSource_Button"
                  Content="Open Source Folder" Click="SelectSource_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- Bottom button bar (mirrors WinForms panel3) -->
    <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4">
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
        <Button AutomationProperties.AutomationId="ImageBattleBG_ImportPng_Button"
                Content="Import Image" Click="ImportPng_Click" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_FERepo_Button"
                Content="FE-Repo" Click="FERepo_Click"
                ToolTip.Tip="Import a 240x160 background from the FE-Repo Battle Frames &amp; Backgrounds folder" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_ExportPng_Button"
                Content="Export Image" Click="ExportPng_Click" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_DecreaseColor_Button"
                Content="Color Reduce" Click="DecreaseColor_Click" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_GraphicsTool_Button"
                Content="Graphics Tool" Click="GraphicsTool_Click" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_ExportPal_Button"
                Content="Export PAL" Click="ExportPal_Click" />
        <Button AutomationProperties.AutomationId="ImageBattleBG_ImportPal_Button"
                Content="Import PAL" Click="ImportPal_Click" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
