<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.ImageTSAEditorView">
  <!-- ImageTSAEditorView - Avalonia parity raise for ImageTSAEditorForm
       (gap-sweep #398, 100 vs 3 controls, -97% density, 30 WF-only labels).

       The TSA editor is INVOKED CONTEXT-DEPENDENTLY by
       ImageFormRef.TSAEditorButton_Click and GraphicsToolForm.TSAEditorButton_Click
       (callers pass width/height/zimg/tsa/palette pointers via Init(...)),
       so the entry-list mirrors WF's caller pattern: a single static row
       per ROM session ("TSA Tile Editor") that holds the inspector state.

       Layout mirrors the WF Designer.cs control tree:
         Row 0: top toolbar  (PaletteIndexComboBox + Zoom + Info + Undo + Redo + Write)
         Row 1: left panel   (Entry list + chipset CHIPLIST scroll area)
                 + central   (Battle canvas + TSAInfo strip + TabControl: Palette / Main Image)

       Context gating: all write buttons (Write / PaletteWrite / Clipboard /
       MainImageImport / MainImageExport) are gated on IsContextLoaded so the
       default MainWindow open path leaves them harmless until a caller (e.g.
       a future GraphicsToolView TSAEditorButton equivalent) invokes Init.

       The KnownGap markers below cover WinForms-only graphics pipelines that
       require the full ImageUtil/ImageFormRef/LZ77 surface to render. We
       follow the pattern from PR #577 (ClassOPDemo) and PR #513 (ImageBattleBG)
       which defer live-image pipelines as KnownGap so the labels-sweep
       audit-trail still passes.
  -->

  <!-- BattleCanvasRender RESOLVED (#808): the TSA-composited main image is now rendered cross-platform via ImageTSAEditorCore.TryRenderMainImage into BattlePreview, with a read-only Export PNG button. Note: export is intentionally NOT byte-identical to the WF canvas for TSA tile indices >= 0x100 because the Core decoder uses the full 10-bit index (& 0x3FF) like ImageUtil.ByteToImage16Tile, whereas the WF TSA canvas masks tile numbers to 8 bits (& 0xff). The 10-bit value is the on-ROM truth, so this is acceptable for a read-only export. -->
  <!-- ChipsetListRender RESOLVED (#819): the chip-list thumbnail (WF MakeCHIPLIST / PATHCHIPLIST_Paint) is now rendered cross-platform via ImageTSAEditorCore.RenderChipList into ChipListPreview — the main-image tiles in WF's 4-column (orig / Hflip / Vflip / HVflip) single-palette-bank-0 strip, read-only. Follow-up to #808/#810 (shared TSA tile/palette loader) and #807 (the 8-col/2-bank battle-screen sibling). -->
  <!-- RESOLVED (#1005): TSAByteWrite (NON-header TSA) — the TSA Cell tab adds a per-cell X/Y editor (Tile ID + H/V flip + palette bank) and the Write button now writes BOTH the edited TSA and the palette under ONE undo scope. Raw TSA is overwritten in place (same-size); LZ77 TSA is recompressed, appended to free space, and the pointer slot repointed (ImageTSAEditorCore.WriteTsaCells). -->
  <!-- RESOLVED (#1071): HeaderTSACellWrite — header-TSA per-cell editing now uses the shared 32-wide bottom-to-top stride (ImageUtilCore.DecodeHeaderTSAToCells / SerializeHeaderTSA, the EXACT inverse). The cell-edit panel is ENABLED for a valid header decode; the Cell X/Y maxima are constrained in code-behind to the header region (HeaderMaxX / HeaderMaxY) so outside-header canvas cells are non-selectable. Write branches to ImageTSAEditorCore.WriteHeaderTsaCells preserving the original {masterHeaderX, masterHeaderY} (raw same-size in-place / LZ77 compress+repoint, byte-identical fault restore). -->
  <!-- KnownGap: NONE — header-TSA editing is RESOLVED (#1071). -->
  <!-- RESOLVED (#974): PaletteToClipboard — PaletteClipboard_Click now packs the 16 palette entries to GBA 5-5-5 big-endian hex (mirroring WF PaletteFormRef.PALETTE_TO_CLIPBOARD_BUTTON_Click) and copies to the system clipboard via the Avalonia IClipboard.SetTextAsync async API. See ImageTSAEditorViewModel.BuildPaletteClipboardHex + PaletteClipboard_Click. -->
  <!-- RESOLVED (#901): MainImageImport — image1_Import is now wired (tilesheet-only). The WF TSA editor builds its main-image ImageFormRef with tsa_pointer=0 and only the ZIMAGE control, so Import encodes a SAME-SIZE PNG to plain 4bpp tiles (ImageToByte16Tile via ImageImportCore.EncodeDirectTiles4bpp), LZ77-compresses, and repoints ONLY the ZImg pointer — TSA + palette are untouched. See TSAImageImportCore.ImportTSAImage + MainImageImport_Click. -->
  <!-- RESOLVED (#974): MainImageExport — MainImageExport_Click now renders the raw 4bpp tilesheet (LZ77-decompressed ZImg, 8-tile-wide strip) via ImageTSAEditorCore.RenderRawTilesheet and saves it to PNG via GbaImageControl.ExportPng. DISTINCT from the read-only TSA-composited Export PNG (#808, ImageTSAEditor_Battle_ExportPng_Button). See ImageTSAEditorViewModel.RenderRawTilesheet + MainImageExport_Click. -->


  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*">

    <!-- ===== Row 0: Top toolbar (mirrors WF top-level controls) ===== -->
    <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" Margin="4">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="4">
        <Label Content="Palette Index" VerticalAlignment="Center" />
        <!-- WF mirror: 0-F PALETTE; we render as bare hex digits since the
             "Palette Index" Label already gives context, and the WF strings
             would fail the L10n heuristic (English-looking but no translation). -->
        <ComboBox AutomationProperties.AutomationId="ImageTSAEditor_PaletteIndex_Combo"
                  Name="PaletteIndexCombo" Width="160" VerticalAlignment="Center">
          <ComboBoxItem Content="0" />
          <ComboBoxItem Content="1" />
          <ComboBoxItem Content="2" />
          <ComboBoxItem Content="3" />
          <ComboBoxItem Content="4" />
          <ComboBoxItem Content="5" />
          <ComboBoxItem Content="6" />
          <ComboBoxItem Content="7" />
          <ComboBoxItem Content="8" />
          <ComboBoxItem Content="9" />
          <ComboBoxItem Content="A" />
          <ComboBoxItem Content="B" />
          <ComboBoxItem Content="C" />
          <ComboBoxItem Content="D" />
          <ComboBoxItem Content="E" />
          <ComboBoxItem Content="F" />
        </ComboBox>
        <Label Content="Zoom" VerticalAlignment="Center" Margin="12,0,0,0" />
        <!-- Zoom options are populated from code-behind via R._() so they are
             translated by the Core l10n facade (ComboBoxItem.Content is not
             walked by ViewTranslationHelper — Copilot review feedback). -->
        <ComboBox AutomationProperties.AutomationId="ImageTSAEditor_Zoom_Combo"
                  Name="ZoomCombo" Width="160" VerticalAlignment="Center" />
        <TextBox AutomationProperties.AutomationId="ImageTSAEditor_Info_Input"
                 Name="InfoBox" IsReadOnly="True" Width="280"
                 Margin="12,0,0,0" VerticalAlignment="Center" />
        <Button AutomationProperties.AutomationId="ImageTSAEditor_Undo_Button"
                Name="UndoButton" Content="Undo" Click="Undo_Click"
                Margin="12,0,0,0" />
        <!-- Redo is WIRED (#974) to the global Core Undo stack
             (CoreState.Undo.RunRedo() + CanRedo already exist). The handler
             guards on CanRedo at runtime, so the button stays enabled like the
             Undo button and the Map Style editor's Redo. -->
        <Button AutomationProperties.AutomationId="ImageTSAEditor_Redo_Button"
                Name="RedoButton" Content="Redo" Click="Redo_Click" />
        <!-- Write is gated on IsContextLoaded - disabled until a caller Init's -->
        <Button AutomationProperties.AutomationId="ImageTSAEditor_Write_Button"
                Name="WriteButton" Content="Write" Click="Write_Click"
                IsEnabled="{Binding IsContextLoaded}"
                Margin="12,0,0,0" />
      </StackPanel>
    </Border>

    <!-- ===== Row 1 Col 0: Entry list + Chipset thumbnail area ===== -->
    <Grid Grid.Row="1" Grid.Column="0" Margin="4" RowDefinitions="*,Auto,*">
      <controls:AddressListControl AutomationProperties.AutomationId="ImageTSAEditor_Entry_List"
                                   Grid.Row="0" Name="EntryList" />
      <Label Grid.Row="1" Content="Chipset Preview" Margin="0,4,0,0" />
      <!-- Chipset thumbnail (WF MakeCHIPLIST / PATHCHIPLIST_Paint) — RESOLVED (#819):
           rendered via ImageTSAEditorCore.RenderChipList into ChipListPreview
           on entry-load + after a successful write (see RefreshChipList). -->
      <Border Grid.Row="2" BorderBrush="DarkGray" BorderThickness="1" Margin="0,4,0,0">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <controls:GbaImageControl AutomationProperties.AutomationId="ImageTSAEditor_ChipList_Image"
                                    Name="ChipListPreview" MinWidth="64" MinHeight="120" />
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- ===== Row 1 Col 1: Battle canvas + TSAInfo + TabControl ===== -->
    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="*,Auto,Auto" Margin="4">

      <!-- Battle canvas (TSA-rendered main image, #808). For non-header TSA the preview tracks in-memory cell edits (#1005); header-TSA stays read-only. -->
      <Border Grid.Row="0" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,0,4">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <controls:GbaImageControl AutomationProperties.AutomationId="ImageTSAEditor_Battle_Image"
                                    Name="BattlePreview" MinWidth="256" MinHeight="160" />
        </ScrollViewer>
      </Border>

      <!-- TSAInfo readout strip (mirrors WF TSAInfo TextBoxEx) + read-only Export PNG -->
      <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
        <TextBox Grid.Column="0" AutomationProperties.AutomationId="ImageTSAEditor_TSAInfo_Input"
                 Name="TSAInfoBox" IsReadOnly="True" Margin="0,0,4,0" />
        <Button Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Battle_ExportPng_Button"
                Name="BattleExportPngButton" Content="Export PNG"
                IsEnabled="{Binding CanExportBattle}"
                Click="BattleExportPng_Click" />
      </Grid>

      <!-- ===== Tabbed editor: Palette + Main Image ===== -->
      <TabControl Grid.Row="2" AutomationProperties.AutomationId="ImageTSAEditor_TabControl"
                  Name="EditorTabControl" Height="320">

        <!-- Palette tab (mirrors WF tabPage1 パレット) -->
        <TabItem AutomationProperties.AutomationId="ImageTSAEditor_Palette_Tab" Header="Palette">
          <ScrollViewer HorizontalScrollBarVisibility="Auto">
            <StackPanel Margin="6" Spacing="6">

              <!-- Palette top bar: Address + Clipboard (inert) + Palette Write -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <!-- Label text matches the existing translation key "Palette Address:"
                     (with trailing colon) so the ja/zh translations from the canonical
                     downstream-entry get applied (Copilot review feedback). -->
                <Label Content="Palette Address:" VerticalAlignment="Center"
                       BorderBrush="DarkGray" BorderThickness="1" Padding="6,3" Width="180"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_PaletteAddress_Input"
                               FormatString="0" Name="PaletteAddressBox" Width="140"
                               Minimum="0" Maximum="4294967295" VerticalAlignment="Center" />
                <!-- Clipboard button is WIRED (#974): packs the 16 palette
                     entries to GBA 5-5-5 big-endian hex and copies to the
                     system clipboard. Always enabled (reads the grid, never
                     writes ROM). -->
                <Button AutomationProperties.AutomationId="ImageTSAEditor_PaletteClipboard_Button"
                        Name="PaletteClipboardButton" Content="Clipboard"
                        ToolTip.Tip="Copy the 16 palette entries to the clipboard as GBA 5-5-5 hex."
                        Click="PaletteClipboard_Click"
                        Margin="12,0,0,0" />
                <Button AutomationProperties.AutomationId="ImageTSAEditor_PaletteWrite_Button"
                        Name="PaletteWriteButton" Content="Palette Write"
                        Click="PaletteWrite_Click"
                        IsEnabled="{Binding IsContextLoaded}"
                        Margin="12,0,0,0" />
              </StackPanel>

              <!-- 16-column 5-row palette grid:
                     Row 0: index label (1-16, mirrors WF label7/15/17/19/...)
                     Row 1: hex preview label (PALETTE_P_n)
                     Row 2: R input (mirrors WF label48="R")
                     Row 3: G input (mirrors WF label49="G")
                     Row 4: B input (mirrors WF label50="B") -->
              <Grid ColumnDefinitions="22,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <!-- Row-label column (R/G/B). Column 0. -->
                <Label Grid.Row="2" Grid.Column="0" Content="R" VerticalAlignment="Center" />
                <Label Grid.Row="3" Grid.Column="0" Content="G" VerticalAlignment="Center" />
                <Label Grid.Row="4" Grid.Column="0" Content="B" VerticalAlignment="Center" />

                <!-- Per-palette-entry columns 1..16. Each populated by the
                     paletteIndexEntry block below. We unroll all 16 here
                     because Avalonia doesn't support ItemsControl with
                     attached Grid.Row/Column - the WF Designer also unrolled. -->

                <!-- ===== Idx 1 ===== -->
                <Label Grid.Row="0" Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_1_Label"
                       Content="1" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_1_Label"
                       Name="PaletteP1" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_1_Input"
                               Name="PaletteR1" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_1_Input"
                               Name="PaletteG1" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="1" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_1_Input"
                               Name="PaletteB1" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 2 ===== -->
                <Label Grid.Row="0" Grid.Column="2" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_2_Label"
                       Content="2" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="2" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_2_Label"
                       Name="PaletteP2" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="2" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_2_Input"
                               Name="PaletteR2" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="2" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_2_Input"
                               Name="PaletteG2" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="2" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_2_Input"
                               Name="PaletteB2" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 3 ===== -->
                <Label Grid.Row="0" Grid.Column="3" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_3_Label"
                       Content="3" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="3" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_3_Label"
                       Name="PaletteP3" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="3" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_3_Input"
                               Name="PaletteR3" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="3" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_3_Input"
                               Name="PaletteG3" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="3" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_3_Input"
                               Name="PaletteB3" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 4 ===== -->
                <Label Grid.Row="0" Grid.Column="4" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_4_Label"
                       Content="4" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="4" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_4_Label"
                       Name="PaletteP4" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="4" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_4_Input"
                               Name="PaletteR4" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="4" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_4_Input"
                               Name="PaletteG4" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="4" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_4_Input"
                               Name="PaletteB4" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 5 ===== -->
                <Label Grid.Row="0" Grid.Column="5" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_5_Label"
                       Content="5" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="5" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_5_Label"
                       Name="PaletteP5" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="5" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_5_Input"
                               Name="PaletteR5" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="5" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_5_Input"
                               Name="PaletteG5" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="5" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_5_Input"
                               Name="PaletteB5" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 6 ===== -->
                <Label Grid.Row="0" Grid.Column="6" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_6_Label"
                       Content="6" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="6" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_6_Label"
                       Name="PaletteP6" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="6" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_6_Input"
                               Name="PaletteR6" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="6" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_6_Input"
                               Name="PaletteG6" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="6" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_6_Input"
                               Name="PaletteB6" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 7 ===== -->
                <Label Grid.Row="0" Grid.Column="7" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_7_Label"
                       Content="7" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="7" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_7_Label"
                       Name="PaletteP7" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="7" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_7_Input"
                               Name="PaletteR7" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="7" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_7_Input"
                               Name="PaletteG7" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="7" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_7_Input"
                               Name="PaletteB7" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 8 ===== -->
                <Label Grid.Row="0" Grid.Column="8" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_8_Label"
                       Content="8" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="8" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_8_Label"
                       Name="PaletteP8" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="8" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_8_Input"
                               Name="PaletteR8" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="8" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_8_Input"
                               Name="PaletteG8" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="8" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_8_Input"
                               Name="PaletteB8" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 9 ===== -->
                <Label Grid.Row="0" Grid.Column="9" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_9_Label"
                       Content="9" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="9" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_9_Label"
                       Name="PaletteP9" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="9" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_9_Input"
                               Name="PaletteR9" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="9" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_9_Input"
                               Name="PaletteG9" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="9" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_9_Input"
                               Name="PaletteB9" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 10 ===== -->
                <Label Grid.Row="0" Grid.Column="10" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_10_Label"
                       Content="10" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="10" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_10_Label"
                       Name="PaletteP10" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="10" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_10_Input"
                               Name="PaletteR10" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="10" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_10_Input"
                               Name="PaletteG10" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="10" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_10_Input"
                               Name="PaletteB10" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 11 ===== -->
                <Label Grid.Row="0" Grid.Column="11" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_11_Label"
                       Content="11" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="11" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_11_Label"
                       Name="PaletteP11" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="11" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_11_Input"
                               Name="PaletteR11" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="11" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_11_Input"
                               Name="PaletteG11" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="11" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_11_Input"
                               Name="PaletteB11" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 12 ===== -->
                <Label Grid.Row="0" Grid.Column="12" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_12_Label"
                       Content="12" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="12" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_12_Label"
                       Name="PaletteP12" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="12" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_12_Input"
                               Name="PaletteR12" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="12" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_12_Input"
                               Name="PaletteG12" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="12" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_12_Input"
                               Name="PaletteB12" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 13 ===== -->
                <Label Grid.Row="0" Grid.Column="13" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_13_Label"
                       Content="13" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="13" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_13_Label"
                       Name="PaletteP13" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="13" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_13_Input"
                               Name="PaletteR13" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="13" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_13_Input"
                               Name="PaletteG13" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="13" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_13_Input"
                               Name="PaletteB13" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 14 ===== -->
                <Label Grid.Row="0" Grid.Column="14" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_14_Label"
                       Content="14" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="14" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_14_Label"
                       Name="PaletteP14" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="14" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_14_Input"
                               Name="PaletteR14" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="14" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_14_Input"
                               Name="PaletteG14" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="14" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_14_Input"
                               Name="PaletteB14" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 15 ===== -->
                <Label Grid.Row="0" Grid.Column="15" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_15_Label"
                       Content="15" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="15" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_15_Label"
                       Name="PaletteP15" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="15" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_15_Input"
                               Name="PaletteR15" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="15" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_15_Input"
                               Name="PaletteG15" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="15" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_15_Input"
                               Name="PaletteB15" Width="60" Minimum="0" Maximum="255" Increment="8" />

                <!-- ===== Idx 16 ===== -->
                <Label Grid.Row="0" Grid.Column="16" AutomationProperties.AutomationId="ImageTSAEditor_Palette_Idx_16_Label"
                       Content="16" HorizontalAlignment="Center" />
                <Label Grid.Row="1" Grid.Column="16" AutomationProperties.AutomationId="ImageTSAEditor_Palette_P_16_Label"
                       Name="PaletteP16" BorderBrush="DarkGray" BorderThickness="1" Width="50" Height="22"
                       HorizontalContentAlignment="Center" />
                <NumericUpDown Grid.Row="2" Grid.Column="16" AutomationProperties.AutomationId="ImageTSAEditor_Palette_R_16_Input"
                               Name="PaletteR16" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="3" Grid.Column="16" AutomationProperties.AutomationId="ImageTSAEditor_Palette_G_16_Input"
                               Name="PaletteG16" Width="60" Minimum="0" Maximum="255" Increment="8" />
                <NumericUpDown Grid.Row="4" Grid.Column="16" AutomationProperties.AutomationId="ImageTSAEditor_Palette_B_16_Input"
                               Name="PaletteB16" Width="60" Minimum="0" Maximum="255" Increment="8" />
              </Grid>

              <!-- Palette UNDO/REDO sub-buttons (mirrors WF UndoPlaetteButton/RedoPaletteButton).
                   Redo is WIRED (#974) to the global Core Undo stack via
                   PaletteRedo_Click -> Redo_Click (guards on CanRedo). -->
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <Button AutomationProperties.AutomationId="ImageTSAEditor_PaletteUndo_Button"
                        Name="PaletteUndoButton" Content="Undo" Click="PaletteUndo_Click" Width="130" />
                <Button AutomationProperties.AutomationId="ImageTSAEditor_PaletteRedo_Button"
                        Name="PaletteRedoButton" Content="Redo" Click="PaletteRedo_Click"
                        Width="130" />
              </StackPanel>

            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- Main Image tab (mirrors WF tabPage2 メイン画像) -->
        <TabItem AutomationProperties.AutomationId="ImageTSAEditor_MainImage_Tab" Header="Main Image">
          <StackPanel Margin="6" Spacing="6">

            <!-- Image address + label (mirrors WF label12=画像 + image1_ZIMAGE) -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label Content="Image" VerticalAlignment="Center"
                     BorderBrush="DarkGray" BorderThickness="1" Padding="6,3" Width="165"
                     HorizontalContentAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_MainImage_Address_Input"
                             FormatString="0" Name="MainImageAddressBox" Width="120"
                             Minimum="0" Maximum="4294967295" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Import button (RESOLVED #901): mirrors WF image1_Import=画像読込 —
                 tilesheet-only, repoints ONLY the ZImg pointer (TSA + palette
                 untouched). Gated on IsContextLoaded.
                 Export button (RESOLVED #974): mirrors WF image1_Export=画像取出 —
                 the raw 4bpp tilesheet PNG (8-tile-wide strip), DISTINCT from the
                 read-only TSA-composited Battle Export PNG (#808). Gated on
                 IsContextLoaded. -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button AutomationProperties.AutomationId="ImageTSAEditor_MainImage_Import_Button"
                      Name="MainImageImportButton" Content="Image Import"
                      ToolTip.Tip="Import a same-size image as the main tilesheet (palette and TSA are not changed)."
                      Click="MainImageImport_Click" IsEnabled="{Binding IsContextLoaded}" Width="167" />
              <Button AutomationProperties.AutomationId="ImageTSAEditor_MainImage_Export_Button"
                      Name="MainImageExportButton" Content="Image Export"
                      ToolTip.Tip="Export the raw main tilesheet (LZ77-decompressed 4bpp tiles) as a PNG."
                      Click="MainImageExport_Click" IsEnabled="{Binding IsContextLoaded}" Width="167" />
            </StackPanel>

            <!-- Image preview area -->
            <Border BorderBrush="DarkGray" BorderThickness="1" MinHeight="128">
              <controls:GbaImageControl AutomationProperties.AutomationId="ImageTSAEditor_MainImage_Image"
                                        Name="MainImagePreview" MinWidth="316" MinHeight="128" />
            </Border>

          </StackPanel>
        </TabItem>

        <!-- TSA Cell tab (#1005 non-header / #1071 header): per-cell editor for
             BOTH non-header AND header TSA. The whole panel is gated on
             CanEditCells (a valid cell grid decoded). For header-TSA the Cell
             X / Cell Y maxima are constrained in code-behind to the header
             region (HeaderMaxX / HeaderMaxY) so cells outside the header region
             are non-selectable / non-editable (not silently ignored). -->
        <TabItem AutomationProperties.AutomationId="ImageTSAEditor_TsaCell_Tab" Header="TSA Cell">
          <StackPanel Margin="6" Spacing="6" IsEnabled="{Binding CanEditCells}">

            <!-- Cell X / Cell Y selectors -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label Content="Cell X" VerticalAlignment="Center" Width="80"
                     HorizontalContentAlignment="Right" />
              <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_TsaCellX_Input"
                             FormatString="0" Name="TsaCellXBox" Width="100"
                             Minimum="0" Maximum="0" VerticalAlignment="Center" />
              <Label Content="Cell Y" VerticalAlignment="Center" Width="80"
                     HorizontalContentAlignment="Right" Margin="12,0,0,0" />
              <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_TsaCellY_Input"
                             FormatString="0" Name="TsaCellYBox" Width="100"
                             Minimum="0" Maximum="0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Tile ID -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label Content="Tile ID" VerticalAlignment="Center" Width="80"
                     HorizontalContentAlignment="Right" />
              <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_TsaCellTileId_Input"
                             FormatString="0" Name="TsaCellTileIdBox" Width="100"
                             Minimum="0" Maximum="1023" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Flip flags -->
            <StackPanel Orientation="Horizontal" Spacing="12">
              <CheckBox AutomationProperties.AutomationId="ImageTSAEditor_TsaCellHFlip_Check"
                        Name="TsaCellHFlipCheck" Content="H-Flip" />
              <CheckBox AutomationProperties.AutomationId="ImageTSAEditor_TsaCellVFlip_Check"
                        Name="TsaCellVFlipCheck" Content="V-Flip" />
            </StackPanel>

            <!-- Palette Bank -->
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Label Content="Palette Bank" VerticalAlignment="Center" Width="80"
                     HorizontalContentAlignment="Right" />
              <NumericUpDown AutomationProperties.AutomationId="ImageTSAEditor_TsaCellBank_Input"
                             FormatString="0" Name="TsaCellBankBox" Width="100"
                             Minimum="0" Maximum="15" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Apply to Cell -->
            <Button AutomationProperties.AutomationId="ImageTSAEditor_TsaCellApply_Button"
                    Name="TsaCellApplyButton" Content="Apply to Cell"
                    Click="TsaCellApply_Click" HorizontalAlignment="Left" />

          </StackPanel>
        </TabItem>

      </TabControl>

    </Grid>

  </Grid>
</UserControl>
