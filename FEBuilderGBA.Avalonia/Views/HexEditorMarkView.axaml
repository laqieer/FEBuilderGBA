<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.HexEditorMarkView"
        Title="Marked Addresses"
        Width="409" Height="685"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockPanel Margin="12,9,12,10">
    <!-- Header label with border -->
    <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1"
            Height="32" Margin="0,0,0,3">
      <TextBlock Text="Marked Addresses" FontWeight="Bold"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Border>
    <!-- Jump button at bottom -->
    <Button DockPanel.Dock="Bottom" Content="Jump To" Width="272" Height="43"
            HorizontalAlignment="Right" Margin="0,6,0,0" Click="JumpTo_Click" />
    <!-- Address list -->
    <ListBox x:Name="AddressList" ItemsSource="{Binding Marks}" />
  </DockPanel>
</Window>
