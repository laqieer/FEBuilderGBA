<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SongTrackImportMidiView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SongTrackImportMidi_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="MIDI Import" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SongTrackImportMidi_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
        </Grid>

        <!-- Instrument Set selection (#1002 Slice 2) -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="SongTrackImportMidi_SelectInstrument_Button" Content="Select Instrument Set..." Click="SelectInstrument_Click" />
          <TextBlock AutomationProperties.AutomationId="SongTrackImportMidi_Instrument_Label" Name="InstrumentLabel" VerticalAlignment="Center" Foreground="Gray" />
        </StackPanel>

        <!-- MIDI file selection -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="SongTrackImportMidi_BrowseMidi_Button" Content="Browse MIDI File..." Click="BrowseMidi_Click" />
          <TextBlock AutomationProperties.AutomationId="SongTrackImportMidi_MidiFile_Label" Name="MidiFileLabel" Text="No file selected" VerticalAlignment="Center" Foreground="Gray" />
        </StackPanel>

        <!-- MIDI metadata display -->
        <Border Name="MidiInfoBorder" IsVisible="false" BorderBrush="Gray" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,8,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="MIDI File Metadata" FontSize="14" FontWeight="SemiBold" />
            <TextBlock AutomationProperties.AutomationId="SongTrackImportMidi_MidiInfo_Label" Name="MidiInfoLabel" Text="" FontFamily="Consolas,Courier New,monospace"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Write-back status -->
        <Border Background="{DynamicResource WarningBackgroundBrush}" BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,8,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="Note" FontWeight="Bold" Foreground="{DynamicResource WarningTextBrush}" />
            <TextBlock Text="Importing replaces the selected song: the converted MIDI is appended to ROM free space and the song-table entry is repointed at it. The change is a single undo step. Pick a destination song on the left, then browse a MIDI file and import."
                       TextWrapping="Wrap" Foreground="{DynamicResource WarningTextBrush}" />
          </StackPanel>
        </Border>

        <!-- Import button -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="SongTrackImportMidi_Import_Button" Name="ImportButton" Content="Import to ROM" Click="ImportMidi_Click" IsEnabled="false" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
