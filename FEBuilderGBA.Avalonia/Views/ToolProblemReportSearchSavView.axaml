<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.ToolProblemReportSearchSavView"
        Title="No SAV file found"
        Width="910" Height="245"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="12,24,12,12">
    <!-- Info label -->
    <TextBlock TextWrapping="Wrap" Height="54"
               Text="{Binding MessageText}" />
    <!-- File selection row -->
    <Grid ColumnDefinitions="157,Auto,130" Margin="0,49,0,0">
      <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
              Height="31" VerticalAlignment="Center">
        <TextBlock Text="sav" HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
      <TextBox Grid.Column="1" Text="{Binding SavFilename}"
               Width="542" Height="25" Margin="17,0,8,0" />
      <Button Grid.Column="2" Content="Browse..." Width="130" Height="31"
              Click="Browse_Click" />
    </Grid>
  </StackPanel>
</Window>
