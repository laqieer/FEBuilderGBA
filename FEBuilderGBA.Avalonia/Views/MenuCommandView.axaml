<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.MenuCommandView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="MenuCommand_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Menu Command Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="220,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="MenuCommand_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Japanese Name Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_JpNamePtr_Input" Grid.Row="1" Grid.Column="1" Name="JpNamePtrBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Name Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuCommand_NameTextId_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="NameTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="MenuCommand_NameTextId_Label" Grid.Row="2" Grid.Column="2" Name="NameTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #NameTextPreview.Text}" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Help Text ID:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuCommand_HelpTextId_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="HelpTextIdBox" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
          <TextBlock AutomationProperties.AutomationId="MenuCommand_HelpTextId_Label" Grid.Row="3" Grid.Column="2" Name="HelpTextPreview" Foreground="Gray" FontSize="11"
                     VerticalAlignment="Center" Margin="4,0,0,0"
                     TextTrimming="CharacterEllipsis" MaxWidth="200"
                     ToolTip.Tip="{Binding #HelpTextPreview.Text}" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Color/ID (u32@8):" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_ColorId_Input" Grid.Row="4" Grid.Column="1" Name="ColorIdBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Usability Routine:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_Usability_Input" Grid.Row="5" Grid.Column="1" Name="UsabilityBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Draw Routine:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_Draw_Input" Grid.Row="6" Grid.Column="1" Name="DrawBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Effect Routine:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_Effect_Input" Grid.Row="7" Grid.Column="1" Name="EffectBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Per-Turn Callback:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_PerTurn_Input" Grid.Row="8" Grid.Column="1" Name="PerTurnBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Cursor Select Action:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_CursorSel_Input" Grid.Row="9" Grid.Column="1" Name="CursorSelBox" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Cancel Action:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MenuCommand_Cancel_Input" Grid.Row="10" Grid.Column="1" Name="CancelBox" Width="200" Margin="0,2" />
        </Grid>

        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,12,0,0">
          <TextBlock AutomationProperties.AutomationId="MenuCommand_UsabilityHint_Label"
                     Name="UsabilityHintLabel" Foreground="Gray" FontSize="11"
                     TextWrapping="Wrap"
                     IsHitTestVisible="False" />
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MenuCommand_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
