<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SystemIconViewerView">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="SystemIconViewer_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="System Icon Viewer" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Icon Index:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SystemIconViewer_IconIndex_Label" Grid.Row="0" Grid.Column="1" Name="IconIndexLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SystemIconViewer_Addr_Label" Grid.Row="1" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SystemIconViewer_ImgPtr_Label" Grid.Row="2" Grid.Column="1" Name="ImgPtrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SystemIconViewer_PalPtr_Label" Grid.Row="3" Grid.Column="1" Name="PalPtrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Tile Offset:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="SystemIconViewer_TileOffset_Label" Grid.Row="4" Grid.Column="1" Name="TileOffsetLabel" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="SystemIconViewer_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="SystemIconViewer_ExportPal_Button" Content="Export PAL" Click="ExportPal_Click" />
          <Button AutomationProperties.AutomationId="SystemIconViewer_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
        </StackPanel>
        <controls:GbaImageControl AutomationProperties.AutomationId="SystemIconViewer_Image_Image" Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
