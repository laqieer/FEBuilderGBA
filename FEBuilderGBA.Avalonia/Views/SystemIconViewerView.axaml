<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.SystemIconViewerView"
        Title="System Icon Viewer" Width="966" Height="656">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />
    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="System Icon Viewer" FontSize="18" FontWeight="Bold" />
        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Icon Index:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="IconIndexLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Image Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Image Pointer:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="ImgPtrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Palette Pointer:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="3" Grid.Column="1" Name="PalPtrLabel" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Tile Offset:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Name="TileOffsetLabel" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Export PNG" Click="ExportPng_Click" />
          <Button Content="Import PNG" Click="ImportPng_Click" />
        </StackPanel>
        <controls:GbaImageControl Name="ImageDisplay" Margin="0,8,0,0" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
