<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.ToolDiffView">
  <DockPanel Margin="12">
    <TextBlock DockPanel.Dock="Top" Text="ROM Diff Tool" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

    <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,4" BorderBrush="LightGray" BorderThickness="1" CornerRadius="2">
      <TextBlock AutomationProperties.AutomationId="ToolDiff_Status_Label" Text="{Binding StatusText}" TextWrapping="Wrap" />
    </Border>

    <TabControl AutomationProperties.AutomationId="ToolDiff_TabControl" Name="MainTabs">

      <!-- 2-ROM diff -->
      <TabItem Header="2-ROM Diff" AutomationProperties.AutomationId="ToolDiff_Diff2_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="160,8,*,8,Auto" RowDefinitions="Auto,8,Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Other ROM:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolDiff_OtherPath_Input" Grid.Row="0" Grid.Column="2" Text="{Binding OtherPath}" />
              <Button AutomationProperties.AutomationId="ToolDiff_OtherBrowse_Button" Grid.Row="0" Grid.Column="4" Content="Browse..." Click="OtherBrowse_Click" Width="100" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Recover Miss Match:" VerticalAlignment="Center" ToolTip.Tip="Minimum number of matching bytes required to end a diff run." />
              <NumericUpDown AutomationProperties.AutomationId="ToolDiff_RecoverMissMatch_Input" Grid.Row="2" Grid.Column="2" Value="{Binding RecoverMissMatch}" Minimum="0" Maximum="65535" />

              <CheckBox AutomationProperties.AutomationId="ToolDiff_CollectFreeSpace_Check" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" IsChecked="{Binding IsCollectFreeSpace}" Content="Collect free space (FE8 only — keeps free-area diffs as a single block)" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolDiff_MakeBinPatch_Button" Content="Make Binary Patch" Click="MakeBinPatch_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <TextBlock Text="Compares the current loaded ROM against another ROM and writes a binary patch (NAME=/TYPE=BIN/BINF: lines) plus .bin sidecars to the chosen output folder."
                         TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- 3-ROM diff -->
      <TabItem Header="3-ROM Diff" AutomationProperties.AutomationId="ToolDiff_Diff3_Tab">
        <ScrollViewer>
          <StackPanel Spacing="8" Margin="8">
            <Grid ColumnDefinitions="160,8,*,8,Auto" RowDefinitions="Auto,8,Auto,8,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="ROM A:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolDiff_AFilePath_Input" Grid.Row="0" Grid.Column="2" Text="{Binding AFilePath}" />
              <Button AutomationProperties.AutomationId="ToolDiff_ABrowse_Button" Grid.Row="0" Grid.Column="4" Content="Browse..." Click="ABrowse_Click" Width="100" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="ROM B:" VerticalAlignment="Center" />
              <TextBox AutomationProperties.AutomationId="ToolDiff_BFilePath_Input" Grid.Row="2" Grid.Column="2" Text="{Binding BFilePath}" />
              <Button AutomationProperties.AutomationId="ToolDiff_BBrowse_Button" Grid.Row="2" Grid.Column="4" Content="Browse..." Click="BBrowse_Click" Width="100" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Recover Miss Match:" VerticalAlignment="Center" />
              <NumericUpDown AutomationProperties.AutomationId="ToolDiff_RecoverMissMatch3_Input" Grid.Row="4" Grid.Column="2" Value="{Binding RecoverMissMatch3}" Minimum="0" Maximum="65535" />
            </Grid>

            <Button AutomationProperties.AutomationId="ToolDiff_MakeBinPatch3_Button" Content="Make 3-Way Binary Patch" Click="MakeBinPatch3_Click" Height="36" HorizontalAlignment="Stretch" />

            <Border BorderBrush="LightGray" BorderThickness="1" Padding="8" CornerRadius="2">
              <TextBlock Text="Emits bytes that ROM A and ROM B agree on but the current ROM lacks. Useful when two modded ROMs share a feature absent from your base."
                         TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>
  </DockPanel>
</UserControl>
