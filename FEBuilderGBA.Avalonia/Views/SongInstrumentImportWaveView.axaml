<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.SongInstrumentImportWaveView"
        Title="Wave Import" Width="520" Height="440"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height">
  <ScrollViewer Margin="4">
    <StackPanel Spacing="10" Margin="12">
      <TextBlock Text="Wave Import" FontSize="18" FontWeight="Bold" />

      <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
        <TextBlock Grid.Column="0" Text="Source file:" VerticalAlignment="Center" />
        <TextBlock AutomationProperties.AutomationId="SongInstrumentImportWave_SourceFile_Label"
                   Grid.Column="1" Text="{Binding SourceFileName}" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   ToolTip.Tip="{Binding SourceFileName}" />
      </Grid>

      <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
        <StackPanel Spacing="8">
          <TextBlock Text="Conversion (sox resample / normalize)" FontWeight="Bold" />

          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sample rate (Hz):" VerticalAlignment="Center" />
            <ComboBox AutomationProperties.AutomationId="SongInstrumentImportWave_Hz_Combo"
                      Grid.Row="0" Grid.Column="1" Name="HzCombo"
                      ItemsSource="{Binding HzValuesList}" SelectedItem="{Binding Hz}"
                      HorizontalAlignment="Stretch" Margin="0,2" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Channel:" VerticalAlignment="Center" />
            <ComboBox AutomationProperties.AutomationId="SongInstrumentImportWave_Channel_Combo"
                      Grid.Row="1" Grid.Column="1" Name="ChannelCombo"
                      ItemsSource="{Binding ChannelValuesList}" SelectedItem="{Binding Channel}"
                      HorizontalAlignment="Stretch" Margin="0,2" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Strip silence:" VerticalAlignment="Center" />
            <ComboBox AutomationProperties.AutomationId="SongInstrumentImportWave_Strip_Combo"
                      Grid.Row="2" Grid.Column="1" Name="StripCombo"
                      ItemsSource="{Binding StripValuesList}" SelectedItem="{Binding Strip}"
                      HorizontalAlignment="Stretch" Margin="0,2" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Volume (%):" VerticalAlignment="Center" />
            <ComboBox AutomationProperties.AutomationId="SongInstrumentImportWave_Volume_Combo"
                      Grid.Row="3" Grid.Column="1" Name="VolumeCombo"
                      ItemsSource="{Binding VolumeValuesList}" SelectedItem="{Binding Volume}"
                      HorizontalAlignment="Stretch" Margin="0,2" />
          </Grid>
        </StackPanel>
      </Border>

      <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
        <StackPanel Spacing="8">
          <TextBlock Text="DPCM compression" FontWeight="Bold" />
          <CheckBox AutomationProperties.AutomationId="SongInstrumentImportWave_UseDpcm_Check"
                    Name="UseDpcmCheck" Content="Compress with DPCM"
                    IsChecked="{Binding UseDpcm}" IsEnabled="{Binding CanUseDpcm}" />
          <TextBlock Text="{Binding DpcmGateMessage}" TextWrapping="Wrap" Foreground="Gray" FontSize="12" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto">
            <TextBlock Grid.Column="0" Text="Lookahead:" VerticalAlignment="Center" />
            <ComboBox AutomationProperties.AutomationId="SongInstrumentImportWave_Lookahead_Combo"
                      Grid.Column="1" Name="LookaheadCombo"
                      ItemsSource="{Binding LookaheadValuesList}" SelectedItem="{Binding Lookahead}"
                      IsEnabled="{Binding CanUseDpcm}" HorizontalAlignment="Stretch" Margin="0,2" />
          </Grid>
        </StackPanel>
      </Border>

      <Button AutomationProperties.AutomationId="SongInstrumentImportWave_Preview_Button"
              Name="PreviewButton" Content="Preview" Click="Preview_Click" />
      <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10" MinHeight="60">
        <TextBlock AutomationProperties.AutomationId="SongInstrumentImportWave_Preview_Label"
                   Name="PreviewLabel" Text="{Binding PreviewText}" TextWrapping="Wrap" />
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button AutomationProperties.AutomationId="SongInstrumentImportWave_OK_Button"
                Name="OkButton" Content="Import" Click="Ok_Click" MinWidth="90" />
        <Button AutomationProperties.AutomationId="SongInstrumentImportWave_Cancel_Button"
                Name="CancelButton" Content="Cancel" Click="Cancel_Click" MinWidth="90" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
