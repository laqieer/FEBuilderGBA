<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.ImageRomAnimeView"
        Title="In-ROM Magic Animation" Width="820" Height="520"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="ImageRomAnime_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="In-ROM Magic Animation" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="ImageRomAnime_Id_Label" Grid.Row="0" Grid.Column="1" Name="IdLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Frame:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="ImageRomAnime_Frame_Input" Grid.Row="1" Grid.Column="1"
                         Name="FrameUpDown" Width="120" HorizontalAlignment="Left"
                         Minimum="0" Maximum="0" Increment="1" FormatString="0"
                         ValueChanged="FrameUpDown_ValueChanged" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button AutomationProperties.AutomationId="ImageRomAnime_ExportPng_Button" Content="Export PNG" Click="ExportPng_Click" />
          <Button AutomationProperties.AutomationId="ImageRomAnime_ImportPng_Button" Content="Import PNG" Click="ImportPng_Click" />
        </StackPanel>

        <TextBlock AutomationProperties.AutomationId="ImageRomAnime_Info_Label" Name="InfoLabel" TextWrapping="Wrap" />

        <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="4" HorizontalAlignment="Left" Margin="0,8,0,0">
          <controls:GbaImageControl AutomationProperties.AutomationId="ImageRomAnime_Frame_Image" Name="FrameImage" />
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
