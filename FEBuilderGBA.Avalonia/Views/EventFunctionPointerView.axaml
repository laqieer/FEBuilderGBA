<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.EventFunctionPointerView"
        Title="Event Function Pointer Editor" Width="1185" Height="658"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <!-- Left column: #1441 Primary/Worldmap filter above the entry list. The
         Worldmap option targets the FE8-only event_function_pointer_table2
         (worldmap event-function pointers, +0x80 id offset). -->
    <Grid Grid.Column="0" RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,4,4,0">
        <TextBlock Text="Filter:" VerticalAlignment="Center" />
        <ComboBox AutomationProperties.AutomationId="EventFunctionPointer_Filter_Combo"
                  Name="FilterComboBox" Width="170" VerticalAlignment="Center" />
      </StackPanel>
      <controls:AddressListControl AutomationProperties.AutomationId="EventFunctionPointer_Entry_List" Grid.Row="1" Name="EntryList" Margin="4" />
    </Grid>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Event Command Function Pointer Table" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="240,200" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="EventFunctionPointer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Event Command Function Pointer:" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown AutomationProperties.AutomationId="EventFunctionPointer_FuncPointerUpDown_Input" FormatString="0" Grid.Row="1" Grid.Column="1" Name="FuncPointerUpDown" Minimum="0" Maximum="4294967295"
                         Margin="0,4" />
        </Grid>

        <Button AutomationProperties.AutomationId="EventFunctionPointer_Write_Button" Name="WriteButton" Content="Write" HorizontalAlignment="Left" Margin="0,8" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
