<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MenuExtendSplitMenuView"
        Title="Menu Extend Split" Width="1257" Height="604"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl AutomationProperties.AutomationId="MenuExtendSplitMenu_Entry_List" Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Split Menu Definition" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="200,200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="MenuExtendSplitMenu_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Command Array:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="MenuExtendSplitMenu_CommandPtr_Label" Grid.Row="1" Grid.Column="1" Name="CommandPtrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="X Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_PosX_Input" FormatString="0" Grid.Row="2" Grid.Column="1" Name="PosXBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Y Position:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_PosY_Input" FormatString="0" Grid.Row="3" Grid.Column="1" Name="PosYBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Width:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Width_Input" FormatString="0" Grid.Row="4" Grid.Column="1" Name="WidthBox" Minimum="0" Maximum="255" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Style:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Style_Input" FormatString="0" Grid.Row="5" Grid.Column="1" Name="StyleBox" Minimum="0" Maximum="4294967295" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Text ID 0:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str0_Input" FormatString="0" Grid.Row="6" Grid.Column="1" Name="Str0Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="7" Grid.Column="0" Text="Text ID 1:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str1_Input" FormatString="0" Grid.Row="7" Grid.Column="1" Name="Str1Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="8" Grid.Column="0" Text="Text ID 2:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str2_Input" FormatString="0" Grid.Row="8" Grid.Column="1" Name="Str2Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="9" Grid.Column="0" Text="Text ID 3:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str3_Input" FormatString="0" Grid.Row="9" Grid.Column="1" Name="Str3Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock Grid.Row="10" Grid.Column="0" Text="Text ID 4:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str4_Input" FormatString="0" Grid.Row="10" Grid.Column="1" Name="Str4Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock AutomationProperties.AutomationId="MenuExtendSplitMenu_Str5_Label" Grid.Row="11" Grid.Column="0" Text="Text ID 5:" VerticalAlignment="Center" Name="Str5Label" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str5_Input" FormatString="0" Grid.Row="11" Grid.Column="1" Name="Str5Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock AutomationProperties.AutomationId="MenuExtendSplitMenu_Str6_Label" Grid.Row="12" Grid.Column="0" Text="Text ID 6:" VerticalAlignment="Center" Name="Str6Label" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str6_Input" FormatString="0" Grid.Row="12" Grid.Column="1" Name="Str6Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />

          <TextBlock AutomationProperties.AutomationId="MenuExtendSplitMenu_Str7_Label" Grid.Row="13" Grid.Column="0" Text="Text ID 7:" VerticalAlignment="Center" Name="Str7Label" />
          <NumericUpDown AutomationProperties.AutomationId="MenuExtendSplitMenu_Str7_Input" FormatString="0" Grid.Row="13" Grid.Column="1" Name="Str7Box" Minimum="0" Maximum="65535" Width="200" Margin="0,2" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MenuExtendSplitMenu_Write_Button" Content="Write" Click="Write_Click" />
          <Button AutomationProperties.AutomationId="MenuExtendSplitMenu_New_Button" Content="New Split Menu" Click="NewAlloc_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
