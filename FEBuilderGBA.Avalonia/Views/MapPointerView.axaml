<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.MapPointerView"
        Title="Map Pointer Editor" Width="1305" Height="532"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <StackPanel Grid.Column="0" Margin="4">
      <ComboBox AutomationProperties.AutomationId="MapPointer_PlistType_Combo" Name="PlistTypeCombo" Margin="0,0,0,4" HorizontalAlignment="Stretch" />
      <controls:AddressListControl AutomationProperties.AutomationId="MapPointer_Entry_List" Name="EntryList" />
    </StackPanel>

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Map Pointer Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock AutomationProperties.AutomationId="MapPointer_Addr_Label" Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Map Data Pointer:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="MapPointer_MapDataPointer_Input" Grid.Row="1" Grid.Column="1" Name="MapDataPointerBox" Width="120" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button AutomationProperties.AutomationId="MapPointer_Write_Button" Content="Write" Click="Write_Click" />
        </StackPanel>

        <!-- PLIST Split/Expand panel — shown only when the ROM is NOT yet split (#1432). -->
        <Border AutomationProperties.AutomationId="MapPointer_PlistSplit_Control" Name="PlistSplitPanel"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,24,0,0"
                IsVisible="False">
          <StackPanel Spacing="8">
            <TextBlock AutomationProperties.AutomationId="MapPointer_PlistSplit_Label" Name="PlistSplitExplainLabel"
                       TextWrapping="Wrap" MaxWidth="700" />
            <Button AutomationProperties.AutomationId="MapPointer_PlistSplit_Button" Name="PlistSplitButton"
                    Content="PLIST Split" Click="PlistSplit_Click" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
