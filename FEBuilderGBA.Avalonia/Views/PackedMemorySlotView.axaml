<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEBuilderGBA.Avalonia.Views.PackedMemorySlotView"
        Title="Packed Memory Slot" Width="600" Height="450"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Packed Memory Slot" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
      <Button Content="Refresh" Click="Refresh_Click" />
      <Button Content="Close" Width="80" Click="Close_Click" />
    </StackPanel>
    <ScrollViewer>
      <StackPanel Spacing="4">
        <TextBlock Text="Memory slot information for packed ROM data:" Foreground="Gray" Margin="0,0,0,8" />
        <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
          <TextBox Name="SlotInfoTextBox" IsReadOnly="True" AcceptsReturn="True"
                   FontFamily="Consolas, Courier New, monospace" MinHeight="250"
                   Watermark="Slot information will appear here..." />
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
