<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FEBuilderGBA.Avalonia.ViewModels"
        x:Class="FEBuilderGBA.Avalonia.Views.LogViewerView"
        x:DataType="vm:LogViewerViewModel"
        Title="Log Viewer" Width="800" Height="560">
  <DockPanel Margin="8" LastChildFill="True">

    <TextBlock DockPanel.Dock="Top" Text="Log Viewer" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />

    <TextBlock DockPanel.Dock="Top"
               Text="The most recent application log lines. Read-only; refreshes live as new messages are logged."
               TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8" />

    <!-- Buttons mirror WinForms LogForm: Save, Copy, Open-log-dir, plus Refresh. -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
      <Button AutomationProperties.AutomationId="LogViewer_Refresh_Button" Name="RefreshButton" Content="Refresh" MinWidth="100" />
      <Button AutomationProperties.AutomationId="LogViewer_Save_Button" Name="SaveButton" Content="Save" MinWidth="100" />
      <Button AutomationProperties.AutomationId="LogViewer_Copy_Button" Name="CopyButton" Content="Copy to clipboard" MinWidth="120" />
      <Button AutomationProperties.AutomationId="LogViewer_OpenDir_Button" Name="OpenDirButton" Content="Open log folder" MinWidth="120" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom"
               AutomationProperties.AutomationId="LogViewer_Status_Label"
               Name="StatusLabel" Foreground="DarkSlateGray" TextWrapping="Wrap" Margin="0,6,0,0" />

    <Border BorderBrush="Gray" BorderThickness="1">
      <TextBox AutomationProperties.AutomationId="LogViewer_Log_Text"
               Name="LogTextBox"
               Text="{Binding LogText, Mode=OneWay}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="NoWrap"
               FontFamily="Consolas,Menlo,Monospace"
               VerticalAlignment="Stretch"
               HorizontalAlignment="Stretch"
               VerticalContentAlignment="Top" />
    </Border>
  </DockPanel>
</Window>
