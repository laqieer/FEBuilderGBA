<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
             x:Class="FEBuilderGBA.Avalonia.Views.SMEPromoListView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel>
    <!-- Top toolbar: Address + Count + Reload — unified via
         EditorTopBarWithInputs (#649). Address/Count remain editable
         (synced to ViewModel by the code-behind on ReloadRequested).
         ShowReadSize=False because this editor only has Address + Count.
         ReadCountMinimum=1 / ReadCountMaximum=256 match the pre-migration
         NumericUpDown limits. -->
    <controls:EditorTopBarWithInputs DockPanel.Dock="Top"
                                     Name="TopBar"
                                     Margin="8,4,8,0"
                                     AutomationProperties.AutomationId="SMEPromoList_TopBar"
                                     ReadStartLabel="Address:"
                                     ReadCountLabel="Count:"
                                     ReadCountMinimum="1"
                                     ReadCountMaximum="256"
                                     ReadStartAutomationId="SMEPromoList_NumericUpDown1_Input"
                                     ReadCountAutomationId="SMEPromoList_NumericUpDown2_Input"
                                     ReloadAutomationId="SMEPromoList_Reload_Button"
                                     ShowReadSize="False"
                                     ReloadRequested="OnTopBarReloadRequested" />

    <Grid ColumnDefinitions="245,*">
      <!-- Left: Address list -->
      <DockPanel Grid.Column="0" Margin="4">
        <TextBlock DockPanel.Dock="Top" Text="Name" FontWeight="Bold"
                   Height="26" VerticalAlignment="Center" />
        <Button AutomationProperties.AutomationId="SMEPromoList_ExpandList_Button" DockPanel.Dock="Bottom" Content="Expand List" Height="30"
                HorizontalAlignment="Stretch" Margin="0,4,0,0" />
        <ListBox AutomationProperties.AutomationId="SMEPromoList_ListBox1_List" ItemsSource="{Binding AddressList}"
                 SelectedIndex="{Binding SelectedIndex}" />
      </DockPanel>

      <!-- Right: Editor area -->
      <DockPanel Grid.Column="1" Margin="4">
        <!-- Address bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="34"
                    Spacing="8" Margin="0,0,0,4">
          <TextBlock Text="Address:" VerticalAlignment="Center" />
          <NumericUpDown AutomationProperties.AutomationId="SMEPromoList_NumericUpDown3_Input" FormatString="0" Value="{Binding CurrentAddress}" Minimum="0"
                         Width="130" Height="25" />
          <TextBlock Text="Size:" VerticalAlignment="Center" />
          <TextBox AutomationProperties.AutomationId="SMEPromoList_TextBox1_Input" Text="{Binding BlockSize}" IsReadOnly="True"
                   Width="82" Height="25" />
          <TextBox AutomationProperties.AutomationId="SMEPromoList_TextBox2_Input" Text="{Binding SelectAddress}" IsReadOnly="True"
                   Width="150" Height="25" />
          <Button AutomationProperties.AutomationId="SMEPromoList_Write_Button" Content="Write" Width="168" Height="30" Click="Write_Click" />
        </StackPanel>

        <!-- Class editor fields -->
        <StackPanel Margin="0,8,0,0" Spacing="12">
          <!-- Base Class row -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Base Class" Width="146" Height="30"
                       VerticalAlignment="Center" FontWeight="Bold" />
            <NumericUpDown AutomationProperties.AutomationId="SMEPromoList_NumericUpDown4_Input" FormatString="0" Value="{Binding B0}" Minimum="0" Maximum="255"
                           Width="72" Height="25" />
            <TextBox AutomationProperties.AutomationId="SMEPromoList_TextBox3_Input" Text="{Binding ClassName0}" IsReadOnly="True"
                     Width="174" Height="25" />
          </StackPanel>
          <!-- Promo Class row -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Promo Class" Width="146" Height="30"
                       VerticalAlignment="Center" FontWeight="Bold" />
            <NumericUpDown AutomationProperties.AutomationId="SMEPromoList_NumericUpDown5_Input" FormatString="0" Value="{Binding B1}" Minimum="0" Maximum="255"
                           Width="72" Height="25" />
            <TextBox AutomationProperties.AutomationId="SMEPromoList_TextBox4_Input" Text="{Binding ClassName1}" IsReadOnly="True"
                     Width="174" Height="25" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Grid>
  </DockPanel>
  </ScrollViewer>
</UserControl>
