<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.AIMapSettingView"
        Title="AI Map Settings" Width="800" Height="500"
        SizeToContent="WidthAndHeight">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="EntryList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="AI Map Settings" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="160,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Trait 1 (flags):" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="Trait1Box" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Trait 2 (flags):" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="2" Grid.Column="1" Name="Trait2Box" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Trait 3 (flags):" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Name="Trait3Box" Minimum="0" Maximum="255" Margin="0,4" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Trait 4 (flags):" VerticalAlignment="Center" Margin="0,4" />
          <NumericUpDown Grid.Row="4" Grid.Column="1" Name="Trait4Box" Minimum="0" Maximum="255" Margin="0,4" />
        </Grid>

        <Button Name="WriteButton" Content="Write" HorizontalAlignment="Right" Margin="0,8" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
