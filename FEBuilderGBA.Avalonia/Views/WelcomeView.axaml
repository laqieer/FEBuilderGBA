<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEBuilderGBA.Avalonia.Views.WelcomeView">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
  <DockPanel Margin="14,10,14,10">
    <!-- Logo area (WinForms pictureBox1 1123x278) -->
    <Border DockPanel.Dock="Top" Height="278" Background="{DynamicResource WelcomeBannerBrush}"
            BorderBrush="{DynamicResource WelcomeBannerBorderBrush}" BorderThickness="1" Margin="0,0,0,8">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="FEBuilderGBA" FontSize="36" FontWeight="Bold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Avalonia Cross-Platform Edition" FontSize="16"
                   Foreground="Gray" HorizontalAlignment="Center" Margin="0,4,0,0" />
        <TextBlock AutomationProperties.AutomationId="Welcome_Version_Label" Name="VersionText" Text="{Binding VersionInfo}" FontSize="12"
                   Foreground="Gray" HorizontalAlignment="Center" Margin="0,4,0,0" />
      </StackPanel>
    </Border>
    <!-- Buttons and Recent Files side by side -->
    <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
      <!-- Action Buttons -->
      <StackPanel Grid.Column="0" Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,16,0">
        <Button AutomationProperties.AutomationId="Welcome_OpenLastROM_Button" Name="OpenLastROMButton" Content="Open Last ROM" MinWidth="200" MaxWidth="400" Height="47"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OpenLastROM_Click" />
        <Button AutomationProperties.AutomationId="Welcome_OpenROM_Button" Name="OpenROMButton" Content="Open ROM" MinWidth="200" MaxWidth="400" Height="50"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OpenROM_Click" />
        <Button AutomationProperties.AutomationId="Welcome_UpdateCheck_Button" Name="UpdateCheckButton" Content="Check for Updates" MinWidth="200" MaxWidth="400" Height="47"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="UpdateCheck_Click" />
        <Button AutomationProperties.AutomationId="Welcome_Man_Button" Name="ManButton" Content="Online Manual" MinWidth="200" MaxWidth="400" Height="47"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="Manual_Click" />
      </StackPanel>

      <!-- Recent Files Section -->
      <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="6" Padding="12" Margin="16,0,0,0"
              VerticalAlignment="Top" Name="RecentFilesBorder">
        <StackPanel Spacing="6">
          <TextBlock Text="Recent Files" FontSize="16" FontWeight="SemiBold" />
          <TextBlock AutomationProperties.AutomationId="Welcome_NoRecentFiles_Label" Name="NoRecentFilesLabel" Text="No recent files" Foreground="Gray" FontSize="12"
                     IsVisible="True" />
          <ItemsControl AutomationProperties.AutomationId="Welcome_RecentFiles_List" Name="RecentFilesList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Content="{Binding Display}" Click="RecentFile_Click" Tag="{Binding Index}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="8,6" Margin="0,2" FontSize="12"
                        Background="Transparent" Cursor="Hand" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
  </ScrollViewer>
</UserControl>
