<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEBuilderGBA.Avalonia.Controls"
        x:Class="FEBuilderGBA.Avalonia.Views.TerrainNameEditorView"
        Title="Terrain Name Editor" Width="1253" Height="790">
  <Grid ColumnDefinitions="250,*">
    <controls:AddressListControl Grid.Column="0" Name="TerrainList" Margin="4" />

    <ScrollViewer Grid.Column="1" Margin="4">
      <StackPanel Spacing="8" Margin="8">
        <TextBlock Text="Terrain Name Editor" FontSize="18" FontWeight="Bold" />

        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="0" Grid.Column="1" Name="AddrLabel" VerticalAlignment="Center" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Text ID:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="1" Grid.Column="1" Name="TextIdBox" Minimum="0" Maximum="65535" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Name="NameLabel" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Write" Click="Write_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
